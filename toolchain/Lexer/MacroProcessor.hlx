enum ImportKind {
    FullModule,          // import Foo::Bar
    AliasedModule,       // import Foo::Bar as Baz
    SpecificMacros,      // import Foo::Bar::{mac1!, mac2!}
    AliasedMacros,       // import Foo::Bar::{mac1! as m1}
    Wildcard,            // import Foo::Bar::*
    DirectoryModule,     // import module Foo::Bar
    Library              // import some_lib
}

struct MacroImport {
    var name: string;       // original name
    var alias: string;      // alias (same as name if no alias)
}

module PreDefinedMacros {
    
}

/// ok lets think we have a few types of imports we need to handle here
/// 1. import Foo::Bar;  // imports module Foo::Bar (as Foo::Bar from Foo/Bar.hlx)
/// 2. import Foo::Bar as Baz; // imports module Foo::Bar as Baz (alias)
/// 3. import Foo::Bar::{mac1!, mac2!}; // imports specific macros from module (no aliasing the macros are avlailable in current scope as mac1! and mac2!)
/// 4. import Foo::Bar::{mac1! as m1, mac2! as m2}; // imports specific macros with aliasing
/// 5. import Foo::Bar::*; // imports all macros from module Foo (wildcard)
/// 6. import module Foo::Bar; // imports module Foo::Bar (which means we import Foo/Bar/module.hlx)
/// 7. lib imports are also there we cant forget those (like import some_lib) (imports some_lib.hlib the custom archive format for helix libraries)

/// scope wise we cant forget that we can go up scopes via `module ::SubModule { ... }`

/*
a few exmaples of macro definitions:

macro foo! { ... }                     // parameterless
macro foo!(a, b) { ... }               // with parameters
macro foo!(a, b = "default") { ... }   // with default parameters
macro foo!(a, ...rest) { ... }         // with variadic parameters
*/

