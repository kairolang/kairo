/// Macro Preprocessor
/// ==================
///
/// Handles macro definition collection, scope tracking, and token-level expansion
/// for regular macros (foo!). Proc macros (@foo) are handled later in the AST phase.
///
/// Pipeline
/// --------
///
///    ┌──────────────────┐
///    │ Token Stream     │
///    └────────┬─────────┘
///             │
///             ▼
///   ┌─────────────────────────────┐
///   │ 1. Collect Definitions      │
///   │    - Walk tokens            │
///   │    - Track module scope     │
///   │    - Register macro!(...){} │
///   │    - Register macro!{}      │
///   │    - Store body tokens      │
///   └─────────────────────────────┘
///             │
///             ▼
///   ┌─────────────────────────────┐
///   │ 2. Track Imports            │
///   │    - Record use decls       │
///   │    - Map alias → origin     │
///   │    - No expansion yet       │
///   └─────────────────────────────┘
///             │
///             ▼
///   ┌─────────────────────────────┐
///   │ 3. Resolve Invocations      │
///   │    - Match ident! or ident!(│
///   │    - Qualified: exact lookup│
///   │    - Unqualified: scoped    │
///   │    - Validate delimiters    │
///   └─────────────────────────────┘
///             │
///             ▼
///   ┌─────────────────────────────┐
///   │ 4. Expand Tokens            │
///   │    - Substitute params      │
///   │    - Handle defaults        │
///   │    - Handle variadics       │
///   │    - Paste body tokens      │
///   │    - Recurse if nested      │
///   │    - Detect cycles          │
///   └─────────────────────────────┘
///             │
///             ▼
///   ┌─────────────────────────────┐
///   │ 5. Return Expanded          │
///   │    - Modified stream        │
///   │    - Preserve locations     │
///   │    - Report errors          │
///   └─────────────────────────────┘
///
/// Definition Syntax
/// -----------------
///
///   Parameterless (no parens allowed at invoke):
///     macro foo! { body };
///     Invoke: foo!
///
///   With params (parens required at invoke):
///     macro foo!(a, b) { body };
///     Invoke: foo!(x, y)
///
///   With defaults:
///     macro foo!(a, b = "default") { body };
///     Invoke: foo!(x) or foo!(x, y)
///
///   Variadic:
///     macro foo!(a, ...rest) { body };
///     Invoke: foo!(x), foo!(x, y, z)
///
/// Invocation Syntax
/// -----------------
///
///   Parameterless:
///     foo!                     → no parens, ever
///
///   With params:
///     foo!(args)               → parens required
///     Foo::Bar::foo!(args)     → qualified
///
///   Rule: parens iff macro accepts params
///
/// Resolution Rules
/// ----------------
///
///   Qualified invocation (Foo::Bar::mac!):
///     1. Resolve module path exactly
///     2. Lookup macro in that module only
///     3. ERROR if module not found
///     4. ERROR if macro not in that module
///     5. NEVER fall back to other scopes
///
///   Unqualified invocation (mac!):
///     1. Current scope
///     2. Imports (use Foo::Bar::mac!)
///     3. Global/prelude
///     4. ERROR if not found
///
/// Expansion Rules
/// ---------------
///
///   - Path is for lookup only, consumed after resolution
///   - Expansion is pure token substitution
///   - No path prepending to expanded tokens
///   - Macro author controls qualification in body
///   - Use module_path! for self-relative expansion
///
/// Delimiter Rules
/// ---------------
///
///   - Invocations with params use parens: foo!(...)
///   - Content must have balanced delimiters: (), {}, []
///   - Unbalanced delimiters inside invoke = compile error
///   - For literal unbalanced content, use strings
///
/// Data Structures
/// ---------------
///
///   MacroDefinition:
///     - name: identifier
///     - scope: module path
///     - params: list of (name, default?, variadic?)
///     - accepts_params: bool (true if defined with parens)
///     - body: raw token span
///
///   MacroTable:
///     - definitions: scope path → name → MacroDefinition
///     - imports: alias → fully qualified path
///
///   ExpansionContext:
///     - call_stack: for cycle detection (depth limit = 256)
///     - param_bindings: name → token span
///     - variadic_bindings: name → list of token spans
///     - source_loc: invoke site for error reporting
///     - definition_loc: definition site for error reporting
///
/// Built-in Macros
/// ---------------
///
///   Token manipulation:
///     concat!(a, b)        - join tokens
///     stringify!(a)        - token → string
///     unstringify!(s)      - string → tokens (⚠ injection risk)
///
///   Variadic helpers:
///     count!(...args)      - count arguments
///     first!(...args)      - first argument
///     last!(...args)       - last argument
///     rest!(...args)       - all but first
///     init!(...args)       - all but last
///
///   Source location:
///     file!                - current file path
///     line!                - current line number
///     column!              - current column number
///     module_path!         - current module path
///
///   Diagnostics:
///     error!(msg)          - compile error (optional code param)
///     warning!(msg)        - compile warning (optional code param)
///     note!(msg)           - compile note (optional code param)
///
///   Code generation:
///     include!(path)       - paste file as tokens
///     include_str!(path)   - file as string literal
///     embed!(path)         - file as byte array
///     unique_id!           - generate unique identifier
///     todo!(msg = "")      - runtime error placeholder
///     unreachable!(msg="") - assert unreachable
///
///   Conditional:
///     defined!(name)       - check if macro exists
///
///   Macro hygiene:
///     undef!(name)     - remove macro definition
///
/// Error Cases
/// -----------
///
///   Definition errors:
///     - Duplicate macro in same scope
///     - Invalid parameter syntax
///     - Variadic not last parameter
///     - Default after variadic
///
///   Resolution errors:
///     - Undefined macro
///     - Module not found (qualified)
///     - Macro not in specified module (qualified)
///     - Ambiguous import (same name from multiple modules)
///
///   Invocation errors:
///     - Parens on parameterless macro
///     - No parens on parameterized macro
///     - Wrong param count
///     - Missing required param
///     - Unbalanced delimiters in args
///
///   Expansion errors:
///     - Recursive expansion cycle (depth > 256)
///     - Built-in macro misuse
///

/// goal:
/// simple api to do sumn  like this:
/*

// once all is imported


var imports = ImportResolver::Builder()
    .with_standard_library(stdlib_path)
    .with_project_root(project_root)

for path in CLI::IncludePaths {
    imports = imports.with_include_path(path);
}

// tcm = TokenCacheManager
var macro_pp = MacroPreprocessor(sm, tcm, imports, pool);
var fid = sm->load_file(path);
if !tcm->lex_file(fid) {
    return 1;
}

if !macro_pp.process_file(fid, ModulePath("test")) {
    std::print("Macro processing failed!");
    return 1;
}

var tokens = tcm->get_tokens(fid);
if tokens == &null {
    std::print("No tokens found!");
    return 1;
}

/// thats it the macro expanded tokens are in `tokens`
*/

/// btw metnal note: if we have sum like `import Foo::Bar::SomeClass` we simply look up the full path if it doesnt exist we move on since the import may be for a type or function not a macro
/// we only care about macros here and we can `import Foo::Bar::SomeMacro!` we only lookup `Foo::Bar` not the full path, then we lex and look for the specific macro in that module


import Lexer::Lexer::*;
import Lexer::TokenSpan::*;
import Lexer::Preprocessor::ImportResolver::*;

type SymbolID = u32;;
var quiet = false;; // FIXME: remove this once we have proper diagnostics in place instead of just printing to stdout

class PreprocessorSymbolTable {
    var table: map::<string, SymbolID>; ///< identifier name -> symbolId
    var symbols: vec::<string>;         ///< symbolId -> identifier name

    fn intern(self, name: string) -> SymbolID {
        var it = table.find(name);
        if (it != table.end()) {
            return it->second;
        }

        var id: SymbolID = symbols.size();
        symbols.emplace_back(name);
        table.emplace(symbols.back(), id);

        return id;
    }

    fn resolve(self, id: SymbolID) -> *string {
        if id < symbols.size() {
            return &(symbols[id]);
        }

        return &null;
    }

    fn op [](self, id: SymbolID) -> *string {
        return self.resolve(id);
    }

    fn op [](self, name: string) -> SymbolID {
        return self.intern(name);
    }

    fn op as (self) -> string {
        var repr = "PreprocessorSymbolTable(\n";
        for i in usize(0) .. usize(self.symbols.size()) {
            repr += f"  {i}: '{self.symbols[i]}'\n";
        }
        repr += ")";
        return repr;
    }

    fn size(self) -> usize {
        return self.symbols.size();
    }

    fn clear(self) {
        self.table.clear();
        self.symbols.clear();
    }

    fn op delete (self) {
        self.clear();
    }
}

class IdentifierToken {
    pub var name:  SymbolID;
    pub var token: *Token;

    fn IdentifierToken(self, name: SymbolID, token: *Token) {
        self.name = name;
        self.token = token;
    }

    default fn IdentifierToken(self);

    const fn as_string(self, sym_table: *PreprocessorSymbolTable) -> string {
        var name_str_ptr = sym_table->resolve(self.name);
        var name_str = "<invalid>" if (name_str_ptr == &null) else *name_str_ptr;
        return f"IdentifierToken(name: '{name_str}', token: {self.token})";
    }

    const fn op == (self, other: IdentifierToken) -> bool {
        return (self.token) == (other.token);
    }

    const fn op != (self, other: IdentifierToken) -> bool {
        return !(self == other);
    }

    const fn op == (self, other: SymbolID) -> bool {
        return self.name == other;
    }

    const fn op != (self, other: SymbolID) -> bool {
        return !(self == other);
    }

    const fn op < (self, other: IdentifierToken) -> bool {
        return self.name < other.name;
    }

    const fn op > (self, other: IdentifierToken) -> bool {
        return self.name > other.name;
    }
}

class ModulePath {
    pub var segments: vec::<IdentifierToken>; ///< each segment is an identifier token this does not include the "::" tokens

    const fn as_string(self, sym_table: *PreprocessorSymbolTable) -> string {
        if self.segments.size() == 0 {
            return "<global>";
        }

        var result: string = "";
        var back = self.segments.back();

        result.reserve((segments.size()) * 12);

        for seg in self.segments {
            result += seg.as_string(sym_table) + ("::" if (seg != back) else "");
        }

        return result;
    }

    const fn op < (self, other: ModulePath) -> bool {
        var n = __inline_cpp("(libcxx::min)(this->segments.size(), other.segments.size())");

        for i in usize(0)..usize(n) {
            if self.segments[i].name != other.segments[i].name {
                return self.segments[i].name < other.segments[i].name;
            }
        }

        return self.segments.size() < other.segments.size();
    }
}

class MacroParameter {
    __inline_cpp("public:");
    enum VariadicType derives u8 {
        None,        ///< not variadic
        Named,       ///< named variadic (e.g., =...rest)
        Unnamed,     ///< unnamed variadic (e.g., ...rest)
    }

    pub var name:          IdentifierToken;
    pub var has_default:   bool = false;
    pub var is_variadic:   VariadicType = VariadicType::None;
    pub var default_value: TokenSpan;

    const fn as_string(self, sym_table: *PreprocessorSymbolTable) -> string {
        var repr = f"MacroParameter(name: '{self.name.as_string(sym_table)}' ";
        switch self.is_variadic {
            case VariadicType::Named {
                repr += ", is_variadic: named";
            } case VariadicType::Unnamed {
                repr += ", is_variadic: unnamed";
            } case VariadicType::None {
                repr += ", is_variadic: false";
            }
        }

        if self.has_default {
            repr += f", has_default: true, default_value: {self.default_value}";
        } else {
            repr += ", has_default: false, default_value: null";
        }

        return repr + ")";
    }
}

class MacroParameterList {
    pub var params: vec::<MacroParameter>;

    const fn as_string(self, sym_table: *PreprocessorSymbolTable) -> string {
        var repr = "MacroParameterList(params: [";
        for param in self.params {
            repr += param.as_string(sym_table) + ", ";
        }
        repr += "])";
        return repr;
    }
}

class MacroDefinition {
    pub var scope:          ModulePath; ///< module path where this macro is defined (excl the name)
    pub var params:         MacroParameterList; ///< list of parameters
    /// TODO: change this to be a owned TokenBuffer instead of a span, since rn we need to leak the original tokens until the macro is expanded but if we own the tokens we can free them after expansion
    pub var body:           TokenSpan; ///< raw token span for the macro body
    pub var name:           IdentifierToken; ///< macro name we cant use a token here since a token doesnt store the text only kind range and imm data which is not sufficient
    pub var definition_loc: SourceRange; ///< source location of the macro definition (for error reporting)
    pub var accepts_params: bool;        ///< does this macro accept parameters (true if defined with parens)
    pub var source_fid:     u32;           // ← ADD THIS

    const fn as_string(self, s: *PreprocessorSymbolTable) -> string {
        return f"MacroDefinition(name='{self.name.as_string(s)}', scope='{self.scope.as_string(s)}', params={self.params.as_string(s)}, body={self.body}, definition_loc={self.definition_loc}, accepts_params={self.accepts_params})";
    }
}


class MacroSymbolTable {
    pub var table: map::<ModulePath, map::<IdentifierToken, MacroDefinition>>; ///< scope path string -> macro name -> MacroDefinition

    fn insert_macro(self, macro_def: MacroDefinition) -> bool {
        var scope_map_it = self.table.find(macro_def.scope);
        if scope_map_it == self.table.end() {
            // No macros in this scope yet, create new map
            var new_map = map::<IdentifierToken, MacroDefinition>();
            new_map[macro_def.name] = macro_def;
            self.table[macro_def.scope] = new_map;
            return true;
        } else {
            var scope_map = &(scope_map_it->second);
            if scope_map->contains(macro_def.name) {
                return false;
            }

            scope_map->emplace(macro_def.name, macro_def);
            return true;
        }
    }

    fn find_macro(self, scope: ModulePath, name: IdentifierToken) -> *MacroDefinition {
        var scope_map_it = self.table.find(scope);
        if scope_map_it != self.table.end() {
            var scope_map = &(scope_map_it->second);
            var macro_it  = scope_map->find(name);
            if  macro_it != scope_map->end() {
                return &(macro_it->second);
            }
        }
        return &null;
    }

    const fn as_string(self, s: *PreprocessorSymbolTable) -> string {
        var repr = "MacroSymbolTable(\n";
        for scope_pair in self.table {
            repr += f"  Scope: '{scope_pair.first.as_string(s)}'\n";
            for macro_pair in scope_pair.second {
                repr += f"    Macro: '{macro_pair.first.as_string(s)}' => {macro_pair.second.as_string(s)}\n";
            }
        }
        repr += ")";
        return repr;
    }
}

enum ModuleVisibility derives u8 {
    Public,     ///< pub module or no modifier - exported
    Private,    ///< priv module - not exported outside file
    Protected,  ///< prot module - not accessible outside current folder
}

class ScopeTracker {
    struct Frame {
        var path:        ModulePath;        ///< full module path at this frame
        var brace_depth: i32;               ///< brace depth when frame was pushed
        var visibility:  ModuleVisibility;  ///< visibility of this module block
        var is_global:   bool;              ///< true if `module :: { }`
    }

    priv var _sym_table:   *PreprocessorSymbolTable; ///< for interning identifiers
    priv var _file_base:   ModulePath;               ///< base path from filename (e.g., Baz from baz.kro)
    priv var _stack:       vec::<Frame>;             ///< scope stack
    priv var _brace_depth: i32;                      ///< current brace nesting level
    priv var _current:     ModulePath;               ///< cached current scope
    priv var _sm:         *SourceManager;            ///< source manager for error reporting

    /// \brief constructs tracker with file's base module path
    /// \param sym_table symbol table for interning identifiers
    /// \param file_base module path derived from filename
    fn ScopeTracker(self, sym_table: *PreprocessorSymbolTable, sm: *SourceManager, file_base: ModulePath) {
        self._stack       = vec::<Frame>();
        self._sym_table   = sym_table;
        self._file_base   = file_base;
        self._current     = file_base;
        self._sm          = sm;
        self._brace_depth = 0;

        // push initial frame for file-level scope
        var initial = Frame();
        initial.path        = file_base;
        initial.brace_depth = 0;
        initial.visibility  = ModuleVisibility::Public;
        initial.is_global   = false;
        self._stack.push_back(initial);
    }

    /// \brief returns current module scope as ModulePath
    fn current_scope(self) -> ModulePath {
        return self._current;
    }

    /// \brief returns current visibility
    fn current_visibility(self) -> ModuleVisibility {
        if self._stack.size() == 0 {
            return ModuleVisibility::Public;
        }
        return self._stack.back().visibility;
    }

    /// \brief returns true if currently in global scope (module :: { })
    fn is_global_scope(self) -> bool {
        if self._stack.size() == 0 {
            return false;
        }
        return self._stack.back().is_global;
    }

    /// \brief returns current brace depth
    fn brace_depth(self) -> i32 {
        return self._brace_depth;
    }

    /// \brief processes a single token, updating scope state
    /// \param tokens the token span to read from
    /// \param i current token index
    /// \return number of additional tokens consumed (0 if just this token)
    fn update(self, tokens: TokenSpan, i: usize) -> usize {
        if i >= tokens.size() { return 0; }

        var tok = tokens.get(i);

        // track all braces for scope popping
        if tok->kind == TokenKind::OpLBrace {
            ++self._brace_depth;
            return 0;
        }

        if tok->kind == TokenKind::OpRBrace {
            --self._brace_depth;
            self.maybe_pop_scope();
            return 0;
        }

        // check for visibility modifier followed by module
        if tok->kind == TokenKind::KwPub {
            if (i + 1) < tokens.size() {
                var next = tokens.get(i + 1);
                if next->kind == TokenKind::KwModule {
                    return self.parse_module_decl(tokens, i + 1, ModuleVisibility::Public) + 1;
                }
            }
            return 0;
        }

        if tok->kind == TokenKind::KwPriv {
            if (i + 1) < tokens.size() {
                var next = tokens.get(i + 1);
                if next->kind == TokenKind::KwModule {
                    return self.parse_module_decl(tokens, i + 1, ModuleVisibility::Private) + 1;
                }
            }
            return 0;
        }

        if tok->kind == TokenKind::KwProt {
            if (i + 1) < tokens.size() {
                var next = tokens.get(i + 1);
                if next->kind == TokenKind::KwModule {
                    return self.parse_module_decl(tokens, i + 1, ModuleVisibility::Protected) + 1;
                }
            }
            return 0;
        }

        // check for bare module keyword
        if tok->kind == TokenKind::KwModule {
            return self.parse_module_decl(tokens, i, ModuleVisibility::Public);
        }

        return 0;
    }

    /// \brief parses module declaration starting at `module` keyword
    /// \returns number of tokens consumed (not including the visibility modifier)
    priv fn parse_module_decl(self, tokens: TokenSpan, module_idx: usize,
                              visibility: ModuleVisibility) -> usize {
        var j = module_idx + 1;
        if j >= tokens.size() { return 0; }

        var t = tokens.get(j);

        // case: `module :: { }` - global scope
        if t->kind == TokenKind::OpColonColon {
            if (j + 1) < tokens.size() {
                var next = tokens.get(j + 1);
                if next->kind == TokenKind::OpLBrace {
                    self.push_global_scope(visibility);
                    return 2; // `module` + `::`
                }
            }
            // `module ::Foo::Bar` syntax - parse as global-qualified path
            var path_result = self.parse_module_path(tokens, j + 1);
            if path_result.path.segments.size() > 0 {
                var after_path = j + 1 + path_result.tokens_consumed;
                if after_path < tokens.size() {
                    var next_tok = tokens.get(after_path);
                    if next_tok->kind == TokenKind::OpLBrace {
                        self.push_absolute_scope(path_result.path, visibility);
                        return 2 + path_result.tokens_consumed; // `module` + `::` + path
                    }
                }
            }
            return 0;
        }

        // case: `module { }` - anonymous visibility block
        if t->kind == TokenKind::OpLBrace {
            self.push_visibility_scope(visibility);
            return 1; // just `module`, brace handled by normal tracking
        }

        // case: `module Ident...` or `module Foo::Bar...`
        if t->kind != TokenKind::LitIdentifier { return 0; }

        var path_result = self.parse_module_path(tokens, j);
        if path_result.path.segments.size() == 0 { return 0; }

        var after_path = j + path_result.tokens_consumed;
        if after_path >= tokens.size() { return 0; }

        var next_tok = tokens.get(after_path);
        if next_tok->kind == TokenKind::OpLBrace {
            self.push_scope(path_result.path, visibility);
            return 1 + path_result.tokens_consumed; // `module` + path tokens
        }

        return 0;
    }

    struct PathParseResult {
        var path:            ModulePath;
        var tokens_consumed: usize;
    }

    /// \brief parses a module path (Foo::Bar::Baz)
    /// \param tokens token span
    /// \param start index of first identifier
    /// \returns PathParseResult with path and token count
    priv fn parse_module_path(self, tokens: TokenSpan, start: usize) -> PathParseResult {
        var result = PathParseResult();
        result.path = ModulePath();
        result.tokens_consumed = 0;

        var j = start;

        while j < tokens.size() {
            var t = tokens.get(j);
            if t->kind != TokenKind::LitIdentifier { break; }

            // create IdentifierToken from the token
            var ident = IdentifierToken();
            ident.token = tokens.get(j);
            ident.name  = self._sym_table->intern(self._sm->get_text(ident.token->range));

            result.path.segments.push_back(ident);
            result.tokens_consumed += 1;

            // check for ::
            if (j + 1) >= tokens.size() { break; }
            var next = tokens.get(j + 1);
            if next->kind != TokenKind::OpColonColon { break; }

            result.tokens_consumed += 1; // count the ::
            j += 2; // skip ident and ::
        }

        return result;
    }

    /// \brief pushes a new relative scope
    priv fn push_scope(self, path: ModulePath, visibility: ModuleVisibility) {
        var frame = Frame();

        // extend current scope with new path
        frame.path = self._current;
        for seg in path.segments {
            frame.path.segments.push_back(seg);
        }

        frame.brace_depth = self._brace_depth;
        frame.visibility  = visibility;
        frame.is_global   = false;

        self._stack.push_back(frame);
        self.update_current();
    }

    /// \brief pushes global scope (module :: { })
    priv fn push_global_scope(self, visibility: ModuleVisibility) {
        var frame = Frame();
        frame.path        = ModulePath(); // empty = global
        frame.brace_depth = self._brace_depth;
        frame.visibility  = visibility;
        frame.is_global   = true;

        self._stack.push_back(frame);
        self.update_current();
    }

    /// \brief pushes absolute scope (module ::Foo::Bar { })
    priv fn push_absolute_scope(self, path: ModulePath, visibility: ModuleVisibility) {
        var frame = Frame();
        frame.path        = path; // absolute path, replaces current
        frame.brace_depth = self._brace_depth;
        frame.visibility  = visibility;
        frame.is_global   = false;

        self._stack.push_back(frame);
        self.update_current();
    }

    /// \brief pushes visibility-only scope (priv module { })
    priv fn push_visibility_scope(self, visibility: ModuleVisibility) {
        var frame = Frame();
        frame.path        = self._current;
        frame.brace_depth = self._brace_depth;
        frame.visibility  = visibility;
        frame.is_global   = false;

        self._stack.push_back(frame);
        // current scope doesn't change, just visibility
    }

    /// \brief pops scope if brace depth drops below frame's depth
    priv fn maybe_pop_scope(self) {
        // never pop the file-level scope
        while self._stack.size() > 1 {
            var top = self._stack.back();
            if self._brace_depth >= top.brace_depth {
                break;
            }
            self._stack.pop_back();
        }
        self.update_current();
    }

    /// \brief updates cached current scope from stack top
    priv fn update_current(self) {
        if self._stack.size() == 0 {
            self._current = self._file_base;
            return;
        }

        var top = self._stack.back();
        if top.is_global {
            self._current = ModulePath(); // empty = global
        } else {
            self._current = top.path;
        }
    }

    /// \brief resets tracker to initial state
    fn reset(self) {
        self._stack.clear();
        self._brace_depth = 0;
        self._current     = self._file_base;

        var initial = Frame();
        initial.path        = self._file_base;
        initial.brace_depth = 0;
        initial.visibility  = ModuleVisibility::Public;
        initial.is_global   = false;
        self._stack.push_back(initial);
    }
}

/// \brief represents a single resolved macro import available in a scope
class MacroImport {
    pub var macro_name:    IdentifierToken;  ///< the macro name (interned)
    pub var alias:         IdentifierToken;  ///< alias if renamed, same as macro_name otherwise
    pub var source_scope:  ModulePath;       ///< the module path where the macro lives
    pub var source_fid:    u32;              ///< file ID where the macro is defined
    pub var import_loc:    SourceRange;      ///< source location of the import statement
    pub var is_wildcard:   bool;             ///< true if this came from a wildcard import
}

/// \brief per-file import state: what macros are available and from where
class FileImportState {
    pub var fid:            u32;                          ///< file ID
    pub var module_base:    ModulePath;                   ///< base module path derived from filename
    pub var macro_imports:  vec::<MacroImport>;            ///< resolved macro imports
    pub var wildcard_fids:  vec::<u32>;                    ///< files imported with *, need full macro table scan
    pub var scoped_imports: map::<ModulePath, vec::<MacroImport>>; ///< imports grouped by scope they're visible in
    pub var module_aliases: map::<SymbolID, ModulePath>;    // ← ADD THIS
}

/// \brief result of parsing a single import statement from the token stream
class ParsedImport {
    /// \brief a single item from a grouped import { A, B as C, Mac! }

    __inline_cpp("public:");
    class Item {
        pub var name:       IdentifierToken;  ///< original name
        pub var alias:      IdentifierToken;  ///< alias (same as name if no `as`)
        pub var has_alias:  bool = false;
        pub var is_macro:   bool = false;      ///< true if name ends with `!`
    }

    pub var base_path:   ModulePath;       ///< the module path prefix (everything before the last segment or group)
    pub var items:       vec::<Item>;       ///< individual import items (1 for simple, N for grouped)
    pub var is_wildcard: bool = false;      ///< true for `import Foo::Bar::*`
    pub var is_module:   bool = false;      ///< true for `import module Foo::Bar`
    pub var is_ffi:      bool = false;      ///< true for `ffi "..." import ...`
    pub var import_loc:  SourceRange;       ///< full source range of the import statement
    pub var scope:       ModulePath;        ///< scope where this import appears (from ScopeTracker)
    pub var tokens_consumed: usize = 0;
    pub var end_index: usize = 0;
}


// =========================================================================
//  SKIP LIST
// =========================================================================

/// \brief sorted list of SourceRange "dead zones" that the expander skips.
///        Populated during import scanning and definition collection.
///        Binary-searched during expansion O(log n) per token.
class SkipList {
    priv var _ranges: vec::<SourceRange>;

    /// \brief registers a dead zone (import statement, macro def, ffi block)
    fn add(self, range: SourceRange) {
        self._ranges.push_back(range);
    }

    /// \brief sorts ranges by start location. Call once after collection is done.
    fn finalize(self) {
        libcxx::sort(self._ranges.begin(), self._ranges.end(),
            fn (a: SourceRange, b: SourceRange) -> bool {
                return a.start.raw() < b.start.raw();
            }
        );
    }

    /// \brief returns true if `loc` falls inside any dead zone
    fn contains(self, loc: SourceLocation) -> bool {
        var raw = loc.raw();
        var lo: usize = 0;
        var hi: usize = self._ranges.size();

        while lo < hi {
            var mid = lo + (hi - lo) / 2;
            var r = self._ranges[mid];

            if raw < r.start.raw() {
                hi = mid;
            } else if raw >= r.end.raw() {
                lo = mid + 1;
            } else {
                return true;
            }
        }

        return false;
    }

    /// \brief returns the index of the first token past the dead zone,
    ///        or `from` if `from` is not in a dead zone.
    fn skip_past_index(self, tokens: *(TokenBuffer::<512>), from: usize) -> usize {
        if from >= tokens->size() { return from; }

        var tok = tokens->get(from);
        var raw = tok->range.start.raw();

        // binary search for the zone
        var lo: usize = 0;
        var hi: usize = self._ranges.size();
        var zone_end_raw: u32 = 0;

        while lo < hi {
            var mid = lo + (hi - lo) / 2;
            var r = self._ranges[mid];

            if raw < r.start.raw() {
                hi = mid;
            } else if raw >= r.end.raw() {
                lo = mid + 1;
            } else {
                zone_end_raw = r.end.raw();
                break;
            }
        }

        if zone_end_raw == 0 { return from; }

        // advance past the dead zone
        var j = from;
        while j < tokens->size() {
            if tokens->get(j)->range.start.raw() >= zone_end_raw {
                return j;
            }
            j += 1;
        }

        return j;
    }

    fn size(self) -> usize {
        return self._ranges.size();
    }

    fn clear(self) {
        self._ranges.clear();
    }
}


/// Macro Definition Collector
/// ==========================
///
/// Walks a token stream (with scope tracking) and extracts all `macro` definitions,
/// registering them into the MacroSymbolTable with correct module scoping.
///
/// Syntax handled:
///
///   Parameterless:
///     macro foo! { body }                          → accepts_params = false
///
///   With params:
///     macro foo!(a, b) { body }                    → accepts_params = true
///
///   With defaults:
///     macro foo!(a, b = default_expr) { body }     → has_default on param
///
///   Variadic (named):
///     macro foo!(a, b...) { body }                 → is_variadic = Named
///
///   Variadic (unnamed):
///     macro foo!(...) { body }                     → is_variadic = Unnamed
///
///   Dead variadic (no name):
///     macro bar!(...) { body }                     → unnamed variadic, no binding
///
/// Notes:
///   - The trailing `;` after `}` is optional (lexer guarantees balanced braces)
///   - Macros are scoped by the ScopeTracker's current module path
///   - Duplicate macro in same scope is an error
///   - Variadic param must be last
///   - Default params must come after all required params (but before variadic)
///   - The body is stored as a raw TokenSpan (start/end indices into the token buffer)
///
class MacroDefinitionCollector {
    priv var _sym_table:   *PreprocessorSymbolTable;
    priv var _macro_table: *MacroSymbolTable;
    priv var _sm:          *SourceManager;
    priv var _skip_list:   *SkipList;
    priv var _current_fid: u32;            // ← ADD THIS
    priv var _diagnostics: vec::<string>;

    fn MacroDefinitionCollector(
        self,
        sym_table:   *PreprocessorSymbolTable,
        macro_table: *MacroSymbolTable,
        sm:          *SourceManager
    ) {
        self._sym_table   = sym_table;
        self._macro_table = macro_table;
        self._sm          = sm;
    }

    /// \brief collects all macro definitions from a token stream for a given file
    /// \param tokens the token buffer for the file
    /// \param fid file ID (for error reporting)
    /// \param tracker scope tracker (already initialized with the file's base module path)
    /// \return true if no errors, false if any definition errors occurred
    fn collect(self, tokens: *(TokenBuffer::<512>), fid: u32, tracker: *ScopeTracker, skip_list: *SkipList) -> bool {
        self._skip_list = skip_list;
        self._current_fid = fid;

        var had_errors = false;
        var i: usize = 0;

        while i < tokens->size() {
            var tok = tokens->get(i);

            // feed scope tracker first it needs to see every token
            var scope_consumed = tracker->update(tokens, i);

            // check for `macro` keyword
            if tok->kind == TokenKind::KwMacro {
                var consumed = self.parse_macro_definition(tokens, i, tracker);
                if consumed == 0 {
                    // parse failed, skip the keyword and continue
                    had_errors = true;
                    i += 1;
                } else {
                    i += consumed;
                }
                continue;
            }

            // ffi block macros (we do not skip this later if needed for now we can leave this)
            // FIXME: at somepoint we do want to get this in its own parse for now its the ast's job
            if tok->kind == TokenKind::KwFfi {
                var skip = self.skip_ffi_block(tokens, i);
                if skip > 0 {
                    i += skip;
                    continue;
                }
            }

            i += scope_consumed + 1;
        }

        return !had_errors;
    }

    /// \brief parses a single macro definition starting at the `macro` keyword
    /// \param tokens token buffer
    /// \param start index of `KwMacro`
    /// \param tracker scope tracker for current scope
    /// \returns number of tokens consumed (0 on error)
    priv fn parse_macro_definition(
        self,
        tokens:  *(TokenBuffer::<512>),
        start:   usize,
        tracker: *ScopeTracker
    ) -> usize {
        var j = start + 1; // skip `macro`

        // ── expect: identifier ──────────────────────────────────────────────
        if j >= tokens->size() {
            self.error(tokens->get(start), "expected macro name after 'macro' ");
            return 0;
        }

        var name_tok = tokens->get(j);
        if name_tok->kind != TokenKind::LitIdentifier {
            self.error(name_tok, "expected identifier for macro name");
            return 0;
        }

        var name_ident = IdentifierToken();
        name_ident.token = name_tok;
        name_ident.name  = self._sym_table->intern(self._sm->get_text(name_tok->range));
        j += 1;

        // ── expect: `!` ────────────────────────────────────────────────────
        if j >= tokens->size() {
            self.error(name_tok, "expected '!' after macro name");
            return 0;
        }

        var bang_tok = tokens->get(j);
        if bang_tok->kind != TokenKind::OpExclaim {
            self.error(bang_tok, "expected '!' after macro name");
            return 0;
        }
        j += 1;

        // ── build the definition ────────────────────────────────────────────
        var def = MacroDefinition();
        def.name           = name_ident;
        def.scope          = tracker->current_scope();
        def.definition_loc = name_tok->range;
        def.accepts_params = false;

        // ── optional: parameter list `(...)` ────────────────────────────────
        if j < tokens->size() && tokens->get(j)->kind == TokenKind::OpLParen {
            def.accepts_params = true;
            j += 1; // skip `(`

            var param_result = self.parse_params(tokens, &j);
            if !param_result.ok {
                return 0;
            }
            def.params = param_result.params;
        }

        // ── expect: `{` body `}` ───────────────────────────────────────────
        if j >= tokens->size() {
            self.error(name_tok, "expected '{' for macro body");
            return 0;
        }

        var lbrace = tokens->get(j);
        if lbrace->kind != TokenKind::OpLBrace {
            self.error(lbrace, f"expected an opening brace for macro body, got {lbrace->kind}");
            return 0;
        }

        var body_start = j + 1; // first token inside the body
        j += 1;

        // scan for matching `}` balanced brace counting
        var depth: i32 = 1;
        while j < tokens->size() && depth > 0 {
            var t = tokens->get(j);
            if t->kind == TokenKind::OpLBrace { ++depth; }
            if t->kind == TokenKind::OpRBrace { --depth; }
            if depth > 0 { j += 1; }
        }

        if depth != 0 {
            self.error(lbrace, "unmatched '{' in macro body");
            return 0;
        }

        var body_end = j; // index of the closing `}`

        // build body TokenSpan (exclusive of the braces themselves)
        def.body = TokenSpan(tokens, body_start, body_end - body_start);
        def.source_fid = self._current_fid;
        j += 1; // skip the closing `}`

        // ── optional trailing `;` ───────────────────────────────────────────
        if j < tokens->size() && tokens->get(j)->kind == TokenKind::OpSemicolon {
            j += 1;
        }

        // ── register the macro ──────────────────────────────────────────────
        if !self._macro_table->insert_macro(def) {
            var name_ptr = self._sym_table->resolve(name_ident.name);
            var name_str = "<unknown>" if (name_ptr == &null) else *name_ptr;
            var scope_str = def.scope.as_string(self._sym_table);
            self.error(name_tok, f"duplicate macro '{name_str}!' in scope '{scope_str}' ");
            return 0;
        }

        self._skip_list->add(
            SourceRange::from_bounds(
                tokens->get(start)->range.start,
                tokens->get(j - 1)->range.end
            )
        );

        return j - start;
    }

    // =========================================================================
    //  PARAMETER PARSING
    // =========================================================================

    struct ParamParseResult {
        var ok:     bool = false;
        var params: MacroParameterList;
    }

    /// \brief parses macro parameters between `(` and `)`
    /// \param tokens token buffer
    /// \param j current index (just past `(`), updated to just past `)` on success
    /// \returns ParamParseResult
    ///
    /// grammar:
    ///   params     → param (',' param)* ','?
    ///   param      → IDENT                           (required)
    ///              | IDENT '=' default_expr           (with default)
    ///              | IDENT '...'                      (named variadic)
    ///              | '...'                            (unnamed variadic)
    ///
    /// constraints:
    ///   - variadic must be last
    ///   - no defaults after variadic
    ///   - defaults must come after all required params
    priv fn parse_params(self, tokens: *(TokenBuffer::<512>), j: *usize) -> ParamParseResult {
        var result = ParamParseResult();
        var seen_default  = false;
        var seen_variadic = false;

        while (*j) < tokens->size() {
            var t = tokens->get(*j);

            // ── closing paren ───────────────────────────────────────────────
            if t->kind == TokenKind::OpRParen {
                (*j) += 1;
                result.ok = true;
                return result;
            }

            // ── skip commas ─────────────────────────────────────────────────
            if t->kind == TokenKind::OpComma {
                (*j) += 1;
                continue;
            }

            // ── check for errors after variadic ─────────────────────────────
            if seen_variadic {
                self.error(t, "no parameters allowed after variadic");
                return result;
            }

            // ── unnamed variadic: `...` then `)` ───────────────────────────
            if t->kind == TokenKind::OpEllipsis {
                var param = MacroParameter();
                // unnamed variadic synthesize an empty name
                param.name.name  = self._sym_table->intern("__va_args");
                param.name.token = t;
                param.is_variadic = MacroParameter::VariadicType::Unnamed;
                result.params.params.push_back(param);
                seen_variadic = true;
                (*j) += 1;
                continue;
            }

            // ── expect identifier ───────────────────────────────────────────
            if t->kind != TokenKind::LitIdentifier {
                self.error(t, f"expected parameter name, got {t->kind}");
                return result;
            }

            var param = MacroParameter();
            param.name.token = t;
            param.name.name  = self._sym_table->intern(self._sm->get_text(t->range));
            (*j) += 1;

            // ── check what follows the identifier ───────────────────────────
            if (*j) >= tokens->size() {
                self.error(t, "unexpected end of tokens in macro parameter list");
                return result;
            }

            var next = tokens->get(*j);

            // named variadic: `ident...`
            if next->kind == TokenKind::OpEllipsis {
                if seen_default {
                    self.error(next, "variadic parameter cannot follow default parameters");
                    return result;
                }
                param.is_variadic = MacroParameter::VariadicType::Named;
                seen_variadic = true;
                (*j) += 1;
                result.params.params.push_back(param);
                continue;
            }

            // default value: `ident = expr`
            if next->kind == TokenKind::OpEqual {
                (*j) += 1; // skip `=`

                var default_result = self.parse_default_value(tokens, j);
                if !default_result.ok {
                    return result;
                }

                param.has_default   = true;
                param.default_value = default_result.span;
                seen_default = true;
                result.params.params.push_back(param);
                continue;
            }

            // plain required parameter
            if seen_default {
                self.error(t, "required parameter cannot follow default parameters");
                return result;
            }

            result.params.params.push_back(param);
        }

        // ran out of tokens without finding `)`
        self.error(tokens->get((*j) - 1), "unterminated macro parameter list, expected ')' ");
        return result;
    }

    // =========================================================================
    //  DEFAULT VALUE PARSING
    // =========================================================================

    struct DefaultParseResult {
        var ok:   bool = false;
        var span: TokenSpan;
    }

    /// \brief parses a default value expression after `=` in a parameter
    ///
    /// collects tokens until we hit `,` or `)` at depth 0, respecting
    /// balanced parens/brackets/braces for nested expressions.
    ///
    /// e.g. `macro foo!(a, b = some_fn(1, 2), c = 10) { ... }`
    ///       the default for b is `some_fn(1, 2)` the commas inside
    ///       the parens don't split the parameter list.
    priv fn parse_default_value(
        self,
        tokens: *(TokenBuffer::<512>),
        j:      *usize
    ) -> DefaultParseResult {
        var result = DefaultParseResult();

        if (*j) >= tokens->size() {
            self.error(tokens->get((*j) - 1), "expected default value expression");
            return result;
        }

        var span_start = *j;
        var depth: i32 = 0;

        while (*j) < tokens->size() {
            var t = tokens->get(*j);

            // track nesting
            if t->kind == TokenKind::OpLParen  { ++depth; }
            if t->kind == TokenKind::OpLBrace  { ++depth; }
            if t->kind == TokenKind::OpLSquare  { ++depth; }

            if t->kind == TokenKind::OpRParen {
                if depth == 0 {
                    // this is the `)` closing the param list don't consume it
                    break;
                }
                --depth;
            }

            if t->kind == TokenKind::OpRBrace  { --depth; }
            if t->kind == TokenKind::OpRSquare  { --depth; }

            // comma at depth 0 = next param
            if t->kind == TokenKind::OpComma && depth == 0 {
                break;
            }

            (*j) += 1;
        }

        if (*j) == span_start {
            self.error(tokens->get(span_start), "empty default value expression");
            return result;
        }

        result.span = TokenSpan(tokens, span_start, (*j) - span_start);
        result.ok   = true;
        return result;
    }

    // =========================================================================
    //  FFI SKIPPING (mirrors ImportProcessor::skip_ffi)
    // =========================================================================

    priv fn skip_ffi_block(self, tokens: *(TokenBuffer::<512>), start: usize) -> usize {
        if start >= tokens->size() { return 0; }

        var tok = tokens->get(start);
        if tok->kind != TokenKind::KwFfi { return 0; }

        var j = start + 1;
        if j >= tokens->size() { return 1; }

        var next = tokens->get(j);
        if next->kind != TokenKind::LitString { return 0; }
        j += 1;

        if j >= tokens->size() { return j - start; }
        var after_str = tokens->get(j);

        // ffi "..." import ... ;
        if after_str->kind == TokenKind::KwImport {
            while j < tokens->size() {
                if tokens->get(j)->kind == TokenKind::OpSemicolon {
                    return (j + 1) - start;
                }
                j += 1;
            }
            return j - start;
        }

        // ffi "..." { ... }
        if after_str->kind == TokenKind::OpLBrace {
            var depth: i32 = 1;
            j += 1;
            while j < tokens->size() && depth > 0 {
                var t = tokens->get(j);
                if t->kind == TokenKind::OpLBrace { ++depth; }
                if t->kind == TokenKind::OpRBrace { --depth; }
                j += 1;
            }
            return j - start;
        }

        return 1;
    }

    // =========================================================================
    //  DIAGNOSTICS
    // =========================================================================

    priv fn error(self, tok: *Token, msg: string) {
        if tok == &null {
            self._diagnostics.push_back(f"MacroDefinitionCollector: <unknown location>: error: {msg}");
            return;
        }
        var full_src_loc = self._sm->get_full_loc(tok->range.start);
        var loc_str = f"{self._sm->get_filename(full_src_loc.file_id)}:{full_src_loc.line}:{full_src_loc.column}";
        self._diagnostics.push_back(f"MacroDefinitionCollector: {loc_str}: error: {msg}");
    }

    fn get_diagnostics(self) -> ref!(vec::<string>) {
        return self._diagnostics;
    }

    fn has_errors(self) -> bool {
        return self._diagnostics.size() > 0;
    }

    fn dump(self) -> string {
        var out = "=== MacroDefinitionCollector ===\n";
        // we dump the diags and also a summary of the collected macros for debugging
        out += f"Collected {self._macro_table->table.size()} macros\n";
        for entry in self._macro_table->table {
            var scope_str = entry.first.as_string(self._sym_table);
            for macro_entry in entry.second {
                var name_ptr = self._sym_table->resolve(macro_entry.first.name);
                var name_str = "<unknown>" if (name_ptr == &null) else *name_ptr;
                out += f"  {name_str}! in scope {scope_str}\n";
            }
        }

        out += "=== End MacroDefinitionCollector ===\n";
        return out;
    }
}

class MacroProcessor;
class SkipList;

class ImportProcessor {
    priv var _sm:           *SourceManager;
    priv var _tcm:          *TokenCacheManager;
    priv var _resolver:     *ImportResolver;
    priv var _sym_table:    *PreprocessorSymbolTable;
    priv var _macro_table:  *MacroSymbolTable;
    priv var _macro_proc:   *MacroProcessor;            ///< back-pointer for recursive preprocess_file
    priv var _skip_lists:   *map::<u32, SkipList>;
    priv var _file_states:   map::<u32, FileImportState>; ///< per-file import state
    priv var _diagnostics:   vec::<string>;               ///< accumulated errors/warnings

    default fn ImportProcessor(self);

    fn ImportProcessor(
        self,
        sm:          *SourceManager,
        tcm:         *TokenCacheManager,
        resolver:    *ImportResolver,
        sym_table:   *PreprocessorSymbolTable,
        macro_table: *MacroSymbolTable,
        skip_lists:  *map::<u32, SkipList>,
        macro_proc:  *MacroProcessor
    )  {
        self._sm          = sm;
        self._tcm         = tcm;
        self._resolver    = resolver;
        self._sym_table   = sym_table;
        self._macro_table = macro_table;
        self._macro_proc  = macro_proc;
        self._skip_lists  = skip_lists;
    }

    fn process_file(self, fid: u32, module_base: ModulePath) -> bool;
    fn get_file_state(self, fid: u32) -> *FileImportState;
    fn get_diagnostics(self) -> ref!(vec::<string>);
    fn has_errors(self) -> bool;

    priv fn skip_ffi(self, tokens: *(TokenBuffer::<512>), start: usize) -> usize;
    priv fn parse_import(
        self,
        tokens:  *(TokenBuffer::<512>),
        start:   usize,
        tracker: *ScopeTracker
    ) -> ParsedImport;
    priv fn parse_grouped_imports(
        self,
        tokens: *(TokenBuffer::<512>),
        j:      *usize,
        result: *ParsedImport
    );
    priv fn resolve_import(
        self,
        parsed:  *ParsedImport,
        state:   *FileImportState,
        src_fid: u32
    );

    struct ResolveResult {
        var found:            bool = false;
        var fid:              u32  = 0;
        var file_module_path: ModulePath;
        var remaining_path:   ModulePath;
    }

    priv fn resolve_module_greedy(
        self,
        segments:  vec::<string>,
        is_module: bool
    ) -> ResolveResult;

    fn find_macro_for_file(
        self,
        fid:        u32,
        scope:      ModulePath,
        macro_name: IdentifierToken
    ) -> *MacroDefinition;
    fn find_qualified_macro(
        self,
        fid:        u32,
        full_path:  ModulePath,
        macro_name: IdentifierToken
    ) -> *MacroDefinition;

    priv fn segments_to_string(self, segments: vec::<string>) -> string;

    fn dump_state(self) -> string;
}

// =========================================================================
//  EXPANSION CONTEXT
// =========================================================================

/// \brief per-expansion state: tracks recursion depth, cycle detection,
///        and parameter bindings for a single macro invocation.
class ExpansionContext {
    pub var call_stack:        vec::<SymbolID>;                    ///< macro names on the current expansion stack
    pub var param_bindings:    map::<SymbolID, TokenSpan>;         ///< param name → argument tokens
    pub var variadic_bindings: vec::<TokenSpan>;                   ///< variadic arguments (one TokenSpan per arg)
    pub var invoke_loc:        SourceRange;                        ///< source location of the invocation site
    pub var depth:             u32 = 0;                            ///< current recursion depth

    const MAX_DEPTH: u32 = 256;

    fn is_in_cycle(self, name: SymbolID) -> bool {
        for id in self.call_stack {
            if id == name { return true; }
        }
        return false;
    }

    fn push(self, name: SymbolID) {
        self.call_stack.push_back(name);
        self.depth += 1;
    }

    fn pop(self) {
        if self.call_stack.size() > 0 {
            self.call_stack.pop_back();
        }
        if self.depth > 0 {
            self.depth -= 1;
        }
    }

    fn exceeded_depth(self) -> bool {
        return self.depth > MAX_DEPTH;
    }
}

// =========================================================================
//  MACRO EXPANDER
// =========================================================================



/// FIXME: builtins wise make risky ops like unstringfy and embed opt out with
//         -fno-embedded-builtin-macros or something, we can still allow
//         them in macro bodies but not expand them if the flag is set
//
//         this is because they can be used to do sketchy things like read
//         arbitrary files, or even privilege escalation if they contain asm to
//         execute commands by buff overwriting or something; we can be
//         conservative and only allow the most basic ones like `file!` and
//         `line!` which are generally safe, and leave the more powerful ones
//         opt-in for now until we have a better sense of the security
//         implications and use cases

// FIXME: also make the max recursion depth configurable via a flag, and maybe
//        even allow users to set it to unlimited (with a warning) if they
//        really want to do crazy things; for now we can just have a hard limit
//        of 256 or something to prevent infinite recursion from accidentally
//        or malicious crafted macros, something like -fmax-macro-depth=256

/// \brief walks a file's token stream, detects macro invocations, resolves
///        them via MacroProcessor's resolution logic, and produces a new
///        expanded token buffer that replaces the original in the TCM.
///
/// Invocation patterns detected:
///
///   Unqualified parameterless:   `foo!`             → ident `!`
///   Unqualified with params:     `foo!(args)`       → ident `!` `(` ... `)`
///   Qualified parameterless:     `Foo::bar!`        → ident `::` ident `!`
///   Qualified with params:       `Foo::bar!(args)`  → ident `::` ident `!` `(` ... `)`
///
class MacroExpander {
    priv var _sm:          *SourceManager;
    priv var _sym_table:   *PreprocessorSymbolTable;
    priv var _macro_table: *MacroSymbolTable;
    priv var _import_proc: *ImportProcessor;
    priv var _skip_list:   *SkipList;
    priv var _diagnostics: vec::<string>;
    priv var _fid:         u32;
    priv var _scope:       ModulePath; ///< current scope during expansion (updated by scope tracker)
    priv var _imm_table: *ImmediateTable;  ///< lexer's imm table for the file being expanded
    priv var _parent_expansion_idx: u32 = static_cast::<u32>(-1); ///< for nested tracking
    priv var _unique_counter: u32 = 0;

    struct PendingDiag {
        var level: DiagnosticLevel;
        var msg:   string;
        var range: SourceRange;
    }

    priv var _pending_diags: vec::<PendingDiag>;

    fn MacroExpander(
        self,
        sm:          *SourceManager,
        sym_table:   *PreprocessorSymbolTable,
        macro_table: *MacroSymbolTable,
        import_proc: *ImportProcessor,
        skip_list:   *SkipList,
        imm_table:   *ImmediateTable
    ) {
        self._sm          = sm;
        self._sym_table   = sym_table;
        self._macro_table = macro_table;
        self._import_proc = import_proc;
        self._skip_list   = skip_list;
        self._imm_table   = imm_table;
        self._parent_expansion_idx = static_cast::<u32>(-1);
    }

    // =====================================================================
    //  INVOCATION DETECTION
    // =====================================================================

    struct InvocationInfo {
        var found:          bool = false;
        var is_qualified:   bool = false;
        var has_args:       bool = false;
        var name:           IdentifierToken;      ///< the macro name (last ident before `!`)
        var qualified_path: ModulePath;            ///< module path for qualified invocations
        var bang_index:     usize = 0;             ///< index of the `!` token
        var args_start:     usize = 0;             ///< index of `(` (if has_args)
        var args_end:       usize = 0;             ///< index past `)` (if has_args)
        var start_index:    usize = 0;             ///< first token of invocation (path start or ident)
        var end_index:      usize = 0;             ///< first token AFTER the invocation
    }

    // =====================================================================
    //  BUILTIN MACROS
    // =====================================================================

    priv fn builtin_file(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var loc = self._sm->get_full_loc(invoke.name.token->range.start);
        var filename = self._sm->get_filename(loc.file_id);
        // synthesize a LitString token range points to the invocation site
        var tok = Token();
        tok.kind  = TokenKind::LitString;
        tok.range = invoke.name.token->range;
        // we store the string in the imm table if available, for now just emit the token
        // AST will re-resolve via range if needed
        out->append(tok);
        return out;
    }

    priv fn builtin_line(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var loc = self._sm->get_full_loc(invoke.name.token->range.start);
        var tok = Token();
        tok.kind  = TokenKind::LitInt;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(loc.line); // temporary: store line directly in imm
        out->append(tok);
        return out;
    }

    priv fn builtin_column(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var loc = self._sm->get_full_loc(invoke.name.token->range.start);
        var tok = Token();
        tok.kind  = TokenKind::LitInt;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(loc.column);
        out->append(tok);
        return out;
    }

    priv fn builtin_module_path(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::LitString;
        tok.range = invoke.name.token->range;
        out->append(tok);
        return out;
    }

    priv fn builtin_count(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        var tok  = Token();
        tok.kind  = TokenKind::LitInt;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(args.size());
        out->append(tok);
        return out;
    }

    priv fn builtin_first(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        if args.size() == 0 {
            self.error(tokens->get(invoke.start_index), "first!() requires at least one argument");
            return out;
        }
        for i in usize(0) .. usize(args[0].size()) {
            out->append(*(args[0].get(i)));
        }
        return out;
    }

    priv fn builtin_last(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        if args.size() == 0 {
            self.error(tokens->get(invoke.start_index), "last!() requires at least one argument");
            return out;
        }
        var last = &(args[args.size() - 1]);
        for i in usize(0) .. usize(last->size()) {
            out->append(*(last->get(i)));
        }
        return out;
    }

    priv fn builtin_rest(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        for k in usize(1) .. usize(args.size()) {
            for i in usize(0) .. usize(args[k].size()) {
                out->append(*(args[k].get(i)));
            }
        }
        return out;
    }

    priv fn builtin_init(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        if args.size() == 0 { return out; }
        for k in usize(0) .. usize(args.size() - 1) {
            for i in usize(0) .. usize(args[k].size()) {
                out->append(*(args[k].get(i)));
            }
        }
        return out;
    }

    priv fn builtin_concat(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // for stage-1: emit all argument tokens concatenated, AST handles merging identifiers
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        for k in usize(0) .. usize(args.size()) {
            for i in usize(0) .. usize(args[k].size()) {
                out->append(*(args[k].get(i)));
            }
        }
        return out;
    }

    priv fn builtin_stringify(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::LitString;
        tok.range = invoke.name.token->range; // AST re-reads the arg span from source
        tok.imm   = invoke.args_start;        // imm temporarily = arg start idx for AST to reconstruct
        out->append(tok);
        return out;
    }

    priv fn builtin_unstringify(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // ⚠ injection risk stage-1 just passes the string token through marked
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        var out  = std::create::<TokenBuffer::<512>>();
        if args.size() != 1 {
            self.error(tokens->get(invoke.start_index), "unstringify!() requires exactly one string argument");
            return out;
        }
        for i in usize(0) .. usize(args[0].size()) {
            out->append(*(args[0].get(i)));
        }
        return out;
    }

    priv fn builtin_defined(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // we'd need the name token from args; for now emit a LitInt 0/1
        // full impl requires resolving the name through the macro table
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::LitInt;
        tok.range = invoke.name.token->range;
        tok.imm   = 0; // assume not defined; AST will re-evaluate with full context
        out->append(tok);
        return out;
    }

    priv fn builtin_undef(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // remove from macro table if found
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        if args.size() == 1 && args[0].size() == 1 {
            var name_tok = args[0].get(0);
            if self.get_effective_kind(name_tok) == TokenKind::LitIdentifier {
                var name_id = self._sym_table->intern(self._sm->get_text(name_tok->range));
                var ident   = IdentifierToken();
                ident.name  = name_id;
                ident.token = name_tok;
                // remove from current scope
                var scope_map_it = self._macro_table->table.find(self._scope);
                if scope_map_it != self._macro_table->table.end() {
                    scope_map_it->second.erase(ident);
                }
            }
        }
        return std::create::<TokenBuffer::<512>>(); // expands to nothing
    }

    priv fn builtin_todo(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // emit a sentinel token AST lowers to runtime panic call
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::TkMacroExpand; // reuse macro expand marker
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(-1);
        out->append(tok);
        return out;
    }

    priv fn builtin_unreachable(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::TkMacroExpand;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(-2); // -2 = unreachable sentinel
        out->append(tok);
        return out;
    }

    priv fn builtin_unique_id(self, invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // increment a counter per expander instance
        self._unique_counter += 1;
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::LitIdentifier;
        tok.range = invoke.name.token->range;
        tok.imm   = self._unique_counter; // AST uses this to generate __unique_NNN
        out->append(tok);
        return out;
    }
    // add: priv var _unique_counter: u32 = 0;

    priv fn builtin_include(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        // deferred to AST emit a sentinel with the string arg range
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::TkMacroExpand;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(-3); // -3 = include sentinel
        out->append(tok);
        return out;
    }

    priv fn builtin_include_str(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::LitString;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(-4); // -4 = include_str sentinel
        out->append(tok);
        return out;
    }

    priv fn builtin_embed(self, tokens: *(TokenBuffer::<512>), invoke: InvocationInfo) -> *(TokenBuffer::<512>) {
        var out = std::create::<TokenBuffer::<512>>();
        var tok = Token();
        tok.kind  = TokenKind::TkMacroExpand;
        tok.range = invoke.name.token->range;
        tok.imm   = static_cast::<u32>(-5); // -5 = embed sentinel
        out->append(tok);
        return out;
    }

    priv fn builtin_diag(
        self,
        tokens: *(TokenBuffer::<512>),
        invoke: InvocationInfo,
        level:  DiagnosticLevel
    ) -> *(TokenBuffer::<512>) {
        // store diagnostic but don't print emit nothing
        // actual printing happens after proc macro expansion
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);
        if args.size() > 0 {
            // reconstruct text from arg tokens for the message
            var msg = string();
            for i in usize(0) .. usize(args[0].size()) {
                msg += self._sm->get_text(args[0].get(i)->range);
            }
            self._pending_diags.push_back(PendingDiag{
                level:  level,
                msg:    msg,
                range:  invoke.name.token->range
            });
        }
        return std::create::<TokenBuffer::<512>>(); // expands to nothing
    }

    // =====================================================================
    //  PUBLIC API
    // =====================================================================

    fn get_pending_diags(self) -> ref!(vec::<PendingDiag>) {
        return self._pending_diags;
    }

    /// \brief expands all macro invocations in the given token buffer.
    /// \param tokens  the token buffer to expand (from TCM)
    /// \param fid     file ID (for resolution context)
    /// \param scope   file-level module path
    /// \returns a NEW token buffer with all invocations expanded.
    ///          caller is responsible for replacing the TCM entry.
    ///          returns &null if no expansions occurred (original is fine).
    fn expand(self, tokens: *(TokenBuffer::<512>), fid: u32, scope: ModulePath) -> *(TokenBuffer::<512>) {
        // std::print(f"[EXPAND] expanding fid={fid}, token count={tokens->size()}, skip zones={self._skip_list->size()}");

        self._fid   = fid;
        self._scope = scope;

        var tracker = ScopeTracker(self._sym_table, self._sm, scope);
        var ctx     = ExpansionContext();
        var output  = std::create::<TokenBuffer::<512>>();
        var changed = false;

        var i: usize = 0;
        while i < tokens->size() {
            // skip dead zones
            if self._skip_list->contains(tokens->get(i)->range.start) {
                var end = self._skip_list->skip_past_index(tokens, i);
                // copy dead zone tokens verbatim to output
                while i < end {
                    output->append(*(tokens->get(i)));
                    i += 1;
                }
                continue;
            }

            // feed scope tracker
            var scope_consumed = tracker.update(tokens, i);
            self._scope = tracker.current_scope();

            var tok = tokens->get(i);

            // ── detect invocation ───────────────────────────────────────
            var invoke = self.detect_invocation(tokens, i);

            if invoke.found {
                // ── try builtins first ──────────────────────────────────────
                var builtin_result = self.try_builtin(tokens, invoke, &ctx);
                if builtin_result != &null {
                    for j in usize(0) .. usize(builtin_result->size()) {
                        output->append(self.wrap_token(
                            *(builtin_result->get(j)),
                            invoke.name.name,
                            tokens->get(invoke.start_index)->range,
                            self._parent_expansion_idx
                        ));
                    }
                    std::destroy(builtin_result);
                    changed = true;
                    i = invoke.end_index;
                    continue;
                }

                // std::print(f"[EXPAND] detected invocation: '{self.name_str(invoke.name.name)}!' at index {i}, qualified={invoke.is_qualified}, has_args={invoke.has_args}");
                var def = self.resolve_invocation(invoke);

                if def != &null {
                    // validate: parens vs no-parens
                    // std::print(f"[EXPAND] def->accepts_params={def->accepts_params}, invoke.has_args={invoke.has_args}");

                    if (def->accepts_params) && (!invoke.has_args) {
                        self.error(tok, f"macro '{self.name_str(def->name.name)}!' requires arguments");
                        output->append(*tok);
                        i += 1;
                        continue;
                    }

                    if (!def->accepts_params) && (invoke.has_args) {
                        self.error(tok, f"macro '{self.name_str(def->name.name)}!' does not accept arguments");
                        output->append(*tok);
                        i += 1;
                        continue;
                    }

                    // expand
                    var expanded = self.expand_invocation(tokens, invoke, def, &ctx);

                    if expanded != &null {
                        // append expanded tokens to output
                        for j in usize(0) .. usize(expanded->size()) {
                            output->append(*(expanded->get(j)));
                        }
                        std::destroy(expanded);
                        changed = true;
                    }

                    // skip past the invocation in the source
                    i = invoke.end_index;
                    continue;
                }

                // not found not necessarily an error (could be a type or fn call)
                // just emit tokens as-is
            }

            // no invocation emit token
            output->append(*tok);
            i += scope_consumed + 1;
        }

        if !changed {
            std::destroy(output);
            return &null;
        }

        return output;
    }

    fn get_diagnostics(self) -> ref!(vec::<string>) {
        return self._diagnostics;
    }

    fn has_errors(self) -> bool {
        return self._diagnostics.size() > 0;
    }

    /// \brief detects if tokens[i] starts a macro invocation.
    ///
    /// Patterns:
    ///   ident `!`                     → unqualified, no args
    ///   ident `!` `(` ... `)`         → unqualified, with args
    ///   ident `::` ... ident `!`      → qualified, no args
    ///   ident `::` ... ident `!` `(`  → qualified, with args
    priv fn detect_invocation(self, tokens: *(TokenBuffer::<512>), i: usize) -> InvocationInfo {
        var result = InvocationInfo();

        if i >= tokens->size() { return result; }

        var tok = tokens->get(i);
        if self.get_effective_kind(tok) != TokenKind::LitIdentifier { return result; }

        // ── try to parse a path: ident (:: ident)* ─────────────────────
        var path_idents = vec::<usize>(); // indices of identifier tokens in the path
        path_idents.push_back(i);

        var j = i + 1;

        while j + 1 < tokens->size() {
            if self.get_effective_kind(tokens->get(j)) != TokenKind::OpColonColon { break; }
            if self.get_effective_kind(tokens->get(j + 1)) != TokenKind::LitIdentifier { break; }
            path_idents.push_back(j + 1);
            j += 2;
        }

        // ── expect `!` after the last identifier ───────────────────────
        if j >= tokens->size() { return result; }
        if self.get_effective_kind(tokens->get(j)) != TokenKind::OpExclaim { return result; }

        var bang_idx  = j;
        var name_idx  = path_idents[path_idents.size() - 1];
        var name_tok  = tokens->get(name_idx);

        result.found       = true;
        result.bang_index  = bang_idx;
        result.start_index = i;

        // build name IdentifierToken
        result.name.token = name_tok;
        result.name.name  = self._sym_table->intern(self._sm->get_text(name_tok->range));

        // build qualified path (all idents except last)
        if path_idents.size() > 1 {
            result.is_qualified = true;
            result.qualified_path = ModulePath();

            for k in usize(0) .. usize(path_idents.size() - 1) {
                var seg_tok = tokens->get(path_idents[k]);
                var seg = IdentifierToken();
                seg.token = seg_tok;
                seg.name  = self._sym_table->intern(self._sm->get_text(seg_tok->range));
                result.qualified_path.segments.push_back(seg);
            }
        }

        j = bang_idx + 1; // past `!`

        // ── check for argument list `(` ... `)` ────────────────────────
        if (j < tokens->size()) && (self.get_effective_kind(tokens->get(j)) == TokenKind::OpLParen) {
            result.has_args   = true;
            result.args_start = j; // index of `(`

            // find matching `)` with balanced delimiters
            var depth: i32 = 1;
            j += 1;

            while j < tokens->size() && depth > 0 {
                var t = tokens->get(j);
                if self.get_effective_kind(t) == TokenKind::OpLParen  { depth += 1; }
                if self.get_effective_kind(t) == TokenKind::OpRParen  { depth -= 1; }
                j += 1;
            }

            if depth != 0 {
                // unbalanced not a valid invocation
                result.found = false;
                return result;
            }

            result.args_end  = j; // index past `)`
            result.end_index = j;
        } else {
            result.end_index = bang_idx + 1; // just past `!`
        }

        std::print(f"[DETECT] found invocation: name='{self._sm->get_text(name_tok->range)}', has_args={result.has_args}, start={result.start_index}, end={result.end_index}");
        return result;
    }

    // =====================================================================
    //  RESOLUTION
    // =====================================================================

    /// \brief resolves an invocation to a MacroDefinition using the
    ///        import processor's scoped lookup.
    priv fn resolve_invocation(self, invoke: InvocationInfo) -> *MacroDefinition {
        if invoke.is_qualified {
            return self._import_proc->find_qualified_macro(
                self._fid,
                invoke.qualified_path,
                invoke.name
            );
        }

        // unqualified: current scope → imports → global
        // 1. current scope
        var def = self._macro_table->find_macro(self._scope, invoke.name);
        if def != &null { return def; }

        // 2. imports (scoped + wildcard)
        def = self._import_proc->find_macro_for_file(
            self._fid,
            self._scope,
            invoke.name
        );
        if def != &null { return def; }

        // 3. global scope
        def = self._macro_table->find_macro(ModulePath(), invoke.name);
        return def;
    }

    priv fn try_builtin(
        self,
        tokens:  *(TokenBuffer::<512>),
        invoke:  InvocationInfo,
        ctx:     *ExpansionContext
    ) -> *(TokenBuffer::<512>) {
        var name_ptr = self._sym_table->resolve(invoke.name.name);
        std::print(f"[BUILTIN] name_ptr={(name_ptr != &null)}, name='{("<null>") if (name_ptr == &null) else (*name_ptr)}' ");
        if name_ptr == &null { return &null; }
        var name = *name_ptr;

        // ── source location builtins ────────────────────────────────────────
        if name == "file" {
            return self.builtin_file(invoke);
        }
        if name == "line" {
            return self.builtin_line(invoke);
        }
        if name == "column" {
            return self.builtin_column(invoke);
        }
        if name == "module_path" {
            return self.builtin_module_path(invoke);
        }

        // ── variadic helpers ────────────────────────────────────────────────
        if name == "count"   { return self.builtin_count(tokens, invoke); }
        if name == "first"   { return self.builtin_first(tokens, invoke); }
        if name == "last"    { return self.builtin_last(tokens, invoke); }
        if name == "rest"    { return self.builtin_rest(tokens, invoke); }
        if name == "init"    { return self.builtin_init(tokens, invoke); }

        // ── token manipulation ──────────────────────────────────────────────
        if name == "concat"      { return self.builtin_concat(tokens, invoke); }
        if name == "stringify"   { return self.builtin_stringify(tokens, invoke); }
        if name == "unstringify" { return self.builtin_unstringify(tokens, invoke); }

        // ── hygiene ─────────────────────────────────────────────────────────
        if name == "defined"  { return self.builtin_defined(invoke); }
        if name == "undef"    { return self.builtin_undef(tokens, invoke); }

        // ── code gen / deferred ─────────────────────────────────────────────
        // these emit placeholder tokens; real work happens in later passes
        if name == "todo"        { return self.builtin_todo(tokens, invoke); }
        if name == "unreachable" { return self.builtin_unreachable(tokens, invoke); }
        if name == "unique_id"   { return self.builtin_unique_id(invoke); }
        if name == "include"     { return self.builtin_include(tokens, invoke); }
        if name == "include_str" { return self.builtin_include_str(tokens, invoke); }
        if name == "embed"       { return self.builtin_embed(tokens, invoke); }

        // ── diagnostics (deferred emit nothing now) ───────────────────────
        if name == "error"   { return self.builtin_diag(tokens, invoke, DiagnosticLevel::Error); }
        if name == "warning" { return self.builtin_diag(tokens, invoke, DiagnosticLevel::Warning); }
        if name == "note"    { return self.builtin_diag(tokens, invoke, DiagnosticLevel::Note); }

        return &null; // not a builtin
    }

    // =====================================================================
    //  EXPANSION
    // =====================================================================

    /// \brief expands a single invocation, returning a new token buffer
    ///        with the body tokens (substituted if parameterized).
    priv fn expand_invocation(
        self,
        tokens: *(TokenBuffer::<512>),
        invoke: InvocationInfo,
        def:    *MacroDefinition,
        ctx:    *ExpansionContext
    ) -> *(TokenBuffer::<512>) {
        // ── cycle detection ─────────────────────────────────────────────
        if ctx->is_in_cycle(def->name.name) {
            var name_str = self.name_str(def->name.name);
            self.error(tokens->get(invoke.start_index),
                f"recursive expansion cycle detected for macro '{name_str}!' ");
            return &null;
        }

        if ctx->exceeded_depth() {
            var name_str = self.name_str(def->name.name);
            self.error(tokens->get(invoke.start_index),
                f"macro expansion depth limit (256) exceeded for '{name_str}!' ");
            return &null;
        }

        ctx->push(def->name.name);
        ctx->invoke_loc = tokens->get(invoke.start_index)->range;

        var saved_parent = self._parent_expansion_idx;
        // we don't have an idx yet before body runs, so we use a sentinel;
        // the actual chaining happens inside wrap_token via tok.imm on already-wrapped tokens
        self._parent_expansion_idx = static_cast::<u32>(-1);

        var result: *(TokenBuffer::<512>);

        if !def->accepts_params {
            result = self.expand_parameterless(def, ctx);
        } else {
            result = self.expand_parameterized(tokens, invoke, def, ctx);
        }

        if result == &null {
            ctx->pop();
            return &null;
        }

        // ── re-scan expansion for nested invocations ────────────────────
        // std::print(f"[EXPAND] expanded '{self.name_str(def->name.name)}!' -> {result->size()} tokens");

        var saved_fid = self._fid;          // ← ADD
        self._fid = def->source_fid;        // ← ADD: resolve from defining file's perspective

        var changed = true;

        while changed {
            changed = false;
            var rescan = std::create::<TokenBuffer::<512>>();
            var k: usize = 0;

            while k < result->size() {
                // std::print(f"[RESCAN] k={k}, token kind={token_kind_to_readable_string(result->get(k)->kind)}, text='{self._sm->get_text(result->get(k)->range)}' ");
                var nested = self.detect_invocation(result, k);

                if nested.found {
                    // try builtins in nested rescan too
                    var nested_builtin = self.try_builtin(result, nested, ctx);
                    if nested_builtin != &null {
                        for j in usize(0) .. usize(nested_builtin->size()) {
                            rescan->append(self.wrap_token(
                                *(nested_builtin->get(j)),
                                nested.name.name,
                                tokens->get(nested.start_index)->range,  // ← but `tokens` here is `result`
                                self._parent_expansion_idx
                            ));
                        }
                        std::destroy(nested_builtin);
                        changed = true;
                        k = nested.end_index;
                        continue;
                    }

                    var nested_def = self.resolve_invocation(nested);

                    if nested_def != &null { // we de-indent this but cant since we need goto and jumps
                        // validate parens match
                        if nested_def->accepts_params == nested.has_args {
                            var nested_ctx = ExpansionContext();  // fresh, empty call stack
                            var expanded = self.expand_invocation(
                                result, nested, nested_def, &nested_ctx
                            );

                            if expanded != &null {
                                for j in usize(0) .. usize(expanded->size()) {
                                    rescan->append(*(expanded->get(j)));
                                }
                                std::destroy(expanded);
                                changed = true;
                                k = nested.end_index;
                                continue;
                            }
                        } else if nested_def->accepts_params && !nested.has_args {
                            self.error(result->get(nested.start_index),
                                f"macro '{self.name_str(nested_def->name.name)}!' requires arguments");
                        } else if (!nested_def->accepts_params) && (nested.has_args) {
                            self.error(result->get(nested.start_index),
                                f"macro '{self.name_str(nested_def->name.name)}!' does not accept arguments");
                        }
                    }
                }

                rescan->append(*(result->get(k)));
                k += 1;
            }

            std::destroy(result);
            result = rescan;
        }

        self._fid = saved_fid;
        self._parent_expansion_idx = saved_parent;
        ctx->pop();
        return result;
    }

    /// \brief expands a parameterless macro: just copy body tokens
    priv fn expand_parameterless(self, def: *MacroDefinition, ctx: *ExpansionContext) -> *(TokenBuffer::<512>) {
        var output = std::create::<TokenBuffer::<512>>();
        var body = def->body;

        // std::print(f"[EXPAND-PL] body.size()={body.size()}, body internal ptr valid={(body.tokens()) != &null}");
        for i in usize(0) .. usize(body.size()) {
            output->append(self.wrap_token(
                *(body.get(i)),
                def->name.name,
                ctx->invoke_loc,        // need to thread this through
                self._parent_expansion_idx
            ));
        }

        return output;
    }

    /// \brief expands a parameterized macro: parse args, bind params, substitute
    priv fn expand_parameterized(
        self,
        tokens: *(TokenBuffer::<512>),
        invoke: InvocationInfo,
        def:    *MacroDefinition,
        ctx:    *ExpansionContext
    ) -> *(TokenBuffer::<512>) {
        // ── parse arguments ─────────────────────────────────────────────
        var args = self.parse_arguments(tokens, invoke.args_start + 1, invoke.args_end - 2);

        // ── bind parameters ─────────────────────────────────────────────
        var bindings = map::<SymbolID, TokenSpan>();
        var variadic = vec::<TokenSpan>();

        var params     = &(def->params.params);
        var required   = usize(0);
        var has_variadic = false;
        var variadic_idx = usize(0);

        // count required params and find variadic
        for k in usize(0) .. usize(params->size()) {
            var p = &((*params)[k]);
            if p->is_variadic != MacroParameter::VariadicType::None {
                has_variadic = true;
                variadic_idx = k;
                break;
            }
            if !p->has_default {
                required += 1;
            }
        }

        var non_variadic_count = (variadic_idx) if has_variadic else params->size();

        // validate arg count
        if (args.size()) < required {
            var name_str = self.name_str(def->name.name);
            self.error(tokens->get(invoke.start_index),
                f"macro '{name_str}!' expects at least {required} arguments, got {args.size()}");
            return &null;
        }

        if (!has_variadic) && ((args.size()) > (params->size())) {
            var name_str = self.name_str(def->name.name);
            self.error(tokens->get(invoke.start_index),
                f"macro '{name_str}!' expects at most {params->size()} arguments, got {args.size()}");
            return &null;
        }

        // bind non-variadic params
        for k in usize(0) .. usize(non_variadic_count) {
            var p = &((*params)[k]);

            if k < args.size() {
                bindings[p->name.name] = args[k];
            } else if p->has_default {
                bindings[p->name.name] = p->default_value;
            }
            // else: already validated above this can't happen
        }

        // bind variadic
        if has_variadic {
            var vp = &((*params)[variadic_idx]);

            for k in usize(non_variadic_count) .. usize(args.size()) {
                variadic.push_back(args[k]);
            }

            // for named variadics, also bind the name to the full variadic span
            // (the body can reference it by name for iteration-like patterns)
            if vp->is_variadic == MacroParameter::VariadicType::Named && variadic.size() > 0 {
                // bind to first arg as a simple reference expansion of variadic
                // iteration is left to built-in macros like count!, first!, etc.
                bindings[vp->name.name] = variadic[0];
            }
        }

        ctx->param_bindings    = bindings;
        ctx->variadic_bindings = variadic;

        // ── substitute ──────────────────────────────────────────────────
        return self.substitute_body(def, ctx);
    }

    /// \brief parses comma-separated arguments between `(` and `)`.
    ///        Respects balanced delimiters for nested expressions.
    /// \param tokens the token buffer
    /// \param start  index of first token INSIDE parens (past `(`)
    /// \param end    index of last token INSIDE parens (before `)`)
    /// \returns vector of TokenSpans, one per argument
    priv fn parse_arguments(
        self,
        tokens: *(TokenBuffer::<512>),
        start:  usize,
        end:    usize
    ) -> vec::<TokenSpan> {
        var args = vec::<TokenSpan>();

        if start > end { return args; } // empty args: `mac!()`

        var depth: i32 = 0;
        var arg_start  = start;

        for i in usize(start) .. usize(end + 1) {
            var t = tokens->get(i);

            if self.get_effective_kind(t) == TokenKind::OpLParen  { depth += 1; }
            if self.get_effective_kind(t) == TokenKind::OpLBrace  { depth += 1; }
            if self.get_effective_kind(t) == TokenKind::OpLSquare { depth += 1; }

            if self.get_effective_kind(t) == TokenKind::OpRParen  { depth -= 1; }
            if self.get_effective_kind(t) == TokenKind::OpRBrace  { depth -= 1; }
            if self.get_effective_kind(t) == TokenKind::OpRSquare { depth -= 1; }

            // comma at depth 0 splits arguments
            if (self.get_effective_kind(t) == TokenKind::OpComma) && (depth == 0) {
                if i > arg_start {
                    args.push_back(TokenSpan(tokens, arg_start, i - arg_start));
                }
                arg_start = i + 1;
                continue;
            }
        }

        // last argument (or only argument if no commas)
        if arg_start <= end {
            args.push_back(TokenSpan(tokens, arg_start, (end + 1) - arg_start));
        }

        return args;
    }

    /// \brief walks the macro body and substitutes parameter references
    ///        with bound argument tokens.
    priv fn substitute_body(
        self,
        def: *MacroDefinition,
        ctx: *ExpansionContext
    ) -> *(TokenBuffer::<512>) {
        var output = std::create::<TokenBuffer::<512>>();
        var body   = def->body;

        for i in usize(0) .. usize(body.size()) {
            var tok = body.get(i);

            if self.get_effective_kind(tok) == TokenKind::LitIdentifier {
                var tok_name = self._sym_table->intern(self._sm->get_text(tok->range));

                if ctx->param_bindings.contains(tok_name) {
                    var bound = &(ctx->param_bindings[tok_name]);
                    for j in usize(0) .. usize(bound->size()) {
                        // wrap each substituted token it came from an argument
                        // site, not the def body, so def_range = arg token range,
                        // invoke_range = call site
                        output->append(self.wrap_token(
                            *(bound->get(j)),
                            def->name.name,
                            ctx->invoke_loc,
                            self._parent_expansion_idx
                        ));
                    }
                    continue;
                }
            }

            // not a param ref still wrap it, tracking that it came from the def body
            output->append(self.wrap_token(
                *tok,
                def->name.name,
                ctx->invoke_loc,
                self._parent_expansion_idx
            ));
        }

        return output;
    }

    priv fn wrap_token(
        self,
        tok:          Token,
        macro_name:   SymbolID,
        invoke_range: SourceRange,
        parent_idx:   u32
    ) -> Token {
        if self._imm_table == &null {
            return tok;
        }

        var info = Immediate::MacroExpansionInfo();
        info.macro_name   = macro_name;
        info.invoke_range = invoke_range;
        info.parent_idx   = parent_idx;

        // if already wrapped, chain through it rather than lose the inner info
        if (tok.kind == TokenKind::TkMacroExpand) && (tok.imm != static_cast::<u32>(-1))
                                                  && (tok.imm != static_cast::<u32>(-2))
                                                  && (tok.imm != static_cast::<u32>(-3))
                                                  && (tok.imm != static_cast::<u32>(-4))
                                                  && (tok.imm != static_cast::<u32>(-5)) {
            // inner is a real expansion record grab original kind/imm from it
            var inner = self._imm_table->get::<Immediate::MacroExpansionInfo>(tok.imm);
            info.original_kind = inner->original_kind;
            info.original_imm  = inner->original_imm;
            info.def_range     = inner->def_range;     // keep innermost def site
            info.parent_idx    = tok.imm;              // current inner becomes parent
        } else {
            info.original_kind = tok.kind;
            info.original_imm  = tok.imm;
            info.def_range     = tok.range;
        }

        var idx = self._imm_table->create::<Immediate::MacroExpansionInfo>();
        (*(self._imm_table->get::<Immediate::MacroExpansionInfo>(idx))) = info;

        var wrapped = tok;
        wrapped.kind  = TokenKind::TkMacroExpand;
        wrapped.imm   = idx;
        // keep tok.range as-is it's the def body site, which is useful for
        // "expanded from" notes; invoke_range in the record is the call site
        return wrapped;
    }

    // =====================================================================
    //  DIAGNOSTICS
    // =====================================================================

    priv fn error(self, tok: *Token, msg: string) {
        if tok == &null {
            self._diagnostics.push_back(f"MacroExpander: <unknown>: error: {msg}");
            return;
        }
        var full_loc = self._sm->get_full_loc(tok->range.start);
        var loc_str  = f"{self._sm->get_filename(full_loc.file_id)}:{full_loc.line}:{full_loc.column}";
        self._diagnostics.push_back(f"MacroExpander: {loc_str}: error: {msg}");
    }

    priv fn name_str(self, id: SymbolID) -> string {
        var ptr = self._sym_table->resolve(id);
        return ("<unknown>") if (ptr == &null) else (*ptr);
    }

    priv fn get_effective_kind(self, tok: *Token) -> TokenKind {
        if tok->kind != TokenKind::TkMacroExpand {
            return tok->kind;
        }
        if tok->imm >= static_cast::<u32>(-10) {
            return tok->kind;
        }
        if self._imm_table == &null {
            return TokenKind::LitIdentifier;
        }
        var info = self._imm_table->get::<Immediate::MacroExpansionInfo>(tok->imm);
        return info->original_kind;
    }
}

class MacroProcessor {
    /// ok so the fundamantals here is quite simple for each file we need to build a symbol table of all the imports
    /// keeping track of scopes and visibilities so when we go to resolve a macro we can do so correctly
    /// we also need to handle re-exports but that can be done in the AST phase
    /// the point of this phase is the build a full map of all available macros in the current file with correct scoping
    /// so then when we get back to the main file we can resolve the macros correctly
    /// this is a per start file processor not a global one
    /// but the tokens are global so we can look up any file we need to process imports later quickly
    /// we have a few kinds of imports to handle
    ///
    ///  1. import Foo::Bar::Baz; - remeber since this isnt a proper import processor we just look up Foo/Bar/Baz to get the path if it doesnt exist we move on (its the ast phase that will error later if its not found)
    ///  2. import Foo::Bar::Baz as Qux; - same as above but we need to remap Qux to Foo::Bar::Baz
    ///  3. import Foo::Bar::*; - wildcard import we need to look up the path for Foo::Bar
    ///  4. import Foo::Bar::{Baz, Qux, Mac!}; - multiple imports from same path we ignore any non macro imports so we still look up Foo::Bar for the file and note we only need Mac! from it
    ///  5. import Foo::Bar::{Baz as Qux, Mac! as MacAlias!}; - same as above but with aliases
    ///  6. import module Foo::Bar; - module is a disambiguation keyword to avoid conflict if we have both Foo/Bar/module.kro and Foo/Bar.kro (when module is specified we only look for Foo/Bar/module.kro)
    ///  7. ffi "..." import Foo::Bar; - ffi imports are ignored by the macro preprocessor since they dont define macros
    ///  8. ffi "..." { ... } - we ignroe these blocks entirely since they wont have kairo code imports in them (THEY might have macro invokes and defs but those are handled in the MacroPreprocessor directly when we scan the tokens)
    ///
    /// ofc we also need to track scopes and visibilities so we know what imports are available where and we can error on private/protected imports used out of scope
    /// like module Foo { import Bar; } // now when the file imports a file that contains that code the import path is techincally Foo::Bar not just Bar and this is handled since now in our main file when we look up `import Foo::Bar::Mac!` we can find it correctly
    /// the processor would look for Foo::Bar (which would or would not exist as a file/module) where if it doesnt we now look for Foo as the module and Bar as the submodule inside it
    ///

    var _pp_sym_table: *PreprocessorSymbolTable;
    var _macro_table:  *MacroSymbolTable;
    var _sm:           *SourceManager;
    var _tcm:          *TokenCacheManager;

    var _pool:     *ThreadPool;
    var _resolver: *ImportResolver;

    var _import_proc:    ImportProcessor;               ///< single shared import processor
    var _processing:     set::<u32>;                    ///< files currently being processed (cycle detection)
    var _processed:      set::<u32>;                    ///< files fully processed
    var _skip_lists:     map::<u32, SkipList>;

    fn MacroProcessor(self, sm: *SourceManager,  tcm:  *TokenCacheManager,
                      resolver: *ImportResolver, pool: *ThreadPool) {
        self._pp_sym_table = std::create::<PreprocessorSymbolTable>();
        self._macro_table  = std::create::<MacroSymbolTable>();
        self._sm           = sm;
        self._tcm          = tcm;
        self._resolver     = resolver;
        self._pool         = pool;

        self._processing   = set::<u32>();
        self._processed    = set::<u32>();

        // single shared import processor back-pointer is `self`
        self._import_proc = ImportProcessor(
            sm, tcm, resolver,
            self._pp_sym_table,
            self._macro_table,
            &self._skip_lists,
            &self
        );
    }

    fn get_symbol_table(self) -> *PreprocessorSymbolTable {
        return self._pp_sym_table;
    }

    fn get_macro_table(self) -> *MacroSymbolTable {
        return self._macro_table;
    }

    fn get_import_processor(self) -> *ImportProcessor {
        return &(self._import_proc);
    }

    fn is_processed(self, fid: u32) -> bool {
        return self._processed.contains(fid);
    }

    fn is_processing(self, fid: u32) -> bool {
        return self._processing.contains(fid);
    }

    fn op delete (self) {
        std::destroy(self._pp_sym_table);
        std::destroy(self._macro_table);
    }

    fn clear(self) {
        self._pp_sym_table->clear();
        self._macro_table->table.clear();
        self._processing.clear();
        self._processed.clear();
    }

    fn preprocess_file(self, fid: u32, module_path: ModulePath, do_expand: bool = false) -> bool {
        if self._processed.contains(fid) {
            return true;
        }

        if self._processing.contains(fid) {
            return true;
        }

        self._processing.insert(fid);

        // ensure skip list exists for this file
        if !self._skip_lists.contains(fid) {
            self._skip_lists[fid] = SkipList();
        }
        var skip_list = &(self._skip_lists[fid]);

        // ── Phase 1: Lex + scan imports ────────────────────────────────
        if (!self._import_proc.process_file(fid, module_path)) && (!quiet) {
            for diag in self._import_proc.get_diagnostics() {
                std::print(diag);
            }
            self._processing.erase(fid);
            return false;
        }

        // ── Phase 2: Collect macro definitions ─────────────────────────
        var tokens = self._tcm->get_tokens(fid);
        if tokens != &null {
            var def_tracker = ScopeTracker(self._pp_sym_table, self._sm, module_path);
            var collector   = MacroDefinitionCollector(
                self._pp_sym_table,
                self._macro_table,
                self._sm
            );

            if (!collector.collect(tokens, fid, &def_tracker, skip_list))  && (!quiet) {
                for diag in collector.get_diagnostics() {
                    std::print(diag);
                }
            }
        }

        // ── Phase 3: Expand macro invocations ──────────────────────────
        if do_expand {
            tokens = self._tcm->get_tokens(fid);
            if tokens != &null {
                skip_list->finalize();  // sort dead zones before expansion

                var lexer_ptr = self._tcm->get_lexer(fid); // need this getter see below
                var imm_ptr = lexer_ptr->get_imm_tbl();

                var expander = MacroExpander(
                    self._sm,
                    self._pp_sym_table,
                    self._macro_table,
                    &(self._import_proc),
                    skip_list,
                    imm_ptr
                );

                var expanded = expander.expand(tokens, fid, module_path);

                if expanded != &null {
                    // replace tokens in TCM with expanded version
                    self._tcm->replace_tokens(fid, expanded);
                }

                if (expander.has_errors()) && (!quiet) {
                    for diag in expander.get_diagnostics() {
                        std::print(diag);
                    }
                }
            }
        }

        // ── Done ───────────────────────────────────────────────────────────
        self._processing.erase(fid);
        self._processed.insert(fid);

        // only dump after the root file finishes (no more files in flight)
        // if self._processing.size() == 0 {
        //     std::print(self._import_proc.dump_state());
        //     std::print(self._macro_table->as_string(self._pp_sym_table));
        // }

        return true;
    }

    static fn unwrap_token(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager) -> Token {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        if tok.kind != TokenKind::TkMacroExpand { return tok; }
        if imm_table == &null { return tok; }

        var current_imm = tok.imm;
        while true {
            if current_imm == static_cast::<u32>(-1) { break; } // sentinel
            var info = imm_table->get::<Immediate::MacroExpansionInfo>(current_imm);
            if info->parent_idx == static_cast::<u32>(-1) {
                // reached the leaf this has the real original kind/imm
                var result = tok;
                result.kind = info->original_kind;
                result.imm  = info->original_imm;
                return result;
            }
            current_imm = info->parent_idx;
        }

        return tok;
    }

    static fn get_invoke_range(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager) -> SourceRange {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        if tok.kind != TokenKind::TkMacroExpand || imm_table == &null {
            return tok.range;
        }
        var info = imm_table->get::<Immediate::MacroExpansionInfo>(tok.imm);
        return info->invoke_range;
    }

    static fn get_def_range(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager) -> SourceRange {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        if tok.kind != TokenKind::TkMacroExpand || imm_table == &null {
            return tok.range;
        }

        var current_imm = tok.imm;
        while true {
            var info = imm_table->get::<Immediate::MacroExpansionInfo>(current_imm);
            if info->parent_idx == static_cast::<u32>(-1) {
                return info->def_range;
            }
            current_imm = info->parent_idx;
        }

        return tok.range;
    }

    static fn get_expansion_chain(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager) -> vec::<SourceRange> {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        var chain = vec::<SourceRange>();
        if tok.kind != TokenKind::TkMacroExpand || imm_table == &null {
            return chain;
        }

        var current_imm = tok.imm;
        while current_imm != static_cast::<u32>(-1) {
            var info = imm_table->get::<Immediate::MacroExpansionInfo>(current_imm);
            chain.push_back(info->invoke_range);
            current_imm = info->parent_idx;
        }

        return chain; // outermost first
    }

    static fn get_macro_name(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager, sym_table: *PreprocessorSymbolTable) -> string {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        if tok.kind != TokenKind::TkMacroExpand || imm_table == &null {
            return "";
        }
        var info = imm_table->get::<Immediate::MacroExpansionInfo>(tok.imm);
        var name_ptr = sym_table->resolve(info->macro_name);
        return ("<unknown>") if (name_ptr == &null) else (*name_ptr);
    }

    static fn format_expansion_trace(tok: Token, tcm: *TokenCacheManager, sm: *SourceManager, sym_table: *PreprocessorSymbolTable) -> string {
        var imm_table = tcm->get_imm_table_for_token(tok, sm);
        if tok.kind != TokenKind::TkMacroExpand || imm_table == &null {
            return "";
        }

        var out = string();
        var current_imm = tok.imm;

        while current_imm != static_cast::<u32>(-1) {
            var info = imm_table->get::<Immediate::MacroExpansionInfo>(current_imm);

            var name_ptr = sym_table->resolve(info->macro_name);
            var name_str = ("<unknown>") if (name_ptr == &null) else (*name_ptr);

            var full_loc = sm->get_full_loc(info->invoke_range.start);
            var loc_str  = f"{sm->get_filename(full_loc.file_id)}:{full_loc.line}:{full_loc.column}";

            out += f"  expanded from macro '{name_str}!' at {loc_str}\n";
            current_imm = info->parent_idx;
        }

        return out;
    }

    static fn is_macro_expanded(tok: Token) -> bool {
        return tok.kind == TokenKind::TkMacroExpand;
    }
}

/// \brief processes a single file: lex it, scan imports, record import state
/// \note does NOT recurse recursion is handled by MacroProcessor::preprocess_file
///       via the back-pointer in resolve_import
fn ImportProcessor::process_file(fid: u32, module_base: ModulePath) -> bool {
    // ensure file is lexed
    if !self._tcm->lex_file(fid) {
        self._diagnostics.push_back(
            f"ImportProcessor: failed to lex file ID {fid}"
        );
        return false;
    }

    var tokens = self._tcm->get_tokens(fid);
    if tokens == &null {
        self._diagnostics.push_back(
            f"ImportProcessor: no tokens for file ID {fid}"
        );
        return false;
    }

    // initialize file state
    var state = FileImportState();
    state.fid         = fid;
    state.module_base = module_base;

    // create scope tracker for this file
    var tracker = ScopeTracker(self._sym_table, self._sm, module_base);

    // scan tokens: feed scope tracker AND extract import statements
    var i: usize = 0;
    while i < tokens->size() {
        var tok = tokens->get(i);

        // feed scope tracker first
        var scope_consumed = tracker.update(tokens, i);

        // check for ffi blocks/imports (skip them)
        if tok->kind == TokenKind::KwFfi {
            var skip = self.skip_ffi(tokens, i);
            i += skip;
            if skip > 0 { continue; }

            // if skip > 0 {
            //     var ffi_start = tokens->get(i);
            //     var ffi_end_idx = i + skip - 1;
            //     if ffi_end_idx < tokens->size() {
            //         (*self._skip_lists)[fid].add(
            //             SourceRange::from_bounds(
            //                 ffi_start->range.start,
            //                 tokens->get(ffi_end_idx)->range.end
            //             )
            //         );
            //     }
            // }
        }

        if tok->kind == TokenKind::KwImport {
            var start_i = i;
            var parsed = self.parse_import(tokens, i, &tracker);

            if !parsed.is_ffi {
                if parsed.items.size() > 0 || parsed.is_wildcard {
                    self.resolve_import(&parsed, &state, fid);

                    if parsed.tokens_consumed > 0 {
                        var first_tok = tokens->get(start_i);
                        var last_idx  = parsed.end_index - 1;
                        if last_idx < tokens->size() {
                            var last_tok = tokens->get(last_idx);
                            (*self._skip_lists)[fid].add(
                                SourceRange::from_bounds(first_tok->range.start, last_tok->range.end)
                            );
                        }
                    }
                }
            }

            i = parsed.end_index;
            if i <= start_i { i = start_i + 1; }
            continue;
        }

        i += scope_consumed + 1;
    }

    // store the state
    self._file_states[fid] = state;

    return true;
}

fn ImportProcessor::get_file_state(fid: u32) -> *FileImportState {
    if self._file_states.contains(fid) {
        return &(self._file_states[fid]);
    }
    return &null;
}

fn ImportProcessor::get_diagnostics() -> ref!(vec::<string>) {
    return self._diagnostics;
}

fn ImportProcessor::has_errors() -> bool {
    return self._diagnostics.size() > 0;
}

// =========================================================================
//  FFI SKIPPING
// =========================================================================

priv fn ImportProcessor::skip_ffi(tokens: *(TokenBuffer::<512>), start: usize) -> usize {
    if start >= tokens->size() { return 0; }

    var tok = tokens->get(start);
    if tok->kind != TokenKind::KwFfi { return 0; }

    var j = start + 1;

    if j >= tokens->size() { return 1; }
    var next = tokens->get(j);

    if next->kind != TokenKind::LitString { return 0; }
    j += 1;

    if j >= tokens->size() { return j - start; }
    var after_str = tokens->get(j);

    // ffi "c++" import ... ;
    if after_str->kind == TokenKind::KwImport {
        while j < tokens->size() {
            if tokens->get(j)->kind == TokenKind::OpSemicolon {
                return (j + 1) - start;
            }
            j += 1;
        }
        return j - start;
    }

    // ffi "c++" { ... }
    if after_str->kind == TokenKind::OpLBrace {
        var depth: i32 = 1;
        j += 1;
        while j < tokens->size() && depth > 0 {
            var t = tokens->get(j);
            if t->kind == TokenKind::OpLBrace { ++depth; }
            if t->kind == TokenKind::OpRBrace { --depth; }
            j += 1;
        }
        return j - start;
    }

    return 1;
}

// =========================================================================
//  IMPORT PARSING (unchanged parse_import, parse_grouped_imports)
// =========================================================================

priv fn ImportProcessor::parse_import(
    tokens:  *(TokenBuffer::<512>),
    start:   usize,
    tracker: *ScopeTracker
) -> ParsedImport {
    var result = ParsedImport();
    result.scope = tracker->current_scope();
    result.import_loc = tokens->get(start)->range;

    var j = start + 1;

    if j >= tokens->size() { return result; }

    if tokens->get(j)->kind == TokenKind::KwModule {
        result.is_module = true;
        j += 1;
    }

    var segments = vec::<IdentifierToken>();
    var last_was_bang = false;

    while j < tokens->size() {
        var t = tokens->get(j);

        if t->kind == TokenKind::LitIdentifier {
            var ident = IdentifierToken();
            ident.token = t;
            ident.name  = self._sym_table->intern(self._sm->get_text(t->range));
            segments.push_back(ident);
            j += 1;

            if j < tokens->size() && tokens->get(j)->kind == TokenKind::OpExclaim {
                last_was_bang = true;
                j += 1;
            }

            if j < tokens->size() && tokens->get(j)->kind == TokenKind::OpColonColon {
                if last_was_bang {
                    break;
                }
                j += 1;
                continue;
            }

            break;
        }

        if t->kind == TokenKind::OpStar {
            result.is_wildcard = true;
            j += 1;
            break;
        }

        if t->kind == TokenKind::OpLBrace {
            j += 1;
            self.parse_grouped_imports(tokens, &j, &result);
            break;
        }

        break;
    }

    if result.is_wildcard {
        result.base_path = ModulePath();
        for seg in segments {
            result.base_path.segments.push_back(seg);
        }
    } else if result.items.size() > 0 {
        result.base_path = ModulePath();
        for seg in segments {
            result.base_path.segments.push_back(seg);
        }
    } else if segments.size() > 0 {
        result.base_path = ModulePath();
        for i in usize(0) .. usize(segments.size() - 1) {
            result.base_path.segments.push_back(segments[i]);
        }

        var item = ParsedImport::Item();
        item.name     = segments[segments.size() - 1];
        item.alias    = item.name;
        item.is_macro = last_was_bang;

        if j < tokens->size() && tokens->get(j)->kind == TokenKind::KwAs {
            j += 1;
            if j < tokens->size() && tokens->get(j)->kind == TokenKind::LitIdentifier {
                var alias_tok = tokens->get(j);
                item.alias.token = alias_tok;
                item.alias.name  = self._sym_table->intern(self._sm->get_text(alias_tok->range));
                item.has_alias = true;
                j += 1;

                if item.is_macro && j < tokens->size() && tokens->get(j)->kind == TokenKind::OpExclaim {
                    j += 1;
                }
            }
        }

        result.items.push_back(item);
    }

    if (j < tokens->size()) && ((tokens->get(j)->kind) == TokenKind::OpSemicolon) {
        j += 1;
    }

    result.end_index = j;
    result.tokens_consumed = j - start;
    return result;
}

priv fn ImportProcessor::parse_grouped_imports(
    tokens: *(TokenBuffer::<512>),
    j:      *usize,
    result: *ParsedImport
) {
    while (*j) < tokens->size() {
        var t = tokens->get(*j);

        if t->kind == TokenKind::OpRBrace {
            (*j) += 1;
            return;
        }

        if t->kind == TokenKind::OpComma {
            (*j) += 1;
            continue;
        }

        if t->kind != TokenKind::LitIdentifier {
            (*j) += 1;
            continue;
        }

        var item = ParsedImport::Item();
        item.name.token = t;
        item.name.name  = self._sym_table->intern(self._sm->get_text(t->range));
        item.alias = item.name;
        (*j) += 1;

        if (*j) < tokens->size() && tokens->get(*j)->kind == TokenKind::OpExclaim {
            item.is_macro = true;
            (*j) += 1;
        }

        if (*j) < tokens->size() && tokens->get(*j)->kind == TokenKind::KwAs {
            (*j) += 1;
            if (*j) < tokens->size() && tokens->get(*j)->kind == TokenKind::LitIdentifier {
                var alias_tok = tokens->get(*j);
                item.alias.token = alias_tok;
                item.alias.name  = self._sym_table->intern(self._sm->get_text(alias_tok->range));
                item.has_alias = true;
                (*j) += 1;

                if item.is_macro && (*j) < tokens->size() && tokens->get(*j)->kind == TokenKind::OpExclaim {
                    (*j) += 1;
                }
            }
        }

        result->items.push_back(item);
    }
}

// =========================================================================
//  IMPORT RESOLUTION
// =========================================================================

priv fn ImportProcessor::resolve_import(
    parsed:  *ParsedImport,
    state:   *FileImportState,
    src_fid: u32
) {
    if parsed->is_ffi { return; }

    var path_strings = vec::<string>();
    for seg in parsed->base_path.segments {
        var name_ptr = self._sym_table->resolve(seg.name);
        if name_ptr != &null {
            path_strings.push_back(*name_ptr);
        }
    }

    if path_strings.size() == 0 && !parsed->is_wildcard && parsed->items.size() > 0 {
        for item in parsed->items {
            var name_ptr = self._sym_table->resolve(item.name.name);
            if name_ptr != &null {
                path_strings.push_back(*name_ptr);
                break; // only use the first item as the module path
            }
        }
    }

    /// print what we're trying to resolve for debugging
    // var debug_path = self.segments_to_string(path_strings);
    // if parsed->is_module {
    //     std::print(f"Resolving module import '{debug_path}' from file ID {src_fid}\n");
    // } else {
    //     std::print(f"Resolving import '{debug_path}' from file ID {src_fid}\n");
    // }

    if path_strings.size() == 0 && !parsed->is_wildcard {
        std::print(
            f"resolve_import: failed to resolve path [{self.segments_to_string(path_strings)}] for import in fid {src_fid}"
        );
        return;
    }

    var resolved = self.resolve_module_greedy(path_strings, parsed->is_module);

    if resolved.fid == 0 && !resolved.found {
        std::print(
            f"resolve_import: failed to resolve path [{self.segments_to_string(path_strings)}] for import in fid {src_fid}"
        );
        return;
    }

    // RECURSE via MacroProcessor this runs the full pipeline
    // (import scan + macro collection) on the dependency file
    if resolved.found && !self._macro_proc->is_processed(resolved.fid) {
        self._macro_proc->preprocess_file(resolved.fid, resolved.file_module_path);
    }

    // gate recording on whether we actually care about this import
    if parsed->is_wildcard {
        state->wildcard_fids.push_back(resolved.fid);

        var imp = MacroImport();
        imp.source_fid   = resolved.fid;
        imp.source_scope = resolved.file_module_path;
        imp.import_loc   = parsed->import_loc;
        imp.is_wildcard  = true;

        if state->scoped_imports.contains(parsed->scope) {
            state->scoped_imports[parsed->scope].push_back(imp);
        } else {
            var imports = vec::<MacroImport>();
            imports.push_back(imp);
            state->scoped_imports[parsed->scope] = imports;
        }
    } else {
        // record module alias for qualified macro resolution
        // e.g. `import imp::Foo` → Foo maps to imp::Foo
        if parsed->items.size() > 0 && resolved.found {
            var item = &(parsed->items[0]);
            var alias_path = resolved.file_module_path;
            for seg in resolved.remaining_path.segments {
                alias_path.segments.push_back(seg);
            }
            alias_path.segments.push_back(item->alias);
            state->module_aliases[item->alias.name] = alias_path;
        }

        var has_macro = false;
        for item in parsed->items {
            if item.is_macro {
                has_macro = true;
                break;
            }
        }
        if !has_macro { return; }

        for item in parsed->items {
            if !item.is_macro { continue; }

            var imp = MacroImport();
            imp.macro_name   = item.name;
            imp.alias        = item.alias;
            imp.source_fid   = resolved.fid;
            imp.source_scope = resolved.remaining_path;
            imp.import_loc   = parsed->import_loc;
            imp.is_wildcard  = false;

            state->macro_imports.push_back(imp);

            if state->scoped_imports.contains(parsed->scope) {
                state->scoped_imports[parsed->scope].push_back(imp);
            } else {
                var imports = vec::<MacroImport>();
                imports.push_back(imp);
                state->scoped_imports[parsed->scope] = imports;
            }
        }
    }
}

priv fn ImportProcessor::resolve_module_greedy(
    segments:  vec::<string>,
    is_module: bool
) -> ResolveResult {
    var result = ResolveResult();

    if segments.size() == 0 { return result; }

    var try_len = segments.size();

    while try_len > 0 {
        var try_segments = vec::<string>();
        for i in usize(0) .. usize(try_len) {
            try_segments.push_back(segments[i]);
        }

        var resolved: std::Expected::<Path, ResolveError>;

        if is_module {
            resolved = self._resolver->resolve_module_dir(try_segments);
        } else {
            resolved = self._resolver->resolve_module(try_segments);
        }

        if resolved.check() {
            var path = *resolved;

            var fid = self._sm->load_file(path);
            if fid != 0 {
                result.found = true;
                result.fid   = fid;

                result.file_module_path = ModulePath();
                for i in usize(0) .. usize(try_len) {
                    var ident = IdentifierToken();
                    ident.name = self._sym_table->intern(segments[i]);
                    ident.token = &null;
                    result.file_module_path.segments.push_back(ident);
                }

                result.remaining_path = ModulePath();
                for i in usize(try_len) .. usize(segments.size()) {
                    var ident = IdentifierToken();
                    ident.name = self._sym_table->intern(segments[i]);
                    ident.token = &null;
                    result.remaining_path.segments.push_back(ident);
                }

                return result;
            }
        }

        if (!resolved.check()) && (resolved.err() == ResolveError::AmbiguousModule) {
            var retry = self._resolver->resolve_module(try_segments);
            if retry.check() {
                var path = *retry;
                var fid = self._sm->load_file(path);
                if fid != 0 {
                    self._diagnostics.push_back(
                        f"ImportProcessor: ambiguous module '{self.segments_to_string(try_segments)}' both file and directory exist"
                    );

                    result.found = true;
                    result.fid   = fid;

                    result.file_module_path = ModulePath();
                    for i in usize(0) .. usize(try_len) {
                        var ident = IdentifierToken();
                        ident.name = self._sym_table->intern(segments[i]);
                        ident.token = &null;
                        result.file_module_path.segments.push_back(ident);
                    }

                    result.remaining_path = ModulePath();
                    for i in usize(try_len) .. usize(segments.size()) {
                        var ident = IdentifierToken();
                        ident.name = self._sym_table->intern(segments[i]);
                        ident.token = &null;
                        result.remaining_path.segments.push_back(ident);
                    }

                    return result;
                }
            }
        }

        try_len -= 1;
    }

    return result;
}

// =========================================================================
//  MACRO LOOKUP
// =========================================================================

fn ImportProcessor::find_macro_for_file(
    fid:        u32,
    scope:      ModulePath,
    macro_name: IdentifierToken
) -> *MacroDefinition {
    var state = self.get_file_state(fid);
    if state == &null { return &null; }

    if state->scoped_imports.contains(scope) {
        var scoped = &(state->scoped_imports[scope]);
        for imp in (*scoped) {
            if (!imp.is_wildcard) && (imp.alias == macro_name) {
                return self._macro_table->find_macro(imp.source_scope, imp.macro_name);
            }
        }
    }

    if state->scoped_imports.contains(scope) {
        var scoped = &(state->scoped_imports[scope]);
        for imp in (*scoped) {
            if imp.is_wildcard {
                var found = self._macro_table->find_macro(imp.source_scope, macro_name);
                if found != &null { return found; }
            }
        }
    }

    for imp in state->macro_imports {
        if (!imp.is_wildcard) && (imp.alias == macro_name) {
            return self._macro_table->find_macro(imp.source_scope, imp.macro_name);
        }
    }

    for wfid in state->wildcard_fids {
        var dep_state = self.get_file_state(wfid);
        if dep_state == &null { continue; }

        var found = self._macro_table->find_macro(dep_state->module_base, macro_name);
        if found != &null { return found; }
    }

    return &null;
}

fn ImportProcessor::find_qualified_macro(
    fid:        u32,
    full_path:  ModulePath,
    macro_name: IdentifierToken
) -> *MacroDefinition {
    // 1. exact scope lookup
    var def = self._macro_table->find_macro(full_path, macro_name);
    if def != &null { return def; }

    // 2. check if first segment is a module alias in this file
    var state = self.get_file_state(fid);
    if (state != &null) && (full_path.segments.size() > 0) {
        var first = full_path.segments[0].name;
        if state->module_aliases.contains(first) {
            var resolved_path = state->module_aliases[first];
            // append remaining segments (everything after the first)
            for k in usize(1) .. usize(full_path.segments.size()) {
                resolved_path.segments.push_back(full_path.segments[k]);
            }
            def = self._macro_table->find_macro(resolved_path, macro_name);
            if def != &null { return def; }
        }
    }

    return &null;
}

// =========================================================================
//  UTILITIES
// =========================================================================

priv fn ImportProcessor::segments_to_string(segments: vec::<string>) -> string {
    var result = "";
    for i in usize(0) .. usize(segments.size()) {
        if i > 0 { result += "::"; }
        result += segments[i];
    }
    return result;
}

fn ImportProcessor::dump_state() -> string {
    var out = "=== ImportProcessor State ===\n";
    out += f"  processed: {self._file_states.size()} files\n";
    out += f"  diagnostics: {self._diagnostics.size()}\n\n";

    for diag in self._diagnostics {
        out += f"  [DIAG] {diag}\n";
    }

    for entry in self._file_states {
        var fid   = entry.first;
        var state = &(entry.second);

        out += f"--- File ID: {fid} ---\n";
        out += f"  module_base: {state->module_base.as_string(self._sym_table)}\n";
        out += f"  macro_imports: {state->macro_imports.size()}\n";

        for imp in state->macro_imports {
            var name_ptr  = self._sym_table->resolve(imp.macro_name.name);
            var alias_ptr = self._sym_table->resolve(imp.alias.name);
            var name_str  = "<invalid>" if (name_ptr == &null) else *name_ptr;
            var alias_str = "<invalid>" if (alias_ptr == &null) else *alias_ptr;

            out += f"    macro: {name_str}!";
            if imp.alias.name != imp.macro_name.name {
                out += f" as {alias_str}!";
            }
            out += f"  (from fid={imp.source_fid}, scope={imp.source_scope.as_string(self._sym_table)})";
            out += f"  wildcard={imp.is_wildcard}\n";
        }

        out += f"  wildcard_fids: {state->wildcard_fids.size()}\n";
        for wfid in state->wildcard_fids {
            out += f"    * fid={wfid}\n";
        }

        out += f"  scoped_imports: {state->scoped_imports.size()} scopes\n";
        for scope_entry in state->scoped_imports {
            out += f"    scope: {scope_entry.first.as_string(self._sym_table)}\n";
            for imp in scope_entry.second {
                if imp.is_wildcard {
                    out += f"      * (wildcard from fid={imp.source_fid})\n";
                } else {
                    var name_ptr = self._sym_table->resolve(imp.macro_name.name);
                    var name_str = "<invalid>" if (name_ptr == &null) else *name_ptr;
                    out += f"      {name_str}! (from fid={imp.source_fid})\n";
                }
            }
        }

        out += "\n";
    }

    out += "=== End ImportProcessor State ===\n";
    return out;
}

/// MacroPreprocessor Test Suite
/// =============================
/// Tests the full macro preprocessor pipeline: import resolution,
/// macro definition collection, and macro expansion.
///
/// Uses virtual files loaded via SourceManager::load_virtual so
/// tests are self-contained with no filesystem dependencies.

fn Test() -> i32 {
    fn make_virtual(sm: *SourceManager, name: string, src: string) -> u32 {
        /// we need to keep the data alive since load_virtual takes a raw ptr
        /// we use a static map to keep the data alive for the duration of the test
        static var store: map::<string, libcxx::string>;
        name = ((Path::temp_dir()) / "kro_test_macro_preprocessor.kro").full_path();
        var nd = std::string_to_nstring(src);
        store[name] = libcxx::string(nd);
        return sm->load_virtual(
            Path(name, false),
            reinterpret_cast::<std::const_ptr::<u8>>(store[name].data()),
            src.size()
        );
    }

    /// helper: preprocess a root file and return the expanded text (tokens joined)
    fn expand_to_text(sm: *SourceManager, tcm: *TokenCacheManager, resolver: *ImportResolver, pool: *ThreadPool, fid: u32) -> string {
        var macro_proc = MacroProcessor(sm, tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        var tokens = tcm->get_tokens(fid);
        if tokens == &null { return "<null>"; }

        var text: string;
        for i in usize(0) .. usize(tokens->size()) {
            var tok = tokens->get(i);
            if tok->kind == TokenKind::TkNewLine { continue; } // skip newlines for clean comparison
            var t = sm->get_text(tok->range);
            if text.size() > 0 { text += " "; }
            text += t;
        }
        return text;
    }

    // make a new dir in the temp folder for our virtual files (to avoid any potential name clashes with real files)
    var temp_dir = ((libcxx::filesystem::temp_directory_path()) / r"kro_test_macro_preprocessor");
    if (!libcxx::filesystem::exists(temp_dir)) {
        libcxx::filesystem::create_directory(temp_dir);
    }

    var pool = std::create::<ThreadPool>(4);
    var vfm  = std::create::<VirtualFileManager>();
    var sm   = std::create::<SourceManager>(pool, vfm);

    finally {
        std::destroy(sm);
        std::destroy(vfm);
        std::destroy(pool);
    }

    var suite = Assert("MacroPreprocessor Tests");

    // =========================================================================
    // 1. BASIC PARAMETERLESS EXPANSION
    // =========================================================================

    suite.equal::<string>("basic: parameterless macro expands to body", "pass", fn () -> string {
        var src = "macro greet! { hello }\ngreet!\n";
        var fid = make_virtual(sm, "basic_parameterless.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // should contain "hello" and NOT contain "greet !"
        if !result.contains("hello") {
            return f"expected 'hello' in output, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 2. MACRO DEFINITION IS IN DEAD ZONE (NOT EXPANDED)
    // =========================================================================

    suite.equal::<string>("dead zone: macro definition body not expanded", "pass", fn () -> string {
        var src = "macro A! { macro_body_token }\n";
        var fid = make_virtual(sm, "dead_zone.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // no invocation output should be exactly the definition tokens (dead zone copied verbatim)
        if result.contains("macro_body_token") {
            0; // this is fine the definition is copied verbatim as part of the dead zone
        }
        // the key test: macro_body_token should NOT appear outside the definition
        // since there's no invocation, the output is just the definition
        return "pass";
    }, 100);

    // =========================================================================
    // 3. NO EXPANSION WHEN NO INVOCATION
    // =========================================================================

    suite.equal::<string>("no-op: file with only definitions returns original tokens", "pass", fn () -> string {
        var src = "macro A! { 1 }\nmacro B! { 2 }\n";
        var fid = make_virtual(sm, "no_invoke.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        // tokens should be unchanged (expand returns null when nothing changed)
        var tokens = tcm.get_tokens(fid);
        if tokens == &null { return "tokens null"; }

        // verify definitions are still present
        var has_macro_kw = false;
        for i in usize(0) .. usize(tokens->size()) {
            if tokens->get(i)->kind == TokenKind::KwMacro {
                has_macro_kw = true;
                break;
            }
        }
        if !has_macro_kw { return "expected macro keyword in unchanged output"; }
        return "pass";
    }, 100);

    // =========================================================================
    // 4. MULTIPLE INVOCATIONS IN SAME FILE
    // =========================================================================

    suite.equal::<string>("multi: multiple invocations in same file", "pass", fn () -> string {
        var src = "macro X! { 42 }\nX!\nX!\nX!\n";
        var fid = make_virtual(sm, "multi_invoke.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // count occurrences of "42"
        var count: i32 = 0;
        var pos: usize = 0;
        while true {
            var found = result.raw_string().find("42", pos);
            if found == string::npos { break; }
            count += 1;
            pos = found + 2;
        }

        if count != 4 { return f"expected 4 occurrences of '42', got {count}, output: '{result}' "; }
        return "pass";
    }, 100);

    // =========================================================================
    // 5. NESTED MACRO EXPANSION (SAME FILE)
    // =========================================================================

    suite.equal::<string>("nested: macro body contains another macro invocation", "pass", fn () -> string {
        var src = "macro inner! { 99 }\nmacro outer! { inner! }\nouter!\n";
        var fid = make_virtual(sm, "nested.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("99") {
            return f"expected '99' from nested expansion, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 6. PARAMETERIZED MACRO SINGLE PARAM
    // =========================================================================

    suite.equal::<string>("params: single parameter substitution", "pass", fn () -> string {
        var src = "macro wrap!(x) { [ x ] }\nwrap!(hello)\n";
        var fid = make_virtual(sm, "single_param.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if (!result.contains("[ hello ]")) && (!result.contains("[hello]")) {
            // check individual tokens
            if !result.contains("hello") {
                return f"expected 'hello' in expansion, got: '{result}' ";
            }
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 7. PARAMETERIZED MACRO MULTIPLE PARAMS
    // =========================================================================

    suite.equal::<string>("params: multiple parameter substitution", "pass", fn () -> string {
        var src = "macro add!(a, b) { a + b }\nadd!(10, 20)\n";
        var fid = make_virtual(sm, "multi_param.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // should expand to: 10 + 20
        if !result.contains("10") || !result.contains("20") || !result.contains("+") {
            return f"expected '10 + 20' in expansion, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 8. DEFAULT PARAMETER
    // =========================================================================

    suite.equal::<string>("params: default parameter used when arg omitted", "pass", fn () -> string {
        var src = "macro say!(msg, loud = false) { msg loud }\nsay!(hi)\n";
        var fid = make_virtual(sm, "default_param.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("hi") {
            return f"expected 'hi' in expansion, got: '{result}' ";
        }
        if !result.contains("false") {
            return f"expected default 'false' in expansion, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 9. DEFAULT PARAMETER OVERRIDDEN
    // =========================================================================

    suite.equal::<string>("params: default parameter overridden by explicit arg", "pass", fn () -> string {
        var src = "macro say!(msg, loud = false) { msg loud }\nsay!(hi, true)\n";
        var fid = make_virtual(sm, "default_override.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if (!result.contains("hi")) || (!result.contains("true")) {
            return f"expected 'hi true' in expansion, got: '{result}' ";
        }

        if (result.contains("false")) && (!result.contains("true")) {
            return f"default 'false' should be overridden, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 10. TOO FEW ARGS ERROR
    // =========================================================================

    suite.equal::<string>("error: too few arguments produces error", "pass", fn () -> string {
        var src = "macro need!(a, b) { a b }\nneed!(only_one)\n";
        var fid = make_virtual(sm, "too_few_args.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        // should have produced an error diagnostic (too few args)
        // the expansion should not produce "only_one" in the final output as expanded
        // (it should either error or leave the invocation as-is)
        return "pass";
    }, 100);

    // =========================================================================
    // 11. TOO MANY ARGS ERROR
    // =========================================================================

    suite.equal::<string>("error: too many arguments produces error", "pass", fn () -> string {
        var src = "macro one!(a) { a }\none!(x, y, z)\n";
        var fid = make_virtual(sm, "too_many_args.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        return "pass";
    }, 100);

    // =========================================================================
    // 12. PARAMETERLESS INVOKED WITH PARENS ERROR
    // =========================================================================

    suite.equal::<string>("error: parameterless macro invoked with parens", "pass", fn () -> string {
        var src = "macro nope! { 1 }\nnope!()\n";
        var fid = make_virtual(sm, "no_params_with_parens.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        // should produce "does not accept arguments" error
        return "pass";
    }, 100);

    // =========================================================================
    // 13. PARAMETERIZED INVOKED WITHOUT PARENS ERROR
    // =========================================================================

    suite.equal::<string>("error: parameterized macro invoked without parens", "pass", fn () -> string {
        var src = "macro need!(x) { x }\nneed!\n";
        var fid = make_virtual(sm, "params_without_parens.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        // should produce "requires arguments" error
        return "pass";
    }, 100);

    // =========================================================================
    // 14. SCOPED MACRO MODULE SCOPE
    // =========================================================================

    suite.equal::<string>("scope: macro inside module is scoped correctly", "pass", fn () -> string {
        var src = "module Foo {\n    macro bar! { scoped_val }\n}\nFoo::bar!\n";
        var fid = make_virtual(sm, "scoped_macro.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("scoped_val") {
            return f"expected 'scoped_val' from Foo::bar!, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 15. NESTED MODULE SCOPE
    // =========================================================================

    suite.equal::<string>("scope: nested module macro expansion", "pass", fn () -> string {
        var src = "module A {\n    module B {\n        macro deep! { found_it }\n    }\n}\nA::B::deep!\n";
        var fid = make_virtual(sm, "nested_scope.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("found_it") {
            return f"expected 'found_it' from A::B::deep!, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 16. DUPLICATE MACRO IN SAME SCOPE ERROR
    // =========================================================================

    suite.equal::<string>("error: duplicate macro definition in same scope", "pass", fn () -> string {
        var src = "macro dup! { 1 }\nmacro dup! { 2 }\n";
        var fid = make_virtual(sm, "duplicate_macro.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var macro_proc = MacroProcessor(sm, &tcm, resolver, pool);
        macro_proc.preprocess_file(fid, ModulePath(), true);

        // should produce a duplicate macro error
        return "pass";
    }, 100);

    // =========================================================================
    // 17. SAME NAME, DIFFERENT SCOPE OK
    // =========================================================================

    suite.equal::<string>("scope: same macro name in different modules is OK", "pass", fn () -> string {
        var src = "module A {\n    macro mac! { from_A }\n}\nmodule B {\n    macro mac! { from_B }\n}\nA::mac!\nB::mac!\n";
        var fid = make_virtual(sm, "same_name_diff_scope.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("from_A") {
            return f"expected 'from_A' from A::mac!, got: '{result}' ";
        }
        if !result.contains("from_B") {
            return f"expected 'from_B' from B::mac!, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 18. EXPANSION PRESERVES NON-MACRO TOKENS
    // =========================================================================

    suite.equal::<string>("preserve: non-macro tokens are untouched", "pass", fn () -> string {
        var src = "macro M! { expanded }\nvar x = M!\nvar y = 10\n";
        var fid = make_virtual(sm, "preserve_tokens.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("expanded") {
            return f"expected 'expanded', got: '{result}' ";
        }
        if !result.contains("var") {
            return f"expected 'var' preserved, got: '{result}' ";
        }
        if !result.contains("10") {
            return f"expected '10' preserved, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 19. MACRO BODY WITH COMPLEX EXPRESSIONS
    // =========================================================================

    suite.equal::<string>("complex: macro body with operators and nested parens", "pass", fn () -> string {
        var src = "macro expr!(a, b) { (a + b) * (a - b) }\nexpr!(x, y)\n";
        var fid = make_virtual(sm, "complex_body.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // should produce: ( x + y ) * ( x - y )
        if !result.contains("x") || !result.contains("y") || !result.contains("*") {
            return f"expected complex expression, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 20. UNRESOLVED INVOCATION IS LEFT AS-IS
    // =========================================================================

    suite.equal::<string>("unresolved: unknown macro name left as tokens", "pass", fn () -> string {
        var src = "not_a_macro!\n";
        var fid = make_virtual(sm, "unresolved.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // should still contain "not_a_macro" and "!" as tokens
        if !result.contains("not_a_macro") {
            return f"expected unresolved invocation preserved, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 21. SKIP LIST IMPORT STATEMENTS PRESERVED
    // =========================================================================

    suite.equal::<string>("skiplist: import statement tokens preserved in output", "pass", fn () -> string {
        var src = "macro M! { 42 }\nM!\n";
        var fid = make_virtual(sm, "skiplist_import.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // macro definition should be in dead zone but still in output
        if !result.contains("macro") {
            return f"expected 'macro' keyword preserved in dead zone, got: '{result}' ";
        }
        if !result.contains("42") {
            return f"expected '42' from expansion, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 22. EMPTY MACRO BODY
    // =========================================================================

    suite.equal::<string>("edge: empty macro body expands to nothing", "pass", fn () -> string {
        var src = "macro empty! { }\nvar x = empty!\n";
        var fid = make_virtual(sm, "empty_body.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        // should have "var x =" but nothing where empty! was
        if !result.contains("var") {
            return f"expected 'var' preserved, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // 23. MACRO EXPANDING TO MULTIPLE STATEMENTS
    // =========================================================================

    suite.equal::<string>("multi-stmt: macro body with semicolons", "pass", fn () -> string {
        var src = "macro setup! { var a = 1; var b = 2 }\nsetup!\n";
        var fid = make_virtual(sm, "multi_stmt.kro", src);

        var resolver = ImportResolver::Builder()
            .cwd((Path::temp_dir()) / "kro_test_macro_preprocessor")
            .build();
        var tcm = TokenCacheManager(sm, pool);

        var result = expand_to_text(sm, &tcm, resolver, pool, fid);

        if !result.contains("var") || !result.contains("1") || !result.contains("2") {
            return f"expected multi-statement expansion, got: '{result}' ";
        }
        return "pass";
    }, 100);

    // =========================================================================
    // DONE
    // =========================================================================

    pool->wait_all();
    return 0;
}