    cmd->define::<FlagKind::String>("manifest-file",  "",  "manifest-file",  "path to a custom Windows manifest file",                                           "");
    cmd->define::<FlagKind::Bool>  ("dll",            "",  "dll",            "produce a DLL (alias for --shared on Windows)",                                    false);
