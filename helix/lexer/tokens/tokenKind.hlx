                return "delete";
            }

        };

        return null;
    }

    fn hex_keywords_to_type(self, hex_word: u64  ) -> TokenType? {
        switch hex_word {
            case 0x0377cc1912b56d96 {
                return TokenType::Keyword_interface;
            }
            case 0x001ae77e1fd5b695 {
                return TokenType::Keyword_requires;
            }
            case 0x001ae6ec42aefb8a {
                return TokenType::Keyword_continue;
            }
            case 0x0000d0b2ac5f0e54 {
                return TokenType::Keyword_finally;
            }
            case 0x0000d0b20962e0f7 {
                return TokenType::Keyword_derives;
            }
            case 0x0000d0b20885548a {
                return TokenType::Keyword_default;
            }
            case 0x0000065320d1d787 {
                return TokenType::Keyword_unsafe;
            }
            case 0x0000065320ce139f {
                return TokenType::Keyword_unless;
            }
            case 0x000006531c93e1aa {
                return TokenType::Keyword_struct;
            }
            case 0x000006531c8a8bad {
                return TokenType::Keyword_static;
            }
            case 0x0000065319306425 {
                return TokenType::Keyword_return;
            }
            case 0x000006530e32c72b {
                return TokenType::Keyword_module;
            }
            case 0x0000065304d03c64 {
                return TokenType::Keyword_inline;
            }
            case 0x0000065304c06f80 {
                return TokenType::Keyword_import;
            }
            case 0x00000652fc34e0ed {
                return TokenType::Keyword_extend;
            }
            case 0x00000652f8838478 {
                return TokenType::Unary_delete;
            }
            case 0x0000003110c7e4dc {
                return TokenType::Keyword_yield;
            }
            case 0x0000003110a3387e {
                return TokenType::Keyword_while;
            }
            case 0x0000003110851175 {
                return TokenType::Primitive_usize;
            }
            case 0x000000311020cb30 {
                return TokenType::Keyword_panic;
            }
            case 0x000000310fea9a72 {
                return TokenType::Keyword_match;
            }
            case 0x000000310fea5417 {
                return TokenType::Keyword_macro;
            }
            case 0x000000310fabeb69 {
                return TokenType::Primitive_isize;
            }
            case 0x000000310f3d3b4c {
                return TokenType::Keyword_const;
            }
            case 0x000000310f3b5edb {
                return TokenType::Keyword_class;
            }
            case 0x000000310f35a568 {
                return TokenType::Keyword_catch;
            }
            case 0x000000310f2c9f4a {
                return TokenType::Keyword_break;
            }
            case 0x000000310f1d34bb {
                return TokenType::Unary_await;
            }
            case 0x000000310f1b69e3 {
                return TokenType::Keyword_async;
            }
            case 0x000000017ca01ea1 {
                return TokenType::Keyword_with;
            }
            case 0x000000017c9faa57 {
                return TokenType::Primitive_void;
            }
            case 0x000000017c9ebd07 {
                return TokenType::Keyword_type;
            }
            case 0x000000017c9e6865 {
                return TokenType::Keyword_test;
            }
            case 0x000000017c9e1397 {
                return TokenType::Primitive_u256;
            }
            case 0x000000017c9e0ef5 {
                return TokenType::Primitive_u128;
            }
            case 0x000000017c9c6daa {
                return TokenType::Keyword_prot;
            }
            case 0x000000017c9c6ce6 {
                return TokenType::Keyword_priv;
            }
            case 0x000000017c977f0b {
                return TokenType::Primitive_i256;
            }
            case 0x000000017c977a69 {
                return TokenType::Primitive_i128;
            }
            case 0x000000017c9674ad {
                return TokenType::Keyword_eval;
            }
            case 0x000000017c96553a {
                return TokenType::Keyword_enum;
            }
            case 0x000000017c964c6e {
                return TokenType::Keyword_else;
            }
            case 0x000000017c9504e1 {
                return TokenType::Keyword_case;
            }
            case 0x000000017c94b391 {
                return TokenType::Primitive_bool;
            }
            case 0x000000000b88af84 {
                return TokenType::Keyword_try;
            }
            case 0x000000000b88abc4 {
                return TokenType::Primitive_u64;
            }
            case 0x000000000b88ab5f {
                return TokenType::Primitive_u32;
            }
            case 0x000000000b889ecc {
                return TokenType::Keyword_pub;
            }
            case 0x000000000b888bca {
                return TokenType::Keyword_let;
            }
            case 0x000000000b887a41 {
                return TokenType::Keyword_has;
            }
            case 0x000000000b8878b8 {
                return TokenType::Primitive_i64;
            }
            case 0x000000000b887853 {
                return TokenType::Primitive_i32;
            }
            case 0x000000000b887815 {
                return TokenType::Primitive_i16;
            }
            case 0x000000000b88738c {
                return TokenType::Keyword_for;
            }
            case 0x000000000b88725a {
                return TokenType::Keyword_ffi;
            }
            case 0x000000000b886c33 {
                return TokenType::Primitive_f80;
            }
            case 0x000000000b886bf5 {
                return TokenType::Primitive_f64;
            }
            case 0x000000000b886b90 {
                return TokenType::Primitive_f32;
            }
            case 0x000000000b886b4e {
                return TokenType::Primitive_f12;
            }
            case 0x0000000000597992 {
                return TokenType::Primitive_u8;
            }
            case 0x0000000000597904 {
                return TokenType::Keyword_op;
            }
            case 0x0000000000597834 {
                return TokenType::Keyword_if;
            }
            case 0x0000000000597806 {
                return TokenType::Primitive_i8;
            }
            case 0x00000000005977d9 {
                return TokenType::Keyword_fn;
            }
            case 0x0000000000597739 {
                return TokenType::Keyword_as;
            }
        };
        return null;

    }
    op == fn (self, other: TokenKind) -> bool{
        if self.kind == other.kind {
            return true;
        }
        return false;
    }

    op != fn (self, other: TokenKind) -> bool{
        if self.kind != other.kind {
            return true;
        }
        return false;
    }
    op == fn (self, other: string) -> bool{
        if self.to_kind(other) == self.kind {
            return true;
        }
        return false;
    }
    
    op != fn (self, other: string) -> bool{
        if self.to_kind(other) != self.kind {
            return true;
        }
        return false;
    }
    
    op == fn (self, other: TokenType) -> bool{
        if self.kind == other {
            return true;
        }
        return false;
    }
    
    op != fn (self, other: TokenType) -> bool{
        if self.kind != other {
            return true;
        }
        return false;
    }


} // end of TokenKind

    

