// DO NOT FORGET OPS CAN START WITH A PREFIX OF l or r

import EvalHash::*;

///
// TODO: change both this and compute_hash to lower the size of the enum from
//       u64 to u32. We don't need that many bits and it will save memory.
///
/// Key: (At) - Annotation, (Kw) - Keyword, (Op) - Operator,
///      (Bi) - Builtin, (Lit) - Literal
enum TokenKind derives u32 {
    ///===----------------------------------------------------------------===///
    ///   Special tokens                  (Reserved values = 0x00 - 0x23)
    ///===----------------------------------------------------------------===///
    TkUnknown     = 0x001, // (unrecognized)
    TkEof         = 0x002, // (end of file)
    TkError       = 0x003, // (lexing error)
    AtComment     = 0x004, // (comment)
    TkNewLine     = 0x005, // (newline)
    TkWhitespace  = 0x006, // (whitespace)                      RESERVED/UNUSED
    TkFileStart   = 0x007, // (start of file)
    TkFileEnd     = 0x008, // (end of file)
    TkGenerated   = 0x009, // (generated code marker)
    TkMacroExpand = 0x00a, // (macro expansion marker)

    ///===----------------------------------------------------------------===///
    //    Special tokens Continued        (Reserved values = 0x24 - 0xFE)
    ///===----------------------------------------------------------------===///
    LitIdentifier    = 0x024,  // <identifier>
    LitInt           = 0x026,  // e.g. "123", "0xFFF", "0b1010", "0o1298"
    LitFloat         = 0x027,  // e.g. "10.290", "0x1.2p-3",
                               //       ".5",    "3.14e-2" , "1e3"

    LitString        = 0x028,  // e.g.  "hello"
    LitChar          = 0x02b,  // e.g.  'a'

    LitNull          = compute_hash::<r"null">(),
    ///===----------------------------------------------------------------===///
    ///   Punctuators
    ///               "#" is valid within identifiers, so we treat it as such
    ///               "$" is an illegal token in kairo
    ///
    /// we are using directly what compute_hash would return since the bootstrap
    ///    compiler does not allow us to use r"{" and r"}" for some reason, and
    ///    it completely changes.
    ///
    ///===----------------------------------------------------------------===///

    /// TODO: after the self-hosted compiler can compile the compiler make this
    ///       use compute_hash instead of raw Hexadecimal.
    ///
    OpLBrace      = static_cast::<u32>(0xd60d1a11), // "{"
    OpRBrace      = static_cast::<u32>(0xd60d6ae3), // "}"
    OpLParen      = compute_hash::<r"("> (),        // "("
    OpRParen      = compute_hash::<r")"> (),        // ")"
    OpLSquare     = compute_hash::<r"["> (),        // "["
    OpRSquare     = compute_hash::<r"]"> (),        // "]"
    OpBackslash   = compute_hash::<r"\\">(),        // "\"
    OpLess        = compute_hash::<r"<"> (),        // "<"
    OpGreater     = compute_hash::<r">"> (),        // ">"
    OpPlus        = compute_hash::<r"+"> (),        // "+"
    OpMinus       = compute_hash::<r"-"> (),        // "-"
    OpStar        = compute_hash::<r"*"> (),        // "*"
    OpSlash       = compute_hash::<r"/"> (),        // "/"
    OpPercent     = compute_hash::<r"%"> (),        // "%"
    OpCaret       = compute_hash::<r"^"> (),        // "^"
    OpPipe        = compute_hash::<r"|"> (),        // "|"
    OpAmp         = compute_hash::<r"&"> (),        // "&"
    OpCaretCaret  = compute_hash::<r"^^">(),        // "^^"    (exponentiation)

    OpRange       = compute_hash::<r"..">(),   // ".."    NOT (clang-compatible)
    OpRangeEqual  = compute_hash::<r"..=">(),  // "..="   NOT (clang-compatible)

    OpTilde       = compute_hash::<r"~">(),    // "~"
    OpQuestion    = compute_hash::<r"?">(),    // "?"     NOT (clang-compatible)
    OpExclaim     = compute_hash::<r"!">(),    // "!"     NOT (clang-compatible)
    OpAt          = compute_hash::<r"@">(),    // "@"     NOT (clang-compatible)

    OpEqual       = compute_hash::<r"=">(),    // "="
    OpPlusPlus    = compute_hash::<r"++">(),   // "++"
    OpMinusMinus  = compute_hash::<r"--">(),   // "--"

    OpSemicolon         = compute_hash::<r";">(),    // ";"
    OpColon             = compute_hash::<r":">(),    // ":"
    
    OpArrow             = compute_hash::<r"->">(),   // "->"
    OpArrowStar         = compute_hash::<r"->*">(),  // "->*"
    OpQuestionArrow     = compute_hash::<r"?->">(),  // "?->"   NOT (clang-comp)
    OpQuestionArrowStar = compute_hash::<r"?->*">(), // "?->*   NOT (clang-comp)
    OpComma             = compute_hash::<r",">(),    // ","
    OpDot               = compute_hash::<r".">(),    // "."
    OpDotStar           = compute_hash::<r".*">(),   // ".*"
    OpColonColon        = compute_hash::<r"::">(),   // "::"
    OpQuestionDot       = compute_hash::<r"?.">(),   // "?."      NOT (clang-comp)
    OpQuestionDotStar   = compute_hash::<r"?.*">(),  // "?.*"     NOT (clang-comp)

    OpEllipsis        = compute_hash::<r"...">(),  // "..."

    ///===----------------------------------------------------------------===///
    ///   Assignment operators (Clang-compatible)
    ///===----------------------------------------------------------------===///
    OpPlusEqual           = compute_hash::<r"+=">(),  // "+="
    OpMinusEqual          = compute_hash::<r"-=">(),  // "-="
    OpStarEqual           = compute_hash::<r"*=">(),  // "*="
    OpSlashEqual          = compute_hash::<r"/=">(),  // "/="
    OpPercentEqual        = compute_hash::<r"%=">(),  // "%="
    OpAmpEqual            = compute_hash::<r"&=">(),  // "&="
    OpPipeEqual           = compute_hash::<r"|=">(),  // "|="
    OpCaretEqual          = compute_hash::<r"^=">(),  // "^="
    OpLessLessEqual       = compute_hash::<r"<<=">(), // "<<="
    OpGreaterGreaterEqual = compute_hash::<r">>=">(), // ">>="
    OpAtEqual             = compute_hash::<r"@=">(),  // "@="   NOT (clang-comp)

    ///===----------------------------------------------------------------===///
    ///   Logical / comparison operators (Clang-compatible)
    ///===----------------------------------------------------------------===///
    OpLessEqualGreater = compute_hash::<r"<=>">(), // "<=>" (spaceship operator)
    OpEqualEqualEqual  = compute_hash::<r"===">(), // "==="     NOT (clang-comp)
    OpEqualEqual       = compute_hash::<r"==">(),  // "=="
    OpExclaimEqual     = compute_hash::<r"!=">(),  // "!="
    OpLessLess         = compute_hash::<r"<<">(),  // "<<"
    OpGreaterGreater   = compute_hash::<r">>">(),  // ">>"
    OpLessEqual        = compute_hash::<r"<=">(),  // "<="
    OpGreaterEqual     = compute_hash::<r">=">(),  // ">="
    OpAmpAmp           = compute_hash::<r"&&">(),  // "&&"
    OpPipePipe         = compute_hash::<r"||">(),  // "||"
    OpPipeGreater      = compute_hash::<r"|>">(),  // (`a |> f(x)`  > `f(a, x)`)
    OpLessPipe         = compute_hash::<r"<|">(),  // (`f <| a`  > `f(a)`)

    ///===----------------------------------------------------------------===///
    ///   Keywords (Clang subset + Kairo)
    ///===----------------------------------------------------------------===///

    /// Control flow
    KwReturn     = compute_hash::<r"return">(),    // "return"
    KwBreak      = compute_hash::<r"break">(),     // "break"
    KwContinue   = compute_hash::<r"continue">(),  // "continue"
    KwPanic      = compute_hash::<r"panic">(),     // "panic"

    KwMatch      = compute_hash::<r"match">(),     // "match"
    KwCase       = compute_hash::<r"case">(),      // "case"
    KwDefault    = compute_hash::<r"default">(),   // "default"

    KwCatch      = compute_hash::<r"catch">(),     // "catch"
    KwTry        = compute_hash::<r"try">(),       // "try"
    KwFinally    = compute_hash::<r"finally">(),   // "finally"

    KwIf         = compute_hash::<r"if">(),        // "if"
    KwElse       = compute_hash::<r"else">(),      // "else"
    KwWhile      = compute_hash::<r"while">(),     // "while"
    KwFor        = compute_hash::<r"for">(),       // "for"
    KwAssert     = compute_hash::<r"assert">(),    // "assert"
    KwLoop       = compute_hash::<r"loop">(),      // "loop"

    /// Declarations
    KwVar        = compute_hash::<r"var">(),       // "var"
    KwConst      = compute_hash::<r"const">(),     // "const"

    KwFn         = compute_hash::<r"fn">(),        // "fn"
    KwOp         = compute_hash::<r"op">(),        // "op"
    KwClass      = compute_hash::<r"class">(),     // "class"
    KwEnum       = compute_hash::<r"enum">(),      // "enum"
    KwType       = compute_hash::<r"type">(),      // "type"
    KwStruct     = compute_hash::<r"struct">(),    // "struct"
    KwInterface  = compute_hash::<r"interface">(), // "interface"
    KwExtend     = compute_hash::<r"extend">(),    // "extend"

    KwModule     = compute_hash::<r"module">(),    // "module"
    KwTest       = compute_hash::<r"test">(),      // "test"

    KwMacro      = compute_hash::<r"macro">(),     // "macro"

    KwImport     = compute_hash::<r"import">(),    // "import"
    KwOverride   = compute_hash::<r"override">(),  // "override"
    KwFinal      = compute_hash::<r"final">(),     // "final"

    KwFfi        = compute_hash::<r"ffi">(),       // "ffi"

    KwImpl       = compute_hash::<r"impl">(),      // "impl"
    KwDerives    = compute_hash::<r"derives">(),   // "derives"

    KwRequires   = compute_hash::<r"requires">(),  // "requires"

    /// Access control
    KwPub        = compute_hash::<r"pub">(),       // "pub"
    KwPriv       = compute_hash::<r"priv">(),      // "priv"
    KwProt       = compute_hash::<r"prot">(),      // "prot"

    /// Specifiers / qualifiers
    KwEval       = compute_hash::<r"eval">(),      // "eval"
    KwUnsafe     = compute_hash::<r"unsafe">(),    // "unsafe"
    KwStatic     = compute_hash::<r"static">(),    // "static"
    KwAsync      = compute_hash::<r"async">(),     // "async"
    KwInline     = compute_hash::<r"inline">(),    // "inline"
    KwAtomic     = compute_hash::<r"atomic">(),    // "atomic"

    /// Special identifiers
    KwSelf       = compute_hash::<r"self">(),      // "self"

    /// Booleans
    KwTrue       = compute_hash::<r"true">(),      // "true"
    KwFalse      = compute_hash::<r"false">(),     // "false"

    ///===----------------------------------------------------------------===///
    ///   Binary operators
    ///===----------------------------------------------------------------===///
    KwIn     = compute_hash::<r"in">(),     // "in"
    KwAs     = compute_hash::<r"as">(),     // "as"
    KwAnd    = compute_hash::<r"and">(),    // "and"
    KwAndEq  = compute_hash::<r"and_eq">(), // "and_eq"
    KwBitand = compute_hash::<r"bitand">(), // "bitand"
    KwBitor  = compute_hash::<r"bitor">(),  // "bitor"
    KwCompl  = compute_hash::<r"compl">(),  // "compl"
    KwNot    = compute_hash::<r"not">(),    // "not"
    KwNotEq  = compute_hash::<r"not_eq">(), // "not_eq"
    KwOr     = compute_hash::<r"or">(),     // "or"
    KwOrEq   = compute_hash::<r"or_eq">(),  // "or_eq"
    KwXor    = compute_hash::<r"xor">(),    // "xor"
    KwXorEq  = compute_hash::<r"xor_eq">(), // "xor_eq"

    ///===----------------------------------------------------------------===///
    ///   Primitive types
    ///===----------------------------------------------------------------===///
    AtVoid  = compute_hash::<r"void">(),  // "void"
    AtBool  = compute_hash::<r"bool">(),  // "bool"

    AtUsize = compute_hash::<r"usize">(), // "usize"
    AtIsize = compute_hash::<r"isize">(), // "isize"

    AtF32   = compute_hash::<r"f32">(),   // "f32"
    AtF64   = compute_hash::<r"f64">(),   // "f64"
    AtF80   = compute_hash::<r"f80">(),   // "f80"
    AtF128  = compute_hash::<r"f128">(),  // "f128"

    AtU8    = compute_hash::<r"u8">(),    // "u8"
    AtU16   = compute_hash::<r"u16">(),   // "u16"
    AtU32   = compute_hash::<r"u32">(),   // "u32"
    AtU64   = compute_hash::<r"u64">(),   // "u64"
    AtU128  = compute_hash::<r"u128">(),  // "u128"
    AtU256  = compute_hash::<r"u256">(),  // "u256"

    AtI8    = compute_hash::<r"i8">(),    // "i8"
    AtI16   = compute_hash::<r"i16">(),   // "i16"
    AtI32   = compute_hash::<r"i32">(),   // "i32"
    AtI64   = compute_hash::<r"i64">(),   // "i64"
    AtI128  = compute_hash::<r"i128">(),  // "i128"
    AtI256  = compute_hash::<r"i256">(),  // "i256"

    ///===----------------------------------------------------------------===///
    ///   Unary keywords
    ///===----------------------------------------------------------------===///
    KwAwait    = compute_hash::<r"await">(),      // "await"
    KwThread   = compute_hash::<r"thread">(),     // "thread" // this is for thread_local storage, not thread spawning
    KwSpawn    = compute_hash::<r"spawn">(),      // "spawn"  // lowkey remove this

    KwDelete   = compute_hash::<r"delete">(),     // "delete"
    KwYield    = compute_hash::<r"yield">(),      // "yield"

    KwSizeOf   = compute_hash::<r"sizeof">(),     // "sizeof"
    KwAlignOf  = compute_hash::<r"alignof">(),    // "alignof"
    KwTypeOf   = compute_hash::<r"typeof">(),     // "typeof"

    ///===----------------------------------------------------------------===///
    ///   Builtins
    ///===----------------------------------------------------------------===///
    BiFile         = compute_hash::<r"__file__">(),     // "__file__"
    BiLine         = compute_hash::<r"__line__">(),     // "__line__"
    BiColumn       = compute_hash::<r"__column__">(),   // "__column__"
    BiFunction     = compute_hash::<r"__function__">(), // "__function__"
    BiModule       = compute_hash::<r"__module__">(),   // "__module__"

    /// builtin attributes
    BiVolatile     = compute_hash::<r"volatile">(),     // "volatile"
    BiPacked       = compute_hash::<r"packed">(),       // "packed"
    BiUnlikely     = compute_hash::<r"unlikely">(),     // "unlikely"
    BiLikely       = compute_hash::<r"likely">(),       // "likely"
    BiInternal     = compute_hash::<r"internal">(),     // "internal"
    BiExperimental = compute_hash::<r"experimental">(), // "experimental"
    BiForceInline  = compute_hash::<r"force_inline">(), // "force_inline"
    BiNoInline     = compute_hash::<r"no_inline">(),    // "no_inline"
    BiDeprecated   = compute_hash::<r"deprecated">(),   // "deprecated"
    BiMustUse      = compute_hash::<r"must_use">(),     // "must_use"
    BiAlignAs      = compute_hash::<r"alignas">(),      // "alignas"
};

//****************************************************************************//
//           MAKE SURE TO KEEP THIS IN SYNC WITH THE ENUM ABOVE               //
//****************************************************************************//

fn is_valid_token_kind(kind: u32) -> bool {
    switch static_cast::<TokenKind>(kind) {
        case TokenKind::TkUnknown:          case TokenKind::TkEof:
        case TokenKind::AtComment:          case TokenKind::TkNewLine:
        case TokenKind::TkFileStart:        case TokenKind::TkFileEnd:
        case TokenKind::TkMacroExpand:      case TokenKind::LitIdentifier:
        case TokenKind::LitInt:             case TokenKind::LitFloat:
        case TokenKind::OpRBrace:           case TokenKind::OpLParen:
        case TokenKind::OpLSquare:          case TokenKind::OpRSquare:
        case TokenKind::OpLess:             case TokenKind::OpGreater:
        case TokenKind::OpMinus:            case TokenKind::OpStar:
        case TokenKind::OpPercent:          case TokenKind::OpCaret:
        case TokenKind::OpAmp:              case TokenKind::OpCaretCaret:
        case TokenKind::OpRangeEqual:       case TokenKind::OpTilde:
        case TokenKind::OpExclaim:          case TokenKind::OpAt:
        case TokenKind::OpPlusPlus:         case TokenKind::OpMinusMinus:
        case TokenKind::OpArrowStar:        case TokenKind::OpQuestionArrow:
        case TokenKind::OpSemicolon:        case TokenKind::OpComma:
        case TokenKind::OpDotStar:          case TokenKind::OpColonColon:
        case TokenKind::OpQuestionDotStar:  case TokenKind::BiAlignAs:
        case TokenKind::OpEllipsis:         case TokenKind::OpPlusEqual:
        case TokenKind::OpStarEqual:        case TokenKind::OpSlashEqual:
        case TokenKind::OpAmpEqual:         case TokenKind::OpPipeEqual:
        case TokenKind::OpLessLessEqual:    case TokenKind::OpGreaterGreaterEqual:
        case TokenKind::OpLessEqualGreater: case TokenKind::OpEqualEqualEqual:
        case TokenKind::OpExclaimEqual:     case TokenKind::OpLessLess:
        case TokenKind::OpLessEqual:        case TokenKind::OpGreaterEqual:
        case TokenKind::OpPipePipe:         case TokenKind::OpPipeGreater:
        case TokenKind::KwReturn:           case TokenKind::KwBreak:
        case TokenKind::KwPanic:            case TokenKind::KwMatch:
        case TokenKind::KwDefault:          case TokenKind::KwCatch:
        case TokenKind::KwFinally:          case TokenKind::TkError:
        case TokenKind::KwIf:               case TokenKind::TkWhitespace:
        case TokenKind::KwElse:             case TokenKind::TkGenerated:
        case TokenKind::KwWhile:            case TokenKind::LitNull:
        case TokenKind::KwFor:              case TokenKind::LitString:
        case TokenKind::KwAssert:           case TokenKind::LitChar:
        case TokenKind::KwLoop:             case TokenKind::OpLBrace:
        case TokenKind::KwVar:              case TokenKind::OpRParen:
        case TokenKind::KwConst:            case TokenKind::OpBackslash:
        case TokenKind::KwFn:               case TokenKind::OpPlus:
        case TokenKind::KwOp:               case TokenKind::OpSlash:
        case TokenKind::KwClass:            case TokenKind::OpPipe:
        case TokenKind::KwEnum:             case TokenKind::OpRange:
        case TokenKind::KwType:             case TokenKind::OpQuestion:
        case TokenKind::KwStruct:           case TokenKind::OpEqual:
        case TokenKind::KwInterface:        case TokenKind::OpArrow:
        case TokenKind::KwExtend:           case TokenKind::OpQuestionArrowStar:
        case TokenKind::KwModule:           case TokenKind::OpColon:
        case TokenKind::KwTest:             case TokenKind::OpDot:
        case TokenKind::KwMacro:            case TokenKind::OpQuestionDot:
        case TokenKind::KwImport:           case TokenKind::AtU64:
        case TokenKind::KwOverride:         case TokenKind::OpMinusEqual:
        case TokenKind::KwFinal:            case TokenKind::OpPercentEqual:
        case TokenKind::KwFfi:              case TokenKind::OpCaretEqual:
        case TokenKind::KwImpl:             case TokenKind::OpAtEqual:
        case TokenKind::KwDerives:          case TokenKind::OpEqualEqual:
        case TokenKind::KwRequires:         case TokenKind::OpGreaterGreater:
        case TokenKind::KwPub:              case TokenKind::OpAmpAmp:
        case TokenKind::KwPriv:             case TokenKind::OpLessPipe:
        case TokenKind::KwProt:             case TokenKind::KwContinue:
        case TokenKind::KwEval:             case TokenKind::KwCase:
        case TokenKind::KwUnsafe:           case TokenKind::KwTry:
        case TokenKind::AtU128:             case TokenKind::KwStatic:
        case TokenKind::AtU256:             case TokenKind::KwAsync:
        case TokenKind::AtI8:               case TokenKind::KwInline:
        case TokenKind::AtI16:              case TokenKind::KwSelf:
        case TokenKind::AtI32:              case TokenKind::KwTrue:
        case TokenKind::AtI64:              case TokenKind::KwFalse:
        case TokenKind::AtI128:             case TokenKind::KwIn:
        case TokenKind::AtI256:             case TokenKind::KwAs:
        case TokenKind::KwAwait:            case TokenKind::KwAnd:
        case TokenKind::KwThread:           case TokenKind::KwAndEq:
        case TokenKind::KwSpawn:            case TokenKind::KwBitand:
        case TokenKind::KwDelete:           case TokenKind::KwBitor:
        case TokenKind::KwYield:            case TokenKind::KwCompl:
        case TokenKind::KwSizeOf:           case TokenKind::KwNot:
        case TokenKind::KwAlignOf:          case TokenKind::KwNotEq:
        case TokenKind::KwTypeOf:           case TokenKind::KwOr:
        case TokenKind::BiFile:             case TokenKind::KwOrEq:
        case TokenKind::BiLine:             case TokenKind::KwXor:
        case TokenKind::BiColumn:           case TokenKind::KwXorEq:
        case TokenKind::BiFunction:         case TokenKind::AtVoid:
        case TokenKind::BiModule:           case TokenKind::AtBool:
        case TokenKind::BiVolatile:         case TokenKind::AtUsize:
        case TokenKind::BiPacked:           case TokenKind::AtIsize:
        case TokenKind::BiUnlikely:         case TokenKind::AtF32:
        case TokenKind::BiLikely:           case TokenKind::AtF64:
        case TokenKind::BiInternal:         case TokenKind::AtF80:
        case TokenKind::BiExperimental:     case TokenKind::AtF128:
        case TokenKind::BiForceInline:      case TokenKind::AtU8:
        case TokenKind::BiNoInline:         case TokenKind::AtU16:
        case TokenKind::BiDeprecated:       case TokenKind::AtU32:
        case TokenKind::BiMustUse:
            return true;
        default:
            return false;
    }
}

//****************************************************************************//
//           MAKE SURE TO KEEP THIS IN SYNC WITH THE ENUM ABOVE               //
//****************************************************************************//

fn token_kind_to_string(kind: TokenKind) -> string {
    switch kind {
        case TokenKind::TkUnknown {             return "tk-unknown"; }
        case TokenKind::TkEof {                 return "tk-eof"; }
        case TokenKind::TkError {               return "tk-error"; }
        case TokenKind::AtComment {             return "tk-comment"; }
        case TokenKind::TkNewLine {             return "tk-new-line"; }
        case TokenKind::TkWhitespace {          return "tk-whitespace"; }
        case TokenKind::TkFileStart {           return "tk-file-start"; }
        case TokenKind::TkFileEnd {             return "tk-file-end"; }
        case TokenKind::TkGenerated {           return "tk-generated"; }
        case TokenKind::TkMacroExpand {         return "tk-macro-expand"; }
        case TokenKind::LitIdentifier {         return "lit-identifier"; }
        case TokenKind::LitNull {               return "lit-null"; }
        case TokenKind::LitInt {                return "lit-int"; }
        case TokenKind::LitFloat {              return "lit-float"; }
        case TokenKind::LitString {             return "lit-string"; }
        case TokenKind::LitChar {               return "lit-char"; }
        case TokenKind::OpLBrace {              return "op-l-brace"; }
        case TokenKind::OpRBrace {              return "op-r-brace"; }
        case TokenKind::OpLParen {              return "op-l-paren"; }
        case TokenKind::OpRParen {              return "op-r-paren"; }
        case TokenKind::OpLSquare {             return "op-l-square"; }
        case TokenKind::OpRSquare {             return "op-r-square"; }
        case TokenKind::OpBackslash {           return "op-backslash"; }
        case TokenKind::OpLess {                return "op-less"; }
        case TokenKind::OpGreater {             return "op-greater"; }
        case TokenKind::OpPlus {                return "op-plus"; }
        case TokenKind::OpMinus {               return "op-minus"; }
        case TokenKind::OpStar {                return "op-star"; }
        case TokenKind::OpSlash {               return "op-slash"; }
        case TokenKind::OpPercent {             return "op-percent"; }
        case TokenKind::OpCaret {               return "op-caret"; }
        case TokenKind::OpPipe {                return "op-pipe"; }
        case TokenKind::OpAmp {                 return "op-amp"; }
        case TokenKind::OpCaretCaret {          return "op-caret-caret"; }
        case TokenKind::OpRange {               return "op-range"; }
        case TokenKind::OpRangeEqual {          return "op-range-equal"; }
        case TokenKind::OpTilde {               return "op-tilde"; }
        case TokenKind::OpQuestion {            return "op-question"; }
        case TokenKind::OpExclaim {             return "op-exclaim"; }
        case TokenKind::OpAt {                  return "op-at"; }
        case TokenKind::OpEqual {               return "op-equal"; }
        case TokenKind::OpPlusPlus {            return "op-plusplus"; }
        case TokenKind::OpMinusMinus {          return "op-minus-minus"; }
        case TokenKind::OpArrow {               return "op-arrow"; }
        case TokenKind::OpArrowStar {           return "op-arrow-star"; }
        case TokenKind::OpQuestionArrow {       return "op-question-arrow"; }
        case TokenKind::OpQuestionArrowStar {   return "op-question-arrow-star"; }
        case TokenKind::OpColon {               return "op-colon"; }
        case TokenKind::OpSemicolon {           return "op-semicolon"; }
