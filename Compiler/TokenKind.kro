        case TokenKind::BiExperimental {        return "bi-experimental"; }
        case TokenKind::BiForceInline {         return "bi-force-inline"; }
        case TokenKind::BiNoInline {            return "bi-no-inline"; }
        case TokenKind::BiDeprecated {          return "bi-deprecated"; }
        case TokenKind::BiMustUse {             return "bi-must-use"; }
        case TokenKind::BiAlignAs {             return "bi-align-as"; }
    }

    return "tk-unknown";
}

fn token_kind_to_readable_string(kind: TokenKind) -> string {
    switch kind {
        case TokenKind::TkUnknown             { return "UNKNOWN";        }
        case TokenKind::TkEof                 { return "END OF FILE";    }
        case TokenKind::TkError               { return "ERROR";          }
        case TokenKind::AtComment             { return "comment";        }
        case TokenKind::TkNewLine             { return "new line";       }
        case TokenKind::TkWhitespace          { return "any whitespace"; }
        case TokenKind::TkFileStart           { return "FILE START";     }
        case TokenKind::TkFileEnd             { return "FILE END";       }
        case TokenKind::TkGenerated           { return "GENERATED";      }
        case TokenKind::TkMacroExpand         { return "MACRO EXPANDED"; }
        case TokenKind::LitIdentifier         { return "identifier";     }
        case TokenKind::LitNull               { return "null";           }
        case TokenKind::LitInt                { return "integer";        }
        case TokenKind::LitFloat              { return "floating point"; }
        case TokenKind::LitString             { return "string";         }
        case TokenKind::LitChar               { return "character";      }
        case TokenKind::OpLBrace              { return "{";   }
        case TokenKind::OpRBrace              { return "}";   }
        case TokenKind::OpLParen              { return "(";   }
        case TokenKind::OpRParen              { return ")";   }
        case TokenKind::OpLSquare             { return "[";   }
        case TokenKind::OpRSquare             { return "]";   }
        case TokenKind::OpBackslash           { return "\\";  }
        case TokenKind::OpLess                { return "<";   }
        case TokenKind::OpGreater             { return ">";   }
        case TokenKind::OpPlus                { return "+";   }
        case TokenKind::OpMinus               { return "-";   }
        case TokenKind::OpStar                { return "*";   }
        case TokenKind::OpSlash               { return "/";   }
        case TokenKind::OpPercent             { return "%";   }
        case TokenKind::OpCaret               { return "^";   }
        case TokenKind::OpPipe                { return "|";   }
        case TokenKind::OpAmp                 { return "&";   }
        case TokenKind::OpCaretCaret          { return "^^";  }
        case TokenKind::OpRange               { return "..";  }
        case TokenKind::OpRangeEqual          { return "..="; }
        case TokenKind::OpTilde               { return "~";   }
        case TokenKind::OpQuestion            { return "?";   }
        case TokenKind::OpExclaim             { return "!";   }
        case TokenKind::OpAt                  { return "@";   }
        case TokenKind::OpEqual               { return "=";   }
        case TokenKind::OpPlusPlus            { return "++";  }
        case TokenKind::OpMinusMinus          { return "--";  }
        case TokenKind::OpArrow               { return "->";  }
        case TokenKind::OpArrowStar           { return "->*"; }
        case TokenKind::OpQuestionArrow       { return "?->"; }
        case TokenKind::OpQuestionArrowStar   { return "?->*"; }
        case TokenKind::OpColon               { return ":"; }
        case TokenKind::OpSemicolon           { return ";"; }
        case TokenKind::OpComma               { return ","; }
        case TokenKind::OpDot                 { return "."; }
        case TokenKind::OpDotStar             { return ".*"; }
        case TokenKind::OpColonColon          { return "::"; }
        case TokenKind::OpQuestionDot         { return "?."; }
        case TokenKind::OpQuestionDotStar     { return "?.*"; }
        case TokenKind::OpEllipsis            { return "..."; }
        case TokenKind::OpPlusEqual           { return "+="; }
        case TokenKind::OpMinusEqual          { return "-="; }
        case TokenKind::OpStarEqual           { return "*="; }
        case TokenKind::OpSlashEqual          { return "/="; }
        case TokenKind::OpPercentEqual        { return "%="; }
        case TokenKind::OpAmpEqual            { return "&="; }
        case TokenKind::OpPipeEqual           { return "|="; }
        case TokenKind::OpCaretEqual          { return "^="; }
        case TokenKind::OpLessLessEqual       { return "<<="; }
        case TokenKind::OpGreaterGreaterEqual { return ">>="; }
        case TokenKind::OpAtEqual             { return "@="; }
        case TokenKind::OpLessEqualGreater    { return "<=>"; }
        case TokenKind::OpEqualEqualEqual     { return "==="; }
        case TokenKind::OpEqualEqual          { return "=="; }
        case TokenKind::OpExclaimEqual        { return "!="; }
        case TokenKind::OpLessLess            { return "<<"; }
        case TokenKind::OpGreaterGreater      { return ">>"; }
        case TokenKind::OpLessEqual           { return "<="; }
        case TokenKind::OpGreaterEqual        { return ">="; }
        case TokenKind::OpAmpAmp              { return "&&"; }
        case TokenKind::OpPipePipe            { return "||"; }
        case TokenKind::OpPipeGreater         { return "|>"; }
        case TokenKind::OpLessPipe            { return "<|"; }
        case TokenKind::KwReturn              { return "return"; }
        case TokenKind::KwBreak               { return "break"; }
        case TokenKind::KwContinue            { return "continue"; }
        case TokenKind::KwPanic               { return "panic"; }
        case TokenKind::KwMatch               { return "match"; }
        case TokenKind::KwCase                { return "case"; }
        case TokenKind::KwDefault             { return "default"; }
        case TokenKind::KwCatch               { return "catch"; }
        case TokenKind::KwTry                 { return "try"; }
        case TokenKind::KwFinally             { return "finally"; }
        case TokenKind::KwIf                  { return "if"; }
        case TokenKind::KwElse                { return "else"; }
        case TokenKind::KwWhile               { return "while"; }
        case TokenKind::KwFor                 { return "for"; }
        case TokenKind::KwAssert              { return "assert"; }
        case TokenKind::KwLoop                { return "loop"; }
        case TokenKind::KwVar                 { return "var"; }
        case TokenKind::KwConst               { return "const"; }
        case TokenKind::KwFn                  { return "fn"; }
        case TokenKind::KwOp                  { return "op"; }
        case TokenKind::KwClass               { return "class"; }
        case TokenKind::KwEnum                { return "enum"; }
        case TokenKind::KwType                { return "type"; }
        case TokenKind::KwStruct              { return "struct"; }
        case TokenKind::KwInterface           { return "interface"; }
        case TokenKind::KwExtend              { return "extend"; }
        case TokenKind::KwModule              { return "module"; }
        case TokenKind::KwTest                { return "test"; }
        case TokenKind::KwMacro               { return "macro"; }
        case TokenKind::KwImport              { return "import"; }
        case TokenKind::KwOverride            { return "override"; }
        case TokenKind::KwFinal               { return "final"; }
        case TokenKind::KwFfi                 { return "ffi"; }
        case TokenKind::KwImpl                { return "impl"; }
        case TokenKind::KwDerives             { return "derives"; }
        case TokenKind::KwRequires            { return "requires"; }
        case TokenKind::KwPub                 { return "pub"; }
        case TokenKind::KwPriv                { return "priv"; }
        case TokenKind::KwProt                { return "prot"; }
        case TokenKind::KwEval                { return "eval"; }
        case TokenKind::KwUnsafe              { return "unsafe"; }
        case TokenKind::KwStatic              { return "static"; }
        case TokenKind::KwAsync               { return "async"; }
        case TokenKind::KwInline              { return "inline"; }
        case TokenKind::KwSelf                { return "self"; }
        case TokenKind::KwTrue                { return "true"; }
        case TokenKind::KwFalse               { return "false"; }
        case TokenKind::KwIn                  { return "in"; }
        case TokenKind::KwAs                  { return "as"; }
        case TokenKind::KwAnd                 { return "and"; }
        case TokenKind::KwAndEq               { return "and_eq"; }
        case TokenKind::KwBitand              { return "bitand"; }
        case TokenKind::KwBitor               { return "bitor"; }
        case TokenKind::KwCompl               { return "compl"; }
        case TokenKind::KwNot                 { return "not"; }
        case TokenKind::KwNotEq               { return "not_eq"; }
        case TokenKind::KwOr                  { return "or"; }
        case TokenKind::KwOrEq                { return "or_eq"; }
        case TokenKind::KwXor                 { return "xor"; }
        case TokenKind::KwXorEq               { return "xor_eq"; }
        case TokenKind::AtVoid                { return "void"; }
        case TokenKind::AtBool                { return "bool"; }
        case TokenKind::AtUsize               { return "usize"; }
        case TokenKind::AtIsize               { return "isize"; }
        case TokenKind::AtF32                 { return "f32"; }
        case TokenKind::AtF64                 { return "f64"; }
        case TokenKind::AtF80                 { return "f80"; }
        case TokenKind::AtF128                { return "f128"; }
        case TokenKind::AtU8                  { return "u8"; }
        case TokenKind::AtU16                 { return "u16"; }
        case TokenKind::AtU32                 { return "u32"; }
        case TokenKind::AtU64                 { return "u64"; }
        case TokenKind::AtU128                { return "u128"; }
        case TokenKind::AtU256                { return "u256"; }
        case TokenKind::AtI8                  { return "i8"; }
        case TokenKind::AtI16                 { return "i16"; }
        case TokenKind::AtI32                 { return "i32"; }
        case TokenKind::AtI64                 { return "i64"; }
        case TokenKind::AtI128                { return "i128"; }
        case TokenKind::AtI256                { return "i256"; }
        case TokenKind::KwAwait               { return "await"; }
        case TokenKind::KwThread              { return "thread"; }
        case TokenKind::KwSpawn               { return "spawn"; }
        case TokenKind::KwDelete              { return "delete"; }
        case TokenKind::KwYield               { return "yield"; }
        case TokenKind::KwSizeOf              { return "sizeof"; }
        case TokenKind::KwAlignOf             { return "alignof"; }
        case TokenKind::KwTypeOf              { return "typeof"; }
        case TokenKind::BiFile                { return "@__file__"; }
        case TokenKind::BiLine                { return "@__line__"; }
        case TokenKind::BiColumn              { return "@__column__"; }
        case TokenKind::BiFunction            { return "@__function__"; }
        case TokenKind::BiModule              { return "@__module__"; }
        case TokenKind::BiVolatile            { return "@volatile"; }
        case TokenKind::BiPacked              { return "@packed"; }
        case TokenKind::BiUnlikely            { return "@unlikely"; }
        case TokenKind::BiLikely              { return "@likely"; }
        case TokenKind::BiInternal            { return "@internal"; }
        case TokenKind::BiExperimental        { return "@experimental"; }
        case TokenKind::BiForceInline         { return "@force_inline"; }
        case TokenKind::BiNoInline            { return "@no_inline"; }
        case TokenKind::BiDeprecated          { return "@deprecated"; }
        case TokenKind::BiMustUse             { return "@must_use"; }
        case TokenKind::BiAlignAs             { return "@alignas"; }
    }

    return "UNKNOWN";
}

fn is_annotation(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::AtI256:    case TokenKind::AtU16:
        case TokenKind::AtVoid:    case TokenKind::AtU32:
        case TokenKind::AtBool:    case TokenKind::AtU64:
        case TokenKind::AtUsize:   case TokenKind::AtU128:
        case TokenKind::AtIsize:   case TokenKind::AtU256:
        case TokenKind::AtF32:     case TokenKind::AtI8:
        case TokenKind::AtF64:     case TokenKind::AtI16:
        case TokenKind::AtF80:     case TokenKind::AtI32:
        case TokenKind::AtF128:    case TokenKind::AtI64:
        case TokenKind::AtU8:      case TokenKind::AtI128:
        case TokenKind::AtComment:
            return true;
        default:
            return false;
    }
}

fn is_keyword(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwReturn:      case TokenKind::KwBreak:
        case TokenKind::KwCase:        case TokenKind::KwDefault:
        case TokenKind::KwIf:          case TokenKind::KwElse:
        case TokenKind::KwLoop:        case TokenKind::KwVar:
        case TokenKind::KwClass:       case TokenKind::KwEnum:
        case TokenKind::KwExtend:      case TokenKind::KwModule:
        case TokenKind::KwFinal:       case TokenKind::KwFfi:
        case TokenKind::KwDerives:     case TokenKind::KwRequires:
        case TokenKind::KwEval:        case TokenKind::KwUnsafe:
        case TokenKind::KwAwait:       case TokenKind::KwThread:
        case TokenKind::KwSizeOf:      case TokenKind::KwAlignOf:
        case TokenKind::KwPanic:       case TokenKind::KwMatch:
        case TokenKind::KwCatch:       case TokenKind::KwTry:
        case TokenKind::KwWhile:       case TokenKind::KwFor:
        case TokenKind::KwConst:       case TokenKind::KwFn:
        case TokenKind::KwType:        case TokenKind::KwStruct:
        case TokenKind::KwTest:        case TokenKind::KwMacro:
        case TokenKind::KwAs:          case TokenKind::KwImpl:
        case TokenKind::KwPub:         case TokenKind::KwPriv:
        case TokenKind::KwStatic:      case TokenKind::KwAsync:
        case TokenKind::KwSpawn:       case TokenKind::KwDelete:
        case TokenKind::KwTypeOf:      case TokenKind::KwContinue:
        case TokenKind::KwFinally:     case TokenKind::KwImport:
        case TokenKind::KwAssert:      case TokenKind::KwOverride:
        case TokenKind::KwOp:          case TokenKind::KwProt:
        case TokenKind::KwInterface:   case TokenKind::KwInline:
        case TokenKind::KwYield:
            return true;
        default:
            return false;
    }
}

fn is_unary_operator(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwNot:        case TokenKind::OpQuestion:
        case TokenKind::KwAwait:      case TokenKind::OpExclaim:
        case TokenKind::KwThread:     case TokenKind::KwCompl:
        case TokenKind::KwSpawn:      case TokenKind::OpAt:
        case TokenKind::KwDelete:     case TokenKind::OpEqual:
        case TokenKind::KwYield:      case TokenKind::OpPlusPlus:
        case TokenKind::KwSizeOf:     case TokenKind::OpMinusMinus:
        case TokenKind::KwAlignOf:    case TokenKind::OpPlus:
        case TokenKind::KwTypeOf:     case TokenKind::OpMinus:
        case TokenKind::KwAs:         case TokenKind::OpStar:
        case TokenKind::OpRange:      case TokenKind::OpAmp:
        case TokenKind::OpTilde:      case TokenKind::OpEllipsis:
            return true;
        default:
            return false;
    }
}

fn is_binary_operator(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwIn:               case TokenKind::OpLessLessEqual:
        case TokenKind::KwAs:               case TokenKind::OpGreaterGreaterEqual:
        case TokenKind::KwAnd:              case TokenKind::OpAtEqual:
        case TokenKind::KwAndEq:            case TokenKind::OpEqual:
        case TokenKind::KwBitand:           case TokenKind::OpLess:
        case TokenKind::KwBitor:            case TokenKind::OpGreater:
        case TokenKind::KwNotEq:            case TokenKind::OpPlus:
        case TokenKind::KwOr:               case TokenKind::OpMinus:
        case TokenKind::KwOrEq:             case TokenKind::OpStar:
        case TokenKind::KwXor:              case TokenKind::OpSlash:
        case TokenKind::KwXorEq:            case TokenKind::OpPercent:
        case TokenKind::OpLessEqualGreater: case TokenKind::OpCaret:
        case TokenKind::OpEqualEqualEqual:  case TokenKind::OpPipe:
        case TokenKind::OpEqualEqual:       case TokenKind::OpAmp:
        case TokenKind::OpExclaimEqual:     case TokenKind::OpCaretCaret:
        case TokenKind::OpLessLess:         case TokenKind::OpRange:
        case TokenKind::OpGreaterGreater:   case TokenKind::OpRangeEqual:
        case TokenKind::OpLessEqual:        case TokenKind::OpAt:
        case TokenKind::OpGreaterEqual:     case TokenKind::OpArrow:
        case TokenKind::OpAmpAmp:           case TokenKind::OpArrowStar:
        case TokenKind::OpPipePipe:         case TokenKind::OpQuestionArrow:
        case TokenKind::OpPipeGreater:      case TokenKind::OpQuestionArrowStar:
        case TokenKind::OpLessPipe:         case TokenKind::OpQuestionDotStar:
        case TokenKind::OpPlusEqual:        case TokenKind::OpCaretEqual:
        case TokenKind::OpMinusEqual:       case TokenKind::OpComma:
        case TokenKind::OpStarEqual:        case TokenKind::OpDot:
        case TokenKind::OpSlashEqual:       case TokenKind::OpDotStar:
        case TokenKind::OpPercentEqual:     case TokenKind::OpQuestionDot:
        case TokenKind::OpAmpEqual:         case TokenKind::OpPipeEqual:
            return true;
        default:
            return false;
    }
}

fn is_assignment_operator(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::OpPlusEqual:      case TokenKind::OpPipeEqual:
        case TokenKind::OpMinusEqual:     case TokenKind::OpCaretEqual:
        case TokenKind::OpStarEqual:      case TokenKind::OpLessLessEqual:
        case TokenKind::OpSlashEqual:     case TokenKind::OpGreaterGreaterEqual:
        case TokenKind::OpPercentEqual:   case TokenKind::OpAtEqual:
        case TokenKind::OpAmpEqual:       case TokenKind::OpEqual:
            return true;
        default:
            return false;
    }
}

fn is_punctuator(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::TkNewLine:    case TokenKind::OpLSquare:
        case TokenKind::TkWhitespace: case TokenKind::OpRSquare:
        case TokenKind::OpLBrace:     case TokenKind::OpBackslash:
        case TokenKind::OpRBrace:     case TokenKind::OpColon:
        case TokenKind::OpLParen:     case TokenKind::OpSemicolon:
        case TokenKind::OpRParen:
            return true;
        default:
            return false;
    }
}

fn is_range_operator(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::OpRange:       case TokenKind::OpRangeEqual:
        case TokenKind::OpLessEqualGreater:
            return true;
        default:
            return false;
    }
}

fn is_operator(kind: TokenKind) -> bool {
    return is_unary_operator(kind)
        || is_binary_operator(kind)
        || is_assignment_operator(kind);
}

fn is_builtin(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::BiFile:       case TokenKind::BiLikely:
        case TokenKind::BiLine:       case TokenKind::BiInternal:
        case TokenKind::BiColumn:     case TokenKind::BiExperimental:
        case TokenKind::BiFunction:   case TokenKind::BiForceInline:
        case TokenKind::BiModule:     case TokenKind::BiNoInline:
        case TokenKind::BiVolatile:   case TokenKind::BiDeprecated:
        case TokenKind::BiPacked:     case TokenKind::BiMustUse:
        case TokenKind::BiUnlikely:   case TokenKind::BiAlignAs:
            return true;
        default:
            return false;
    }
}

fn is_special(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwSelf:
        case TokenKind::TkUnknown:
        case TokenKind::TkEof:
        case TokenKind::TkError:
        case TokenKind::AtComment:
        case TokenKind::TkNewLine:
        case TokenKind::TkWhitespace:
        case TokenKind::TkFileStart:
        case TokenKind::TkFileEnd:
        case TokenKind::TkGenerated:
        case TokenKind::TkMacroExpand:
            return true;
        default:
            return false;
    }
}

fn is_internal(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::TkUnknown:
        case TokenKind::TkEof:
        case TokenKind::TkError:
        case TokenKind::TkFileStart:
        case TokenKind::TkFileEnd:
        case TokenKind::TkGenerated:
        case TokenKind::TkMacroExpand:
            return true;
        default:
            return false;
    }
}

fn is_literal(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwTrue:
        case TokenKind::KwFalse:
        case TokenKind::LitIdentifier:
        case TokenKind::LitNull:
        case TokenKind::LitInt:
        case TokenKind::LitFloat:
        case TokenKind::LitString:
        case TokenKind::LitChar:
            return true;
        default:
            return false;
    }
}

fn is_substitutable(kind: TokenKind) -> bool {
    switch kind {
        case TokenKind::KwAnd:
        case TokenKind::KwAndEq:
        case TokenKind::KwBitand:
        case TokenKind::KwBitor:
        case TokenKind::KwCompl:
        case TokenKind::KwNot:
        case TokenKind::KwNotEq:
        case TokenKind::KwOr:
        case TokenKind::KwOrEq:
        case TokenKind::KwXor:
        case TokenKind::KwXorEq:
            return true;
        default:
            return false;
    }
}

fn substitute(kind: TokenKind) -> TokenKind {
    switch kind {
        case TokenKind::KwAnd:     return TokenKind::OpAmpAmp;
        case TokenKind::KwAndEq:   return TokenKind::OpAmpEqual;
        case TokenKind::KwBitand:  return TokenKind::OpAmp;
        case TokenKind::KwBitor:   return TokenKind::OpPipe;
        case TokenKind::KwCompl:   return TokenKind::OpTilde;
        case TokenKind::KwNot:     return TokenKind::OpExclaim;
        case TokenKind::KwNotEq:   return TokenKind::OpExclaimEqual;
        case TokenKind::KwOr:      return TokenKind::OpPipePipe;
        case TokenKind::KwOrEq:    return TokenKind::OpPipeEqual;
        case TokenKind::KwXor:     return TokenKind::OpCaret;
        case TokenKind::KwXorEq:   return TokenKind::OpCaretEqual;
        default:                   return TokenKind::TkUnknown;
    }
}