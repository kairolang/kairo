        case TokenKind::OpQuestionDotStar {     return "op-question-dot-star"; }
        case TokenKind::OpEllipsis {            return "op-ellipsis"; }
        case TokenKind::OpPlusEqual {           return "op-plus-equal"; }
        case TokenKind::OpMinusEqual {          return "op-minus-equal"; }
