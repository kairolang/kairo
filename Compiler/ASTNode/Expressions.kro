///
/// \invariant Recovery node casting contract:
///
/// When kind == ExprKind::RecoveryExpr and recovery_kind == ExprKind::X,
/// the node was allocated as X and it is ALWAYS safe to cast:
///
///   static_cast<X*>(recovery_expr_ptr)
///
/// This is guaranteed by create_error() on every concrete node class.
/// Sema relies on this invariant for partial recovery type checking.
/// Codegen relies on this to emit defaults for broken nodes.
///
/// DO NOT allocate a bare Expr and set recovery_kindthe cast will
/// read out of bounds. Always use the concrete node's create_error().
///

///   [x] IntegerLiteralExpr                                                 ///
///   [x] FloatingLiteralExpr                                                ///
///   [x] StringLiteralExpr                                                  ///
///   [x] CharacterLiteralExpr                                               ///
///   [x] BooleanLiteralExpr                                                 ///
///   [x] NullLiteralExpr                                                    ///
///   [x] ListLiteralExpr                                                    ///
///   [x] TupleLiteralExpr                                                   ///
///   [x] SetLiteralExpr                                                     ///
///   [x] MapLiteralExpr                                                     ///
///   [x] ArrayInitializerExpr                                               ///
///   [x] VectorInitializerExpr                                              ///
///   [x] MapInitializerExpr                                                 ///
///   [x] SetInitializerExpr                                                 ///
///   [x] NamedInitializerExpr                                               ///
///   [x] AnonInitializerExpr                                                ///
///   [x] ChainExpr                                                          ///
///   [x] NamedIdentExpr                                                     ///
///   [x] GroupingExpr                                                       ///
///   [x] UnaryOperatorExpr                                                  ///
///   [x] BinaryOperatorExpr                                                 ///
///   [x] AssignOperatorExpr                                                 ///
///   [x] ImplConformanceExpr                                                ///
///   [x] DerivesRelationExpr                                                ///
///   [x] TernaryExpr                                                        ///
///   [x] IfExpr                                                             ///
///   [x] InlineTryCatchExpr                                                 ///
///   [x] RangeExpr                                                          ///
///   [x] AwaitExpr                                                          ///
///   [x] SpawnExpr                                                          ///
///   [x] ThreadExpr                                                         ///
///   [x] SizeOfExpr                                                         ///
///   [x] AlignOfExpr                                                        ///
///   [x] TypeOfExpr                                                         ///
///   [x] EvalExpr                                                           ///
///   [x] SelfExpr                                                           ///
///   [x] DeleteExpr                                                         ///
///   [x] SubscriptExpr                                                      ///
///   [x] TypeCastExpr                                                       ///
///   [x] MacroInvocationExpr                                                ///
///   [x] PackExpansionExpr                                                  ///
///   [x] ImplicitBoundaryCastExpr                                           ///
///   [ ] ClosureExpr                                                        ///


import ASTNode::Base::*;
import AST::ASTContext::*;
import AST::Support::*;
import ASTNode::PrimaryExpressions::*;

/// \class PrimitiveLiteralExpr
/// \brief abstract base for all atomic constant expressions in the AST.
///
/// \details represents literal values that map directly to primitive machine
///          types
///          (integers, floats, booleans) or fundamental language constructs
///          (null, characters). unlike `CollectionExpr` which aggregates other
///          nodes, primitive literals are leaf nodes carrying a single source
///          `Token`.
///
/// examples of Kairo code resulting in these nodes: `42`, `3.14f32`, `'x'`,
/// `true`, `null`.
///
/// \note despite the name, `StringLiteralExpr` derives from this class even
///       though it may involve multiple tokens due to concatenation or
///       interpolation.
class PrimitiveLiteralExpr derives Expr {
    

    /// \enum Kind
    /// \brief discriminates the specific primitive type of the literal.
    enum Kind derives u8 {
        /// \brief whole-number constants.
        ///
        /// \details covers decimal, hex (`0x`), octal (`0o`), and binary (`0b`)
        ///          formats. may include type suffixes like `u8` or `i64`.
        ///          example: `255u8`.
        IntegerLiteral,

        /// \brief fractional and exponential constants.
        ///
        /// \details stored as raw text to preserve precision until evaluated.
        ///          example: `1.23e-4`, `0.5f32`.
        FloatingLiteral,

        /// \brief single Unicode codepoint constants.
        ///
        /// \details includes escape sequences and hex/unicode escapes.
        ///          example: `'a'`, `'\n'`, `'\u{1F600}'`.
        CharacterLiteral,

        /// \brief sequence of characters or bytes.
        ///
        /// \details includes support for raw strings, byte strings, and
        ///          multi-line
        ///          delimiters. handles implicit concatenation of adjacent
        ///          literals. example: `"hello" " world"`.
        StringLiteral,

        /// \brief logical constants.
        ///
        /// \details limited to the keywords `true` and `false`.
        BooleanLiteral,

        /// \brief the pointer/reference null sentinel.
        ///
        /// \details covers both the keyword `null` and the address-of form
        ///          `&null`.
        NullLiteral,
    }

    pub var value: Token;       ///< the source token representing the literal
                                ///  value.
    pub var ctx:   *ASTContext; ///< pointer to the context for identifier and
                                ///  source resolution.

    /// \brief type-safe casting support for the Expr hierarchy.
    /* OVERRIDE */
    static fn classof(ptr: *Expr) -> bool {
        return (ptr->kind == ExprKind::IntegerLiteralExpr)
            || (ptr->kind == ExprKind::FloatingLiteralExpr)
            || (ptr->kind == ExprKind::CharacterLiteralExpr)
            || (ptr->kind == ExprKind::StringLiteralExpr)
            || (ptr->kind == ExprKind::BooleanLiteralExpr)
            || (ptr->kind == ExprKind::NullLiteralExpr);
    }

    /// \brief retrieves the underlying source token.
    ///
    /// \note for `StringLiteralExpr` nodes, this returns the first token in the
    ///       sequence.
    fn get_value(self) -> Token {
        return self.value;
    }

    /// \brief resolves the token into its textual representation from the
    ///        source buffer.
    fn get_value_text(self) -> TokenText {
        return TokenText::from_token(self.value, self.ctx);
    }
}

/// \class CollectionExpr
/// \brief abstract base for expression nodes that represent literal collection
///        aggregates.
///
/// \details provides a common interface and categorization for Kairo's
///          collection literals,
///          such as lists `[1, 2, 3]`, sets `{1, 2}`, maps `{ "key": "val" }`,
///          and tuples `(a, b, c)`. it serves as the parent class for specific
///          initializer and literal expressions, allowing sema and codegen to
///          handle grouped initialization logic via the `collection_kind`
///          discriminator.
class CollectionExpr derives Expr {
    

    /// \enum Kind
    /// \brief identifies the specific structural category of the collection.
    ///
    /// \details used for quick dispatch without checking the `ExprKind`. it
    ///          distinguishes
    ///          between sequences (List, Tuple), unique sets (Set), and
    ///          associative pairs (Map).
    enum Kind derives u8 {
        Set,
        Tuple,
        List,
        Map
    }

    pub var collection_kind: Kind; ///< category of this collection, assigned
                                   ///  during construction.

    static fn classof(ptr: *Expr) -> bool {
        return (ptr->kind == ExprKind::SetLiteralExpr)
            || (ptr->kind == ExprKind::TupleLiteralExpr)
            || (ptr->kind == ExprKind::MapLiteralExpr)
            || (ptr->kind == ExprKind::ListLiteralExpr);
    }
}

/// \class IntegerLiteralExpr
/// \brief represents a numeric integer constant in the source code.
///
/// \details this node encapsulates integer literals of various bases (binary,
///          octal,
///          decimal, hex) and sizes. it preserves the original source structure
///          including prefixes (e.g., `0x`) and suffixes (e.g., `u64`) via the
///          `int_data` payload.
///
/// literal examples:
/// ```
/// var a = 42; // DecimalInt var b = 0xFF_u8; // HexInt with suffix var c =
/// 0b1010;     // BinaryInt var d = 1_000_000; // DecimalInt with separators
/// ```
///
/// during sema, the raw numeric value is validated against the inferred or
/// explicit target type. for values exceeding 128-bit storage, a `BigInt` is
/// lazily allocated.
class IntegerLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief the lexical base representation of the literal.
    enum Kind derives u8 {
        DecimalInt, ///< base 10: `123`.
        HexInt,     ///< base 16: `0xABC`.
        BinaryInt,  ///< base 2:  `0b101`.
        OctalInt,   ///< base 8:  `0o755`.
    }

    pub var int_kind: Kind;                 ///< identifies the radix used in
                                            ///  source.
    pub var int_data: *(Immediate::IntData); ///< detailed numeric and
                                             ///  source-range payload.

    /// \brief allocates and initializes a new IntegerLiteralExpr node.
    ///
    /// \param ctx      ASTContext for arena allocation.
    /// \param int_kind the radix format used in the source text.
    /// \param tok      the raw Token produced by the lexer.
    /// \param data     pre-parsed numeric data and sub-ranges.
    /// \param range    full source range of the literal.
    static fn create(
        ctx:      *ASTContext,
        int_kind:  Kind,
        tok:       Token,
        data:     *(Immediate::IntData),
        range:     SourceRange
    ) -> *IntegerLiteralExpr {
        var node            = ctx->alloc::<IntegerLiteralExpr>();
        node->kind          = ExprKind::IntegerLiteralExpr;
        node->range         = range;
        node->ctx           = ctx;
        node->value         = tok;
        node->int_kind      = int_kind;
        node->int_data      = data;
        return node;
    }

    /// \brief creates a recovery node for a syntactically invalid integer
    ///        literal.
    ///
    /// \details used when a literal is malformed (e.g., invalid digits for a
    ///          base)
    ///          to allow parsing to continue while marking the node as
    ///          erroneous.
    static fn create_error(
        ctx:      *ASTContext,
        int_kind:  Kind,
        tok:       Token,
        data:     *(Immediate::IntData),
        range:     SourceRange
    ) -> *IntegerLiteralExpr {
        var node            = create(ctx, int_kind, tok, data, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::IntegerLiteralExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::IntegerLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::IntegerLiteralExpr;
    }

    fn is_negative(self) -> bool { return (self.int_data->flags & 0b10)  != 0; }
    fn is_unsigned(self) -> bool { return (self.int_data->flags & 0b01)  != 0; }
    fn is_big(self)      -> bool { return (self.int_data->flags & 0b100) != 0; }

    /// \brief returns true if the literal explicitly specified a type suffix.
    ///
    /// NOTE: does not indicate which suffix was used; call `get_suffix()` for
    /// text.
    fn has_suffix(self) -> bool { return (self.int_data->flags & 0b1000)  != 0; }

    /// \brief returns true if the literal has a base prefix like `0x` or `0b`.
    fn has_prefix(self) -> bool { return (self.int_data->flags & 0b10000) != 0; }

    fn is_decimal(self) -> bool { return self.int_kind == Kind::DecimalInt; }
    fn is_hex(self)     -> bool { return self.int_kind == Kind::HexInt;     }
    fn is_binary(self)  -> bool { return self.int_kind == Kind::BinaryInt;  }
    fn is_octal(self)   -> bool { return self.int_kind == Kind::OctalInt;   }

    fn get_kind(self) -> Kind { return self.int_kind; }

    /// \brief extracts the type suffix text (e.g., `u32`) from the source.
    fn get_suffix(self) -> TokenText {
        return TokenText::from_range(self.int_data->suffix, self.ctx);
    }

    /// \brief extracts the base prefix text (e.g., `0x`) from the source.
    fn get_prefix(self) -> TokenText {
        return TokenText::from_range(self.int_data->prefix, self.ctx);
    }

    /// \brief extracts the numeric body text, excluding prefix and suffix.
    fn get_body(self) -> TokenText {
        return TokenText::from_range(self.int_data->body, self.ctx);
    }

    fn get_value_as_u64(self) -> u64 { return self.int_data->value_lo; }
    fn get_value_as_i64(self) -> i64 { return static_cast::<i64>(self.int_data->value_lo); }

    /// \brief returns a BigInt representation of the literal value.
    ///
    /// \details lazily allocates and caches a `BigInt` inside `int_data` if it
    ///          hasn't
    ///          been requested yet. ensures the sign bit is correctly
    ///          propagated from the internal flags.
    fn get_value_as_bigint(self) -> *BigInt {
        if self.int_data->big == &null {
            self.int_data->big = std::create::<BigInt>(self.int_data->value_lo);

            if self.is_negative() {
                (self.int_data->big->sign) = -1;
            }
        }
        return self.int_data->big;
    }

    fn get_base(self) -> u8  { return self.int_data->base;  }
    fn get_bits(self) -> u16 { return self.int_data->bits;  }
    fn get_flags(self) -> u8 { return self.int_data->flags; }
}

/// \class FloatingLiteralExpr
/// \brief represents a floating-point literal in the source code.
///
/// \details encodes both decimal (e.g., `3.14159`) and hexadecimal (e.g.,
///          `0x1.0p-10`)
///          floating-point constants. the node preserves the original source
///          text components prefix, body, and suffix via an attached
///          `FloatData` payload.
///
/// value representation:
///   - for standard precision, values are stored as `f80` (extended precision).
///   - for literals exceeding `f80` limits or requiring exact arbitrary
///     precision,
///     the `use_bigfloat` flag is set, though bigfloat parsing is currently a
///     FIXME.
///
/// \note hex floats use a base-2 exponent prefixed by 'p', as per IEEE 754.
class FloatingLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief discriminates between the two lexical formats of floating-point
    ///        literals.
    enum Kind derives u8 {
        /// standard decimal float: `1.2`, `1.2e-3`, `.5`, or `1.`.
        DecimalFloat,

        /// hexadecimal float: `0x1.8p+1`, `0x1p-3`, or `0x1.FFFp+127`. the
        /// exponent is always base-2 (the 'p' exponent).
        HexFloat,
    }

    pub var float_kind: Kind;                   ///< lexical format used
                                                ///  (decimal vs hex).
    pub var float_data: *(Immediate::FloatData); ///< detailed payload
                                                 ///  containing parsed bits and
                                                 ///  source ranges.

    /// \brief primary factory method for constructing a valid floating-point
    ///        literal node.
    ///
    /// \param ctx        the ASTContext for arena allocation.
    /// \param float_kind lexical kind of the literal.
    /// \param tok        the raw Token produced by the lexer.
    /// \param data       pointer to the pre-parsed FloatData structure.
    /// \param range      the full source range of the literal.
    static fn create(
        ctx:        *ASTContext,
        float_kind: Kind,
        tok:        Token,
        data:       *(Immediate::FloatData),
        range:      SourceRange
    ) -> *FloatingLiteralExpr {
        var node = ctx->alloc::<FloatingLiteralExpr>();

        node->kind       = ExprKind::FloatingLiteralExpr;
        node->range      = range;
        node->ctx        = ctx;
        node->value      = tok;
        node->float_kind = float_kind;
        node->float_data = data;

        return node;
    }

    /// \brief constructs a recovery node when floating-point parsing fails.
    ///
    /// \details sets the node kind to `RecoveryExpr` to signal an error state
    ///          to sema
    ///          while preserving the `FloatingLiteralExpr` identity in
    ///          `recovery_kind`.
    static fn create_error(
        ctx:        *ASTContext,
        float_kind: Kind,
        tok:        Token,
        data:       *(Immediate::FloatData),
        range:      SourceRange
    ) -> *FloatingLiteralExpr {
        var node            = create(ctx, float_kind, tok, data, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::FloatingLiteralExpr;

        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::FloatingLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::FloatingLiteralExpr;
    }

    fn is_decimal(self) -> bool {
        return self.float_kind == Kind::DecimalFloat;
    }

    fn is_hex(self) -> bool {
        return self.float_kind == Kind::HexFloat;
    }

    /// \brief returns true if the literal is prefixed with a negative sign.
    fn is_negative(self) -> bool {
        return (self.float_data->flags & 0b10) != 0;
    }

    /// \brief returns true if an exponent part (e/E or p/P) was present in the
    ///        source.
    fn has_exponent(self) -> bool {
        return (self.float_data->flags & 0b01) != 0;
    }

    /// \brief indicates if the literal requires arbitrary-precision storage.
    fn use_bigfloat(self) -> bool {
        return (self.float_data->flags & 0b1000) != 0;
    }

    /// \brief returns true if a type suffix (e.g., `f32`, `f64`) was present.
    fn has_suffix(self) -> bool {
        return (self.float_data->flags & 0b10000) != 0;
    }

    fn get_suffix(self) -> TokenText {
        return TokenText::from_range(self.float_data->suffix, self.ctx);
    }

    fn get_prefix(self) -> TokenText {
        return TokenText::from_range(self.float_data->prefix, self.ctx);
    }

    /// \brief returns the numeric body of the literal (excluding
    ///        prefix/suffix).
    fn get_body(self) -> TokenText {
        return TokenText::from_range(self.float_data->body, self.ctx);
    }

    /// \brief returns the native `f80` representation of the literal value.
    fn get_value_as_f80(self) -> f80 {
        return self.float_data->value_ieee;
    }

    __inline_cpp("template<typename ... Ts>
    BigFloat* get_value_as_bigfloat(Ts&&...ts) {
        // we need this path to crash at compile time if we try to use:
        // get_value_as_bigfloat()
        // since its incomplete

        static_assert(
            not (libcxx::is_same_v<Ts,Ts> && ...),
            \"TODO: implement parsing the float literal text into the \"
            \"BigFloat struct, since some literals may exceed f80 precision \"
            \"and require arbitrary-precision parsing to get the correct value.  \"
            \"This is non-trivial but necessary for correctness, especially \"
            \"for hex floats which can represent values that are not exactly \"
            \"representable in binary floating-point formats.  In the meantime, \"
            \"we can return an approximate value based on the f80 representation, \"
            \"but this should be fixed before we consider the floating-point literal \"
            \"implementation complete.\"
        );

        if (this->float_data->big_float == nullptr) {
            // TODO
        }

        return this->float_data->big_float;
    }");

    /// \brief returns the width in bits specified by the literal or inferred by
    ///        sema.
    fn get_bits(self) -> u32 {
        return self.float_data->bits;
    }

    /// \brief returns the numeric base (10 for decimal, 16 for hex).
    fn get_base(self) -> u8 {
        return self.float_data->base;
    }

    fn get_flags(self) -> u8 {
        return self.float_data->flags;
    }

    fn get_kind(self) -> Kind {
        return self.float_kind;
    }
}

/// \class StringLiteralExpr
/// \brief represents a string literal, potentially composed of multiple
///        concatenated segments.
///
/// \details in Kairo, string literals are represented as a chain of
///          `SingleString` components.
///          this structure handles implicit concatenation (e.g., `"a" "b"`
///          becoming `"ab"`) as well as specialized types like byte strings and
///          interpolated format strings.
///
/// examples:
/// ```
/// var a = "hello"; // StringLiteral var b = b"bytes"; // ByteStringLiteral var
/// c = f"val: {x}"; // FormatStringLiteral var d = "part1" "part2"; // chain of
/// two StringLiterals
/// ```
///
/// interpolation is preserved as a sequence of token buffers that are lowered
/// to formatting calls or string builders during sema and codegen.
class StringLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief defines the encoding and interpolation capabilities of a string
    ///        segment.
    enum Kind derives u8 {
        /// plain UTF-8 string literal. supports standard escape sequences.
        StringLiteral,

        /// raw byte string. restricted to ASCII or escaped hex/octal bytes.
        /// cannot contain interpolation.
        ByteStringLiteral,

        /// interpolated UTF-8 string. contains embedded expressions inside
        /// `{}`.
        FormatStringLiteral,

        /// interpolated byte string.
        FormatByteStringLiteral,
    }

    /// \struct SingleString
    /// \brief a single lexical string component within a potential chain.
    struct SingleString {
        pub var string_kind: Kind;                    ///< encoding/interpolation
                                                      ///  mode.
        pub var string_data: *(Immediate::StringData); ///< pointer to
                                                       ///  lexer-allocated
                                                       ///  metadata.
    }

    /// \brief the sequence of strings that form this expression.
    ///
    /// \details concatenated strings like `"a" "b"` are stored as multiple
    ///          entries.
    ///          most methods on this class default to index 0, which covers the
    ///          common case of a single, non-concatenated literal.
    pub var string_chain: FrozenList::<SingleString>;

    /// \brief allocates and initializes a new StringLiteralExpr in the provided
    ///        context.
    ///
    /// \param ctx ASTContext providing the arena for the expression and its
    ///        chain.
    /// \param chain temporary collection of string segments to be frozen into
    ///        the node.
    /// \param range full source range spanning from the first prefix to the
    ///        last suffix.
    static fn create(
        ctx:   *ASTContext,
        chain: *vec::<SingleString>,
        range:  SourceRange
    ) -> *StringLiteralExpr {
        var node = ctx->alloc::<StringLiteralExpr>();

        node->kind  = ExprKind::StringLiteralExpr;
        node->range = range;
        node->ctx   = ctx;

        var arr = ctx->alloc_array::<SingleString>(chain->size());
        for var i: usize = 0; i < chain->size(); ++i {
            arr[i] = (*chain)[i];
        }

        node->string_chain.from_raw(arr, chain->size());
        return node;
    }

    /// \brief creates a StringLiteralExpr marked as a recovery node for error
    ///        resilience.
    static fn create_error(
        ctx:   *ASTContext,
        chain: *vec::<SingleString>,
        range:  SourceRange
    ) -> *StringLiteralExpr {
        var node            = create(ctx, chain, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::StringLiteralExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::StringLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::StringLiteralExpr;
    }

    /// \brief returns true if the segment is a standard UTF-8 string without
    ///        formatting.
    fn is_plain(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return (s->string_kind) == Kind::StringLiteral;
    }

    /// \brief returns true if the segment is a byte string (f-byte or plain
    ///        byte).
    fn is_byte(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return ((s->string_kind) == Kind::ByteStringLiteral)
            || ((s->string_kind) == Kind::FormatByteStringLiteral);
    }

    /// \brief returns true if the segment contains interpolation markers.
    fn is_format(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return ((s->string_kind) == Kind::FormatStringLiteral)
            || ((s->string_kind) == Kind::FormatByteStringLiteral);
    }

    fn is_format_only(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return (s->string_kind) == Kind::FormatStringLiteral;
    }

    fn is_format_byte(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return (s->string_kind) == Kind::FormatByteStringLiteral;
    }

    /// \brief extracts the prefix (e.g., `b`, `f`, `bf`) from the source.
    fn get_prefix(self, idx: usize = 0) -> TokenText {
        var s = self.string_chain[idx];
        if s == &null { return TokenText("", SourceRange::invalid(), false, false); }
        return TokenText::from_token(s->string_data->prefix, self.ctx);
    }

    /// \brief extracts the suffix (e.g., closing quotes) from the source.
    fn get_suffix(self, idx: usize = 0) -> TokenText {
        var s = self.string_chain[idx];
        if s == &null { return TokenText("", SourceRange::invalid(), false, false); }
        return TokenText::from_token(s->string_data->suffix, self.ctx);
    }

    /// \brief returns the raw text content inside the quotes.
    fn get_body(self, idx: usize = 0) -> TokenText {
        var s = self.string_chain[idx];
        if s == &null { return TokenText("", SourceRange::invalid(), false, false); }
        return TokenText::from_range(s->string_data->body, self.ctx);
    }

    /// \brief retrieves the list of token buffers and ranges representing
    ///        interpolated expressions.
    fn get_exprs(self, idx: usize = 0)
        -> libcxx::deque::<(*TokenBuffer::<16>, SourceRange)> {
        return self.string_chain[idx]->string_data->exprs;
    }

    fn get_kind(self, idx: usize = 0) -> Kind {
        var s = self.string_chain[idx];
        if s == &null { return Kind::StringLiteral; }
        return (s->string_kind);
    }

    /// \brief returns true if the string body contains physical newline
    ///        characters.
    fn is_multi_line(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }

        var body_text = self.get_body().get_text();
        return body_text.raw_string().find('\n') != string::npos;
    }

    /// \brief checks if the segment contains any `{}` interpolation
    ///        expressions.
    fn has_interpolation(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return !(s->string_data->exprs.empty());
    }

    /// \brief returns true if the literal is `""` or `b""` with no content.
    fn is_empty(self, idx: usize = 0) -> bool {
        var s = self.string_chain[idx];
        if s == &null { return false; }
        return self.get_body().get_text().empty();
    }
}/// \class CharacterLiteralExpr
/// \brief represents a single character literal in the source code.
///
/// \details encapsulates various forms of character literals including standard
///          ASCII, escape sequences, and Unicode codepoints. the node stores
///          both the raw token and structured `char_data` to allow sema to
///          distinguish between how the character was written (e.g., 'A' vs
///          '\x41').
///
/// example Kairo source: `var c = 'a';` -> `AsciiChar` `var n = '\n';` ->
/// `EscapeChar` `var u = '\u{1F600}';` -> `UnicodeChar`
class CharacterLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief discriminates the syntactic form used to express the character.
    enum Kind derives u8 {
        /// plain ASCII character: 'a' | 'Z' | '0'.
        AsciiChar,

        /// escape sequence character: '\n' | '\t' | '\r' | '\\' | '\''.
        EscapeChar,

        /// hex escape character: '\x41'. must represent a valid ASCII value.
        HexEscapeChar,

        /// Unicode codepoint: '\u{1F600}' | '\u{0041}'.
        UnicodeChar,

        /// null character: '\0'.
        NullChar,
    }

    pub var char_kind: Kind;                   ///< the specific syntax used for
                                               ///  the literal.
    pub var char_data: *(Immediate::CharData); ///< detailed token information
                                               ///  and source spans.

    /// \brief creates a valid CharacterLiteralExpr node.
    ///
    /// \param ctx       ASTContext for arena allocation.
    /// \param char_kind the discriminated kind of the character.
    /// \param tok       the primary token representing the literal.
    /// \param data      pointer to persistent character metadata.
    /// \param range source range covering the entire literal including quotes.
    static fn create(
        ctx:       *ASTContext,
        char_kind: Kind,
        tok:       Token,
        data:      *(Immediate::CharData),
        range:     SourceRange
    ) -> *CharacterLiteralExpr {
        var node = ctx->alloc::<CharacterLiteralExpr>();

        // from Expr
        node->kind      = ExprKind::CharacterLiteralExpr;
        node->range     = range;

        // from PrimitiveLiteralExpr
        node->ctx       = ctx;

        // from CharacterLiteralExpr
        node->value     = tok;
        node->char_kind = char_kind;
        node->char_data = data;

        return node;
    }

    /// \brief creates a CharacterLiteralExpr wrapped in a RecoveryExpr node.
    ///
    /// \details used when the parser encounters a malformed character literal
    ///          (e.g.,
    ///          invalid escape sequence) but can still recover enough
    ///          information to continue analysis.
    static fn create_error(
        ctx:       *ASTContext,
        char_kind: Kind,
        tok:       Token,
        data:      *(Immediate::CharData),
        range:     SourceRange
    ) -> *CharacterLiteralExpr {
        var node            = create(ctx, char_kind, tok, data, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::CharacterLiteralExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::CharacterLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::CharacterLiteralExpr;
    }

    fn is_ascii(self)      -> bool { return self.char_kind == Kind::AsciiChar;     }
    fn is_escape(self)     -> bool { return self.char_kind == Kind::EscapeChar;    }
    fn is_hex_escape(self) -> bool { return self.char_kind == Kind::HexEscapeChar; }
    fn is_unicode(self)    -> bool { return self.char_kind == Kind::UnicodeChar;   }
    fn is_null(self)       -> bool { return self.char_kind == Kind::NullChar;      }

    /// \brief returns the textual prefix of the literal (e.g., the opening
    ///        quote).
    fn get_prefix(self) -> TokenText {
        return TokenText::from_token(self.char_data->prefix, self.ctx);
    }

    /// \brief returns the textual suffix of the literal (e.g., the closing
    ///        quote).
    fn get_suffix(self) -> TokenText {
        return TokenText::from_token(self.char_data->suffix, self.ctx);
    }

    /// \brief returns the content of the character literal excluding the
    ///        quotes.
    fn get_body(self) -> TokenText {
        return TokenText::from_range(self.char_data->body, self.ctx);
    }

    fn get_kind(self) -> Kind {
        return self.char_kind;
    }
}

/// \class BooleanLiteralExpr
/// \brief represents a boolean constant `true` or `false` in source code.
///
/// \details boolean literals are handled as primitive constants. they are
///          lowered to `i1` values during codegen.
class BooleanLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief discriminates between the two possible boolean states.
    enum Kind derives u8 {
        BoolTrue,  ///< represents the `true` keyword.
        BoolFalse, ///< represents the `false` keyword.
    }

    pub var bool_kind: Kind; ///< whether this node evaluates to true or false.

    /// \brief creates a new BooleanLiteralExpr node.
    ///
    /// \param ctx        ASTContext used for node allocation.
    /// \param bool_kind  the boolean value (true/false).
    /// \param tok        the keyword token from the lexer.
    /// \param range      the source range spanning the keyword.
    static fn create(
        ctx:       *ASTContext,
        bool_kind: Kind,
        tok:       Token,
        range:     SourceRange
    ) -> *BooleanLiteralExpr {
        var node = ctx->alloc::<BooleanLiteralExpr>();

        // from Expr
        node->kind  = ExprKind::BooleanLiteralExpr;
        node->range = range;

        // from PrimitiveLiteralExpr
        node->ctx = ctx;

        // from BooleanLiteralExpr
        node->value     = tok;
        node->bool_kind = bool_kind;

        return node;
    }

    /// \brief creates a recovery node for a malformed boolean expression.
    ///
    /// \details used by the parser to maintain a valid AST structure when a
    ///          boolean
    ///          literal is expected but a syntax error occurs. the node is
    ///          marked as a `RecoveryExpr` to suppress downstream sema
    ///          diagnostics.
    static fn create_error(
        ctx:       *ASTContext,
        bool_kind: Kind,
        tok:       Token,
        range:     SourceRange
    ) -> *BooleanLiteralExpr {
        var node            = create(ctx, bool_kind, tok, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::BooleanLiteralExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::BooleanLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::BooleanLiteralExpr;
    }

    fn is_true(self) -> bool {
        return self.bool_kind == Kind::BoolTrue;
    }

    fn is_false(self) -> bool {
        return self.bool_kind == Kind::BoolFalse;
    }
}

/// \class NullLiteralExpr
/// \brief represents the literal `null` or `&null` in source code.
///
/// \details encodes the specific flavor of the null keyword. Kairo
///          distinguishes
///          between the generic `null` (which may be used for nullable types)
///          and the explicit pointer-null `&null`.
///
/// examples:
/// ```kairo
/// var x: *i32 = &null; // Kind::NullRef var y: i32? = null; // Kind::Null
/// ```
///
/// sema determines if the specific `Kind` is valid for the target type context.
class NullLiteralExpr derives PrimitiveLiteralExpr {
    

    /// \enum Kind
    /// \brief defines the syntactic form of the null literal.
    enum Kind derives u8 {
        /// the keyword `null`. used for nullable types (`T?`) or pointers.
        Null,

        /// the sequence `&null`. explicitly represents a null pointer value.
        NullRef,
    }

    pub var null_kind: Kind;  ///< the specific flavor of null used.
    pub var amp_token: Token; ///< stores the `&` token when `null_kind` is
                              ///  `NullRef`.

    /// \brief factory method for creating a valid NullLiteralExpr.
    ///
    /// \param ctx        ASTContext for node allocation.
    /// \param null_kind  the syntactic variant (null vs &null).
    /// \param amp_token  the `&` token, or an invalid token if Kind::Null.
    /// \param tok        the `null` keyword token.
    /// \param range      the full source range of the expression.
    static fn create(
        ctx:       *ASTContext,
        null_kind: Kind,
        amp_token: Token,
        tok:       Token,
        range:     SourceRange
    ) -> *NullLiteralExpr {
        var node        = ctx->alloc::<NullLiteralExpr>();

        node->kind      = ExprKind::NullLiteralExpr;
        node->range     = range;

        node->ctx       = ctx;

        node->value     = tok;
        node->null_kind = null_kind;
        node->amp_token = amp_token;

        return node;
    }

    /// \brief factory method for creating a NullLiteralExpr that failed
    ///        validation.
    ///
    /// \details marks the node as `RecoveryExpr` to prevent cascading errors
    ///          while
    ///          preserving the `null` semantics for IDE support or local
    ///          analysis.
    static fn create_error(
        ctx:       *ASTContext,
        null_kind: Kind,
        amp_token: Token,
        tok:       Token,
        range:     SourceRange
    ) -> *NullLiteralExpr {
        var node            = create(ctx, null_kind, amp_token, tok, range);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::NullLiteralExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::NullLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::NullLiteralExpr;
    }

    fn is_null(self) -> bool {
        return self.null_kind == Kind::Null;
    }

    fn is_null_ref(self) -> bool {
        return self.null_kind == Kind::NullRef;
    }

    fn get_amp_token(self) -> Token {
        return self.amp_token;
    }
}

/// \class ArrayInitializerExpr
/// \brief represents the allocation and initialization of a fixed-size array.
///
/// \details this node represents array allocation expressions such as `new
///          int[10]`
///          or fixed-size array declarations where the size is provided as an
///          expression. it captures both the base element type and the
///          expression determining the array's extent. unlike a list literal,
///          this node is used for dynamic or uninitialized allocation where
///          elements may be default-constructed.
///
/// EXAMPLE: `var buffer = new u8[1024];` results in an `ArrayInitializerExpr`
/// where `element_type` is `u8` and `size_expr` is an `IntegerLiteralExpr` for
/// `1024`.
class ArrayInitializerExpr derives CollectionExpr {
    pub var element_type: *Type; ///< the base type of individual array
                                 ///  elements.
    pub var size_expr:    *Expr; ///< expression evaluating to the array length.

    /// \brief creates a well-formed array initializer node.
    ///
    /// \param ctx             the ASTContext to allocate the node from.
    /// \param range source range covering the allocation keyword through the
    ///        size.
    /// \param collection_kind semantic category of the collection (e.g. Heap,
    ///        Stack).
    /// \param element_type the type of the elements to be stored in the array.
    /// \param size_expr expression defining the number of elements to allocate.
    static fn create(
        ctx:             *ASTContext,
        range:            SourceRange,
        collection_kind:  CollectionExpr::Kind,
        element_type:    *Type,
        size_expr:       *Expr
    ) -> *ArrayInitializerExpr {
        var node = ctx->alloc::<ArrayInitializerExpr>();

        // from Expr
        node->kind  = ExprKind::ArrayInitializerExpr;
        node->range = range;

        // CollectionExpr
        node->collection_kind = collection_kind;

        // from ArrayInitializerExpr
        node->element_type = element_type;
        node->size_expr    = size_expr;

        return node;
    }

    /// \brief creates a node marked as a RecoveryExpr to allow parsing to
    ///        continue.
    ///
    /// \details used when the initializer is syntactically present but
    ///          semantically
    ///          invalid (e.g. non-integral size expression). the original kind
    ///          is preserved in `recovery_kind`.
    static fn create_error(
        ctx:             *ASTContext,
        range:            SourceRange,
        collection_kind:  CollectionExpr::Kind,
        element_type:    *Type,
        size_expr:       *Expr
    ) -> *ArrayInitializerExpr {
        var node = create(ctx, range, collection_kind, element_type, size_expr);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ArrayInitializerExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::ArrayInitializerExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::ArrayInitializerExpr;
    }
}

/// \class VectorInitializerExpr
/// \brief represents the initialization of a heap-allocated `Vector<T>`.
///
/// \details generated when a collection is initialized with vector semantics,
///          typically via the `vec [ ... ]` syntax. this node encapsulates the
///          element type and the sequence of initializers. it derives from
///          `CollectionExpr` to inherit the list of element expressions.
///
/// ```kairo
/// var v = vec [1, 2, 3]; // VectorInitializerExpr with element_type i32
/// ```
class VectorInitializerExpr derives CollectionExpr {
    pub var element_type: *Type; ///< the resolved T in Vector<T>. null until
                                 ///  sema.

    /// \brief creates a new VectorInitializerExpr node.
    ///
    /// \param ctx             the ASTContext to allocate the node from.
    /// \param range source range covering the entire `vec [...]` expression.
    /// \param collection_kind determines if this is a literal or an
    ///        initializer.
    /// \param element_type    the type of elements stored in the vector.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type
    ) -> *VectorInitializerExpr {
        var node = ctx->alloc::<VectorInitializerExpr>();

        // from Expr
        node->kind  = ExprKind::VectorInitializerExpr;
        node->range = range;

        // CollectionExpr
        node->collection_kind = collection_kind;

        // from VectorInitializerExpr
        node->element_type = element_type;

        return node;
    }

    /// \brief creates a VectorInitializerExpr marked as a RecoveryExpr.
    ///
    /// \details used during parsing or sema when a vector initializer is
    ///          syntactically
    ///          present but contains semantic errors (e.g., mismatched types).
    ///          this allows subsequent passes to skip the node while preserving
    ///          its range.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type
    ) -> *VectorInitializerExpr {
        var node = create(ctx, range, collection_kind, element_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::VectorInitializerExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::VectorInitializerExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::VectorInitializerExpr;
    }
}

/// \class MapInitializerExpr
/// \brief represents the initialization of a map-like collection.
///
/// \details this node acts as a base for concrete map initializations such as
///          `MapLiteralExpr`. it captures the explicit or inferred types of the
///          keys and values stored within the collection.
///
/// example Kairo source: `var m: map<i32, str> = { 1: "one", 2: "two" };`
///
/// here, the `{...}` block is lowered to a `MapLiteralExpr` (deriving from this
/// class) where `key_type` is `i32` and `value_type` is `str`.
class MapInitializerExpr derives CollectionExpr {
    pub var key_type:   *Type; ///< the type of keys allowed in this map.
    pub var value_type: *Type; ///< the type of values mapped to the keys.

    /// \brief creates a new MapInitializerExpr node.
    ///
    /// \param ctx             the ASTContext used for memory allocation.
    /// \param range           the source range covering the entire initializer.
    /// \param collection_kind determines if this is a standard map or a
    ///        specialized variant.
    /// \param key_type        the semantic type of the map keys.
    /// \param value_type      the semantic type of the map values.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        key_type:        *Type,
        value_type:      *Type
    ) -> *MapInitializerExpr {
        var node = ctx->alloc::<MapInitializerExpr>();

        // from Expr
        node->kind   = ExprKind::MapInitializerExpr;
        node->range  = range;

        // from CollectionExpr
        node->collection_kind = collection_kind;

        // from MapInitializerExpr
        node->key_type   = key_type;
        node->value_type = value_type;

        return node;
    }

    /// \brief creates a MapInitializerExpr wrapped in a RecoveryExpr sentinel.
    ///
    /// \details use this when the parser encounters a malformed map
    ///          initializer.
    ///          it allows sema to perform limited recovery or type checking
    ///          while signaling that the expression is invalid.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        key_type:        *Type,
        value_type:      *Type
    ) -> *MapInitializerExpr {
        var node = create(ctx, range, collection_kind, key_type, value_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MapInitializerExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MapInitializerExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::MapInitializerExpr;
    }
}

/// \class SetInitializerExpr
/// \brief base AST node for set-based collection initializers and literals.
///
/// \details represents a set construction expression such as `set::<i32>{1, 2,
///          3}`.
///          this node serves as a base for both explicit `SetLiteralExpr` nodes
///          and generic set-like collection initializers. the `element_type`
///          tracks the type of the members within the set, while the inherited
///          `collection_kind` identifies the specific set implementation.
///
/// sema is responsible for validating that all elements within the collection
/// are compatible with the designated `element_type`.
class SetInitializerExpr derives CollectionExpr {
    pub var element_type: *Type; ///< type of individual elements within the
                                 ///  set.

    /// \brief creates a new SetInitializerExpr node in the provided context.
    ///
    /// \param ctx             the ASTContext to allocate the node from.
    /// \param range           source range spanning the entire initializer.
    /// \param collection_kind determines the underlying set implementation.
    /// \param element_type    the type of values the set is intended to hold.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type
    ) -> *SetInitializerExpr {
        var node = ctx->alloc::<SetInitializerExpr>();

        // from Expr
        node->kind  = ExprKind::SetInitializerExpr;
        node->range = range;

        // from CollectionExpr
        node->collection_kind = collection_kind;

        // from SetInitializerExpr
        node->element_type = element_type;

        return node;
    }

    /// \brief creates a SetInitializerExpr node marked as a recovery node.
    ///
    /// \details used during parsing or sema when a set initializer is detected
    ///          but contains structural or type errors. the `kind` is set to
    ///          `ExprKind::RecoveryExpr` while `recovery_kind` preserves the
    ///          original identity for diagnostic purposes.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type
    ) -> *SetInitializerExpr {
        var node = create(ctx, range, collection_kind, element_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SetInitializerExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SetInitializerExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SetInitializerExpr;
    }
}

/// \class SetLiteralExpr
/// \brief represents a set literal expression in Kairo source.
///
/// \details encodes an unordered collection of unique elements, e.g., `{1, 2,
///          3}`.
///          while the syntax resembles an array or list literal,
///          `SetLiteralExpr` is specifically lowered into a unique-element
///          container.
///
/// sema is responsible for validating that all `values` are of `element_type`
/// and for performing deduplication and sorting if necessary. the `is_deduped`
/// and `is_sorted` flags allow subsequent passes (like dataflow analysis or
/// codegen) to skip redundant passes over the element list.
class SetLiteralExpr derives SetInitializerExpr {
    /// arbitrary limit to prevent overflow in the bitset used for deduping
    /// small sets and to cap memory consumption of large literals.
    pub const MAX_VALUES: usize = 65535;
    pub const MAX_INDEX:  usize = MAX_VALUES - 1;

    pub var values:     FrozenList::<*Expr>;
    pub var is_deduped: bool = false;        ///< true if sema has removed
                                             ///  duplicate elements.
    pub var is_sorted:  bool = false;        ///< true if elements are in
                                             ///  canonical order.

    /// \brief allocates and initializes a new SetLiteralExpr.
    ///
    /// \param ctx             ASTContext for arena allocations.
    /// \param range           source range spanning the `{` to the `}`.
    /// \param collection_kind semantic flavor of the set (e.g. HashSet vs
    ///        TreeSet).
    /// \param element_type    the resolved type of the elements within the set.
    /// \param values temporary buffer of element expressions to be frozen.
    /// \param is_deduped      initial state of the deduplication flag.
    /// \param is_sorted       initial state of the sorting flag.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type,
        values:          *vec::<*Expr>,
        is_deduped:      bool,
        is_sorted:       bool
    ) -> *SetLiteralExpr {
        var node = ctx->alloc::<SetLiteralExpr>();

        // from Expr
        node->kind  = ExprKind::SetLiteralExpr;
        node->range = range;

        // CollectionExpr
        node->collection_kind = collection_kind;

        // from SetInitializerExpr
        node->element_type = element_type;

        // from SetLiteralExpr
        var arr = ctx->alloc_array::<*Expr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->is_deduped = is_deduped;
        node->is_sorted  = is_sorted;

        return node;
    }

    /// \brief creates a SetLiteralExpr wrapped in a RecoveryExpr kind.
    ///
    /// \details used when the parser encounters a malformed set literal but
    ///          can still recover a partial list of expressions. ensures
    ///          subsequent passes treat the node as a failure point.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:    *Type,
        values:          *vec::<*Expr>,
        is_deduped:      bool,
        is_sorted:       bool
    ) -> *SetLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            element_type,
            values,
            is_deduped,
            is_sorted
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SetLiteralExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SetLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SetLiteralExpr;
    }
}

/// \class TupleLiteralExpr
/// \brief represents an ordered, heterogeneous collection of values in source
///        code.
///
/// \details a `TupleLiteralExpr` is the AST representation of a tuple literal,
///          such
///          as `(1, "hello", 3.14)`. unlike an `ArrayInitializerExpr`, tuples
///          in Kairo are typically heterogeneous, though sema may mark them as
///          homogeneous if all element types unify.
///
/// the literal is lowered to a fixed-size product type. during sema, each
/// element in `values` is matched against the corresponding type in the
/// expected `TupleType`.
class TupleLiteralExpr derives CollectionExpr {
    

    /// \struct TupleValueExpr
    /// \brief represents a single element within a tuple literal.
    ///
    /// \details carries both the expression and metadata used for lowering and
    ///          optimization. the `element_type` is crucial for handling
    ///          implicit conversions of literal elements to their target tuple
    ///          slots.
    struct TupleValueExpr {
        var value:        *Expr;  ///< the expression providing the value for
                                  ///  this slot.
        var element_type: *Type;  ///< slot type from the tuple definition; null
                                  ///  until sema.
        var index:        u32;    ///< zero-based position within the tuple.
    }

    pub var values:         FrozenList::<TupleValueExpr>;
    pub var is_homogeneous: bool = false;                ///< true if all
                                                         ///  elements share the
                                                         ///  same type.

    pub const MAX_VALUES: usize = 65535;                 ///< architectural
                                                         ///  limit for tuple
                                                         ///  element count.
    pub const MAX_INDEX:  usize = MAX_VALUES - 1;

    /// \brief creates a valid TupleLiteralExpr node.
    ///
    /// \param ctx             ASTContext for node and element array allocation.
    /// \param range source range covering the entire literal, including
    ///        parentheses.
    /// \param collection_kind semantic classification of the collection.
    /// \param values temporary list of elements to be frozen into the node.
    /// \param is_homogeneous initial homogeneity flag, usually refined by sema.
    static fn create(
        ctx:             *ASTContext,
        range:            SourceRange,
        collection_kind:  CollectionExpr::Kind,
        values:          *vec::<TupleValueExpr>,
        is_homogeneous:   bool
    ) -> *TupleLiteralExpr {
        var node = ctx->alloc::<TupleLiteralExpr>();

        node->kind            = ExprKind::TupleLiteralExpr;
        node->range           = range;
        node->collection_kind = collection_kind;

        var arr = ctx->alloc_array::<TupleValueExpr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->is_homogeneous = is_homogeneous;

        return node;
    }

    /// \brief creates a recovery node for a malformed tuple literal.
    ///
    /// \details used by the parser when a tuple structure is identified but
    ///          contains
    ///          inner syntax errors. allows sema to proceed with a partial
    ///          tree.
    static fn create_error(
        ctx:             *ASTContext,
        range:            SourceRange,
        collection_kind:  CollectionExpr::Kind,
        values:          *vec::<TupleValueExpr>,
        is_homogeneous:   bool
    ) -> *TupleLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            values,
            is_homogeneous
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TupleLiteralExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TupleLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::TupleLiteralExpr;
    }
}

/// \class MapLiteralExpr
/// \brief represents an explicit map construction using brace-enclosed
///        key-value pairs.
///
/// \details describes Kairo source expressions like `map{ "key" => 10, "other"
///          => 20 }`.
///          unlike a `MapInitializerExpr` which may describe an empty map or a
///          dynamically-sized allocation, the `MapLiteralExpr` carries an
///          explicit list of key and value sub-expressions.
///
/// sema populates the `key_type` and `value_type` fields of each
/// `MapKeyValueExpr` during type checking to account for potential implicit
/// conversions or heterogeneous literal resolution.
class MapLiteralExpr derives MapInitializerExpr {
    

    /// \struct MapKeyValueExpr
    /// \brief a single key-value mapping within the literal.
    struct MapKeyValueExpr {
        var key:        *Expr;
        var value:      *Expr;
        var key_type:   *Type;   ///< desugared type of the key; null until
                                 ///  sema.
        var value_type: *Type;   ///< desugared type of the value; null until
                                 ///  sema.
    }

    pub var entries: FrozenList::<MapKeyValueExpr>;

    pub const MAX_VALUES: usize = 65535;          ///< implementation limit for
                                                  ///  literal elements.
    pub const MAX_INDEX:  usize = MAX_VALUES - 1;

    /// \brief allocates and initializes a valid MapLiteralExpr.
    ///
    /// \param ctx              ASTContext for node and array allocation.
    /// \param range            source range of the full literal.
    /// \param collection_kind  indicates the specific map-like container kind.
    /// \param values temporary vector of pairs to be frozen into the node.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        values:          *vec::<MapKeyValueExpr>
    ) -> *MapLiteralExpr {
        var node = ctx->alloc::<MapLiteralExpr>();

        node->kind  = ExprKind::MapLiteralExpr;
        node->range = range;

        node->collection_kind = collection_kind;

        var arr = ctx->alloc_array::<MapKeyValueExpr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->entries.from_raw(arr, values->size());

        return node;
    }

    /// \brief creates a MapLiteralExpr wrapped in a RecoveryExpr for error
    ///        resilience.
    ///
    /// \details used when the parser encounters a malformed map literal but can
    ///          still
    ///          extract some key-value pairs to aid in diagnostic recovery.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        values:          *vec::<MapKeyValueExpr>,
        is_homogeneous:  bool
    ) -> *MapLiteralExpr {
        var node = create(ctx, range, collection_kind, values);

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MapLiteralExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MapLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::MapLiteralExpr;
    }
}

/// \class ListLiteralExpr
/// \brief represents a sequence of comma-separated expressions enclosed in
///        square brackets.
///
/// \details constructs a fixed-size collection literal, such as `[1, 2, 3]`.
///          although
///          syntactically identical at the parse level, sema disambiguates
///          these into either stack-allocated fixed-size arrays or SIMD vector
///          types based on the expected type in the assignment or call context.
///
/// lowering considerations:
///   - `ListType::Array` lowers to an LLVM array constant or `alloca`
///     initialization.
///   - `ListType::Vector` lowers to an LLVM `fixed_vector` type for SIMD
///     operations.
class ListLiteralExpr derives ArrayInitializerExpr {
    

    /// \enum ListType
    /// \brief discriminates between standard array and SIMD vector semantics.
    enum ListType derives u8 {
        Array,
        Vector
    }

    pub var values:   FrozenList::<*Expr>;
    pub const MAX_VALUES: usize = 65535;   ///< implementation limit to prevent
                                           ///  AST bloat.
    pub const MAX_INDEX:  usize = MAX_VALUES - 1;

    /// \brief defines the semantic flavor of the literal.
    ///
    /// \details populated by sema during type checking. stored in the AST to
    ///          guide
    ///          codegen optimizations and backend type selection.
    pub var list_type: ListType;

    /// \brief allocates and initializes a new ListLiteralExpr.
    ///
    /// \param ctx             ASTContext for node and element-list allocation.
    /// \param range           source range spanning the outer brackets.
    /// \param collection_kind inherited category from CollectionExpr.
    /// \param list_type       the specific Array or Vector flavor.
    /// \param element_type    resolved type of the contained values.
    /// \param values temporary buffer of expressions to be frozen into the
    ///        node.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        list_type:       ListType,
        element_type:    *Type,
        values:          *vec::<*Expr>
    ) -> *ListLiteralExpr {
        var node = ctx->alloc::<ListLiteralExpr>();

        node->kind            = ExprKind::ListLiteralExpr;
        node->range           = range;
        node->collection_kind = collection_kind;

        var arr = ctx->alloc_array::<*Expr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->element_type = element_type;
        node->size_expr    = &null;

        return node;
    }

    /// \brief constructs a node tagged as a RecoveryExpr to allow parsing to
    ///        continue.
    ///
    /// \details used when the literal is syntactically valid but semantically
    ///          broken
    ///          (e.g., mismatched element types that cannot be unified).
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        list_type:       ListType,
        element_type:    *Type,
        values:          *vec::<*Expr>
    ) -> *ListLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            list_type,
            element_type,
            values
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ListLiteralExpr;

        return node;
    }

    fn is_array(self)  -> bool { return self.list_type == ListType::Array;  }
    fn is_vector(self) -> bool { return self.list_type == ListType::Vector; }
    fn get_size(self) -> usize { return self.values.size(); }
    fn get_element_type(self) -> *Type { return self.element_type; }

    static fn classof(ptr: *Expr) -> bool {
        return (ptr->kind) == ExprKind::ListLiteralExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::ListLiteralExpr;
    }
}

/// \class NamedInitializerExpr
/// \brief represents an explicit struct or class initialization with named
///        members.
///
/// \details encodes a Kairo initialization expression where the target type is
///          specified and members are initialized by name rather than position.
///          example source: `Point { .x = 10, .y = 20 }`.
///
/// during sema, the compiler validates that all provided field names exist
/// within the resolved `name` type and that no mandatory fields are omitted.
/// the `name` field may represent a simple identifier or a complex qualified
/// type path.
class NamedInitializerExpr derives Expr {
    pub var values: FrozenList::<NamedValue>; ///< collection of
                                              ///  name-to-expression pairs.
    pub var name:   *Type;                    ///< the target type being
                                              ///  initialized.

    /// \brief allocates and initializes a new NamedInitializerExpr node.
    ///
    /// \param ctx    ASTContext used for node and array allocation.
    /// \param range  source range covering the entire initialization block.
    /// \param name   the type being constructed.
    /// \param values temporary vector of parsed values, copied into permanent
    ///        arena storage.
    static fn create(
        ctx:    *ASTContext,
        range:   SourceRange,
        name:   *Type,
        values: *vec::<NamedValue>
    ) -> *NamedInitializerExpr {
        var node = ctx->alloc::<NamedInitializerExpr>();

        node->kind  = ExprKind::NamedInitializerExpr;
        node->range = range;
        node->ctx   = ctx;

        var arr = ctx->alloc_array::<NamedValue>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->name = name;
        node->ctx  = ctx;

        return node;
    }

    /// \brief creates a sentinel node to represent a failed named
    ///        initialization attempt.
    ///
    /// \details sets the `kind` to `RecoveryExpr` to prevent cascading sema
    ///          errors
    ///          while preserving the original `NamedInitializerExpr` identity
    ///          in `recovery_kind` for diagnostic tooling.
    static fn create_error(
        ctx:    *ASTContext,
        range:   SourceRange,
        name:   *Type,
        values: *vec::<NamedValue>
    ) -> *NamedInitializerExpr {
        var node            = create(ctx, range, name, values);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::NamedInitializerExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::NamedInitializerExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::NamedInitializerExpr;
    }

    fn has_values(self) -> bool {
        return !(self.values.is_empty());
    }

    fn get_name(self) -> *Type {
        return self.name;
    }
}

/// \class AnonInitializerExpr
/// \brief represents an anonymous struct or tuple-like initializer list.
///
/// \details this node represents an initializer where field names are omitted,
///          such
///          as `Point{10.0, 20.0}`. while it stores `NamedValue` structures,
///          the names in these structures are typically invalid or missing.
///          during semantic analysis, these values are mapped to the
///          corresponding fields of the target type by index, and
///          `NamedValue::field_type` is populated accordingly.
///
/// sema uses this mapping to transition from a positional list to a fully-typed
/// initialization sequence. if the number of values does not match the target
/// type's field count, or if positional initialization is disallowed, sema will
/// emit a diagnostic and may convert the node to a recovery state.
class AnonInitializerExpr derives Expr {
    /// positional initialization values. the identifier in each `NamedValue` is
    /// usually empty/invalid for this expression kind.
    pub var values: FrozenList::<NamedValue>;

    /// \brief creates a new `AnonInitializerExpr` node.
    ///
    /// \param ctx     ASTContext for arena allocation.
    /// \param range   source range covering the `{ ... }` block.
    /// \param values  temporary vector of values collected by the parser.
    static fn create(
        ctx:    *ASTContext,
        range:   SourceRange,
        values: *vec::<NamedValue>
    ) -> *AnonInitializerExpr {
        var node = ctx->alloc::<AnonInitializerExpr>();

        node->kind  = ExprKind::AnonInitializerExpr;
        node->range = range;
        node->ctx   = ctx;

        var arr = ctx->alloc_array::<NamedValue>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->ctx = ctx;
        return node;
    }

    /// \brief creates a node marked as a `RecoveryExpr` to prevent cascading
    ///        errors.
    ///
    /// \details used when the initializer is syntactically valid but occurs in
    ///          a
    ///          context where positional initialization is invalid or the
    ///          argument count is visibly incorrect.
    static fn create_error(
        ctx:    *ASTContext,
        range:   SourceRange,
        values: *vec::<NamedValue>
    ) -> *AnonInitializerExpr {
        var node            = create(ctx, range, values);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::AnonInitializerExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::AnonInitializerExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::AnonInitializerExpr;
    }

    fn has_values(self) -> bool {
        return !(self.values.is_empty());
    }
}

/// \class MethodCallExpr
/// \brief represents a method invocation on an object or type.
///
/// \details encapsulates calls of the form `receiver.method::<T>(args)`. the
///          receiver
///          and the method name are both contained within the `name` field as a
///          `ChainExpr`. during sema, this node is used to resolve the correct
///          function overload based on the receiver's type and the provided
///          arguments.
///
/// EXAMPLE: `my_object.calculate::<i32>(10, 20)`
class MethodCallExpr derives Expr {
    pub var name:         *ChainExpr;          ///< the call chain, including
                                               ///  the receiver and method
                                               ///  identifier.
    pub var generic_args: FrozenList::<*Type>; ///< explicit type arguments,
                                               ///  e.g., the `T` in
                                               ///  `method::<T>()`.
    pub var args:         FrozenList::<*Expr>; ///< positional arguments passed
                                               ///  to the method.

    /// \brief creates a new MethodCallExpr node.
    ///
    /// \param ctx ASTContext used for arena allocation of the node and its
    ///        lists.
    /// \param range         source range covering the entire call expression.
    /// \param name the chain expression representing the receiver and method.
    /// \param generic_args  vector of type arguments, if any.
    /// \param args          vector of argument expressions.
    static fn create(
        ctx:          *ASTContext,
        range:        SourceRange,
        name:         *ChainExpr,
        generic_args: *vec::<*Type>,
        args:         *vec::<*Expr>
    ) -> *MethodCallExpr {
        var node = ctx->alloc::<MethodCallExpr>();

        node->kind  = ExprKind::MethodCallExpr;
        node->range = range;
        node->ctx   = ctx;
        node->name  = name;

        var gen_arr = ctx->alloc_array::<*Type>(generic_args->size());
        for var i: usize = 0; i < generic_args->size(); ++i {
            gen_arr[i] = (*generic_args)[i];
        }
        node->generic_args.from_raw(gen_arr, generic_args->size());

        var arg_arr = ctx->alloc_array::<*Expr>(args->size());
        for var i: usize = 0; i < args->size(); ++i {
            arg_arr[i] = (*args)[i];
        }
        node->args.from_raw(arg_arr, args->size());

        return node;
    }

    /// \brief creates a MethodCallExpr marked as a RecoveryExpr for
    ///        error-resilient parsing.
    ///
    /// \details used when the parser encounters a malformed method call but can
    ///          still
    ///          identify the intended structure. allows sema to continue with
    ///          diminished information without emitting cascading errors.
    static fn create_error(
        ctx:          *ASTContext,
        range:        SourceRange,
        name:         *ChainExpr,
        generic_args: *vec::<*Type>,
        args:         *vec::<*Expr>
    ) -> *MethodCallExpr {
        var node            = create(ctx, range, name, generic_args, args);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MethodCallExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MethodCallExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::MethodCallExpr;
    }

    fn has_generic_args(self) -> bool {
        return !(self.generic_args.is_empty());
    }

    fn has_args(self) -> bool {
        return !(self.args.is_empty());
    }

    /// \brief retrieves the final segment of the call chain.
    ///
    /// \details this segment typically contains the identifier of the method
    ///          being called.
    fn get_last_name(self) -> *ChainExpr::ChainSegment {
        return self.name->last();
    }

    fn get_generic_args(self) -> FrozenList::<*Type> {
        return self.generic_args;
    }
}

/// \class UnaryOperatorExpr
/// \brief represents an expression using a single-operand operator.
///
/// \details covers both prefix (e.g., `-x`, `*ptr`, `&val`) and postfix
///          (e.g., `i++`, `j--`) operations. the specific behavior is
///          determined by the `operator` token kind and the `prefix` boolean
///          flag.
///
/// example Kairo source:
/// ````kairo
/// var x = !found; // prefix OpExclaim var y = count++; // postfix OpPlusPlus
/// ````
class UnaryOperatorExpr derives Expr {
    pub var operator: Token; ///< the operator token. stored for diagnostics and
                             ///  lowering.
    pub var operand:  *Expr; ///< the expression being operated upon.

    /// true for prefix operators like `-x`, false for postfix operators like
    /// `x++`.
    pub var prefix: bool;

    /// \brief creates a well-formed UnaryOperatorExpr node.
    ///
    /// \param ctx      ASTContext for arena allocation.
    /// \param range    full source range covering operator and operand.
    /// \param operator the operator token; must satisfy `is_unary_operator`.
    /// \param operand  the sub-expression.
    /// \param prefix   true if the operator appears before the operand.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr,
        prefix:   bool
    ) -> *UnaryOperatorExpr {
        var node       = ctx->alloc::<UnaryOperatorExpr>();
        node->kind     = ExprKind::UnaryOperatorExpr;
        node->range    = range;
        node->ctx      = ctx;
        node->operator = operator;
        assert(is_unary_operator(operator.kind) && r"Expected a unary operator token");
        node->operand  = operand;
        node->prefix   = prefix;
        return node;
    }

    /// \brief creates a UnaryOperatorExpr tagged as a RecoveryExpr.
    ///
    /// \details used by sema or the parser when the expression is syntactically
    ///          a unary operation but fails semantic validation (e.g., invalid
    ///          types for the operator). preserves the structure for tooling.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr,
        prefix:   bool
    ) -> *UnaryOperatorExpr {
        var node            = create(ctx, range, operator, operand, prefix);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::UnaryOperatorExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::UnaryOperatorExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::UnaryOperatorExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_operand(self) -> *Expr {
        return self.operand;
    }

    /// \brief checks if this is a prefix pointer dereference `*ptr`.
    fn is_dereference(self) -> bool {
        return (self.operator.kind == TokenKind::OpStar) && self.prefix;
    }

    /// \brief checks if this is a prefix address-of operation `&val`.
    fn is_address_of(self) -> bool {
        return (self.operator.kind == TokenKind::OpAmp) && self.prefix;
    }

    /// \brief checks if this is a prefix logical negation `!val`.
    fn is_logical_not(self) -> bool {
        return (self.operator.kind == TokenKind::OpExclaim) && self.prefix;
    }

    /// \brief checks if this is a prefix unary plus `+val`.
    fn is_unary_plus(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlus) && self.prefix;
    }

    /// \brief checks if this is a postfix increment `val++`.
    fn is_postfix_increment(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlusPlus) && !self.prefix;
    }

    /// \brief checks if this is a postfix decrement `val--`.
    fn is_postfix_decrement(self) -> bool {
        return (self.operator.kind == TokenKind::OpMinusMinus) && !self.prefix;
    }

    /// \brief checks if this is a prefix increment `++val`.
    fn is_prefix_increment(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlusPlus) && self.prefix;
    }

    /// \brief checks if this is a prefix decrement `--val`.
    fn is_prefix_decrement(self) -> bool {
        return (self.operator.kind == TokenKind::OpMinusMinus) && self.prefix;
    }

    /// \brief checks if this is a prefix bitwise complement `~val`.
    fn is_bitwise_not(self) -> bool {
        return (self.operator.kind == TokenKind::OpTilde) && self.prefix;
    }
}

/// \class BinaryOperatorExpr
/// \brief represents a binary expression consisting of a left operand, an
///        operator, and a right operand.
///
/// \details this node covers standard arithmetic, logical, and bitwise
///          operations,
///          such as `a + b`, `x && y`, or `i << 2`. the specific operation is
///          determined by the `operator` token kind.
///
/// \note specialized binary operations like assignments (`a = b`) or ranges
///       (`0..10`)
///       derive from this class but may carry additional semantic state.
class BinaryOperatorExpr derives Expr {
    pub var operator: Token; ///< the operator token (e.g., `+`, `==`, `&`).
    pub var left:     *Expr; ///< the left-hand side operand.
    pub var right:    *Expr; ///< the right-hand side operand.

    /// \brief allocates and initializes a new BinaryOperatorExpr.
    ///
    /// \param ctx       the ASTContext for arena allocation.
    /// \param range the full source range encompassing both operands and the
    ///        operator.
    /// \param operator  the operator token; must satisfy `is_binary_operator`.
    /// \param left      the expression on the left of the operator.
    /// \param right     the expression on the right of the operator.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *BinaryOperatorExpr {
        var node       = ctx->alloc::<BinaryOperatorExpr>();

        // from Expr
        node->kind     = ExprKind::BinaryOperatorExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from BinaryOperatorExpr
        node->operator = operator;

        // this does only run in debug mode so its fine to have
        assert(is_binary_operator(operator.kind) && r"Expected a binary operator token");

        node->left     = left;
        node->right    = right;

        return node;
    }

    /// \brief creates a BinaryOperatorExpr flagged as a RecoveryExpr.
    ///
    /// \details used during parsing when a binary expression is syntactically
    ///          present but contains internal errors. the `recovery_kind`
    ///          preserves the original intent for use in diagnostic heuristics.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *BinaryOperatorExpr {
        var node            = create(ctx, range, operator, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::BinaryOperatorExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::BinaryOperatorExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::BinaryOperatorExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_left(self) -> *Expr {
        return self.left;
    }

    fn get_right(self) -> *Expr {
        return self.right;
    }
}

/// \class AssignOperatorExpr
/// \brief represents an assignment or compound-assignment expression.
///
/// \details models expressions like `a = b` or `a += b`. while structurally
///          identical to a `BinaryOperatorExpr`, this node is separated to
///          facilitate sema validation of l-value requirements on the `left`
///          operand and to handle the specific semantics of compound updates.
///
/// example Kairo source: `x = 10;` -> simple assignment. `y *= scale;` ->
/// compound assignment.
class AssignOperatorExpr derives BinaryOperatorExpr {
    // we do validate this in input to verfiy it is the right kind of assignment
    // operator, but we still want to store the token for error reporting and
    // codegen purposes

    /// \brief creates a well-formed AssignOperatorExpr node.
    ///
    /// \param ctx       ASTContext for node allocation.
    /// \param range source range covering from the start of `left` to the end
    ///        of `right`.
    /// \param operator  the assignment token (e.g., `=`, `+=`, `<<=`).
    /// \param left the destination expression (must resolve to an l-value).
    /// \param right     the value expression.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *AssignOperatorExpr {
        var node = ctx->alloc::<AssignOperatorExpr>();

        // from Expr
        node->kind  = ExprKind::AssignOperatorExpr;
        node->range = range;
        node->ctx   = ctx;

        // from BinaryOperatorExpr
        node->operator = operator;
        assert(is_assignment_operator(operator.kind) && r"Expected an assignment operator token");
        node->left  = left;
        node->right = right;

        return node;
    }

    /// \brief creates a node marked as a RecoveryExpr to allow parsing to
    ///        continue after an error.
    ///
    /// \details used when the assignment syntax is structurally valid but
    ///          semantic or
    ///          contextual constraints fail during initial construction.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *AssignOperatorExpr {
        var node            = create(ctx, range, operator, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::AssignOperatorExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::AssignOperatorExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::AssignOperatorExpr;
    }

    // we get these from BinaryOperatorExpr:
    //      fn get_operator(self) -> Token
    //      fn get_left(self) -> *Expr
    //      fn get_right(self) -> *Expr

    /// \brief returns true if the operator is a simple `=` without an
    ///        arithmetic update.
    fn is_simple_assignment(self) -> bool {
        return self.operator.kind == TokenKind::OpEqual;
    }
}

/// \class ImplConformanceExpr
/// \brief represents a compile-time check for interface or trait conformance.
///
/// \details generated by the `is` operator or during explicit trait constraint
///          checks.
///          this node evaluates whether a type `left` conforms to one or more
///          interfaces or traits specified in `right`.
///
/// example Kairo source: `my_type is MyInterface` `T is (TraitA + TraitB)`
///
/// lowered by sema into a boolean value. if multiple traits are provided, the
/// expression evaluates to true only if `left` conforms to every trait in
/// `right`.
class ImplConformanceExpr derives Expr {
    pub var left:  *Type;               ///< the subject type being tested for
                                        ///  conformance.
    pub var right: FrozenList::<*Type>;  ///< list of interface/trait types to
                                         ///  check against.

    /// \brief creates a valid conformance expression.
    ///
    /// \param ctx    ASTContext used for node and list allocation.
    /// \param range  source range covering the entire expression.
    /// \param left   the subject type.
    /// \param right  temporary vector of traits, copied into a `FrozenList`.
    static fn create(
        ctx:   *ASTContext,
        range: SourceRange,
        left:  *Type,
        right: *vec::<*Type>
    ) -> *ImplConformanceExpr {
        var node = ctx->alloc::<ImplConformanceExpr>();

        // from Expr
        node->kind  = ExprKind::ImplConformanceExpr;
        node->range = range;
        node->ctx   = ctx;

        // from ImplConformanceExpr
        node->left = left;

        var arr = ctx->alloc_array::<*Type>((*right).size());
        for var i: usize = 0; i < (*right).size(); ++i {
            arr[i] = (*right)[i];
        }

        node->right.from_raw(arr, (*right).size());
        return node;
    }

    /// \brief creates a conformance expression marked as a `RecoveryExpr`.
    ///
    /// \details used when the parser encounters a conformance check that is
    ///          syntactically valid but semantically broken (e.g. invalid
    ///          types). preserves the original node structure for IDE support
    ///          and tooling.
    static fn create_error(
        ctx:   *ASTContext,
        range: SourceRange,
        left:  *Type,
        right: *vec::<*Type>
    ) -> *ImplConformanceExpr {
        var node            = create(ctx, range, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ImplConformanceExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::ImplConformanceExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::ImplConformanceExpr;
    }

    fn get_left(self) -> *Type {
        return self.left;
    }

    fn get_right(self) -> FrozenList::<*Type> {
        return self.right;
    }

    /// \brief returns the trait at a specific index, or null if out of bounds.
    fn get_trait(self, idx: usize) -> *Type {
        if (idx >= self.right.size()) {
            return &null;
        }

        return *self.right[idx];
    }
}

/// \class DerivesRelationExpr
/// \brief represents a type inheritance or conformance check expression.
///
/// \details encodes a check to determine if a type inherits from or conforms
///          to one or more other types.
///
/// EXAMPLE: `MyClass derives InterfaceA, InterfaceB`
///
/// here, `MyClass` is the `left` type, and the list `[InterfaceA, InterfaceB]`
/// forms the `right` operand. in the compiler, this is often used in generic
/// constraints or explicit boolean expressions.
class DerivesRelationExpr derives Expr {
    pub var left:  *Type;               ///< the subject type being tested.
    pub var right: FrozenList::<*Type>; ///< the set of target types
                                        ///  (bases/interfaces).

    /// \brief constructs a valid DerivesRelationExpr node.
    ///
    /// \param ctx    ASTContext used for node and array allocation.
    /// \param range  source range covering the entire expression.
    /// \param left   the type being checked.
    /// \param right a temporary vector of target types, copied into a
    ///        FrozenList.
    static fn create(
        ctx:   *ASTContext,
        range:  SourceRange,
        left:  *Type,
        right: *vec::<*Type>
    ) -> *DerivesRelationExpr {
        var node = ctx->alloc::<DerivesRelationExpr>();

        node->kind  = ExprKind::DerivesRelationExpr;
        node->range = range;
        node->ctx   = ctx;

        node->left  = left;

        var arr = ctx->alloc_array::<*Type>((*right).size());
        for var i: usize = 0; i < (*right).size(); ++i {
            arr[i] = (*right)[i];
        }

        node->right.from_raw(arr, (*right).size());
        return node;
    }

    /// \brief constructs a DerivesRelationExpr wrapped in a RecoveryExpr.
    ///
    /// \details used when the expression is syntactically present but
    ///          semantically
    ///          broken, allowing the parser to continue while marking the node
    ///          as invalid for subsequent transformation passes.
    static fn create_error(
        ctx:   *ASTContext,
        range:  SourceRange,
        left:  *Type,
        right: *vec::<*Type>
    ) -> *DerivesRelationExpr {
        var node            = create(ctx, range, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::DerivesRelationExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::DerivesRelationExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::DerivesRelationExpr;
    }

    fn get_left(self) -> *Type {
        return self.left;
    }

    fn get_right(self) -> FrozenList::<*Type> {
        return self.right;
    }
}

/// \class IfExpr
/// \brief represents a conditional control-flow expression or statement.
///
/// \details in Kairo, `if` is an expression that can yield a value if all
///          branches
///          result in a compatible type. this node encapsulates the entire
///          chain of `if`, `else if`, and `else` components.
///
/// example source:
/// ```kairo
/// var x = if (cond) { 1 } else if (other) { 2 } else { 3 };
/// ```
///
/// if-expressions used as statements are lowered the same way but their
/// resulting value is ignored. sema validates that if an `IfExpr` is used in an
/// assignment context, an `else` branch must be present to ensure the
/// expression always produces a value.
class IfExpr derives Expr {
    

    /// \enum BranchKind
    /// \brief categorizes the syntactic role of a specific branch.
    enum BranchKind derives u8 {
        If,     ///< the initial `if (condition) { ... }` block.
        ElseIf, ///< any subsequent `else if (condition) { ... }` block.
        Else    ///< the terminal `else { ... }` block.
    }

    /// \struct IfBranch
    /// \brief represents a single conditional or unconditional code block.
    struct IfBranch {
        var condition: *Expr;      ///< null for `Else` branches; evaluated for
                                   ///  truthiness.
        var body:      *Expr;      ///< the expression or block to execute if
                                   ///  the condition matches.
        var kind:      BranchKind;
    }

    pub var   branches:     FrozenList::<IfBranch>;
    pub const MAX_BRANCHES: usize = 255;

    /// \brief the threshold for triggering maintainability warnings.
    ///
    /// \details we parse more than this number, but this constant defines the
    ///          point at
    ///          which the parser emits a diagnostic regarding excessive
    ///          cyclomatic complexity.
    pub const RECOMMENDED_MAX_BRANCHES: usize = 4;

    /// \brief allocates and initializes a new IfExpr.
    ///
    /// \param ctx      ASTContext for node and branch array allocation.
    /// \param range full source range from the `if` keyword to the end of the
    ///        final block.
    /// \param branches temporary vector of branches collected during parsing.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        branches: *vec::<IfBranch>
    ) -> *IfExpr {
        var node = ctx->alloc::<IfExpr>();

        // from Expr
        node->kind  = ExprKind::IfExpr;
        node->range = range;
        node->ctx   = ctx;

        // from IfExpr
        var arr = ctx->alloc_array::<IfBranch>(branches->size());
        for var i: usize = 0; i < branches->size(); ++i {
            arr[i] = (*branches)[i];
        }

        node->branches.from_raw(arr, branches->size());
        return node;
    }

    /// \brief creates an IfExpr marked as a RecoveryExpr for error resilience.
    ///
    /// \details used when parsing fails within branches but enough structure
    ///          exists
    ///          to continue semantic analysis on the partial node.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        branches: *vec::<IfBranch>
    ) -> *IfExpr {
        var node            = create(ctx, range, branches);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::IfExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::IfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::IfExpr;
    }

    fn get_branches(self) -> FrozenList::<IfBranch> {
        return self.branches;
    }

    fn has_else_branch(self) -> bool {
        return self.branches.any(fn(x: *IfBranch) -> bool {
            return x->kind == BranchKind::Else;
        });
    }

    /// \brief returns the terminal else branch if present, otherwise returns
    ///        null.
    fn get_else_branch(self) -> *IfBranch {
        for var i: usize = 0; i < self.branches.size(); ++i {
            if self.branches[i]->kind == BranchKind::Else {
                return self.branches[i];
            }
        }

        return &null;
    }

    /// \brief filters the branch list to return only `If` and `ElseIf` nodes.
    fn get_if_branches(self) -> vec::<*IfBranch> {
        var result: vec::<*IfBranch>;
        result.reserve(self.branches.size());

        for var i: usize = 0; i < self.branches.size(); ++i {
            if ((self.branches[i]->kind) == BranchKind::If) || ((self.branches[i]->kind) == BranchKind::ElseIf) {
                result.emplace_back(self.branches[i]);
            }
        }

        return result;
    }

    fn get_else_if_branches(self) -> vec::<*IfBranch> {
        var result: vec::<*IfBranch>;
        result.reserve(self.branches.size());

        for var i: usize = 0; i < self.branches.size(); ++i {
            if (self.branches[i]->kind) == BranchKind::ElseIf {
                result.emplace_back(self.branches[i]);
            }
        }

        return result;
    }

    /// \brief returns a list of branches marked as `Else`.
    ///
    /// \note valid Kairo source should only ever contain one `Else` branch at
    ///       the end.
    fn get_else_branches(self) -> vec::<*IfBranch> {
        var else_branches: vec::<*IfBranch>;
        for var i: usize = 0; i < self.branches.size(); ++i {
            if (self.branches[i]->kind) == BranchKind::Else {
                else_branches.emplace_back(self.branches[i]);
            }
        }

        return else_branches;
    }

    fn has_multiple_branches(self) -> bool {
        return self.branches.size() > 1;
    }

    /// \brief checks if the expression contains both an initial `if` and a
    ///        terminal `else`.
    ///
    /// \details this is often used during sema to determine if the `IfExpr` is
    ///          guaranteed to produce a value in all execution paths.
    fn meets_min_requirement(self) -> bool {
        var has_if_branch   = false;
        var has_else_branch = false;

        for var i: usize = 0; i < self.branches.size(); ++i {
            if (self.branches[i]->kind) == BranchKind::If {
                has_if_branch = true;
            } else if self.branches[i]->kind == BranchKind::Else {
                has_else_branch = true;
            }

            if has_if_branch && has_else_branch {
                return true;
            }
        }

        return false;
    }
}

/// \class TernaryExpr
/// \brief factory class for C-style ternary expressions `cond ? a : b`.
///
/// \details in the Kairo AST, ternary expressions are lowered directly into
///          the more general `IfExpr` representation. `TernaryExpr` acts as a
///          factory that constructs an `IfExpr` with exactly two branches: an
///          `If` branch containing the true-expression, and an `Else` branch
///          containing the false-expression.
///
/// EXAMPLE lowering: `x ? y : z` -> `if x { y } else { z }`
///
/// NOTE: this class exists to support the parser's legacy ternary expression
/// syntax. The parser is expected to emit a deprecation warning as ternary
/// expressions are being phased out in favor of `if` expressions.
class TernaryExpr derives IfExpr {
    /// \brief creates a well-formed `IfExpr` from ternary components.
    ///
    /// \param ctx ASTContext for allocating the expression and branch array.
    /// \param range      source range covering from the start of the condition
    ///                   to the end of the false-expression.
    /// \param condition  the boolean condition expression.
    /// \param true_expr  the expression to evaluate if the condition is true.
    /// \param false_expr the expression to evaluate if the condition is false.
    static fn create(
        ctx:        *ASTContext,
        range:      SourceRange,
        condition:  *Expr,
        true_expr:  *Expr,
        false_expr: *Expr
    ) -> *IfExpr {
        var node = ctx->alloc::<IfExpr>();

        node->kind  = ExprKind::IfExpr;
        node->range = range;
        node->ctx   = ctx;

        var arr = ctx->alloc_array::<IfBranch>(2);
        arr[0]  = IfBranch(condition, true_expr, BranchKind::If);
        arr[1]  = IfBranch(&null, false_expr, BranchKind::Else);

        node->branches.from_raw(arr, 2);
        return node;
    }

    /// \brief creates an `IfExpr` wrapped in a `RecoveryExpr` for error
    ///        handling.
    ///
    /// \details used when the ternary syntax is recognized but one or more
    ///          sub-expressions contain errors. marks the node as a recovery
    ///          node to prevent downstream sema crashes while preserving the
    ///          intended structure for IDE tooling.
    static fn create_error(
        ctx:        *ASTContext,
        range:      SourceRange,
        condition:  *Expr,
        true_expr:  *Expr,
        false_expr: *Expr
    ) -> *IfExpr {
        var node            = create(ctx, range, condition, true_expr, false_expr);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::IfExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::IfExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::IfExpr;
    }
}

/// \class InlineTryCatchExpr
/// \brief represents an expression-level try-catch construct.
///
/// \details models expressions that perform error handling inline, returning a
///          value
///          from either the successful `try` branch or a matching `catch`
///          branch.
///
/// ```kairo
/// var x = try fallible_call() catch(Error::Bad) 0 catch 1;
/// ```
///
/// the lowered AST maintains a flat list of branches where the first branch is
/// typically the `try` site. sema ensures that types across all potential exit
/// points are compatible.
class InlineTryCatchExpr derives Expr {
    

    /// \enum BranchKind
    /// \brief categorizes the role of a branch within the expression.
    enum BranchKind derives u8 {
        Try,      ///< the primary fallible expression.
        Catch,    ///< a guarded handler for a specific error condition.
        CatchAll  ///< an unguarded fallback handler (e.g. `catch { ... }`).
    }

    /// \struct TryCatchBranch
    /// \brief a single execution path within the try-catch expression.
    struct TryCatchBranch {
        var condition: *Expr; ///< error pattern to match. null for `Try` or
                              ///  `CatchAll`.
        var body:      *Expr; ///< the expression to evaluate if this branch is
                              ///  taken.
        var kind:      BranchKind;
    }

    pub var   branches:                 FrozenList::<TryCatchBranch>;
    pub const MAX_BRANCHES:             usize = 255;
    pub const RECOMMENDED_MAX_BRANCHES: usize = 4;

    /// \brief initializes a new InlineTryCatchExpr node.
    ///
    /// \param ctx       ASTContext for arena allocation.
    /// \param range     full source range of the try-catch construct.
    /// \param branches  temporary buffer of branches collected by the parser.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        branches: *vec::<TryCatchBranch>
    ) -> *InlineTryCatchExpr {
        var node = ctx->alloc::<InlineTryCatchExpr>();

        node->kind  = ExprKind::InlineTryCatchExpr;
        node->range = range;
        node->ctx   = ctx;

        var arr = ctx->alloc_array::<TryCatchBranch>(branches->size());
        for var i: usize = 0; i < branches->size(); ++i {
            arr[i] = (*branches)[i];
        }

        node->branches.from_raw(arr, branches->size());
        return node;
    }

    /// \brief creates a node marked for recovery after a parsing error.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        branches: *vec::<TryCatchBranch>
    ) -> *InlineTryCatchExpr {
        var node            = create(ctx, range, branches);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::InlineTryCatchExpr;
        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::InlineTryCatchExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::InlineTryCatchExpr;
    }

    fn get_branches(self) -> FrozenList::<TryCatchBranch> {
        return self.branches;
    }

    fn has_catch_all_branch(self) -> bool {
        return self.branches.any(fn(x: *TryCatchBranch) -> bool {
            return x->kind == BranchKind::CatchAll;
        });
    }

    /// \brief locates the fallback branch if one exists.
    /// \return pointer to the CatchAll branch, or null if only specific catches
    ///         exist.
    fn get_catch_all_branch(self) -> *TryCatchBranch {
        for var i: usize = 0; i < self.branches.size(); ++i {
            if self.branches[i]->kind == BranchKind::CatchAll {
                return self.branches[i];
            }
        }

        return &null;
    }

    fn get_try_branches(self) -> vec::<*TryCatchBranch> {
        var result: vec::<*TryCatchBranch>;
        result.reserve(self.branches.size());

        for var i: usize = 0; i < self.branches.size(); ++i {
            if self.branches[i]->kind == BranchKind::Try {
                result.emplace_back(self.branches[i]);
            }
        }

        return result;
    }

    fn get_catch_branches(self) -> vec::<*TryCatchBranch> {
        var result: vec::<*TryCatchBranch>;
        result.reserve(self.branches.size());

        for var i: usize = 0; i < self.branches.size(); ++i {
            if self.branches[i]->kind == BranchKind::Catch {
                result.emplace_back(self.branches[i]);
            }
        }

        return result;
    }

    fn has_multiple_branches(self) -> bool {
        return self.branches.size() > 1;
    }

    /// \brief validates that the expression is syntactically complete.
    ///
    /// \details a valid inline try-catch requires at least one `try` site and
    ///          at
    ///          least one mechanism to handle an error (`catch` or `catch
    ///          all`).
    fn meets_min_requirement(self) -> bool {
        var has_try_branch                = false;
        var has_catch_or_catch_all_branch = false;

        for var i: usize = 0; i < self.branches.size(); ++i {
            if self.branches[i]->kind == BranchKind::Try {
                has_try_branch = true;
            } else if (self.branches[i]->kind == BranchKind::Catch)
                   || (self.branches[i]->kind == BranchKind::CatchAll) {
                has_catch_or_catch_all_branch = true;
            }

            if has_try_branch && has_catch_or_catch_all_branch {
                return true;
            }
        }

        return false;
    }
}

/// \class RangeExpr
/// \brief represents a range construction expression using range operators.
///
/// \details models expressions that define a sequence or interval, such as
///          `0..10`
///          (exclusive), `0..=10` (inclusive), or `0.<>10` (half-open). while
///          it derives from `BinaryOperatorExpr`, it is treated as a distinct
///          node kind to facilitate range-specific sema checks and specialized
///          codegen for iterator lowering.
///
/// example Kairo source: `for i in 0..count { ... }` `var slice =
/// arr[start..=end];`
class RangeExpr derives BinaryOperatorExpr {
    /// \brief creates a new RangeExpr node.
    ///
    /// \param ctx      ASTContext for node allocation.
    /// \param range    full source span of the range expression.
    /// \param operator the range operator token (`..`, `..=`, or `.<>`).
    /// \param left     the lower bound expression.
    /// \param right    the upper bound expression.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *RangeExpr {
        var node = ctx->alloc::<RangeExpr>();

        // from Expr
        node->kind  = ExprKind::RangeExpr;
        node->range = range;
        node->ctx   = ctx;

        // from BinaryOperatorExpr
        node->operator = operator;
        assert(is_range_operator(operator.kind) && r"Expected a range operator token");

        node->left  = left;
        node->right = right;

        return node;
    }

    /// \brief creates a RangeExpr flagged as a recovery node for error
    ///        resilience.
    ///
    /// \details used by the parser when a range expression is syntactically
    ///          valid but
    ///          semantically malformed, allowing later stages to skip it while
    ///          preserving the original node kind for diagnostics.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:     *Expr,
        right:    *Expr
    ) -> *RangeExpr {
        var node            = create(ctx, range, operator, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::RangeExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::RangeExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::RangeExpr;
    }

    /// returns true if the range includes its upper bound (`..=`).
    fn is_inclusive_range(self) -> bool {
        return self.operator.kind == TokenKind::OpRangeEqual;
    }

    /// returns true if the range excludes its upper bound (`..`).
    fn is_exclusive_range(self) -> bool {
        return self.operator.kind == TokenKind::OpRange;
    }

    /// returns true if the range uses the half-open operator syntax (`.<>`).
    fn is_half_open_range(self) -> bool {
        return self.operator.kind == TokenKind::OpLessEqualGreater;
    }
}

/// \class AwaitExpr
/// \brief represents an asynchronous suspension point in the control flow.
///
/// \details an `AwaitExpr` is a unary operator that suspends the execution of
///          the current `async` function or closure until the operand's
///          underlying task (typically a `Future<T>`) completes.
///
/// EXAMPLE Kairo: `var result = await fetch_data();`
///
/// sema validates that the operand is awaitable and that this expression
/// appears within a valid asynchronous context.
class AwaitExpr derives UnaryOperatorExpr {
    /// \brief constructs a valid AwaitExpr node.
    ///
    /// \param ctx      the ASTContext managing this node's lifetime.
    /// \param range the full source range of the expression, including `await`.
    /// \param operator the `await` keyword token.
    /// \param operand  the expression being awaited.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *AwaitExpr {
        var node       = ctx->alloc::<AwaitExpr>();

        // from Expr
        node->kind     = ExprKind::AwaitExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwAwait && r"Expected an await operator token");

        node->operand  = operand;
        node->prefix   = true; // await is always a prefix operator
        return node;
    }

    /// \brief constructs an AwaitExpr node marked as a recovery node.
    ///
    /// \details used during parsing when an await expression is syntactically
    ///          present but contains internal errors. the `recovery_kind`
    ///          preserves the intent for IDE tooling and better diagnostics.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *AwaitExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::AwaitExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::AwaitExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::AwaitExpr;
    }
}

/// \class SpawnExpr
/// \brief represents an asynchronous task creation via the `spawn` operator.
///
/// \details a `SpawnExpr` wraps a function or method call expression,
///          indicating
///          that the callee should be executed on a background task runner
///          rather than the current stack. the result of a `spawn` expression
///          is a handle (typically a `Future<T>` or `Task<T>`) representing the
///          background work.
///
/// ```kairo
/// var task = spawn fetch_data(id);
/// ```
///
/// lowering involves creating a closure for the operand's arguments and
/// scheduling the call with the runtime's task orchestrator.
class SpawnExpr derives UnaryOperatorExpr {
    /// \brief allocates and initializes a new SpawnExpr node.
    ///
    /// \param ctx       the ASTContext providing arena storage.
    /// \param range the full source range encompassing `spawn` and its operand.
    /// \param operator  the `spawn` keyword token.
    /// \param operand the expression (usually a `MethodCallExpr`) to be
    ///        executed.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *SpawnExpr {
        var node       = ctx->alloc::<SpawnExpr>();

        // from Expr
        node->kind     = ExprKind::SpawnExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwSpawn && r"Expected a spawn operator token");

        node->operand  = operand;
        node->prefix   = true; // spawn is always a prefix operator
        return node;
    }

    /// \brief creates a SpawnExpr flagged as a recovery node for parser error
    ///        handling.
    ///
    /// \details used when the `spawn` syntax is correctly identified but the
    ///          operand
    ///          is malformed or missing. this allows sema to perform local
    ///          analysis without attempting to lower an invalid task creation.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *SpawnExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SpawnExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SpawnExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SpawnExpr;
    }
}

/// \class ThreadExpr
/// \brief represents a dedicated thread creation expression.
///
/// \details a `ThreadExpr` corresponds to the `thread` prefix operator applied
///          to a callable or block. unlike `spawn`, which typically uses a
///          managed task pool, `thread` creates a new OS-level thread of
///          execution.
///
/// ```kairo
/// var t = thread do_work(args...);
/// ```
///
/// it inherits from `UnaryOperatorExpr` as it wraps a single expression (the
/// callable to be executed). the operator token is always
/// `TokenKind::KwThread`.
class ThreadExpr derives UnaryOperatorExpr {
    /// \brief constructs a valid `ThreadExpr` node.
    ///
    /// \param ctx       ASTContext for node allocation.
    /// \param range     source range covering the operator and the operand.
    /// \param operator  the `thread` keyword token.
    /// \param operand   the expression to be executed on the new thread.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *ThreadExpr {
        var node = ctx->alloc::<ThreadExpr>();

        // from Expr
        node->kind  = ExprKind::ThreadExpr;
        node->range = range;
        node->ctx   = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwThread && r"Expected a thread operator token");

        node->operand = operand;
        node->prefix  = true; // thread is always a prefix operator
        return node;
    }

    /// \brief constructs a `ThreadExpr` marked as a `RecoveryExpr`.
    ///
    /// \details used during parsing when a thread expression is syntactically
    ///          present but contains internal semantic or structural errors.
    ///          prevents cascading errors while preserving the subtree for IDE
    ///          tooling or error reporting.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *ThreadExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ThreadExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::ThreadExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::ThreadExpr;
    }
}

/// \class EvalExpr
/// \brief represents a compile-time evaluation request using the `eval`
///        keyword.
///
/// \details wrapping an expression in `eval` forces the compiler to evaluate
///          that
///          sub-expression at compile time and substitute the result into the
///          AST as a literal or constant value.
///
/// ```kairo
/// var x = eval(1 + 2); // 'x' is initialized with the constant 3.
/// ```
///
/// \note lowered to a constant value during sema or early IR generation. if the
///       expression cannot be evaluated at compile time, a semantic error is
///       issued.
class EvalExpr derives UnaryOperatorExpr {
    /// \brief creates a valid EvalExpr node.
    ///
    /// \param ctx       ASTContext for node allocation.
    /// \param range full source range including the `eval` keyword and operand.
    /// \param operator  the `KwEval` token.
    /// \param operand   the expression to be evaluated.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *EvalExpr {
        var node = ctx->alloc::<EvalExpr>();

        // from Expr
        node->kind     = ExprKind::EvalExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwEval && r"Expected an eval operator token");

        node->operand  = operand;
        node->prefix   = true; // eval is always a prefix operator
        return node;
    }

    /// \brief creates an EvalExpr node marked for error recovery.
    ///
    /// \details used when the parser identifies an `eval` construct but the
    ///          operand
    ///          is malformed. allows sema to skip evaluation attempts while
    ///          preserving the original intent for diagnostics.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *EvalExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::EvalExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::EvalExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::EvalExpr;
    }
}

/// \class UnsafeExpr
/// \brief represents an explicit unsafe block or expression-level escape.
///
/// \details `UnsafeExpr` models the use of the `unsafe` keyword to opt-out of
///          memory safety or pointer checks for a specific sub-expression. In
///          the Kairo grammar, this appears as:
///          ```kairo
///          var x = unsafe ptr.offset(10);
///          ```
///          Where `ptr.offset(10)` is the `operand`. The parser treats `unsafe`
///          as a prefix unary operator. During sema, this node informs the
///          checker that safety violations within `operand` should be
///          permitted, provided they are strictly contained.
///
/// \note `UnsafeExpr` is always a prefix operator.
class UnsafeExpr derives UnaryOperatorExpr {
    /// \brief allocates and initializes a new UnsafeExpr node.
    ///
    /// \param ctx      the ASTContext for arena allocation.
    /// \param range the full source range of the expression, including
    ///        `unsafe`.
    /// \param operator the `unsafe` keyword token.
    /// \param operand  the sub-expression being wrapped in the unsafe context.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *UnsafeExpr {
        var node       = ctx->alloc::<UnsafeExpr>();

        // from Expr
        node->kind     = ExprKind::UnsafeExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwUnsafe && r"Expected an unsafe operator token");

        node->operand  = operand;
        node->prefix   = true; // unsafe is always a prefix operator
        return node;
    }

    /// \brief creates a node that is marked for error recovery.
    ///
    /// \details used when an unsafe expression is syntactically valid but
    ///          semantically broken (e.g. invalid operand type), allowing
    ///          further parsing while signaling the error to sema.
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *UnsafeExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::UnsafeExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::UnsafeExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::UnsafeExpr;
    }
}

/// \class DeleteExpr
/// \brief represents an explicit memory deallocation expression.
///
/// \details models the `delete ptr` syntax used to free heap-allocated memory.
///          as a subclass of `UnaryOperatorExpr`, it treats the pointer being
///          freed as its sub-expression.
///
/// example Kairo source: `delete my_ptr;`
///
/// lowering considerations: during sema, the `operand` type must be validated
/// as a pointer or a type with a reachable deallocation strategy. if the
/// operand is a managed pointer or reference that does not support manual
/// deletion, a diagnostic is emitted.
class DeleteExpr derives UnaryOperatorExpr {
    /// \brief creates a well-formed `DeleteExpr` node.
    ///
    /// \param ctx      the ASTContext for node allocation.
    /// \param range full source range spanning the `delete` keyword and the
    ///        operand.
    /// \param operator the `Token` representing the `delete` keyword.
    /// \param operand  the expression resulting in the pointer to be deleted.
    static fn create(
        ctx:      *ASTContext,
        range:     SourceRange,
        operator:  Token,
        operand:   *Expr
    ) -> *DeleteExpr {
        var node = ctx->alloc::<DeleteExpr>();

        // from Expr
        node->kind     = ExprKind::DeleteExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwDelete && r"Expected a delete operator token");

        node->operand  = operand;
        node->prefix   = true; // delete is always a prefix operator

        return node;
    }

    /// \brief creates a `DeleteExpr` node marked for recovery after a parse
    ///        error.
    ///
    /// \details used when the `delete` keyword is identified but the operand or
    ///          surrounding syntax is malformed. the node is typed as
    ///          `RecoveryExpr` to signal to sema that it should not attempt
    ///          full validation.
    static fn create_error(
        ctx:      *ASTContext,
        range:     SourceRange,
        operator:  Token,
        operand:   *Expr
    ) -> *DeleteExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::DeleteExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::DeleteExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::DeleteExpr;
    }
}

/// \class TypeOfExpr
/// \brief represents a type-querying operator such as `typeof` or `sizeof`.
///
/// \details this node models operators that query properties of either a type
///          directly or the type of an expression. in Kairo, `sizeof(T)` and
///          `sizeof(expr)` both lower to a `TypeOfExpr` (specifically its
///          subclass `SizeOfExpr`).
///
/// when the operand is a type, `operand_is_type` is true and `operand_type` is
/// populated. when the operand is an expression, `operand_is_type` is false,
/// `operand_type` is null, and the expression is stored in the `operand` field
/// inherited from `UnaryOperatorExpr`.
///
/// \note while this class is named `TypeOfExpr`, it acts as the base for
///       `SizeOfExpr`, `AlignOfExpr`, and any future type-trait queries.
class TypeOfExpr derives UnaryOperatorExpr {
    pub var operand_is_type: bool;  ///< true if the operand was a type name
                                    ///  (e.g. `sizeof(i32)`).
    pub var operand_type:    *Type; ///< the resolved type if `operand_is_type`
                                    ///  is true; otherwise null.

    /// \brief creates a new TypeOfExpr node.
    ///
    /// \param ctx             the ASTContext to allocate from.
    /// \param range           the full source range of the expression.
    /// \param operator        the operator token (e.g. `KwSizeof`).
    /// \param operand the expression operand; null if `operand_is_type` is
    ///        true.
    /// \param operand_is_type flag indicating if the query is on a type or an
    ///        expression.
    /// \param operand_type the type operand; null if `operand_is_type` is
    ///        false.
    static fn create(
        ctx:             *ASTContext,
        range:           SourceRange,
        operator:        Token,
        operand:         *Expr,
        operand_is_type: bool,
        operand_type:    *Type
    ) -> *TypeOfExpr {
        var node = ctx->alloc::<TypeOfExpr>();

        // from Expr
        node->kind  = ExprKind::TypeOfExpr;
        node->range = range;
        node->ctx   = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwSizeOf && r"Expected a sizeof operator token");

        node->operand = operand;
        node->prefix  = true; // sizeof is always a prefix operator

        // from TypeOfExpr
        node->operand_is_type = operand_is_type;

        if (operand_is_type) {
            assert((operand_type != &null) && r"Expected operand_type to be set when operand_is_type is true");
            node->operand_type = operand_type;
        } else {
            assert((operand_type == &null) && r"Expected operand_type to be null when operand_is_type is false");
            node->operand_type = &null;
        }

        return node;
    }

    /// \brief creates a TypeOfExpr node marked as a RecoveryExpr.
    ///
    /// \details used by the parser when a type query is syntactically present
    ///          but contains
    ///          semantic errors (e.g. an unresolvable type name). this allows
    ///          sema to continue with a known-invalid node.
    static fn create_error(
        ctx:             *ASTContext,
        range:           SourceRange,
        operator:        Token,
        operand:         *Expr,
        operand_is_type: bool,
        operand_type:    *Type
    ) -> *TypeOfExpr {
        var node            = create(ctx, range, operator, operand, operand_is_type, operand_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TypeOfExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TypeOfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::TypeOfExpr;
    }

    fn is_operand_type(self) -> bool {
        return self.operand_is_type;
    }

    /// \brief returns the type operand if `operand_is_type` is true, else null.
    fn get_operand_type(self) -> *Type {
        if (!self.operand_is_type) {
            return &null;
        }

        return self.operand_type;
    }

    /// \brief returns the expression operand if `operand_is_type` is false,
    ///        else null.
    fn get_operand_expr(self) -> *Expr {
        if (self.operand_is_type) {
            return &null;
        }

        return self.operand;
    }
}

/// \class SizeOfExpr
/// \brief represents a compile-time request for the size of a type or an
///        expression.
///
/// \details `SizeOfExpr` is a specialized `TypeOfExpr` that evaluates to a
///          `usize`
///          representing the memory footprint of its operand in bytes. It
///          handles both type-based queries `sizeof(T)` and expression-based
///          queries `sizeof(expr)`.
///
/// ```kairo
/// var a = sizeof(u32); // operand_is_type = true var b = sizeof(my_var); //
/// operand_is_type = false
/// ```
///
/// results are calculated based on the target-specific data layout during sema
/// or constant evaluation.
class SizeOfExpr derives TypeOfExpr {
    /// \brief allocates and initializes a new SizeOfExpr node.
    ///
    /// \param ctx             the ASTContext to allocate from.
    /// \param range the full source range encompassing the `sizeof` call.
    /// \param operator        the `sizeof` keyword token.
    /// \param operand the target expression, or null if querying a type
    ///        directly.
    /// \param operand_is_type discriminator for the query kind.
    /// \param operand_type the resolved type being queried, or null if querying
    ///        an expression.
    static fn create(
        ctx:             *ASTContext,
        range:            SourceRange,
        operator:         Token,
        operand:          *Expr,
        operand_is_type:  bool,
        operand_type:     *Type
    ) -> *SizeOfExpr {
        var node = ctx->alloc::<SizeOfExpr>();

        // from Expr
        node->kind  = ExprKind::SizeOfExpr;
        node->range = range;
        node->ctx   = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwSizeOf && r"Expected a sizeof operator token");

        node->operand = operand;
        node->prefix  = true; // sizeof is always a prefix operator

        // from TypeOfExpr
        node->operand_is_type = operand_is_type;

        if (operand_is_type) {
            assert((operand_type != &null) && r"Expected operand_type to be set when operand_is_type is true");
            node->operand_type = operand_type;
        } else {
            assert((operand_type == &null) && r"Expected operand_type to be null when operand_is_type is false");
            node->operand_type = &null;
        }

        return node;
    }

    /// \brief constructs a SizeOfExpr wrapped in a RecoveryExpr kind.
    ///
    /// \details used when the parser encounters a malformed `sizeof` expression
    ///          but can
    ///          still recover enough structure to continue. Allows the compiler
    ///          to provide completion and navigation support in broken code.
    static fn create_error(
        ctx:             *ASTContext,
        range:            SourceRange,
        operator:         Token,
        operand:          *Expr,
        operand_is_type:  bool,
        operand_type:     *Type
    ) -> *SizeOfExpr {
        var node            = create(ctx, range, operator, operand, operand_is_type, operand_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SizeOfExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SizeOfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SizeOfExpr;
    }
}

/// \class AlignOfExpr
/// \brief represents a compile-time alignment query using the `alignof`
///        operator.
///
/// \details evaluates to the alignment requirements of a type or the type of an
///          expression, measured in bytes. stored as a `TypeOfExpr` because it
///          shares the dual-nature operand (type or expression).
///
/// ```kairo
/// var a = alignof(i32); // operand is a type var b = alignof(my_var); //
/// operand is an expression
/// ```
///
/// the resulting value is always a constant of type `usize`.
class AlignOfExpr derives TypeOfExpr {
    /// \brief creates a validated AlignOfExpr node.
    ///
    /// \param ctx             the ASTContext for node allocation.
    /// \param range           the full source range of the expression.
    /// \param operator        the `alignof` token.
    /// \param operand the expression being queried, or null if a type was
    ///        provided.
    /// \param operand_is_type flag indicating if the query was on a type
    ///        literal.
    /// \param operand_type the resolved type being queried, or null if an
    ///        expression was provided.
    static fn create(
        ctx:             *ASTContext,
        range:            SourceRange,
        operator:         Token,
        operand:          *Expr,
        operand_is_type:  bool,
        operand_type:     *Type
    ) -> *AlignOfExpr {
        var node = ctx->alloc::<AlignOfExpr>();

        // from Expr
        node->kind     = ExprKind::AlignOfExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwAlignOf && r"Expected an alignof operator token");

        node->operand  = operand;
        node->prefix   = true; // alignof is always a prefix operator

        // from TypeOfExpr
        node->operand_is_type = operand_is_type;

        if (operand_is_type) {
            assert((operand_type != &null) && r"Expected operand_type to be set when operand_is_type is true");
            node->operand_type = operand_type;
        } else {
            assert((operand_type == &null) && r"Expected operand_type to be null when operand_is_type is false");
            node->operand_type = &null;
        }

        return node;
    }

    /// \brief creates an AlignOfExpr wrapped in a RecoveryExpr for error
    ///        resilience.
    ///
    /// \details used by the parser when an `alignof` expression is
    ///          syntactically
    ///          present but contains internal semantic or grammatical errors.
    static fn create_error(
        ctx:             *ASTContext,
        range:            SourceRange,
        operator:         Token,
        operand:          *Expr,
        operand_is_type:  bool,
        operand_type:     *Type
    ) -> *AlignOfExpr {
        var node            = create(ctx, range, operator, operand, operand_is_type, operand_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::AlignOfExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::AlignOfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::AlignOfExpr;
    }
}

/// \class SelfExpr
/// \brief represents the `self` keyword used to refer to the current instance.
///
/// \details encodes a reference to the receiver of a method or the current
///          instance within a class, struct, or interface scope. for example,
///          in `fn method(self) { self.field = 0; }`, the second `self` is
///          lowered to a `SelfExpr`.
///
/// sema resolves this expression to the implicit or explicit `self` parameter
/// of the containing function. it derives from `NamedIdentExpr` to treat the
/// `self` keyword as a specialized identifier.
class SelfExpr derives NamedIdentExpr {
    /// \brief allocates and initializes a new `SelfExpr` node.
    ///
    /// \param ctx    the AST context used for node allocation.
    /// \param range  the full source range of the `self` expression.
    /// \param token  the `self` keyword token; must be `TokenKind::KwSelf`.
    static fn create(
        ctx:   *ASTContext,
        range: SourceRange,
        token: Token
    ) -> *SelfExpr {
        var node = ctx->alloc::<SelfExpr>();

        // from Expr
        node->kind  = ExprKind::SelfExpr;
        node->range = range;
        node->ctx   = ctx;

        // from NamedIdentExpr
        node->name  = token;

        assert(token.kind == TokenKind::KwSelf && r"Expected a self keyword token");

        return node;
    }

    /// \brief creates a `SelfExpr` marked as a recovery node.
    ///
    /// \details used by the parser when `self` is found in an invalid context
    ///          (e.g., inside a static function) to allow continued parsing
    ///          while suppressing downstream type-checking errors.
    static fn create_error(
        ctx:   *ASTContext,
        range: SourceRange,
        token: Token
    ) -> *SelfExpr {
        var node            = create(ctx, range, token);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SelfExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SelfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SelfExpr;
    }
}

/// \class SubscriptExpr
/// \brief represents an indexing or slicing operation on a collection or
///        pointer.
///
/// \details handles both single-element access (e.g., `arr[index]`) and slice
///          projections (e.g., `arr[1..5]`). the distinction is tracked by the
///          `is_slice` flag, which determines whether the expression evaluates
///          to an element type or a slice view of the base.
///
/// for slice operations, the `index` field typically points to a `RangeExpr`.
/// for regular subscripts, the `index` must evaluate to an integral type
/// compatible with the collection's indexing requirements.
class SubscriptExpr derives Expr {
    pub var base:     *Expr; ///< the expression being indexed (e.g., the `arr`
                             ///  in `arr[i]`).
    pub var index:    *Expr; ///< the index or range expression (e.g., the `i`
                             ///  in `arr[i]`).
    pub var is_slice: bool;  ///< true if this is a slice subscript like
                             ///  `arr[1..3]`, false if a regular subscript like
                             ///  `arr[1]`.

    /// \brief creates a new SubscriptExpr node in the provided ASTContext.
    static fn create(
        ctx:      *ASTContext,
        range:    SourceRange,
        base:     *Expr,
        index:    *Expr,
        is_slice: bool
    ) -> *SubscriptExpr {
        var node = ctx->alloc::<SubscriptExpr>();

        // from Expr
        node->kind  = ExprKind::SubscriptExpr;
        node->range = range;
        node->ctx   = ctx;

        // from SubscriptExpr
        node->base     = base;
        node->index    = index;
        node->is_slice = is_slice;

        return node;
    }

    /// \brief creates a SubscriptExpr node tagged as a RecoveryExpr for error
    ///        resilience.
    ///
    /// \details used by the parser when a subscript is syntactically present
    ///          but
    ///          semantically invalid (e.g., indexing a non-indexable type).
    static fn create_error(
        ctx:      *ASTContext,
        range:    SourceRange,
        base:     *Expr,
        index:    *Expr,
        is_slice: bool
    ) -> *SubscriptExpr {
        var node            = create(ctx, range, base, index, is_slice);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SubscriptExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SubscriptExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SubscriptExpr;
    }

    fn get_base(self) -> *Expr {
        return self.base;
    }

    fn get_index(self) -> *Expr {
        return self.index;
    }
}

/// \class TypeCastExpr
/// \brief represents an explicit type conversion using the `as` operator.
///
/// \details in the Kairo AST, type casts are treated as high-level expressions
///          rather
///          than binary operators, even though they utilize an infix keyword.
///          this node captures both the source expression and the resolved
///          target type.
///
/// \code
/// var x = 10 as f64;
/// \endcode
/// in the example above, `10` is the `left` operand, `as` is the `operator`,
/// and `f64` is the `target_type`.
class TypeCastExpr derives Expr {
    pub var operator:    Token; ///< the cast operator token; must be
                                ///  `TokenKind::KwAs`.
    pub var left:        *Expr; ///< the expression being converted.
    pub var target_type: *Type; ///< the resulting type the operand is cast
                                ///  into.

    /// \brief allocates and initializes a new TypeCastExpr.
    ///
    /// \param ctx          ASTContext for node allocation.
    /// \param range full source range encompassing the operand and target type.
    /// \param operator     the `as` token.
    /// \param left         the expression whose value is being cast.
    /// \param target_type  the resolved type to cast into.
    static fn create(
        ctx:         *ASTContext,
        range:       SourceRange,
        operator:    Token,
        left:        *Expr,
        target_type: *Type
    ) -> *TypeCastExpr {
        var node = ctx->alloc::<TypeCastExpr>();

        // from Expr
        node->kind  = ExprKind::TypeCastExpr;
        node->range = range;
        node->ctx   = ctx;

        // from TypeCastExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwAs && r"Expected a cast operator token");

        node->left        = left;
        node->target_type = target_type;

        return node;
    }

    /// \brief creates a TypeCastExpr marked as a recovery node for error
    ///        resilience.
    ///
    /// \details used during parsing or sema when a cast expression is
    ///          syntactically
    ///          present but semantically invalid. this allows the compiler to
    ///          continue analysis while tracking that this node represents a
    ///          failed cast.
    static fn create_error(
        ctx:         *ASTContext,
        range:       SourceRange,
        operator:    Token,
        left:        *Expr,
        target_type: *Type
    ) -> *TypeCastExpr {
        var node            = create(ctx, range, operator, left, target_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TypeCastExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TypeCastExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::TypeCastExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_left(self) -> *Expr {
        return self.left;
    }

    fn get_target_type(self) -> *Type {
        return self.target_type;
    }
}

/// \class MacroInvocationExpr
/// \brief represents a call to a compiler-defined or user-defined macro.
///
/// \details covers both procedural and declarative macro calls in the AST.
///          syntactically, these appear as either basic bang-calls `name!(...)`
///          or attribute-style calls `@name(...)`. the compiler treats these as
///          expressions that are typically expanded during the sema pass,
///          though some may persist or be lowered directly to intrinsic
///          operations.
///
/// EXAMPLE: `print!("val: {}", x)` results in a `MacroInvocationExpr` where
/// `is_basic` is true. `@serialize(obj)` results in a `MacroInvocationExpr`
/// where `is_basic` is false.
class MacroInvocationExpr derives Expr {
    pub var macro_path: *ChainExpr;           ///< unresolved path to the macro
                                              ///  definition.
    pub var args:       FrozenList::<*Expr>;  ///< arguments passed to the
                                              ///  macro.
    pub var is_basic:   bool = false;         ///< true for `name!()`, false for
                                              ///  `@name()`.

    /// \brief allocates and initializes a new macro invocation node.
    ///
    /// \param ctx         ASTContext for arena allocation.
    /// \param range full source range from the start of the path/at-sign to the
    ///        closing paren.
    /// \param macro_path  the identifier or path used to look up the macro.
    /// \param args temporary vector of argument expressions to be frozen into
    ///        the node.
    /// \param is_basic    discriminator for the `!` vs `@` syntax.
    static fn create(
        ctx:        *ASTContext,
        range:      SourceRange,
        macro_path: *ChainExpr,
        args:       *vec::<*Expr>,
        is_basic:   bool
    ) -> *MacroInvocationExpr {
        var node = ctx->alloc::<MacroInvocationExpr>();

        // from Expr
        node->kind  = ExprKind::MacroInvocationExpr;
        node->range = range;
        node->ctx   = ctx;

        // from MacroInvocationExpr
        node->macro_path = macro_path;

        var arr = ctx->alloc_array::<*Expr>(args->size());
        for var i: usize = 0; i < args->size(); ++i {
            arr[i] = (*args)[i];
        }

        node->args.from_raw(arr, args->size());
        node->is_basic = is_basic;

        return node;
    }

    /// \brief creates a macro invocation node marked as a recovery expression.
    ///
    /// \details used by the parser when a macro call is syntactically valid but
    ///          known to be semantically broken (e.g. invalid argument types
    ///          encountered early). allows the compiler to continue parsing
    ///          while suppressing redundant diagnostics.
    static fn create_error(
        ctx:        *ASTContext,
        range:      SourceRange,
        macro_path: *ChainExpr,
        args:       *vec::<*Expr>,
        is_basic:   bool
    ) -> *MacroInvocationExpr {
        var node            = create(ctx, range, macro_path, args, is_basic);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MacroInvocationExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MacroInvocationExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::MacroInvocationExpr;
    }

    /// \brief returns the final segment of the macro path.
    fn get_macro_name(self) -> *ChainExpr::ChainSegment {
        return self.macro_path->last();
    }

    fn get_args(self) -> FrozenList::<*Expr> {
        return self.args;
    }
}

/// \class PackExpansionExpr
/// \brief represents a variadic pack expansion.
///
/// \details a pack expansion consists of a pattern and an ellipsis `...`
///          operator
///          that triggers expansion over a template or function parameter pack.
///          the expansion can be either prefixed (e.g., `...args`) or postfixed
///          (e.g., `args...`) depending on the context and syntactic style.
///
/// ```kairo
/// fn print_all(args: ...T) { do_something(args...); // PackExpansionExpr
/// (postfix) consume(...args); // PackExpansionExpr (prefix) }
/// ```
///
/// lowering this node requires identifying the unexpanded parameter packs
/// within the `pattern`. if no packs are found during sema, the expansion is
/// ill-formed.
class PackExpansionExpr derives Expr {
    pub var pattern:  *Expr;
    pub var prefixed: bool;  ///< true if the ellipsis precedes the pattern
                             ///  (`...expr`).

    /// \brief creates a well-formed pack expansion node.
    ///
    /// \param ctx       ASTContext for node allocation.
    /// \param range source range covering both the pattern and the ellipsis.
    /// \param pattern   the expression to be expanded.
    /// \param prefixed  the syntactic orientation of the ellipsis.
    static fn create(
        ctx:      *ASTContext,
        range:     SourceRange,
        pattern:  *Expr,
        prefixed:  bool
    ) -> *PackExpansionExpr {
        var node = ctx->alloc::<PackExpansionExpr>();

        // from Expr
        node->kind     = ExprKind::PackExpansionExpr;
        node->range    = range;
        node->ctx      = ctx;

        // from PackExpansionExpr
        node->pattern  = pattern;
        node->prefixed = prefixed;

        return node;
    }

    /// \brief creates a pack expansion node marked for error recovery.
    ///
    /// \details used when the expansion syntax is detected but the pattern
    ///          itself
    ///          is malformed or no valid pack is found within the pattern.
    static fn create_error(
        ctx:      *ASTContext,
        range:     SourceRange,
        pattern:  *Expr,
        prefixed:  bool
    ) -> *PackExpansionExpr {
        var node            = create(ctx, range, pattern, prefixed);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::PackExpansionExpr;

        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::PackExpansionExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::PackExpansionExpr;
    }

    fn get_pattern(self) -> *Expr {
        return self.pattern;
    }
}/// \class ImplicitBoundaryCastExpr
/// \brief represents an implicit type conversion at a foreign function
///        interface (FFI) boundary.
///
/// \details inserted by sema when a Kairo value is passed to or returned from
///          an `__inline_cpp`
///          block or an `extern` C++ function. it bridges the semantic gap
///          between Kairo's high-level type system and the physical ABI
///          requirements of the target C++ type.
///
/// these nodes are invisible to the programmer and do not appear in source
/// code. they serve as hints for codegen to emit necessary conversion logic,
/// such as wrapping/unwrapping pointers or adjusting calling conventions.
///
/// EXAMPLE lowering: `extern fn f(x: i32); f(5);` ->
/// `f(ImplicitBoundaryCastExpr(5, i32, int))`
class ImplicitBoundaryCastExpr derives Expr {
    pub var operand:         *Expr; ///< the underlying expression being cast.
    pub var source_type:     *Type; ///< the native Kairo type of the operand.
    pub var target_abi_type: *Type; ///< the target C++ ABI type required at the
                                    ///  boundary.

    /// \brief creates a new ImplicitBoundaryCastExpr node.
    ///
    /// \param ctx             ASTContext used for node allocation.
    /// \param range source range, typically inherited from the `operand`.
    /// \param operand         the expression to be cast.
    /// \param source_type     native Kairo type.
    /// \param target_abi_type destination ABI type.
    static fn create(
        ctx:             *ASTContext,
        range:            SourceRange,
        operand:         *Expr,
        source_type:     *Type,
        target_abi_type: *Type
    ) -> *ImplicitBoundaryCastExpr {
        var node = ctx->alloc::<ImplicitBoundaryCastExpr>();

        // from Expr
        node->kind  = ExprKind::ImplicitBoundaryCastExpr;
        node->range = range;
        node->ctx   = ctx;

        // from ImplicitBoundaryCastExpr
        node->operand         = operand;
        node->source_type     = source_type;
        node->target_abi_type = target_abi_type;

        return node;
    }

    static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::ImplicitBoundaryCastExpr;
    }

    static fn expr_kind() -> ExprKind {
        return ExprKind::ImplicitBoundaryCastExpr;
    }

    fn get_operand(self) -> *Expr {
        return self.operand;
    }

    fn get_source_type(self) -> *Type {
        return self.source_type;
    }

    fn get_target_abi_type(self) -> *Type {
        return self.target_abi_type;
    }
}

/// \class ClosureExpr
/// \brief represents an anonymous function literal or lambda expression.
///
/// \details captures the source representation of a closure, such as `|x, y| x
///          + y`.
///          lowering considerations include capturing local variables by value
///          or reference and generating an anonymous struct to hold the capture
///          state.
///
/// \note closures may be generic and involve complex type inference; this node
///       remains an empty shell until the compiler's transition to a more
///       complete generic type system is finalized.
class ClosureExpr derives Expr {
    // nothing here for now since clousres can have gernics types need to be complete
}

// free function: is_primary_expr
eval fn is_primary_expr(expr: *Expr) -> bool {
    switch expr->kind {
        case ExprKind::IntegerLiteralExpr:
        case ExprKind::FloatingLiteralExpr:
        case ExprKind::StringLiteralExpr:
        case ExprKind::CharacterLiteralExpr:
        case ExprKind::BooleanLiteralExpr:
        case ExprKind::NullLiteralExpr:
        case ExprKind::ListLiteralExpr:
        case ExprKind::TupleLiteralExpr:
        case ExprKind::SetLiteralExpr:
        case ExprKind::MapLiteralExpr:
        case ExprKind::ArrayInitializerExpr:
        case ExprKind::VectorInitializerExpr:
        case ExprKind::MapInitializerExpr:
        case ExprKind::SetInitializerExpr:
        case ExprKind::NamedInitializerExpr: // ambiguous
        case ExprKind::AnonInitializerExpr:
        case ExprKind::ChainExpr: // ambiguous
        case ExprKind::NamedIdentExpr:
        case ExprKind::SelfExpr:
        case ExprKind::GroupingExpr:
        case ExprKind::IfExpr:
        case ExprKind::InlineTryCatchExpr:
        case ExprKind::ClosureExpr:
        case ExprKind::MacroInvocationExpr: // ambiguous
        case ExprKind::SizeOfExpr:
        case ExprKind::AlignOfExpr:
        case ExprKind::TypeOfExpr:
        case ExprKind::AwaitExpr:
        case ExprKind::SpawnExpr:
        case ExprKind::ThreadExpr:
        case ExprKind::EvalExpr:
        case ExprKind::UnaryOperatorExpr: // ambiguous
        case ExprKind::PackExpansionExpr: // ambiguous
            return true;

        default:
            return false;
    }

    return false;
}