import ASTNode::Base::*;

///
/// \brief RTTI casting system for Kairo AST nodes.
///
/// All casts are based on the kind field at offset 0 of every node.
/// No vtable, no dynamic_cast, no typeid.
///
/// Three cast functions per hierarchy:
///   isa<T>(ptr)     check if ptr is a T, no cast
///   cast<T>(ptr)    assert + static_cast, crashes in debug if wrong
///   dyn_cast<T>(ptr)returns null if not a T, T* if it is
///
/// The kind field is always valid even on RecoveryExpr nodes because
/// create_error() always allocates the full concrete node and sets
/// recovery_kind. See the recovery casting contract in Expr.
///
/// Recovery casting:
///   isa_recovery<T>(ptr)     checks recovery_kind instead of kind
///   cast_recovery<T>(ptr)    cast via recovery_kind, debug assert
///   dyn_cast_recovery<T>(ptr)safe cast via recovery_kind
///
/// Usage:
///   if isa::<IntegerLiteralExpr>(e) { ... }
///   var lit = cast::<IntegerLiteralExpr>(e);
///   if var lit = dyn_cast::<IntegerLiteralExpr>(e) { ... }
///
fn <T> isa(ptr: *Expr) -> bool {
    if ptr == &null {
        return false;
    }

    return T::classof(ptr);
}

fn <T> isa(ptr: *Stmt) -> bool {
    if ptr == &null {
        return false;
    }

    return T::classof(ptr);
}

fn <T> isa(ptr: *Decl) -> bool {
    if ptr == &null {
        return false;
    }

    return T::classof(ptr);
}

fn <T> isa(ptr: *Type) -> bool {
    if ptr == &null {
        return false;
    }

    return T::classof(ptr);
}

__inline_cpp("
template <typename T>
inline const T *cast(const Expr *ptr) {
    assert(ptr != nullptr && \"cast<>: null pointer\");
    assert(T::classof(ptr) && \"cast<>: incorrect type\");
    return static_cast<const T*>(ptr);
}

template <typename T>
inline const T *cast(const Stmt *ptr) {
    assert(ptr != nullptr && \"cast<>: null pointer\");
    assert(T::classof(ptr) && \"cast<>: incorrect type\");
    return static_cast<const T*>(ptr);
}

template <typename T>
inline const T *cast(const Decl *ptr) {
    assert(ptr != nullptr && \"cast<>: null pointer\");
    assert(T::classof(ptr) && \"cast<>: incorrect type\");
    return static_cast<const T*>(ptr);
}

template <typename T>
inline const T *cast(const Type *ptr) {
    assert(ptr != nullptr && \"cast<>: null pointer\");
    assert(T::classof(ptr) && \"cast<>: incorrect type\");
    return static_cast<const T*>(ptr);
}
");

fn <T> cast(ptr: *Expr) -> *T {
    assert((ptr != &null)    && r"cast<>: null pointer");
    assert((T::classof(ptr)) && r"cast<>: incorrect type");
    return static_cast::<*T>(ptr);
}

fn <T> cast(ptr: *Stmt) -> *T {
    assert((ptr != &null)    && r"cast<>: null pointer");
    assert((T::classof(ptr)) && r"cast<>: incorrect type");
    return static_cast::<*T>(ptr);
}

fn <T> cast(ptr: *Decl) -> *T {
    assert((ptr != &null)    && r"cast<>: null pointer");
    assert((T::classof(ptr)) && r"cast<>: incorrect type");
    return static_cast::<*T>(ptr);
}

fn <T> cast(ptr: *Type) -> *T {
    assert((ptr != &null)    && r"cast<>: null pointer");
    assert((T::classof(ptr)) && r"cast<>: incorrect type");
    return static_cast::<*T>(ptr);
}


fn <T> dyn_cast(ptr: *Expr) -> *T {
    if (ptr != &null) && isa::<T>(ptr) {
        return static_cast::<*T>(ptr);
    }

    return &null;
}

fn <T> dyn_cast(ptr: *Stmt) -> *T {
    if (ptr != &null) && isa::<T>(ptr) {
        return static_cast::<*T>(ptr);
    }

    return &null;
}

fn <T> dyn_cast(ptr: *Decl) -> *T {
    if (ptr != &null) && isa::<T>(ptr) {
        return static_cast::<*T>(ptr);
    }

    return &null;
}

fn <T> dyn_cast(ptr: *Type) -> *T {
    if (ptr != &null) && isa::<T>(ptr) {
        return static_cast::<*T>(ptr);
    }

    return &null;
}


