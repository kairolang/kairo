/// Support code for the parser and related tools.  This is not intended to be
/// a general-purpose library, but rather a place for shared utilities that
/// are used across multiple parser components (e.g. the main parser, the
/// lexer, the AST printer, etc).

/// This contains:
///   - Common data strcutures, interfaces, and utilities for the parser and related tools.
///   - Also our custom RTTI system.

///   [x] IntegerLiteralExpr                                                 ///
///   [x] FloatingLiteralExpr                                                ///
///   [x] StringLiteralExpr                                                  ///
///   [x] CharacterLiteralExpr                                               ///
///   [x] BooleanLiteralExpr                                                 ///
///   [x] NullLiteralExpr                                                    ///

///   [-] ListLiteralExpr                                                    ///
///   [-] TupleLiteralExpr                                                   ///
///   [-] SetLiteralExpr                                                     ///
///   [-] MapLiteralExpr                                                     ///

///   [-] ArrayInitializerExpr                                               ///
///   [-] VectorInitializerExpr                                              ///
///   [-] MapInitializerExpr                                                 ///
///   [-] SetInitializerExpr                                                 ///

///   [ ] NamedInitializerExpr                                               ///
///   [ ] AnonInitializerExpr                                                ///
///   [ ] QualifiedPathExpr                                                  ///
///   [ ] GroupingExpr                                                       ///
///   [ ] UnaryOperatorExpr                                                  ///
///   [ ] BinaryOperatorExpr                                                 ///
///   [ ] ImplConformanceExpr                                                ///
///   [ ] DerivesRelationExpr                                                ///
///   [ ] ConditionalExpr                                                    ///
///   [ ] IfExpr                                                             ///
///   [ ] InlineTryCatchExpr                                                 ///
///   [ ] RangeExpr                                                          ///
///   [ ] ClosureExpr                                                        ///
///   [ ] AwaitExpr                                                          ///
///   [ ] SpawnExpr                                                          ///
///   [ ] ThreadExpr                                                         ///
///   [ ] MacroInvocationExpr                                                ///
///   [ ] SizeOfExpr                                                         ///
///   [ ] AlignOfExpr                                                        ///
///   [ ] TypeOfExpr                                                         ///
///   [ ] EvalExpr                                                           ///
///   [ ] SelfExpr                                                           ///
