///   [ ] SubscriptExpr                                                      ///
///   [ ] PackExpansionExpr                                                  ///
///   [ ] DestructuringBindingExpr                                           ///
///   [ ] MatchBindingExpr                                                   ///
///   [ ] TypeCastExpr                                                       ///
