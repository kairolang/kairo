{
  "version": "0.2.0",
  "configurations": [
    {
        "name": "Run Kairo File",
        "request": "launch",
        "cwd": "${workspaceFolder}",
        "preLaunchTask": "build-kairo-current",
        "console": "integratedTerminal",   // <—— important
        "stopAtEntry": false,
        
        // Defaults (non-Windows → cppdbg)
        "type": "cppdbg",
        "program": "${workspaceFolder}/build/.gens/dbg_run",
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb",

        "osx": {
            "MIMode": "lldb",
            "miDebuggerPath": "/usr/bin/lldb"
        },
        "windows": {
            "type": "cppvsdbg",
            "program": "${workspaceFolder}/build/.gens/dbg_run.exe"
        }
    }
  ]
}
