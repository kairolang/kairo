// this is the language definition for helix
// this is higher level then ebnf and is used to define the syntax of helix
// this is a sudo code language that defines the syntax and ast structure of helix


class Point {
    pub let x: f32
    pub let y: f32
}


class Shape {
    pub fn area() -> f32 { return 0.0 }
}

class Circle derives Shape {
    pub fn area() -> f32 { return 3.14 * radius * radius }
    pub let radius: f32
}

class Base {
    pub fn greet() -> str { return "Hello from Base" }
}

class Derived derives Base {
    pub fn greet(names: string) -> str { return "Hello from Derived" }
}


class Base1 {
    pub fn message() -> str { return "Base1" }
}

class Base2 {
    pub fn message() -> str { return "Base2" }
}

class Derived derives Base1, Base2 {
    pub fn message_base1() -> str { return Base1.message() }
    pub fn message_base2() -> str { return Base2.message() }
}


class Animal {
    pub fn speak() -> str { return "Unknown sound" }
}

class Dog derives Animal {
    pub fn speak() -> str { return "Bark" }
}

fn make_noise(a: Box<Animal>) {
    print(a.speak()) // Uses v-table lookup
}

fn make_noise(a: T) requires <T> if T has Animal {
    print(a.speak())  // No v-table lookup, method is inlined
}

class SecureData {
    priv let key: str

    pub fn get_key() -> str { return key }
}