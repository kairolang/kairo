class NamedIdentifier derives Expr {
    var name: Token;
    
    fn get_name() -> string {

    }
};

class NamedDecl derives Decl, NamedIdentifier { // contains name

}

class <T> ReDeclarable {
    var first:    *T;   // canonical first decl seen
    var previous: *T;   // previous in chain, null if first
    var most_recent: *T; // tail of chain

    fn get_canonical(self) -> *T { return self.first; }
    fn get_previous(self)  -> *T { return self.previous; }
    fn get_last(self)      -> *T { return self.most_recent; }
}

class BasicParameterDecl derives NamedDecl {
    // name is inherited from NamedIdentifier
    // also inherits range and kind from Expr, but kind is always ParameterDecl
    enum Kind {
        /// Basic typed parameter: x: i32
        /// Most common case.
        Typed,

        /// Typed with default value: x: i32 = 0
        TypedWithDefault,

        /// Const parameter value cannot be mutated inside the function.
        /// const x: i32
        Const,

        /// Self receiver by value consumes the object.
        /// self
        SelfValue,

        /// Self receiver by pointer borrows the object.
        /// &self
        SelfPointer,

        /// Pointer-prefixed parameter caller passes value, fn sees pointer.
        /// *x: i32
        /// Distinct from a parameter whose TYPE is a pointer.
        PointerReceiver,

        /// Unsafe Pointer-prefixed parameter caller passes value, fn sees pointer.
        /// unsafe *x: i32
        UnsafePointerReceiver,

        /// Named parameter caller must supply the name at call site.
        /// Distinct from positional: named: x: i32
        Named,

        /// Kairo variadic pack: ..args: [i32]
        /// Caller passes zero or more values, collected into a slice.
        VariadicPack,
    }

    var typ: *Type;
    var default_value: *Expr;  // optional, for default parameters
    var param_kind: Kind;

    fn is_variadic_pack(self) -> bool {
        return self.param_kind == Kind::VariadicPack;
    }

    fn is_self_receiver(self) -> bool {
        return (self.param_kind == Kind::SelfValue)
            || (self.param_kind == Kind::SelfPointer);
    }

    fn is_const(self) -> bool {
        return self.param_kind == Kind::Const;
    }

    fn is_pointer_receiver(self) -> bool {
        return self.param_kind == Kind::PointerReceiver;
    }
     
    fn is_named(self) -> bool {
        return self.param_kind == Kind::Named;
    }

    fn is_typed(self) -> bool {
        return (self.param_kind == Kind::Typed)
            || (self.param_kind == Kind::TypedWithDefault);
    }

    fn has_default(self) -> bool {
        return (self.param_kind == Kind::TypedWithDefault)
            || (self.default_value != &null);
    }

    fn is_self_receiver_by_value(self) -> bool {
        return self.param_kind == Kind::SelfValue;
    }

    fn is_self_receiver_by_pointer(self) -> bool {
        return self.param_kind == Kind::SelfPointer;
    }

    fn is_unsafe_pointer_receiver(self) -> bool {
        return self.param_kind == Kind::UnsafePointerReceiver;
    }
};

class ParamList derives BasicParameterDecl {
    const MAX_PARAMS: usize = 256;
    const MAX_INDEX:  usize = MAX_PARAMS - 1;
    var param_list :  ArenaList::<BasicParameterDecl>;
};


enum InlineBlockLang derives u8 {
    /// Clang: -x assembler-with-cpp
    /// inline "asm" { }
    Asm,

    /// Clang: -x c
    /// inline "c" { }
    C,

    /// Clang: -x c++
    /// inline "c++" { }
    Cxx,

    /// Clang: -x cuda  (requires CUDA toolkit)
    /// inline "cuda" { }
    Cuda,

    /// Clang: -x hip  (requires ROCm)
    /// inline "hip" { }
    Hip,

    /// Clang: -x opencl
    /// inline "OpenCL" { }
    OpenCL,

    /// Clang: -x hlsl  (Clang 15+)
    /// inline "hlsl" { }
    Hlsl,

    /// Apple metal compiler (xcrun metal), NOT standard Clang
    /// requires Apple toolchain
    /// inline "metal" { }
    Metal,

    /// OpenCL source compiled to SPIR-V via --target=spirv32/spirv64
    /// not a separate language, just OpenCL with a different target
    /// inline "spirv" { }
    SpirV,

    /// naga or tint compiler, NOT Clang
    /// requires separate WGSL toolchain
    /// inline "wgsl" { }
    Wgsl,

    /// glslang or shaderc, NOT Clang
    /// requires separate GLSL toolchain
    /// inline "glsl" { }
    Glsl,

    /// does absolutely nothing, just for fucks and giggles
    /// ACTUALLY MIGHT BE USEFUL FOR ADDING KAIRO DIRECTLY INTO C++ CODE
    /// inline "kairo" { }
    Kairo,
};