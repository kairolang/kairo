///------------------------------------------------------------ KAIRO -------///
/// Support code for the parser and related tools.  This is not intended to be
/// a general-purpose library, but rather a place for shared utilities that
/// are used across multiple parser components (e.g. the main parser, the
/// lexer, the AST printer, etc).

/// This contains:
///   - Common data strcutures, interfaces, and utilities for the parser and related tools.
///   - Also our custom RTTI system.

import Core::Memory::ArenaList::*;
import Core::Source::SourceRange::*;
import Core::Source::SourceManager::*;
import Lexer::Token::*;
import Lexer::Immediate::*;

import Parser::DeclContextKind::*;
import Parser::DeclKind::*;
import Parser::ExprKind::*;
import Parser::PatternKind::*;
import Parser::TypeKind::*;
import Parser::StmtKind::*;

class Expr {
    pub var _range: SourceRange;
    pub var _kind:  ExprKind;
    // required for getting the actual text from a token's source range
    pub var _sm:      *SourceManager;
    pub var _imm_tbl: *ImmediateTable;

    fn range(self) -> SourceRange {
        return self._range;
    }

    fn kind(self) -> ExprKind {
        return self._kind;
    }
    
    static fn classof(ptr: *Expr) -> bool;
}

class Stmt {
    pub var _range: SourceRange;
    pub var _kind:  StmtKind;
    // required for getting the actual text from a token's source range
    pub var _sm:      *SourceManager;
    pub var _imm_tbl: *ImmediateTable;

    fn range(self) -> SourceRange {
        return self._range;
    }

    fn kind(self) -> StmtKind {
        return self._kind;
    }
    
    static fn classof(ptr: *Stmt) -> bool;
}

class Decl {
    pub var _range: SourceRange;
    pub var _kind:  DeclKind;
    // required for getting the actual text from a token's source range
    pub var _sm:      *SourceManager;
    pub var _imm_tbl: *ImmediateTable;

    fn range(self) -> SourceRange {
        return self._range;
    }

    fn kind(self) -> DeclKind {
        return self._kind;
    }
    
    static fn classof(ptr: *Decl) -> bool;
}

class Type {
    pub var _range: SourceRange;
    pub var _kind:  ExprKind;
    // required for getting the actual text from a token's source range
    pub var _sm:      *SourceManager;
    pub var _imm_tbl: *ImmediateTable;

    fn range(self) -> SourceRange {
        return self._range;
    }

    fn kind(self) -> ExprKind {
        return self._kind;
    }
    
    static fn classof(ptr: *Type) -> bool;
}

