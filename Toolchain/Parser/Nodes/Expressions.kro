        return self.base;
    }

    fn get_index(self) -> *Expr {
        return self.index;
    }
}

class TypeCastExpr derives Expr {
    pub var operator:    Token; // the cast operator token, e.g. 'as'
    pub var left:        *Expr; // the operand being casted, stored in the
    pub var target_type: *Type; // we don't use the right side of the binary operator for type casts, instead we store the target type in the TypeCastExpr itself

    static fn create(
        ctx: *ASTContext,
        range: SourceRange,
        operator: Token,
        left: *Expr,
        target_type: *Type
    ) -> *TypeCastExpr {
        var node = ctx->alloc::<TypeCastExpr>();
        // from Expr
        node->kind     = ExprKind::TypeCastExpr;
        node->range    = range;
        // from TypeCastExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwAs && r"Expected a cast operator token");
        node->left     = left;
        node->target_type = target_type;
        return node;
    }

    static fn create_error(
        ctx: *ASTContext,
        range: SourceRange,
        operator: Token,
        left: *Expr,
        target_type: *Type
    ) -> *TypeCastExpr {
        var node            = create(ctx, range, operator, left, target_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TypeCastExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TypeCastExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::TypeCastExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_left(self) -> *Expr {
        return self.left;
    }

    fn get_target_type(self) -> *Type {
        return self.target_type;
    }
}

class MacroInvocationExpr derives Expr {
    pub var macro_path: *ChainExpr;
    pub var args: FrozenList::<*Expr>;
    pub var is_basic: bool = false; // true for foo!(), false for @foo()

    static fn create(
        ctx: *ASTContext,
        range: SourceRange,
        macro_path: *ChainExpr,
        args: *vec::<*Expr>, // a temp stack allocated vector
        is_basic: bool
    ) -> *MacroInvocationExpr {
        var node = ctx->alloc::<MacroInvocationExpr>();
        // from Expr
        node->kind     = ExprKind::MacroInvocationExpr;
        node->range    = range;
        // from MacroInvocationExpr
        node->macro_path = macro_path;
        var arr = ctx->alloc_array::<*Expr>(args->size());
        for var i: usize = 0; i < args->size(); ++i {
            arr[i] = (*args)[i];
        }

        node->args.from_raw(arr, args->size());
        node->is_basic = is_basic;
        return node;
    }

    static fn create_error(
        ctx: *ASTContext,
        range: SourceRange,
        macro_path: *ChainExpr,
        args: *vec::<*Expr>, // a temp stack allocated vector
        is_basic: bool
    ) -> *MacroInvocationExpr {
        var node            = create(ctx, range, macro_path, args, is_basic);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MacroInvocationExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MacroInvocationExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::MacroInvocationExpr;
    }

    fn get_macro_name(self) -> *ChainExpr::ChainSegment {
        return self.macro_path->last();
    }

    fn get_args(self) -> FrozenList::<*Expr> {
        return self.args;
    }
}

