class SetLiteralExpr derives SetInitializerExpr {
    // Node: SetLiteralExpr list of distinct (value Expr*) values
    pub const MAX_VALUES: usize = 65535; // arbitrary limit to prevent overflow in the bitset used for deduping small sets, and to prevent excessive memory usage in general
    pub const MAX_INDEX: usize = MAX_VALUES - 1;

    pub var values: FrozenList::<*Expr>;
    pub var is_deduped: bool = false; // set to true by sema after deduping the values, so that later stages can skip redundant deduping if needed
    pub var is_sorted: bool = false; // set to true by sema after sorting the values, so that later stages can skip redundant sorting if needed

    static fn create(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:   *Type,
        values:         *vec::<*Expr>, // a temp stack allocated vector
        is_deduped:      bool,
        is_sorted:       bool
    ) -> *SetLiteralExpr {
        var node = ctx->alloc::<SetLiteralExpr>();
        // from Expr
        node->kind     = ExprKind::SetLiteralExpr;
        node->range    = range;
        // CollectionExpr
        node->collection_kind = collection_kind;
        // from SetInitializerExpr
        node->element_type = element_type;
        // from SetLiteralExpr
        var arr = ctx->alloc_array::<*Expr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->is_deduped = is_deduped;
        node->is_sorted = is_sorted;

        return node;
    }

    static fn create_error(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        element_type:   *Type,
        values:         *vec::<*Expr>, // a temp stack allocated vector
        is_deduped:      bool,
        is_sorted:       bool
    ) -> *SetLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            element_type,
            values,
            is_deduped,
            is_sorted
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SetLiteralExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SetLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SetLiteralExpr;
    }
}

class TupleLiteralExpr derives CollectionExpr {
    // Node: MapLiteralExpr list of (key Expr*, value Expr*) pairs.
    __inline_cpp("public:");

    struct TupleValueExpr {
        var value: *Expr;
        var element_type: *Type; // set by sema based on the corresponding element type in the tuple type, so that later stages can optimize based on known element type
        var index: u32; // the index of this value within the tuple, used for error reporting and optimization purposes
    }

    pub var values: FrozenList::<TupleValueExpr>;
    pub var is_homogeneous: bool = false; // set to true by sema
    pub const MAX_VALUES: usize = 65535; // arbitrary limit
    pub const MAX_INDEX: usize = MAX_VALUES - 1;

    static fn create(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        values: *vec::<TupleValueExpr>, // a temp stack allocated vector
        is_homogeneous: bool
    ) -> *TupleLiteralExpr {
        var node = ctx->alloc::<TupleLiteralExpr>();
        // from Expr
        node->kind     = ExprKind::TupleLiteralExpr;
        node->range    = range;
        // CollectionExpr
        node->collection_kind = collection_kind;
        // from TupleLiteralExpr
        var arr = ctx->alloc_array::<TupleValueExpr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->is_homogeneous = is_homogeneous;

        return node;
    }

    static fn create_error(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        values: *vec::<TupleValueExpr>, // a temp stack allocated vector
        is_homogeneous: bool
    ) -> *TupleLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            values,
            is_homogeneous
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TupleLiteralExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TupleLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::TupleLiteralExpr;
    }
}

