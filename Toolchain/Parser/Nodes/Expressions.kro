class UnsafeExpr derives UnaryOperatorExpr {
    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *UnsafeExpr {
        var node = ctx->alloc::<UnsafeExpr>();
        // from Expr
        node->kind     = ExprKind::UnsafeExpr;
        node->range    = range;
        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwUnsafe && r"Expected an unsafe operator token");

        node->operand  = operand;
        node->prefix   = true; // unsafe is always a prefix operator
        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *UnsafeExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::UnsafeExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::UnsafeExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::UnsafeExpr;
    }
}

class DeleteExpr derives UnaryOperatorExpr {
    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *DeleteExpr {
        var node = ctx->alloc::<DeleteExpr>();
        // from Expr
        node->kind     = ExprKind::DeleteExpr;
        node->range    = range;
        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwDelete && r"Expected a delete operator token");

        node->operand  = operand;
        node->prefix   = true; // delete is always a prefix operator
        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr
    ) -> *DeleteExpr {
        var node            = create(ctx, range, operator, operand);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::DeleteExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::DeleteExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::DeleteExpr;
    }
}

class TypeOfExpr derives UnaryOperatorExpr {
    pub var operand_is_type: bool; // true if operand is a type, false if operand is an expression
    pub var operand_type:   *Type; // only set if operand_is_type is true, otherwise null

    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr,
        operand_is_type: bool,
        operand_type: *Type
    ) -> *TypeOfExpr {
        var node = ctx->alloc::<TypeOfExpr>();
        // from Expr
        node->kind     = ExprKind::TypeOfExpr;
        node->range    = range;
        // from UnaryOperatorExpr
        node->operator = operator;
        assert(operator.kind == TokenKind::KwSizeOf && r"Expected a sizeof operator token");

        node->operand  = operand;
        node->prefix   = true; // sizeof is always a prefix operator

        // from TypeOfExpr
        node->operand_is_type = operand_is_type;

        if (operand_is_type) {
            assert((operand_type != &null) && r"Expected operand_type to be set when operand_is_type is true");
            node->operand_type = operand_type;
        } else {
            assert((operand_type == &null) && r"Expected operand_type to be null when operand_is_type is false");
            node->operand_type = &null;
        }

        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand:  *Expr,
        operand_is_type: bool,
        operand_type: *Type
    ) -> *TypeOfExpr {
        var node            = create(ctx, range, operator, operand, operand_is_type, operand_type);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::TypeOfExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::TypeOfExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::TypeOfExpr;
    }

    fn is_operand_type(self) -> bool {
        return self.operand_is_type;
    }

    fn get_operand_type(self) -> *Type {
        if (!self.operand_is_type) {
            return &null;
        }

        return self.operand_type;
    }

    fn get_operand_expr(self) -> *Expr {
        if (self.operand_is_type) {
            return &null;
        }

        return self.operand;
    }
}

