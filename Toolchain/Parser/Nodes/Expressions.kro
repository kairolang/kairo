class SubscriptExpr derives Expr {
    pub var base:  *Expr;
    pub var index: *Expr;
    pub var is_slice: bool; // true if this is a slice subscript like arr[1..3], false if this is a regular subscript like arr[1]

    static fn create(
        ctx: *ASTContext,
        range: SourceRange,
        base: *Expr,
        index: *Expr,
        is_slice: bool
    ) -> *SubscriptExpr {
        var node = ctx->alloc::<SubscriptExpr>();
        // from Expr
        node->kind     = ExprKind::SubscriptExpr;
        node->range    = range;
        // from SubscriptExpr
        node->base     = base;
        node->index    = index;
        node->is_slice = is_slice;
        return node;
    }

    static fn create_error(
        ctx: *ASTContext,
        range: SourceRange,
        base: *Expr,
        index: *Expr,
        is_slice: bool
    ) -> *SubscriptExpr {
        var node            = create(ctx, range, base, index, is_slice);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::SubscriptExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::SubscriptExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::SubscriptExpr;
    }

