class MethodCallExpr derives Expr {
    // this is for method calls, we have a full chainExpr on the left side (the call)
    // optional gernics, and a list of arguments.
    pub var name: *ChainExpr;
    pub var generic_args: FrozenList::<*Type>;
    pub var args: FrozenList::<*Expr>;

    static fn create(
        ctx: *ASTContext,
        range: SourceRange,
        name: *ChainExpr,
        generic_args: *vec::<*Type>,
        args: *vec::<*Expr>
    ) -> *MethodCallExpr {
        var node = ctx->alloc::<MethodCallExpr>();
        // from Expr
        node->kind     = ExprKind::MethodCallExpr;
        node->range    = range;
        // from MethodCallExpr
        node->name = name;

        var gen_arr = ctx->alloc_array::<*Type>(generic_args->size());
        for var i: usize = 0; i < generic_args->size(); ++i {
            gen_arr[i] = (*generic_args)[i];
        }

        node->generic_args.from_raw(gen_arr, generic_args->size());

        var arg_arr = ctx->alloc_array::<*Expr>(args->size());
        for var i: usize = 0; i < args->size(); ++i {
            arg_arr[i] = (*args)[i];
        }

        node->args.from_raw(arg_arr, args->size());

        return node;
    }

    static fn create_error(
        ctx: *ASTContext,
        range: SourceRange,
        name: *ChainExpr,
        generic_args: *vec::<*Type>,
        args: *vec::<*Expr>
    ) -> *MethodCallExpr {
        var node            = create(ctx, range, name, generic_args, args);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::MethodCallExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::MethodCallExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::MethodCallExpr;
    }

    fn has_generic_args(self) -> bool {
        return !(self.generic_args.is_empty());
    }

    fn has_args(self) -> bool {
        return !(self.args.is_empty());
    }

    fn get_last_name(self) -> *ChainExpr::ChainSegment {
        return self.name->last();
    }

    fn get_generic_args(self) -> FrozenList::<*Type> {
        return self.generic_args;
    }
}

class UnaryOperatorExpr derives Expr {
    // we do validate this in input to verfiy it is the right kind of unary
    // operator, but we still want to store the token for error reporting and
    // codegen purposes
    pub var operator: Token;
    pub var operand: *Expr;

    // true for prefix operators like -x, false for postfix operators like x++
    pub var prefix: bool;

    // we have acess to the following functions the parser would check on:
    // is_unary_operator
    // is_binary_operator
    // is_assignment_operator
    // is_punctuator
    // is_operator

    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand: *Expr,
        prefix: bool
    ) -> *UnaryOperatorExpr {
        var node = ctx->alloc::<UnaryOperatorExpr>();
        // from Expr
        node->kind     = ExprKind::UnaryOperatorExpr;
        node->range    = range;
        // from UnaryOperatorExpr
        node->operator = operator;
        assert(is_unary_operator(operator.kind) && r"Expected a unary operator token");
        node->operand  = operand;
        node->prefix   = prefix;
        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        operand: *Expr,
        prefix: bool
    ) -> *UnaryOperatorExpr {
        var node            = create(ctx, range, operator, operand, prefix);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::UnaryOperatorExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::UnaryOperatorExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::UnaryOperatorExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_operand(self) -> *Expr {
        return self.operand;
    }

    fn is_dereference(self) -> bool {
        return (self.operator.kind == TokenKind::OpStar) && self.prefix;
    }

    fn is_address_of(self) -> bool {
        return (self.operator.kind == TokenKind::OpAmp) && self.prefix;
    }

    fn is_logical_not(self) -> bool {
        return (self.operator.kind == TokenKind::OpExclaim) && self.prefix;
    }

    fn is_unary_plus(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlus) && self.prefix;
    }

    fn is_postfix_increment(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlusPlus) && !self.prefix;
    }

    fn is_postfix_decrement(self) -> bool {
        return (self.operator.kind == TokenKind::OpMinusMinus) && !self.prefix;
    }

    fn is_prefix_increment(self) -> bool {
        return (self.operator.kind == TokenKind::OpPlusPlus) && self.prefix;
    }

    fn is_prefix_decrement(self) -> bool {
        return (self.operator.kind == TokenKind::OpMinusMinus) && self.prefix;
    }

    fn is_bitwise_not(self) -> bool {
        return (self.operator.kind == TokenKind::OpTilde) && self.prefix;
    }
}

class BinaryOperatorExpr derives Expr {
    pub var operator: Token;
    pub var left:    *Expr;
    pub var right:   *Expr;

    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:    *Expr,
        right:   *Expr
    ) -> *BinaryOperatorExpr {
        var node = ctx->alloc::<BinaryOperatorExpr>();
        // from Expr
        node->kind     = ExprKind::BinaryOperatorExpr;
        node->range    = range;
        // from BinaryOperatorExpr
        node->operator = operator;
        // this does only run in debug mode so its fine to have
        assert(is_binary_operator(operator.kind) && r"Expected a binary operator token");
        node->left     = left;
        node->right    = right;
        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:    *Expr,
        right:   *Expr
    ) -> *BinaryOperatorExpr {
        var node            = create(ctx, range, operator, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::BinaryOperatorExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::BinaryOperatorExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::BinaryOperatorExpr;
    }

    fn get_operator(self) -> Token {
        return self.operator;
    }

    fn get_left(self) -> *Expr {
        return self.left;
    }

    fn get_right(self) -> *Expr {
        return self.right;
    }
}

class AssignOperatorExpr derives BinaryOperatorExpr {
    // we do validate this in input to verfiy it is the right kind of assignment
    // operator, but we still want to store the token for error reporting and
    // codegen purposes

    static fn create(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:    *Expr,
        right:   *Expr
    ) -> *AssignOperatorExpr {
        var node = ctx->alloc::<AssignOperatorExpr>();
        // from Expr
        node->kind     = ExprKind::AssignOperatorExpr;
        node->range    = range;
        // from BinaryOperatorExpr
        node->operator = operator;
        assert(is_assignment_operator(operator.kind) && r"Expected an assignment operator token");
        node->left     = left;
        node->right    = right;
        return node;
    }

    static fn create_error(
        ctx:     *ASTContext,
        range:    SourceRange,
        operator: Token,
        left:    *Expr,
        right:   *Expr
    ) -> *AssignOperatorExpr {
        var node            = create(ctx, range, operator, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::AssignOperatorExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::AssignOperatorExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::AssignOperatorExpr;
    }

    // we get these from BinaryOperatorExpr:
    //      fn get_operator(self) -> Token
    //      fn get_left(self) -> *Expr
    //      fn get_right(self) -> *Expr

    fn is_simple_assignment(self) -> bool {
        return self.operator.kind == TokenKind::OpEqual;
    }
}

class ImplConformanceExpr derives Expr {
    pub var left:  *Type;
    pub var right: FrozenList::<*Type>;

    static fn create(
        ctx: *ASTContext,
        range: SourceRange,
        left: *Type,
        right: *vec::<*Type> // a temp stack allocated vector
    ) -> *ImplConformanceExpr {
        var node = ctx->alloc::<ImplConformanceExpr>();
        // from Expr
        node->kind     = ExprKind::ImplConformanceExpr;
        node->range    = range;
        // from ImplConformanceExpr
        node->left     = left;
        var arr = ctx->alloc_array::<*Type>((*right).size());
        for var i: usize = 0; i < (*right).size(); ++i {
            arr[i] = (*right)[i];
        }

        node->right.from_raw(arr, (*right).size());
        return node;
    }

    static fn create_error(
        ctx:   *ASTContext,
        range:  SourceRange,
        left:  *Type,
        right: *vec::<*Type> // a temp stack allocated vector
    ) -> *ImplConformanceExpr {
        var node            = create(ctx, range, left, right);
        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ImplConformanceExpr;
        return node;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return ptr->kind == ExprKind::ImplConformanceExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::ImplConformanceExpr;
    }

    fn get_left(self) -> *Type {
        return self.left;
    }

    fn get_right(self) -> FrozenList::<*Type> {
        return self.right;
    }

    fn get_trait(self, idx: usize) -> *Type {
        if (idx >= self.right.size()) {
            return &null;
        }

        return *self.right[idx];
    }
}

