class ListLiteralExpr derives ArrayInitializerExpr { /// [ ... ]
    // Node: ListLiteralExpr basic ordered bag of values , either
    __inline_cpp("public:");
    enum ListType derives u8 {
        Array,
        Vector
    }

    pub var values: FrozenList::<*Expr>;
    pub const MAX_VALUES: usize = 65535; // arbitrary limit
    pub const MAX_INDEX: usize = MAX_VALUES - 1;

    // this is set by sema when deguessing the literal based
    // on the expected type context, but it is stored in the AST so that later
    // stages can still distinguish between array and vector literals if needed
    // (e.g. for codegen optimizations)
    pub var list_type: ListType;

    static fn create(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        list_type: ListType,
        element_type: *Type,
        values: *vec::<*Expr> // a temp stack allocated vector
    ) -> *ListLiteralExpr {
        var node = ctx->alloc::<ListLiteralExpr>();
        // from Expr
        node->kind     = ExprKind::ListLiteralExpr;
        node->range    = range;
        // CollectionExpr
        node->collection_kind = collection_kind;
        // from ArrayInitializerExpr
        var arr = ctx->alloc_array::<*Expr>(values->size());
        for var i: usize = 0; i < values->size(); ++i {
            arr[i] = (*values)[i];
        }

        node->values.from_raw(arr, values->size());
        node->element_type = element_type;
        node->size_expr = &null;
        return node;
    }

    static fn create_error(
        ctx:            *ASTContext,
        range:           SourceRange,
        collection_kind: CollectionExpr::Kind,
        list_type: ListType,
        element_type: *Type,
        values: *vec::<*Expr> // a temp stack allocated vector
    ) -> *ListLiteralExpr {
        var node = create(
            ctx,
            range,
            collection_kind,
            list_type,
            element_type,
            values
        );

        node->kind          = ExprKind::RecoveryExpr;
        node->recovery_kind = ExprKind::ListLiteralExpr;
        return node;
    }



    fn is_array(self) -> bool {
        return self.list_type == ListType::Array;
    }

    fn is_vector(self) -> bool {
        return self.list_type == ListType::Vector;
    }

    fn get_size(self) -> usize {
        return self.values.size();
    }

    fn get_element_type(self) -> *Type {
        return self.element_type;
    }

    /* OVERRIDE */ static fn classof(ptr: *Expr) -> bool {
        return (ptr->kind) == ExprKind::ListLiteralExpr;
    }

    /* OVERRIDE */ static fn expr_kind() -> ExprKind {
        return ExprKind::ListLiteralExpr;
    }
}

