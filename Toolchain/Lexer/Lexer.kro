    }, 1000);

    suite.equal::<string>("lex hex floats", "pass", fn () -> string {
        var res = create_lexer_from_string_with_diag("0x1.0p0 0x1.0p4 0x1.0p-4", sm, pool, &test_diag);
        var lexer = libcxx::get::<0>(res);
