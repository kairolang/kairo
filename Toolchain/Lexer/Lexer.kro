ffi "c++" import "Lexer/CharTable.hh";

import Lexer::Token::*;
import Lexer::TokenBuffer::*;
import Lexer::Immediate::*;
import Lexer::BalanceTracker::*;
import Lexer::HexParser::*;
import Lexer::OctalParser::*;

import Core::Include::SourceManager::*;
import Core::Include::Testing::*;
import Core::Diagnostics::DiagEngine::*;
import Core::Diagnostics::DiagRegistry::*;

/// \brief tracks git merge conflict marker detection state during lexing
/// \details used to emit clean diagnostics when conflict markers are found
///
/// to prevent issues later down the pipeline
/// we need to be able to detect git conflict markers in the source code.
/// ignore them and emit clean diagnostics if they are found.
/// this enum represents the state of conflict marker detection.
enum ConflictMarker derives u8 { // TODO: add conflit erroring to show issue with git merge conflict
    None,     ///< no conflict detected.
    Start,    ///< conflict start "<<<<<<<<" marker detected.
    Separator,///< conflict separator "========" marker detected.
    End       ///< conflict end ">>>>>>>>" marker detected.
}

/// \brief coarse classification of the previously emitted token
/// \details used for context-sensitive lexing decisions
enum LastTokenKind derives u8 {
    None,
    Text,
    Name,
    Symbol,
    Number,
}

/// \brief utf-8 aware lexer for kairo source files
/// \details
///  - performs tokenization only
///  - no semantic validation beyond lexical correctness
///  - produces immediate nodes for literals
///  - supports f-strings, byte strings, nested comments, and unicode
class Lexer {
    /// lowkey this formatting style looks a lot better tbh
    var _tokens        :  TokenBuffer::<512> = TokenBuffer::<512>();
    var _file_buffer   :  MemoryBuffer;
    var _imm_tbl       :  ImmediateTable;
    var _sm            : *SourceManager;
    var _pool          : *ThreadPool = &null;
    var _cursor        :  usize = 0; // last pos is always file_size - 1
    var _last_token    :  usize = 0;
    var _fid           :  u32   = 0;
    var _end_pos       :  usize = 0;
    var _initialized   :  bool  = false;
    var _last_kind     :  LastTokenKind = LastTokenKind::None;
    var _last_text     : *Token = &null;
    var _last_was_bang :  bool = false;
    pub var _balance   :  BalanceTracker;
    var _diag          : *DiagEngine = &null;
    var cached_data    :  std::const_ptr::<u8> = &null; // used for lex_slice to avoid repeated file_data() calls

    /// \brief lightweight handle over string/char immediates
    /// \details abstracts over StringData vs CharData
    class TextImm {
        var lexer: *Lexer;
        var delim: u8;
        var idx:   u32;
            
        /// \brief default constructor
        fn TextImm(self) {
            self.lexer = &null;
            self.delim = 0;
            self.idx   = 0;
        }

        /// \brief constructs handle for an existing immediate
        /// \param lexer owning lexer
        /// \param delim string delimiter (' or ")
        /// \param idx immediate table index
        fn TextImm(self, lexer: *Lexer, delim: u8, idx: u32) {
            self.lexer = lexer;
            self.delim = delim;
            self.idx   = idx;
        }

        /// \brief returns f-string expression list
        /// \returns deque of token buffers + source ranges
        fn get_exprs(self) -> ref!(libcxx::deque::<(*TokenBuffer::<16>, SourceRange)>) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->exprs;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->exprs;
            }
        }

        /// \brief returns prefix token
        /// \returns token reference
        fn get_prefix(self) -> ref!(Token) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->prefix;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->prefix;
            }
        }

        /// \brief returns suffix token
        /// \returns token reference
        fn get_suffix(self) -> ref!(Token) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->suffix;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->suffix;
            }
        }

        /// \brief returns body source range
        /// \returns source range reference
        fn get_body(self) -> ref!(SourceRange) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->body;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->body;
            }
        }

        /// \brief returns next immediate link
        /// \returns next index reference
        fn get_next(self) -> ref!(u32) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->next;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->next;
            }
        }

        /// \brief returns prefix classification
        /// \returns prefix kind
        fn get_prefix_kind(self) -> ref!(Immediate::TextPrefixKind) {
            if self.delim == 0x22 {
                var imm = lexer->get_imm::<Immediate::StringData>(self.idx);
                return imm->prefix_kind;
            } else {
                var imm = lexer->get_imm::<Immediate::CharData>(self.idx);
                return imm->prefix_kind;
            }
        }
    }

    /// \brief transient context for string / char lexing
    /// \details lives only during lex_text
    struct TextCtx {
        struct FormatSpec { /// f-string format specifier context
            var start: usize;
            var end: usize;
        }

        var lexer           : *Lexer;
        var start           : SourceLocation;

        var delim           : u8;
        var imm_idx         : u32;
        var is_format       : bool;
        var is_bytes        : bool;
        var imm             : TextImm;
        var prefix          : Token;

        var body_start      : SourceLocation;
        var body_end        : SourceLocation;

        var in_format_depth : usize;
        var terminators     : libcxx::stack::<SourceLocation>;
        var fstring_specs   : libcxx::deque::<FormatSpec>;

        var has_error       : bool;
        var error_token     : Token;
    }

    /// \brief transient context for number lexing
    struct NumberCtx {
        /// \brief tracks what was last seen while lexing a number
        enum LastWasState derives u8 {
            None,
            Digit,
            Underscore,
            Dot,
            Prefix,
            Exponent
        }

        var start: SourceLocation;

        var base:         u8;
        var has_prefix:   bool;
        var has_suffix:   bool;
        var has_decimal:  bool;
        var has_exponent: bool;

        var number_start: SourceLocation;
        var number_end:   SourceLocation;
        var prefix_start: SourceLocation;
        var prefix_end:   SourceLocation;
        var suffix:       Token;

        var last: LastWasState;
        var allows_sign_next: bool;

    }
    
    /// \brief checks if character is a valid digit in the given base
    /// \param c input character
    /// \param base numeric base (2, 8, 10, 16)
    /// \returns true if c is a digit allowed for `base` (2, 8, 10, 16)
    inline static priv fn is_base_digit(c: char32, base: u8) -> bool {
        switch base {
            case 2  { return (c == '0') || (c == '1'); }
            case 8  { return (c >= '0') && (c <= '7'); }
            case 10 { return (c >= '0') && (c <= '9'); }
            case 16 {
                return ((c >= '0') && (c <= '9'))
                    || ((c >= 'A') && (c <= 'F'))
                    || ((c >= 'a') && (c <= 'f'));
            }
            default { return false; }
        }
    }

    /// \brief checks if character is a valid exponent character for the given base
    /// \param c input character
    /// \param base numeric base (10, 16)
    /// \returns true if `c` starts an exponent for the given base
    inline static priv fn is_exponent_char(c: char32, base: u8) -> bool {
        return ((base == 10) && ((c == 'e') || (c == 'E')))
            || ((base == 16) && ((c == 'p') || (c == 'P')));
    }

    /// \brief checks if character is a decimal digit
    /// \param c input character
    /// \returns true if `c` is a decimal digit
    inline static priv fn is_decimal_digit(c: char32) -> bool {
        return (c >= '0') && (c <= '9');
    }

    ///========= LEXER API ==========///

    /// \brief gets the next token from the input stream
    /// \param start starting source location of the token
    /// \param decode decoded character at the current cursor position
    /// \returns next token
    inline priv fn get_token(
        self,
        const start  : SourceLocation,
        const decode : DecodeResult
    ) -> Token {
        const cls: CharClass = self.classify(decode.chr);

        switch cls {
            case CharClass::Identifier {
                // identifier or keyword
                return self.lex_name(start);
            } case CharClass::Number {
                // integer or float literal
                return self.lex_number(start);
            } case CharClass::Operator {
                // this is either an operator or punctuation
                return self.lex_symbol(start);
            } case CharClass::String {
                // string or char literal
                return self.lex_text(start);
            } case CharClass::Unassigned: case CharClass::Illegal {
                // illegal character
                return self.lex_illegal(start);
            } case CharClass::NewLine: case CharClass::Whitespace {
                // whitespace or newline
                return self.lex_whitespace(
                    start,
                    normalize_char32(decode.chr),
                    decode.len,
                    cls
                );
            }
        }

        self.advance_cursor(decode.len);
        return self.create_unrecognized_token(start);
    }

    /// \brief lexes the entire file associated with the given file ID
    /// \param fid file ID to lex
    /// \returns true on success
    fn lex(self, fid: u32) -> bool {
        if !self.load_file(fid) {
            Logger::error(Logger::Stage::Lexer, f"Lexer::lex: failed to load fid={fid}");
            return false;
        }

        self._sm->wait_for_line_index(fid); // ensure line index is ready
        self._fid         = fid;
        self._initialized = true;

        if self.file_data() == &null {
            Logger::error(Logger::Stage::Lexer, f"Lexer::lex: null file_data for fid={fid}");
            return false;
        }

        /// we can now do some immediate math to figure out where does the char fall under
        /// we have the following ranges to consider
        /// identifiers/keywords:
        /// 'a' - 'z' | 'A' - 'Z' |'0' - '9' | '_' | '#'
        ///  operators/punctuation:
        /// '{' '}' '(' ')' '[' ']' '+' '-' '*' '/' '%' '^' '|' '&' '~' '<' '>' '!' '=' '?' '@' ':' ';' ',' '.' '\'
        /// string literals are a coumpund or single since they can have a prefix or postfix
        /// 0x22 "' " '#"' '#"'

        while !self.is_eof() {
            /// this is where the main lexing loop will go
            /// our first step is to do 1 operation to figure out which basic range the char falls under
            var current_char = self.peek_char32();
            var token: Token = get_token(
                self.get_source_location(),
                current_char
            );

            /// we only avoid appending whitespace tokens for now
            if token != TokenKind::TkWhitespace {
                // balance tracking
                if token.kind == TokenKind::OpExclaim {
                    self._last_was_bang = true;
                } else {
                    if self._last_was_bang && BalanceTracker::is_opener(token.kind) {
                        self._balance.push(token.kind, token.range.start, true);
                    } else if BalanceTracker::is_opener(token.kind) {
                        self._balance.push(token.kind, token.range.start, false);
                    } else if BalanceTracker::is_closer(token.kind) {
                        self._balance.pop(token.kind, token.range.start);
                    }
                    self._last_was_bang = false;
                }
                
                self._tokens.append(token);
                
                if (token == TokenKind::LitString)
                || (token == TokenKind::LitChar) {
                    self._last_text = (self._tokens[self._tokens.size() - 1]);
                }
            }

            if token.kind == TokenKind::TkError {
                self._diag->report(DiagCode(DiagID::S011E), token.range.start,
                    f"invalid token '{self._sm->get_text(token.range)}': expected '{token_kind_to_readable_string(static_cast::<TokenKind>(token.imm))}' ")
                    .first(token.range).emit();
            }
        }

        // finalize balance checking
        self._balance.finalize();

        Logger::info(Logger::Stage::Lexer, f"Lexer::lex: fid={fid} tokens={self._tokens.size()} errors={self._diag->error_count()}");
        return true;
    }

    /// \brief routes balance-tracker errors through the diagnostic engine
    /// \details call this after lex() to flush any unclosed/mismatched delimiter errors
    fn emit_errors(self) {
        Logger::debug(Logger::Stage::Lexer, f"Lexer::emit_errors: balance_errors={self._balance.errors.size()}");

        for var i: usize = 0; i < self._balance.errors.size(); ++i {
            var err      = self._balance.errors[i];
            var open_range = SourceRange::from_bounds(err.open_loc, err.open_loc);
            var err_range  = SourceRange::from_bounds(err.loc, err.loc);

            switch err.kind {
                case BalanceTracker::BalanceErrorKind::Unclosed {
                    var msg = (f"unclosed macro invocation delimiter; expected '{token_kind_to_readable_string(err.expected)}' ")
                        if err.is_macro
                        else (f"unclosed delimiter; expected '{token_kind_to_readable_string(err.expected)}' ");

                    var code: DiagID;
                    if      err.expected == TokenKind::OpRParen  { code = DiagID::S019E; }
                    else if err.expected == TokenKind::OpRSquare { code = DiagID::S020E; }
                    else                                          { code = DiagID::S021E; }

                    self._diag->report(DiagCode(code), err.open_loc, msg)
                        .first(open_range, "opened here").emit();

                } case BalanceTracker::BalanceErrorKind::Unexpected {
                    self._diag->report(DiagCode(DiagID::S034E), err.loc,
                        f"unexpected '{token_kind_to_readable_string(err.found)}' with no matching opener")
                        .first(err_range).emit();

                } case BalanceTracker::BalanceErrorKind::Mismatched {
                    var msg = (f"mismatched macro delimiter: expected '{token_kind_to_readable_string(err.expected)}' to close macro, found '{token_kind_to_readable_string(err.found)}' ")
                        if err.is_macro
                        else (f"mismatched delimiter: expected '{token_kind_to_readable_string(err.expected)}', found '{token_kind_to_readable_string(err.found)}' ");

                    self._diag->report(DiagCode(DiagID::S035E), err.loc, msg)
                        .first(err_range)
                        .second(open_range, "opened here") // TODO: should this be a sub error or a second note?
                        .emit();
                }
            }
        }
    }

    /// \brief lexes a slice of the current file between start and end positions
    /// \param start starting position (inclusive)
    /// \param end ending position (exclusive)
    /// \returns token buffer containing lexed tokens
    /// \template N TokenBuffer chunk size
    fn <const N: usize> lex_slice(self, start: usize, end: usize) -> * TokenBuffer::<N> {
        var tokens = std::create::<TokenBuffer::<N>>();

        /// we first store state info:
        var last_token  = self._last_token;
        var last_text   = self._last_text;
        var last_kind   = self._last_kind;
        var cursor      = self._cursor;

        self._cursor  = start;
        self._end_pos = end;

        if self.file_data() == &null {
            return tokens;
        }

        while !self.is_eof() {
            /// this is where the main lexing loop will go
            /// our first step is to do 1 operation to figure out which basic range the char falls under
            var current_char = self.peek_char32();
            var token: Token = get_token(
                self.get_source_location(),
                current_char
            );

            /// we only avoid appending whitespace tokens for NOW
            if token != TokenKind::TkWhitespace {
                tokens->append(token);

                if (token == TokenKind::LitString)
                || (token == TokenKind::LitChar) {
                    self._last_text = (self._tokens[self._tokens.size() - 1]);
                }
            }
        }

        // route invalid tokens from the slice through the diagnostic engine
        for var i: usize = 0; i < tokens->size(); ++i {
            var token = tokens->get(i);

            if (token->kind) == TokenKind::TkError {
                self._diag->report(DiagCode(DiagID::S011E), token->range.start,
                    f"invalid token '{self._sm->get_text(token->range)}': expected '{token_kind_to_readable_string(static_cast::<TokenKind>(token->imm))}' ")
                    .first(token->range).emit();
            }
        }

        // now we restore state
        self._end_pos    = 0;
        self._cursor     = cursor;
        self._last_token = last_token;
        self._last_text  = last_text;
        self._last_kind  = last_kind;

        return tokens;
    }

    /// \brief a default destructor pretty self-explanatory
    delete fn Lexer(self);

    /// \brief default constructor
    /// \details initializes lexer with source manager and thread pool
    /// \param sm source manager pointer
    /// \param pool thread pool pointer
    /// \returns initialized lexer
    fn Lexer(self, sm: *SourceManager, pool: *ThreadPool, diag: *DiagEngine) {
        self._sm   = sm;
        self._pool = pool;
        self._diag = diag;
        self._imm_tbl.initialize(sm);
        self._initialized = false; // we only initialize on lex call
        Logger::info(Logger::Stage::Lexer, "Lexer: initialized");
    }

    /// \brief destroys the lexer and its resources
    /// \details cleans up token buffer and other allocated resources
    inline priv fn destroy(self) {
        self._tokens.destroy();
        self._imm_tbl.reset();
        self._balance.clear();
    }

    inline priv fn shutdown(self) {
        self._tokens.shutdown();
        self._imm_tbl.destroy();
        self._balance.clear();
    }

    /// \brief destructor
    fn op delete (self) {
        self.shutdown();
    }

    /// \brief loads the file buffer for the given file ID
    /// \param fid file ID to load
    /// \returns true on success
    inline priv fn load_file(self, fid: u32) -> bool {
        if self._sm == &null {
            return false;
        }

        // if we already have a buffer loaded, keep it
        if self._file_buffer.is_valid() {
            return true;
        }

        var buffer = self._sm->get_buffer(fid);

        if buffer == null || (!(*buffer).is_valid()) {
            Logger::error(Logger::Stage::Lexer, f"Lexer::load_file: invalid buffer for fid={fid}");
            return false;
        }

        self._file_buffer = *buffer;
        Logger::debug(Logger::Stage::Lexer, f"Lexer::load_file: fid={fid} size={self._file_buffer.size()}B");
        return true;
    }

    ///========= GETTERS/SETTERS ==========///

    fn tokens(self) -> *(TokenBuffer::<512>) {
        return &(self._tokens);
    }

    inline priv fn is_eof(self) -> bool {
        return self._cursor > (self.file_size() - 1);
    }

    inline priv fn current_data(self) -> std::const_ptr::<u8> {
        return self.file_data() + self._cursor;
    }

    inline priv fn remaining_offset(self) -> usize {
        return self.file_size() - self._cursor - 1;
    }

    inline priv fn file_size(self) -> usize {
        if self._end_pos > 0 {
            return self._end_pos;
        }

        return self._file_buffer.size();
    }

    inline priv fn file_data(self) -> std::const_ptr::<u8> {
        if self.cached_data == &null {
            if !self._file_buffer.is_valid() {
                return &null;
            }
            self.cached_data = self._file_buffer.data();
        }

        return self.cached_data;
    }

    inline priv fn advance_cursor(self, count: usize = 1) {
        /// NOTE: removing the bounds check for now, since either the
        ///       clamp or the (self._cursor + count) >= self.file_size() is
        ///       bugged, we need to re-evaluate this logic later, however
        ///       I fixed another issue in the VirtualFileManager that was
        ///       preventing it from reading the last byte in a SourceFile
        ///       see the commit "fe83937" for the fix.

        // if (self._cursor + count) >= self.file_size() {
        //     self._cursor = self.file_size() - 1;
        //     return;
        // }

        self._last_advanced = count;
        self._cursor       += count;
    }

    inline priv fn retreat_cursor(self, count: usize = 1) {
        if count > self._cursor {
            self._cursor = 0;
            return;
        }

        self._last_advanced = -(static_cast::<isize>(count));
        self._cursor       -=  count;
    }

    inline priv fn retreat_cursor_to_last(self) {
        if self._last_advanced > 0 {
            self.retreat_cursor(static_cast::<usize>(self._last_advanced));
        } else if self._last_advanced < 0 {
            self.advance_cursor(static_cast::<usize>(-self._last_advanced));
        }
    }

    ///========= LEXER INTERNALS ==========///

    /// 1 would be the immediate next char
    inline priv fn peek_char32(self, offset: isize = 0) -> DecodeResult {
        var data: std::const_ptr::<u8> = self.current_data();
        var size: usize                = self.remaining_offset() + 1;

        if offset < 0 {
            data -= (-offset);
            size += static_cast::<usize>(-offset);
        } else {
            data += static_cast::<usize>(offset);
            size -= static_cast::<usize>(offset);
        }

        if (size <= 0) {
            return DecodeResult('\0', 0);
        }

        return UTF8View::decode_utf8(data, size); // +1 for null terminator
    }

    inline priv fn get_char32(self) -> DecodeResult {
        var result = self.peek_char32();

        self.advance_cursor((result.len) if (result.len > 0) else 1);
        return result;
    }

    inline priv fn <const N: usize> get_char32(self, const max_unicode_len: u8 = 4) -> array::<DecodeResult, N> {
        var res = self.peek_char32::<N>(max_unicode_len);
        self.advance_cursor(res.size());
        return res;
    }

    inline priv fn <const N: usize> peek_char32(self, const max_unicode_len: u8 = 4) -> array::<DecodeResult, N> {
        var res = array::<DecodeResult, N>();
        res.fill(DecodeResult('\0', 0));

        var data: std::const_ptr::<u8> = self.current_data();
        var remain: usize = self.remaining_offset() + 1;

        if remain == 0 {
            return res;
        }

        var consumed: usize = 0;
        var out_i: usize = 0;

        if (max_unicode_len != 1) {
            while (out_i < N) && (consumed < remain) {
                var d = UTF8View::decode_utf8(data + consumed, remain - consumed);
                if d.len == 0 { break; }

                res[out_i] = d;
                consumed += d.len;
                ++out_i;
            }

            return res;
        }

        const eval if defined(__AVX512BW__) && defined(__AVX512VL__) {
            const STRIDE: usize = 64;

            while (out_i < N) {
                var rem = remain - consumed;
                if rem < STRIDE { break; } // <-- HARD BOUNDARY

                var ptr = data + consumed;

                // fully within mapping?
                // (only necessary if your MemoryBuffer isn't guaranteed padded)
                // Here we assume `remain` is correct for mapping.

                var chunk: __m512i =
                    _mm512_loadu_si512(reinterpret_cast::<const *__m512i>(ptr));

                var mask: __mmask64 = _mm512_movepi8_mask(chunk);

                if mask == 0 { // fully ASCII
                    var limit = STRIDE;
                    if out_i + STRIDE > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += limit;
                    continue;
                } else { // first non-ASCII stops SIMD processing
                    var first = libcxx::countr_zero(mask);

                    var limit = first;
                    if out_i + limit > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += first;
                    break;
                }
            }
        } else if defined(__AVX2__) {
            const STRIDE: usize = 32;

            while (out_i < N) {
                var rem = remain - consumed;
                if rem < STRIDE { break; }

                var ptr = data + consumed;

                var chunk: __m256i =
                    _mm256_loadu_si256(reinterpret_cast::<const *__m256i>(ptr));

                var hi = _mm256_movemask_epi8(chunk);
                if hi == 0 {
                    var limit = STRIDE;
                    if out_i + STRIDE > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += limit;
                    continue;
                } else {
                    var first = libcxx::countr_zero(hi);

                    var limit = first;
                    if out_i + limit > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += first;
                    break;
                }
            }
        } else if defined(__SSE2__) {
            const STRIDE: usize = 16;

            while (out_i < N) {
                var rem = remain - consumed;
                if rem < STRIDE { break; }

                var ptr = data + consumed;
                var chunk: __m128i =
                    _mm_loadu_si128(reinterpret_cast::<std::const_ptr::<__m128i>>(ptr));

                var hi = _mm_movemask_epi8(chunk);
                if hi == 0 {
                    var limit = STRIDE;
                    if out_i + STRIDE > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += limit;
                    continue;
                } else {
                    var first = libcxx::countr_zero(static_cast::<u32>(hi));

                    var limit = first;
                    if out_i + limit > N {
                        limit = N - out_i;
                    }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += first;
                    break;
                }
            }
        } else if defined(__ARM_NEON) {
            const STRIDE: usize = 16;
            const hi_mask: uint8x16_t = vdupq_n_u8(0x80);

            while (out_i < N) {
                var rem = remain - consumed;
                if rem < STRIDE { break; }

                var ptr = data + consumed;

                var chunk = vld1q_u8(ptr);
                var hi = vandq_u8(chunk, hi_mask);
                hi = vtstq_u8(hi, hi_mask);

                var tmp: std::Memory::buffer::<u8, 16>;
                vst1q_u8(tmp, hi);

                var bitmask: u32 = 0;
                for var k: usize = 0; k < 16; ++k {
                    if tmp[k] != 0 { bitmask |= (1 << k); }
                }

                if bitmask == 0 {
                    var limit = STRIDE;
                    if out_i + STRIDE > N { limit = N - out_i; }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += limit;
                    continue;
                } else {
                    var first = libcxx::countr_zero(bitmask);

                    var limit = first;
                    if out_i + limit > N { limit = N - out_i; }

                    for var j: usize = 0; j < limit; ++j {
                        res[out_i] = DecodeResult(static_cast::<char32>(ptr[j]), 1);
                        ++out_i;
                    }

                    consumed += first;
                    break;
                }
            }
        }

        while (out_i < N) && (consumed < remain) {
            var d = UTF8View::decode_utf8(data + consumed, remain - consumed);
            if d.len == 0 { break; }

            res[out_i] = d;
            consumed += d.len;
            ++out_i;
        }

        return res;
    }


    inline priv fn get_source_location(self) -> SourceLocation {
        // self._cursor can never be over or equal to file size
        return self._sm->get_loc(self._fid, self._cursor);
    }

    inline priv fn get_source_location(self, pos: usize) -> SourceLocation {
        // self._cursor can never be over or equal to file size
        return self._sm->get_loc(self._fid, pos);
    }

    inline priv fn create_source_range(self, start: SourceLocation) -> SourceRange {
        return SourceRange::from_bounds(start, self.get_source_location());
    }

    inline priv fn create_source_range(self, start: usize, end: usize) -> SourceRange {
        return SourceRange::from_bounds(
            self.get_source_location(start),
            self.get_source_location(end)
        );
    }

    inline priv fn create_error_token(self, start: SourceLocation, expected: TokenKind, kind: TokenKind = TokenKind::TkError) -> Token {
        self._last_kind = LastTokenKind::None;
        return {
            .range : self.create_source_range(start),
            .kind  : kind,
            .imm   : static_cast::<u32>(expected)
        };
    }

    inline priv fn create_unrecognized_token(self, start: SourceLocation, kind: TokenKind = TokenKind::TkUnknown) -> Token {
        self._last_kind = LastTokenKind::None;
        return {
            .range : self.create_source_range(start),
            .kind  : kind,
            .imm   : 0
        };
    }

    var _last_advanced: isize = 0;

    ///========= Char Classification ==========///
    static fn classify(chr: char32) -> CharClass {
        return classify_char32(chr);
    }

    var _conflict_state: ConflictMarker = ConflictMarker::None;

    ///========= Lexical Parsing Functions ==========///

    inline priv fn lex_name(self, start: SourceLocation) -> Token {
        /// 1. identifier
        /// 2. keyword
        ///
        /// keywords are ASCII-only A-Za-z0-9_
        /// identifiers allow UTF-8 and all valid name chars.
        ///
        /// keywords must hash fully and cannot contain:
        ///   - utf8 chars
        ///   - '#'
        ///   - anything outside [A-Za-z0-9_]
        ///
        /// identifiers have no max length.
        /// keywords max length is 32 u8 chars.
        ///
        /// we hash keyword candidates as long as the stream stays
        /// within the ascii keyword subset and under MAX_KEYWORD_LENGTH.
        ///
        /// the moment we hit a utf-8 multibyte char or a non-keyword-safe char,
        /// the whole lexeme becomes an identifier.

        const MAX_KEYWORD_LENGTH: usize = 32;

        var token: Token = Token();
        var hash: HashState = HashState();
        var length: usize = 0;
        var first = self.peek_char32(); // read first char

        var c0 = self.is_valid_name(first);

        if c0 == 0 {
            self.advance_cursor(first.len);
            return create_unrecognized_token(start);
        }

        if (first.len > 1) && (c0 == 2) {
            self.advance_cursor(first.len);
            
            while !self.is_eof() {
                var dec = self.peek_char32();
                if self.is_valid_name(dec) == 0 {
                    break;
                }
                self.advance_cursor(dec.len);
            }
            
            token = TokenKind::LitIdentifier;
            token = self.create_source_range(start);
            self._last_kind = LastTokenKind::Name;
            return token;
        }

        hash.mix(first.chr);
        length += 1;
        self.advance_cursor(1);

        while length < MAX_KEYWORD_LENGTH && !self.is_eof() {
            var d = self.peek_char32();
            if d.len != 1 {
                break;
            }

            var c: u8 = static_cast::<u8>(d.chr);

            // A-Z a-z _ 0-9 without branches
            var lo = c | 0x20;
            var is_alpha = (lo >= 'a') && (lo <= 'z');
            var is_digit = (c >= '0') && (c <= '9');
            var is_us    = (c == '_') || (c == '#');

            if !(is_alpha || is_digit || is_us) {
                break; // not keyword-allowed ASCII
            }

            hash.mix(d.chr);
            self.advance_cursor(1);
            length += 1;
        }

        if length <= MAX_KEYWORD_LENGTH {
            var h = hash.finalize();
            if is_valid_token_kind(h) {
                var kind = static_cast::<TokenKind>(h);
                var sub  = substitute(kind);
                token  = sub if (sub != TokenKind::TkUnknown) else kind;
                token = self.create_source_range(start);

                /// we do also need to do a quick sub check since we support c++
                /// style word operators (yes its a bad feature, but its only
                /// sake of c++ devs migrating to kairo)
                self._last_kind = LastTokenKind::Name;
                return token;
            }
        }

        while !self.is_eof() {
            var dec = self.peek_char32();
            if self.is_valid_name(dec) == 0 {
                break;
            }
            self.advance_cursor(dec.len);
        }

        /// we also need a quick second check to see if a string
        token  = TokenKind::LitIdentifier;
        token = self.create_source_range(start);

        var dec = self.peek_char32();
        if (dec.chr == 0x22) || (dec.chr == 0x27) && (length < 3) {
            // WE HAVE A STRING HERE
            // we also now need to see if our prefix is f, b, fb, or bf
            // and set the imm to 0, for invalid, 1 for format, 2 for bytes, 3 for bytes and format
            
            var h = hash.finalize();
            var ptype: u8 = 0;

            switch h {
                case compute_hash::<r"f">(): case compute_hash::<r"F">() {
                    ptype = 1;
                }
                
                case compute_hash::<r"b">(): case compute_hash::<r"B">() {
                    ptype = 2;
                }

                case compute_hash::<r"fB">(): case compute_hash::<r"FB">():
                case compute_hash::<r"Fb">(): case compute_hash::<r"fb">():
                case compute_hash::<r"Bf">(): case compute_hash::<r"BF">():
                case compute_hash::<r"bF">(): case compute_hash::<r"bf">() {
                    ptype = 3;
                }
            }

            if ptype != 0 {
                token.imm = ptype;
                return self.lex_text(self.get_source_location(), token);
            }
        }

        self._last_kind = LastTokenKind::Name;
        return token;
    }

    /// FIXME:  this number lexer is fine for stage1 but it's not the final
    ///         design. suffix detection is still kinda hacky, exponent rules
    ///         aren't fully spec'd, underscore validation is half-baked, and
    ///         hex-float edge cases are doing whatever they want as long as
    ///         the pipeline doesn't break on basic inputs or downstream stages.
    ///
    /// rewrite this once the self-hosted compiler is stable enough to bootstrap
    /// itself. the final version needs:
    /// - a real suffix grammar (not “first non-digit = suffix”)
    /// - stricter underscore rules across bases (consistent with clang/gcc)
    /// - consistent error paths for malformed floats
    /// - a saner state machine instead of this stitched logic
    /// - full separation of lexing vs semantic validation
    ///
    inline priv fn lex_number(self, start: SourceLocation, is_dot: bool = false) -> Token {
        var ctx = self.init_number_ctx(start, is_dot);
        
        while (self.scan_number_body(ctx)) && (!self.is_eof()) {
            0; // keep scanning
        }

        ctx.number_end = self.get_source_location();

        self.scan_number_suffix(ctx);
        return self.finalize_number(ctx);
    }

    inline priv fn init_number_ctx(self, start: SourceLocation, is_dot: bool) -> NumberCtx {
        var ctx: NumberCtx;

        ctx.start            = start;
        ctx.base             = 10;
        ctx.has_prefix       = false;
        ctx.has_decimal      = is_dot;
        ctx.has_exponent     = false;
        ctx.allows_sign_next = false;

        ctx.prefix_start = SourceLocation();
        ctx.prefix_end   = SourceLocation();
        ctx.number_start = start;
        ctx.last         = NumberCtx::LastWasState::None;

        var chars = self.peek_char32::<2>();

        if (!is_dot) && (chars[0].len == 1)
                     && (chars[0].chr == '0')
                     && (chars[1].len == 1) {

            switch static_cast::<char>(chars[1].chr) {
                case 'b': case 'B' { ctx.base = 2;  ctx.has_prefix = true; }
                case 'o': case 'O' { ctx.base = 8;  ctx.has_prefix = true; }
                case 'x': case 'X' { ctx.base = 16; ctx.has_prefix = true; }
            }

            if ctx.has_prefix {
                ctx.prefix_start  = start;
                self.advance_cursor(chars[0].len + chars[1].len);
                ctx.prefix_end    = self.get_source_location();
                ctx.number_start  = ctx.prefix_end;
                ctx.last          = NumberCtx::LastWasState::Prefix;
                return ctx;
            }
        }

        if is_dot {
            self.advance_cursor(chars[0].len);
            ctx.last = NumberCtx::LastWasState::Dot;
        } else {
            ctx.last = NumberCtx::LastWasState::Digit;
        }

        return ctx;
    }
    
    inline priv fn scan_number_body(self, ctx: ref!(NumberCtx)) -> bool {
        var chars = self.peek_char32::<16>();

        for var i: usize = 0; i < 16; ++i {
            var d = chars[i];
            var c = normalize_char32(d.chr);

            if ctx.has_exponent {
                if ctx.allows_sign_next && (c == '+' || c == '-') {
                    self.advance_cursor(d.len);
                    ctx.allows_sign_next = false;
                    ctx.last             = NumberCtx::LastWasState::Exponent;
                    continue;
                }

                if !(Lexer::is_decimal_digit(c)) {
                    return false;
                }

                self.advance_cursor(d.len);
                ctx.last = NumberCtx::LastWasState::Digit;
                continue;
            }

            if c == '_' {
                if ctx.last != NumberCtx::LastWasState::Digit {
                    return false;
                }
                ctx.last = NumberCtx::LastWasState::Underscore;
                self.advance_cursor(d.len);
                continue;
            }

            if Lexer::is_base_digit(c, ctx.base) {
                ctx.last = NumberCtx::LastWasState::Digit;
                self.advance_cursor(d.len);
                continue;
            }

            if c == '.' && ctx.base != 2 && ctx.base != 8 {
                // check for range operator
                var next = self.peek_char32(1);
                if next.len == 1 && next.chr == '.' {
                    return false; // range operator, stop here
                }
                
                if ctx.has_decimal
                || ctx.last == NumberCtx::LastWasState::Dot
                || ctx.last == NumberCtx::LastWasState::Underscore {
                    return false;
                }

                ctx.has_decimal = true;
                ctx.last        = NumberCtx::LastWasState::Dot;
                self.advance_cursor(d.len);
                continue;
            }

            if Lexer::is_exponent_char(c, ctx.base) {
                if ctx.has_exponent
                || ctx.last == NumberCtx::LastWasState::Underscore {
                    return false;
                }

                ctx.has_exponent     = true;
                ctx.allows_sign_next = true;
                ctx.last             = NumberCtx::LastWasState::Exponent;
                self.advance_cursor(d.len);
                continue;
            }

            return false;
        }

        return true; // we are not done yet
    }

    inline priv fn scan_number_suffix(self, ctx: ref!(NumberCtx)) {
        var d = self.peek_char32();
        
        if self.is_valid_name(d) != 0 {
            ctx.suffix = self.lex_name(self.get_source_location());
            ctx.has_suffix = true;
        } else {
            ctx.suffix = Token();
            ctx.has_suffix = false;
        }
    }

    inline priv fn finalize_number(self, ctx: ref!(NumberCtx)) -> Token {
        var is_float = ctx.has_decimal || ctx.has_exponent;

        var tok: Token;
        tok = TokenKind::LitFloat if is_float else TokenKind::LitInt;
        tok = self.create_source_range(ctx.start);

        var   imm_idx: u32 = (self._imm_tbl.create::<Immediate::FloatData>())
           if is_float else  (self._imm_tbl.create::<Immediate::IntData>());

        tok.imm = imm_idx;

        if is_float {
            var imm = self.get_imm::<Immediate::FloatData>(imm_idx);

            imm->flags = 0;
            imm->base = ctx.base;
            imm->body = SourceRange::from_bounds(ctx.number_start, ctx.number_end);

            // bit0: has_exponent
            if ctx.has_exponent {
                imm->flags |= 0b00000001;
            }

            // bit2: is_hex_float (0x prefix)
            if ctx.base == 16 {
                imm->flags |= 0b00000100;
            }

            // bit4: has_suffix
            if ctx.has_suffix {
                imm->flags |= 0b00010000;
                imm->suffix = ctx.suffix.range;
            }

            if ctx.has_prefix {
                imm->prefix = SourceRange::from_bounds(ctx.prefix_start, ctx.prefix_end);
            }

            imm->evaluate(self._sm);
        } else {
            var imm = self.get_imm::<Immediate::IntData>(imm_idx);

            // lexer fully defines its flag domain
            imm->flags = 0;

            imm->base = ctx.base;
            imm->body = SourceRange::from_bounds(ctx.number_start, ctx.number_end);

            // bit4: has_prefix
            if ctx.has_prefix {
                imm->flags |= 0b00010000;
                imm->prefix = SourceRange::from_bounds(ctx.prefix_start, ctx.prefix_end);
            }

            // bit3: has_suffix
            if ctx.has_suffix {
                imm->flags |= 0b00001000;
                imm->suffix = ctx.suffix.range;
            }

            imm->evaluate(self._sm);
        }

        self._last_kind = LastTokenKind::Number;
        return tok;
    }

    inline priv fn lex_symbol(self, start: SourceLocation) -> Token {
        const CHARS: array::<DecodeResult, 4> = self.peek_char32::<4>(1);
        const C1: DecodeResult = CHARS[0];
        const C2: DecodeResult = CHARS[1];
        const C3: DecodeResult = CHARS[2];
        const C4: DecodeResult = CHARS[3];

        if !self.is_valid_symbol(C1) {
            self.advance_cursor(C1.len);
            return create_unrecognized_token(start);
        }

        if (C1.chr == '.') && (C2.len == 1) && (C2.chr >= '0') && (C2.chr <= '9') {
            return self.lex_number(start, true);
        }

        var hash1 = HashState();
        hash1.mix(C1.chr);

        var best_hash: u64 = 0;
        var best_len: usize = 0;

        var h1 = hash1.finalize();
        if is_valid_token_kind(h1) {
            best_hash = h1;
            best_len = 1;
        }

        if self.is_valid_symbol(C2) {
            var hash2 = hash1.copy();
            hash2.mix(C2.chr);
            var h2 = hash2.finalize();
            
            if h2 == compute_hash::<r"//">() {
                self.advance_cursor(2);
                return self.lex_line_comment(start);
            }
            if h2 == compute_hash::<r"/*">() {
                self.advance_cursor(2);
                return self.lex_block_comment(start);
            }
            if h2 == compute_hash::<r"*/">() {
                self.advance_cursor(2);
                return self.create_error_token(start, TokenKind::AtComment);
            }
            
            if is_valid_token_kind(h2) {
                best_hash = h2;
                best_len = 2;
            }

            if self.is_valid_symbol(C3) {
                var hash3 = hash2.copy();
                hash3.mix(C3.chr);
                var h3 = hash3.finalize();
                
                if is_valid_token_kind(h3) {
                    best_hash = h3;
                    best_len = 3;
                }

                if self.is_valid_symbol(C4) {
                    var hash4 = hash3.copy();
                    hash4.mix(C4.chr);
                    var h4 = hash4.finalize();
                    
                    if is_valid_token_kind(h4) {
                        best_hash = h4;
                        best_len = 4;
                    }
                }
            }
        }

        // ── git conflict marker detection ──────────────────────────────
        // check for 7+ repeated '<', '=', '>'
        if (C1.chr == '<') || (C1.chr == '>') || (C1.chr == '=') {
            var conflict_char = C1.chr;
            var run_len: usize = 0;

            // count how many in a row (need 7)
            var scan_offset: isize = 0;
            while run_len < 7 {
                var sc = self.peek_char32(scan_offset);
                if sc.chr != conflict_char || sc.len == 0 { break; }
                run_len += 1;
                scan_offset += 1;
            }

            if run_len >= 7 {
                // consume to end of line
                var line_start = start;
                while !self.is_eof() {
                    var d = self.peek_char32();
                    if d.chr == 0x0A || d.chr == 0x0D || d.len == 0 { break; }
                    self.advance_cursor(d.len);
                }

                switch conflict_char {
                    case '<' { self._conflict_state = ConflictMarker::Start; }
                    case '=' { self._conflict_state = ConflictMarker::Separator; }
                    case '>' { self._conflict_state = ConflictMarker::End; }
                }

                // TODO: emit proper conflict diagnostic
                Logger::warn(Logger::Stage::Lexer, f"Lexer::lex_symbol: git conflict marker detected ({run_len} chars) at fid={self._fid} cursor={self._cursor}");
                return self.create_error_token(start, TokenKind::TkError, TokenKind::TkError);
            }
        }

        if best_len > 0 {
            self.advance_cursor(best_len);
            return self.make_symbol_token(best_hash, start);
        }

        // No valid token found
        self.advance_cursor(1);
        return create_error_token(start, static_cast::<TokenKind>(h1));
    }

    inline priv fn make_symbol_token(self, hash: u64, start: SourceLocation) -> Token {
        var token = Token();
        token = static_cast::<TokenKind>(hash);
        token = self.create_source_range(start);
        self._last_kind = LastTokenKind::Symbol;
        return token;
    }

    inline priv fn lex_line_comment(self, start: SourceLocation) -> Token {
        while !self.is_eof() {
            var d = self.peek_char32();
            if d.len == 0 || d.chr == 0x0A || d.chr == 0x0D {
                break;
            }
            self.advance_cursor(d.len);
        }

        var token = Token();
        token = TokenKind::AtComment;
        token = self.create_source_range(start);
        token = 0;
        return token;
    }

    inline priv fn lex_block_comment(self, start: SourceLocation) -> Token {
        var nest_depth: i32 = 1;
        
        while (!self.is_eof()) && (nest_depth > 0) {
            var chars = self.peek_char32::<2>();
            
            if (chars[0].chr == '*') && (chars[1].chr == '/') {
                nest_depth -= 1;
                self.advance_cursor(2);
                continue;
            }
            if (chars[0].chr == '/') && (chars[1].chr == '*') {
                nest_depth += 1;
                self.advance_cursor(2);
                continue;
            }
            
            self.advance_cursor(chars[0].len);
        }

        if nest_depth > 0 {
            Logger::warn(Logger::Stage::Lexer, f"Lexer::lex_block_comment: unterminated block comment fid={self._fid}");
            return self.create_error_token(start, TokenKind::AtComment);
        }

        var token = Token();
        token = TokenKind::AtComment;
        token = self.create_source_range(start);
        token = 0;
        return token;
    }

    /// TODO: so this is good enough for now but theres a quite a few problems
    ///       starting with if theres a string and nothing else in the file
    ///       no tokens get emitted?
    ///       also error handling is very week here. i have tested a lot of broken
    ///       strings and escapes/etc.
    ///
    inline priv fn lex_text(self, start: SourceLocation, prefix: Token = Token()) -> Token {
        var ctx = self.init_text_ctx(start, prefix);
        if ctx.has_error { return ctx.error_token; }

        self.scan_text_body(ctx);

        if !self.finalize_text(ctx) {
            return self.create_error_token(start, TokenKind::LitString);
        }

        self.lex_text_suffix(ctx);
        self.emit_fstring_exprs(ctx);

        return self.make_text_token(ctx);
    }

    inline priv fn init_text_ctx( self, start: SourceLocation, prefix: Token) -> TextCtx {
        var ctx: TextCtx;
        ctx.lexer = &self;
        ctx.start = start;
        ctx.has_error = false;

        var d = self.peek_char32();
        if d.chr != 0x22 && d.chr != 0x27 {
            ctx.has_error = true;
            Logger::error(Logger::Stage::Lexer, f"Lexer::scan_text_body: unterminated string at fid={self._fid} cursor={self._cursor}");
            var _r015 = SourceRange::from_bounds(start, self.get_source_location());
            self._diag->report(DiagCode(DiagID::S015E), _r015.start,
                f"expected string or character literal delimiter ('{0x22 as char}' or '{0x27 as char}')")
                .first(_r015).emit();
            ctx.error_token = self.create_error_token(start, TokenKind::LitString);
            return ctx;
        }

        ctx.delim = d.chr;
        self.advance_cursor(d.len);
        ctx.body_start = self.get_source_location();

        if ctx.delim == 0x22 {
            ctx.imm_idx = self._imm_tbl.create::<Immediate::StringData>();
            ctx.imm = TextImm(&self, ctx.delim, ctx.imm_idx);
        } else {
            ctx.imm_idx = self._imm_tbl.create::<Immediate::CharData>();
            ctx.imm = TextImm(&self, ctx.delim, ctx.imm_idx);
        }

        ctx.is_format = false;
        ctx.is_bytes  = false;

        if prefix == TokenKind::LitIdentifier {
            switch prefix.imm {
                case 1 { ctx.is_format = true; }
                case 2 { ctx.is_bytes  = true; }
                case 3 {
                    ctx.is_format = true;
                    ctx.is_bytes  = true;
                }
            }

            ctx.prefix = prefix;
        }

        ctx.in_format_depth = 0;
        ctx.terminators     = libcxx::stack::<SourceLocation>();
        ctx.fstring_specs   = libcxx::deque::<TextCtx::FormatSpec>();

        return ctx;
    }

    inline priv fn scan_text_body(self, ctx: ref!(TextCtx)) {
        while !self.is_eof() {
            var d = self.peek_char32();

            if ctx.in_format_depth > 0 {
                self.scan_format_expr(ctx, d);
                continue;
            }

            switch d.chr {
                case 0x22: case 0x27 { // " or '
                    if d.chr == ctx.delim {
                        ctx.body_end = self.get_source_location();
                        self.advance_cursor(d.len);
                        return;
                    }

                    self.advance_cursor(d.len); /// just normal char
                }

                case 0x7b { // {
                    if ctx.is_format {
                        ctx.in_format_depth = 1;
                        ctx.terminators.push(self.get_source_location());
                        self.advance_cursor(d.len);

                        ctx.fstring_specs.push_back(TextCtx::FormatSpec{
                            start: self._cursor,
                            end:   0
                        });
                        continue;
                    }

                    self.advance_cursor(d.len);
                }

                case 0x7d { // } - this is only called if our format depth is 0
                    if ctx.is_format {
                        ctx.has_error = true;
                        var _r016 = SourceRange::from_bounds(
                            self.get_source_location(),
                            self.get_source_location(self._cursor + d.len)
                        );
                        self._diag->report(DiagCode(DiagID::S016E), _r016.start,
                            "unmatched '}' in format string literal; use '\\\\}' for a literal brace")
                            .first(_r016).emit();
                    }

                    self.advance_cursor(d.len);
                }

                case 0x5c { // escape
                    var esc_start = self.get_source_location();
                    self.advance_cursor(d.len);
                    if !self.is_valid_escape(esc_start, ctx.is_bytes, ctx.is_format) {
                        ctx.has_error = true;
                        // is_valid_escape already emitted the specific diagnostic
                    }
                }

                default {
                    self.advance_cursor(d.len);
                }
            }
        }

        ctx.has_error = true;
        var _r012 = SourceRange::from_bounds(ctx.start, self.get_source_location());
        self._diag->report(DiagCode(DiagID::S012E), _r012.start,
            f"unterminated string literal; add a closing '{0x22 as char}' to end the string")
            .first(_r012).emit();
    }

    inline priv fn scan_format_expr(self, ctx: ref!(TextCtx), d: DecodeResult) {
        switch d.chr {
            case 0x22: case 0x27 {  // " or ' string inside expression
                self.advance_cursor(d.len);
                self.scan_string_in_fstring_expr(d.chr);
            }

            case 0x7b {  // {
                ++ctx.in_format_depth;
                ctx.terminators.push(self.get_source_location());
                self.advance_cursor(d.len);
            }

            case 0x7d {  // }
                --ctx.in_format_depth;
                if ctx.in_format_depth == 0 {
                    ctx.fstring_specs.back().end = self._cursor;
                }
                ctx.terminators.pop();
                self.advance_cursor(d.len);
            }

            case 0x0a {  // newline
                ctx.has_error = true;
                var _r018 = SourceRange::from_bounds(
                    self.get_source_location(),
                    self.get_source_location(self._cursor + d.len)
                );
                self._diag->report(DiagCode(DiagID::S018E), _r018.start,
                    "newline inside format string interpolation expression; expressions must be on a single line")
                    .first(_r018).emit();
                self.advance_cursor(d.len);
            }

            default {
                self.advance_cursor(d.len);
            }
        }
    }

    /// \brief scans a string literal inside an f-string expression
    /// \details skips to matching quote, handling escapes but not nested f-strings
    inline priv fn scan_string_in_fstring_expr(self, quote: char32) {
        // opening quote already consumed
        while !self.is_eof() {
            var c = self.peek_char32();
            
            if c.chr == quote {
                self.advance_cursor(c.len);
                return;
            }
            
            if c.chr == 0x5c {  // backslash escape
                self.advance_cursor(c.len);
                if !self.is_eof() {
                    var next = self.peek_char32();
                    self.advance_cursor(next.len);
                }
                continue;
            }
            
            self.advance_cursor(c.len);
        }

        // unterminated error will be caught by outer f-string termination check
    }

    inline priv fn finalize_text(self, ctx: ref!(TextCtx)) -> bool {
        if ctx.has_error {
            return false;
        }

        if !ctx.terminators.empty() {
            return false;
        }

        return true;
    }

    inline priv fn lex_text_suffix(self, ctx: ref!(TextCtx)) {
        if self.is_valid_name(self.peek_char32()) != 0 {
            var suffix = self.lex_name(self.get_source_location());
            if suffix.kind != TokenKind::TkUnknown {
                ctx.imm.get_suffix() = suffix.range;
            }
        }
    }

    inline priv fn emit_fstring_exprs(self, ctx: ref!(TextCtx)) {
        if !(ctx.is_format) { return; }

        for spec in ctx.fstring_specs {
            ctx.imm.get_exprs().push_back((
                self.lex_slice::<16>(spec.start, spec.end),
                self.create_source_range(spec.start, spec.end)
            ));
        }
    }

    inline priv fn make_text_token(self, ctx: ref!(TextCtx)) -> Token {
        var tok: Token;
        tok = TokenKind::LitString if ctx.delim == 0x22 else TokenKind::LitChar;
        tok = self.create_source_range(ctx.start);
        tok.imm = ctx.imm_idx;
        self._last_kind = LastTokenKind::Text;

        ctx.imm.get_body() = SourceRange::from_bounds(
            ctx.start,
            ctx.body_start
        );

        (ctx.imm.get_prefix()) = ctx.prefix;
        ctx.imm.get_prefix_kind() = (
            Immediate::TextPrefixKind::BytesFormat if ctx.is_format && ctx.is_bytes
            else Immediate::TextPrefixKind::Format if ctx.is_format
            else Immediate::TextPrefixKind::Bytes  if ctx.is_bytes
            else Immediate::TextPrefixKind::None
        );

        return tok;
    }

    inline priv fn lex_illegal(self, start: SourceLocation) -> Token {
        return self.lex_name(start);
    }

    inline priv fn lex_whitespace(self, start: SourceLocation, first_char: char32, first_len: usize, first_class: CharClass) -> Token {
        /// we consume all whitespace and newlines here
        /// we can batch spaces and newlines into a single new line
        /// we also batch just spaces into a single space token
        /// mixing spaces and newlines creates a new line token
        /// newlines do need to be tracked for line endings since `;` are optional
        /// at the end of lines in Kairo.

        var token: Token = Token();

        switch first_class {
            case CharClass::Whitespace {
                token = TokenKind::TkWhitespace;
            } case CharClass::NewLine {
                token = TokenKind::TkNewLine;
            } default {
                self.advance_cursor(); // consume first char
                return create_unrecognized_token(start);
            }
        }

        self.advance_cursor(first_len);

        while !self.is_eof() {
            var current_char = self.peek_char32();
            var c: char32  = normalize_char32(current_char.chr);

            switch self.classify(c) {
                case CharClass::Whitespace {
                    if token != TokenKind::TkNewLine {
                        token = TokenKind::TkWhitespace;
                    }
                } case CharClass::NewLine {
                    token = TokenKind::TkNewLine;
                } default {
                    token = self.create_source_range(start);
                    return token;
                }
            }

            self.advance_cursor(current_char.len);
        }

        token = self.create_source_range(start);
        return token;
    }

    inline static fn is_valid_symbol(c: DecodeResult) -> bool {
        if (c.len == 0) || (c.len > 1) || (c.chr > 127) || (c.chr == '\0') {
            return false;
        }

        switch (c.chr) {
            case MACRO_UNICODE_OPERATOR_CHAR_CASES {
                return true;
            } default {
                return false;
            }
        }
    }

    inline static fn is_valid_name(c: DecodeResult) -> u8 { /// 0 = false
                                                            /// 1 = keyword
                                                            /// 2 = identifier
        if (c.len == 0) || (c.chr == '\0') {
            return 0;
        }

        if (c.len > 1) || (c.chr == '#') {
            return 2;
        }

        switch (c.chr) {
            case MACRO_UNICODE_KEYWORD_CASES {
                return 1;
            } default {
                return 0;
            }
        }
    }
    
    inline inline priv fn is_valid_escape(self, start: SourceLocation, is_byte: bool, is_format: bool) -> bool {
        var chars = self.peek_char32::<10>();

        // 2 classes one for octal and one for hex
        // 2 very simple classes contains a is_digit function and a push_back function
        // both store values in usize internally and have a check(against: usize) -> bool function
        // and a getter to return the final value along with a digits count

        switch chars[0].chr {
            /// byte escapes
            case 'n': case 'r': case 't': case 'v': case 'f': case 'a':
            case 0x27: case 0x22: case 0x5c { // both
                self.advance_cursor(chars[0].len);
            }

            /// standard escapes / both
            case '{': case '}' { // both
                self.advance_cursor(chars[0].len);

                if is_format {
                    return true;
                }

                var range = SourceRange::from_bounds(
                    start,
                    self.get_source_location()
                );

                self._diag->report(DiagCode(DiagID::S022E), range.start,
                    "'\\{' and '\\}' escapes are only valid inside format strings (f\"...\"); remove the backslash or use an f-string prefix")
                    .first(range).emit();
                return false;
            }

            case 'x': case 'X' { // both // \xHH (exactly 2 hex digits)
                var hex_parser = HexParser();
                self.advance_cursor(chars[0].len);

                for (var i: usize = 1; i <= 2; ++i) {
                    if !hex_parser.is_digit(chars[i].chr) {
                        var range = SourceRange::from_bounds(
                            start,
                            self.get_source_location()
                        );

                        self.advance_cursor(chars[i].len);
                        self._diag->report(DiagCode(DiagID::S023E), range.start,
                            f"invalid '\\x' hex escape '{self._sm->get_text(range)}': expected exactly 2 hex digits (0-9, a-f, A-F)")
                            .first(range).emit();
                        return false;
                    }

                    hex_parser.push_back(chars[i].chr);
                    self.advance_cursor(chars[i].len);
                }

                var value = hex_parser.get_value();

                // explicit byte-range check
                if value > 0xFF {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S024E), range.start,
                        f"hex escape '{self._sm->get_text(range)}' is out of byte range (0x00-0xFF)")
                        .first(range).emit();
                    return false;
                }
            }
            
            case '0': case '1': case '2': case '3': // \ooo (1-3 octal digits)
            case '4': case '5': case '6': case '7' { // only byte
                var octal_parser = OctalParser();
                
                // first digit is guaranteed to be valid
                octal_parser.push_back(chars[0].chr);
                self.advance_cursor(chars[0].len);

                // we have no loops since we need exactly 1-3 digits
                if octal_parser.is_digit(chars[1].chr) {
                    octal_parser.push_back(chars[1].chr);
                    self.advance_cursor(chars[1].len);

                    if octal_parser.is_digit(chars[2].chr) {
                        octal_parser.push_back(chars[2].chr);
                        self.advance_cursor(chars[2].len);
                    }
                }

                if !is_byte {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S025E), range.start,
                        f"octal escape '{self._sm->get_text(range)}' is only valid in byte strings (b\"...\"); use '\\u' for unicode codepoints")
                        .first(range).emit();
                    return false;
                }

                /// we now validate the value
                var value = octal_parser.get_value();

                if octal_parser.get_digits() < 1 || octal_parser.get_digits() > 3 {
                    // defensive: should never happen
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S026E), range.start,
                        f"octal escape '{self._sm->get_text(range)}' must contain 1 to 3 digits")
                        .first(range).emit();
                    return false;
                }

                // explicit byte-range check
                if value > 0xFF {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S027E), range.start,
                        f"octal escape '{self._sm->get_text(range)}' is out of byte range (0-255, i.e., \\0-\\377)")
                        .first(range).emit();
                    return false;
                }
            }

            case 'u' { // only !byte // \uHHHH (exactly 4 hex digits)
                var hex_parser = HexParser();
                self.advance_cursor(chars[0].len);

                for (var i: usize = 1; i <= 4; ++i) {
                    if !hex_parser.is_digit(chars[i].chr) {
                        var range = SourceRange::from_bounds(
                            start,
                            self.get_source_location()
                        );

                        self.advance_cursor(chars[i].len);
                        self._diag->report(DiagCode(DiagID::S028E), range.start,
                            f"invalid '\\u' unicode escape '{self._sm->get_text(range)}': expected exactly 4 hex digits (0-9, a-f, A-F)")
                            .first(range).emit();
                        return false;
                    }

                    hex_parser.push_back(chars[i].chr);
                    self.advance_cursor(chars[i].len);
                }

                if is_byte {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S029E), range.start,
                        f"unicode escape '\\u' is not valid in a byte string; use '\\x' for raw byte values")
                        .first(range).emit();
                    return false;
                }

                var value = hex_parser.get_value();

                // check for valid unicode range
                if value > 0xFFFF {
                    // defensive: impossible with 4 hex digits, but documents intent
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S030E), range.start,
                        f"unicode escape '{self._sm->get_text(range)}' is out of the valid range (U+0000-U+FFFF for '\\u')")
                        .first(range).emit();
                    return false;
                }

                // Surrogate halves are invalid Unicode scalar values
                if (value >= 0xD800) && (value <= 0xDFFF) {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S031E), range.start,
                        f"unicode escape '{self._sm->get_text(range)}' encodes a surrogate code point (U+D800-U+DFFF), which is not a valid unicode scalar value")
                        .first(range).emit();
                    return false;
                }
            }

            case 'U' { // only !byte // \UHHHHHHHH (exactly 8 hex digits)
                var hex_parser = HexParser();
                self.advance_cursor(chars[0].len);

                // we have no loops since we need exactly 8 digits
                for (var i: usize = 1; i <= 8; ++i) {
                    if !hex_parser.is_digit(chars[i].chr) {
                        var range = SourceRange::from_bounds(
                            start,
                            self.get_source_location()
                        );

                        self.advance_cursor(chars[i].len);
                        self._diag->report(DiagCode(DiagID::S028E), range.start,
                            f"invalid '\\U' unicode escape '{self._sm->get_text(range)}': expected exactly 8 hex digits (0-9, a-f, A-F)")
                            .first(range).emit();
                        return false;
                    }

                    hex_parser.push_back(chars[i].chr);
                    self.advance_cursor(chars[i].len);
                }

                if is_byte {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S029E), range.start,
                        f"unicode escape '\\U' is not valid in a byte string; use '\\x' for raw byte values")
                        .first(range).emit();
                    return false;
                }

                var value = hex_parser.get_value();

                // check for valid unicode range
                if value > 0x10FFFF {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S030E), range.start,
                        f"unicode escape '{self._sm->get_text(range)}' is out of the valid unicode range (U+0000-U+10FFFF)")
                        .first(range).emit();
                    return false;
                }

                // Surrogate halves are invalid Unicode scalar values
                if (value >= 0xD800) && (value <= 0xDFFF) {
                    var range = SourceRange::from_bounds(
                        start,
                        self.get_source_location()
                    );

                    self._diag->report(DiagCode(DiagID::S031E), range.start,
                        f"unicode escape '{self._sm->get_text(range)}' encodes a surrogate code point (U+D800-U+DFFF), which is not a valid unicode scalar value")
                        .first(range).emit();
                    return false;
                }
            }

            case 'b' { // only !byte // \b (backspace)
                self.advance_cursor(chars[0].len);

                if !is_byte {
                    return true;
                }

                var range = SourceRange::from_bounds(
                    start,
                    self.get_source_location()
                );

                self._diag->report(DiagCode(DiagID::S032E), range.start,
                    f"'\\b' (backspace) escape is not valid in a byte string; use '\\x08' instead")
                    .first(range).emit();
                return false;
            }

            default {
                self.advance_cursor(chars[0].len);

                var range = SourceRange::from_bounds(
                    start,
                    self.get_source_location()
                );

                self._diag->report(DiagCode(DiagID::S033E), range.start,
                    f"unknown escape sequence '{self._sm->get_text(range)}' ")
                    .first(range).emit();
                return false;
            }
        }

        return true;
    }

    inline fn has_errors(self) -> bool {
        return self._diag->has_errors();
    }

    inline fn error_count(self) -> u32 {
        return self._diag->error_count();
    }

    inline static fn set_kind(tok: *Token, hash_state: *HashState) {
        var hash: u64 = hash_state->finalize();

        if is_valid_token_kind(hash) {
            tok->kind = static_cast::<TokenKind>(hash);
            return;
        } else {
            tok->kind = TokenKind::TkError;
            tok->imm = static_cast::<u32>(hash);
            return;
        }
    }

    fn <T> get_imm(self, imm_idx: u32) -> *T {
        return self._imm_tbl.get::<T>(imm_idx);
    }

    fn get_imm_tbl(self) -> *ImmediateTable {
        return &self._imm_tbl;
    }

    fn wait_for_imm_evaluation(self) {
        self._imm_tbl.wait_for_evaluation();
    }

    static fn get_text(token: Token, sm: *SourceManager) -> string {
        return sm->get_text(token.range);
    }

    fn reset(self) {
        self._cursor = 0;
        self._last_kind = LastTokenKind::None;
        self._last_was_bang = false;
        self._imm_tbl.reset();
        self._tokens.clear();
        self._balance.clear();
    }
}

fn Test() -> i32 {
    std::print("=== Lexer Test Suite ===\n ");

    var pool = std::create::<ThreadPool>(4);
    var vfm  = std::create::<VirtualFileManager>();
    var sm   = std::create::<SourceManager>(pool, vfm);
    var test_diag = DiagEngine();

    finally {
        std::destroy(sm);
        std::destroy(vfm);
        std::destroy(pool);
    }

    var suite = Assert("Lexer Tests");

    // =========================================================================
    // HELPER: Create a lexer from string content
    // =========================================================================

    static var data: libcxx::string;
    
    var create_lexer_from_string_with_diag = fn (content: string, sm: *SourceManager, pool: *ThreadPool, diag: *DiagEngine) -> (*Lexer, u32) {
        var temp_path = (libcxx::filesystem::temp_directory_path()) / (libcxx::filesystem::path(r"hlx_lexer_test.kro"));
        sm->reset();
        var temp_data = std::string_to_nstring(content);
        data = libcxx::string(temp_data);

        var path  = Path(temp_path.generic_wstring(), false);
        var ptr   = reinterpret_cast::<std::const_ptr::<u8>>(data.data());
        var fid   = sm->load_virtual(path, ptr, data.size());
        var lexer = std::create::<Lexer>(sm, pool, diag);

        return (lexer, fid);
    };

    // =========================================================================
    // HELPER: Dump tokens for debugging
    // =========================================================================
    
    var dump_tokens = fn (tokens: *(TokenBuffer::<512>), expected_count: usize, text: string = "none provided") -> string {
        var ret = "";
        for var i: usize = 0; i < tokens->size(); ++i {
            ret += f"\t{(*(tokens->get(i))) as string}, text: '{sm->get_text(tokens->get(i)->range)}'\n";
        }
        ret += f"\texpected {expected_count} tokens but got {tokens->size()}";
        return f"invalid token count\n\tgot tokens:\n{ret}";
    };
    
    // =========================================================================
    // BASIC TOKENIZATION
    // =========================================================================

    suite.equal::<string>("lex empty file", "pass", fn () -> string {
        var res = create_lexer_from_string_with_diag(" ", sm, pool, &test_diag);
        var lexer = libcxx::get::<0>(res);
        var fid = libcxx::get::<1>(res);
        
        finally { std::destroy(lexer); }
        
        if !lexer->lex(fid) {
            return "lexer failed to lex";
        }
        
        var tokens = lexer->tokens();
        if tokens->size() != 0 {
            return f"expected 0 tokens for empty file, got {tokens->size()}";
        }
        
        if lexer->has_errors() {
            return f"lexer reported {lexer->error_count()} error(s) (check DiagEngine consumer for details)";
        }

        return "pass";
    }, 1000);

    suite.equal::<string>("lex single identifier", "pass", fn () -> string {
        var res = create_lexer_from_string_with_diag("foo", sm, pool, &test_diag);
        var lexer = libcxx::get::<0>(res);
        var fid = libcxx::get::<1>(res);
        
        finally { std::destroy(lexer); }
        
        if !lexer->lex(fid) { return "lexer failed to lex"; }
        
        var tokens = lexer->tokens();
        if tokens->size() != 1 {
            return dump_tokens(tokens, 1);
        }
        
        var tok = tokens->get(0);
        if tok->kind != TokenKind::LitIdentifier {
            return f"expected LitIdentifier, got {token_kind_to_readable_string(tok->kind)}";
        }
        if sm->get_text(tok->range) != "foo" {
            return f"expected text 'foo', got '{sm->get_text(tok->range)}' ";
        }
        
        if lexer->has_errors() {
            return f"lexer reported {lexer->error_count()} error(s) (check DiagEngine consumer for details)";
        }

        return "pass";
    }, 1000);

    suite.equal::<string>("lex keywords", "pass", fn () -> string {
        var res = create_lexer_from_string_with_diag("fn var const class if else while for return", sm, pool, &test_diag);
        var lexer = libcxx::get::<0>(res);
        var fid = libcxx::get::<1>(res);
        
        finally { std::destroy(lexer); }
        
        if !lexer->lex(fid) { return "lexer failed to lex"; }
        
        var tokens = lexer->tokens();
        var expected = vec::<TokenKind>();
        expected.push_back(TokenKind::KwFn);
        expected.push_back(TokenKind::KwVar);
        expected.push_back(TokenKind::KwConst);
        expected.push_back(TokenKind::KwClass);
        expected.push_back(TokenKind::KwIf);
