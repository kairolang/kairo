        var res = create_lexer_from_string_with_diag("1_000 1_000_000 0xFF_FF 0b1010_1010", sm, pool, &test_diag);
        var lexer = libcxx::get::<0>(res);
        var fid = libcxx::get::<1>(res);
        
        finally { std::destroy(lexer); }
        
