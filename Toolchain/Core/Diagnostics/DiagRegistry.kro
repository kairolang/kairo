          case 16 { return DiagID::S016E; }
          case 17 { return DiagID::S017E; }
          case 18 { return DiagID::S018E; }
          case 22 { return DiagID::S022E; }
          case 23 { return DiagID::S023E; }
          case 24 { return DiagID::S024E; }
          case 25 { return DiagID::S025E; }
          case 26 { return DiagID::S026E; }
          case 27 { return DiagID::S027E; }
          case 28 { return DiagID::S028E; }
          case 29 { return DiagID::S029E; }
          case 30 { return DiagID::S030E; }
          case 31 { return DiagID::S031E; }
          case 32 { return DiagID::S032E; }
          case 33 { return DiagID::S033E; }
          case 34 { return DiagID::S034E; }
          case 35 { return DiagID::S035E; }
          case 36 { return DiagID::S036E; }
          case 37 { return DiagID::S037E; }
          case 38 { return DiagID::S038E; }
          case 39 { return DiagID::S039E; }
          case 40 { return DiagID::S040E; }
          case 42 { return DiagID::S042E; }
          case 43 { return DiagID::S043E; }
          case 44 { return DiagID::S044E; }
          default { std::crash(std::Error::RuntimeError("invalid diag number for S and severity Error")); }
        }
      }
      case DiagSeverity::Fatal {
        switch num {
          case 1 { return DiagID::S001F; }
          default { std::crash(std::Error::RuntimeError("invalid diag number for S and severity Fatal")); }
        }
      }
      default { std::crash(std::Error::RuntimeError("invalid diag severity")); }
    }
    std::crash(std::Error::RuntimeError("reached unreachable code in Diag::S"));
    return DiagID::Invalid; // unreachable
  }
