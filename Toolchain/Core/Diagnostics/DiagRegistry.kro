    case DiagID::R001R { return "This is placeholder diagnostics. (Remark)"; }
    case DiagID::R001V { return "This is placeholder diagnostics. (Verbose)"; }
    case DiagID::R001N { return "This is placeholder diagnostics. (Note)"; }
    case DiagID::R001D { return "This is placeholder diagnostics. (Debug)"; }
    case DiagID::R001E { return "This is placeholder diagnostics. (Error)"; }
    case DiagID::R001F { return "This is placeholder diagnostics. (Fatal)"; }
    case DiagID::R003E { return "The macro was invoked but no definition was found in the\ncurrent scope, imported scopes, or global scope."; }
    case DiagID::R003W { return "The macro was invoked but could not be resolved. This may\nindicate a missing import or a typo in the macro name.\nExpansion was skipped."; }
    case DiagID::R003N { return "Related to an undefined macro reference above."; }
    case DiagID::R002E { return "# failed to lex imported file\n\nthe preprocessor attempted to lex a file that is referenced by an import statement, but the lexer\nreturned an error. this usually means the file does not exist, cannot be read, or contains\nunrecoverable lexical errors.\n\n## how to fix\nverify that the imported file path is correct and that the file is accessible and well-formed."; }
    case DiagID::R004E { return "# no tokens for imported file\n\nthe preprocessor successfully located an imported file but obtained an empty or null token stream.\nthis is an internal consistency error that may indicate a corrupted token cache or a double-load race.\n\n## how to fix\nif this is a user-visible error, file a bug report. ensure the file is not empty and that the\nlexer processes it before the preprocessor runs."; }
    case DiagID::R005W { return "# ambiguous module\n\na module path resolves to both a directory (`Foo/Bar/`) and a file (`Foo/Bar.kro`). the compiler\nwill prefer the file, but this is likely a project layout mistake.\n\n## how to fix\nrename one of the conflicting paths or use the `module` disambiguation keyword (`import module Foo::Bar`)\nto explicitly select the directory-based module."; }
    case DiagID::R006E { return "# macro requires arguments\n\na parameterized macro was invoked without providing any arguments. macros defined with a parameter\nlist must be called with matching arguments.\n\n## example\n\n- correct usage:\n```kairo\nmacro add!(a, b) { a + b }\nvar x = add!(1, 2);\n```\n\n- incorrect usage:\n```kairo\nvar x = add!;   // missing argument list\n```\n\n## how to fix\nadd the argument list: `add!(1, 2)`."; }
    case DiagID::R007E { return "# macro does not accept arguments\n\na parameterless macro (defined without a parameter list) was invoked with arguments.\n\n## example\n\n- correct usage:\n```kairo\nmacro greet! { \"hello\" }\nvar s = greet!;\n```\n\n- incorrect usage:\n```kairo\nvar s = greet!(\"world\");  // unexpected args\n```\n\n## how to fix\nremove the argument list from the invocation."; }
    case DiagID::R008E { return "# macro expansion error\n\nan error occurred while expanding a macro invocation. this covers argument count mismatches, too\nmany arguments, too few arguments, or errors in nested expansion.\n\n## how to fix\ncheck the macro definition for the expected parameter list and ensure the invocation supplies\nthe correct number of arguments. see the accompanying note for the exact problem."; }
    case DiagID::R009E { return "# builtin macro error\n\na compiler-provided builtin macro (such as `error!`, `warn!`, `first!`, `last!`, `unstringify!`)\nwas called with incorrect arguments or in an unsupported context.\n\n## how to fix\nconsult the builtin macro documentation for the expected argument types and counts."; }
    case DiagID::R010E { return "# error!() macro diagnostic\n\nthe source file explicitly invoked `error!(message)` to emit a compile-time error.\nthis is a user-defined diagnostic, not a compiler bug."; }
    case DiagID::R010W { return "# warn!() macro diagnostic\n\nthe source file explicitly invoked `warn!(message)` to emit a compile-time warning.\nthis is a user-defined diagnostic, not a compiler bug."; }
    case DiagID::R010N { return "# note!() macro diagnostic\n\nthe source file explicitly invoked `note!(message)` to emit a compile-time note."; }
    case DiagID::R011E { return "# failed to resolve import path\n\nthe preprocessor attempted to resolve an import path but could not locate a matching file or module.\nthis may indicate a missing file, a typo in the import statement, or an incorrect project layout.\n\n## how to fix\nverify that the imported file or module exists and that the import statement uses the correct path."; }
    case DiagID::SC001W { return "This is placeholder diagnostics. (Warning)"; }
    case DiagID::SC001I { return "This is placeholder diagnostics. (Info)"; }
    case DiagID::SC001R { return "This is placeholder diagnostics. (Remark)"; }
    case DiagID::SC001V { return "This is placeholder diagnostics. (Verbose)"; }
    case DiagID::SC001N { return "This is placeholder diagnostics. (Note)"; }
    case DiagID::SC001D { return "This is placeholder diagnostics. (Debug)"; }
    case DiagID::SC001E { return "This is placeholder diagnostics. (Error)"; }
    case DiagID::SC001F { return "This is placeholder diagnostics. (Fatal)"; }
    case DiagID::S001W { return "This is placeholder diagnostics. (Warning)"; }
    case DiagID::S001I { return "This is placeholder diagnostics. (Info)"; }
    case DiagID::S001R { return "This is placeholder diagnostics. (Remark)"; }
    case DiagID::S001V { return "This is placeholder diagnostics. (Verbose)"; }
    case DiagID::S001N { return "This is placeholder diagnostics. (Note)"; }
    case DiagID::S001D { return "This is placeholder diagnostics. (Debug)"; }
    case DiagID::S001E { return "This is placeholder diagnostics. (Error)"; }
    case DiagID::S001F { return "This is placeholder diagnostics. (Fatal)"; }
    case DiagID::S041E { return "# return type mismatch error\n\nthis error occurs when the return type of a function does not match the type of the expression in the return statement.\nthe compiler expects the return type to be consistent with the declared return type of the function.\n\n## example\n\n- correct usage:\n```kairo\nfn add(a: i32, b: i32) -> i32 {\n    return a + b; // this is correct, as the return type matches the declared type\n}\n```\n\n- incorrect usage:\n```kairo\nfn add(a: i32, b: i32) -> i32 {\n    return \"a\" + \"b\"; // this is incorrect, since the return type is a string, not an i32\n}\n```\n\n## how to fix\nensure that the expression in the return statement matches the declared return type of the function. if necessary,\nyou can change the return type of the function or modify the return expression to match the expected type."; }
    case DiagID::S041W { return "# return type mismatch warning\n\nthis warning occurs when the return type of a function does not exactly match the type of the expression in the return statement.\nthe compiler will apply an implicit conversion to make the types compatible, but it is recommended to ensure that the return types match exactly to avoid undefined behavior or unexpected behavior.\n\n## example\n\n- correct usage:\n```kairo\nfn add(a: i32, b: i32) -> i32 {\n    return a + b; // this is correct, as the return type matches the declared type\n}\n```\n\n- incorrect usage:\n```kairo\nfn add(a: i32, b: i32) -> i32 {\n    return a + b as f32; // this is incorrect, since the return type is f32, not an i32. an implicit conversion will be applied, but it is better to ensure that the return types match exactly. in this case it might round the result to the wrong value which would be unexpected behavior.\n}\n```\n\n## tip\n\nundefined behavior vs unexpected behavior:\n- undefined behavior: the program may crash or produce unpredictable results. this is usually caused by memory corruption or invalid operation that the compiler cannot detect but can lead to serious issues.\n- unexpected behavior: the program may run but produce results that are not what the programmer intended\n- both undefined behavior and unexpected behavior can lead to bugs and security vulnerabilities, so it is important to write code that is well-defined and behaves as expected."; }
    case DiagID::S011E { return "# invalid token error\n\nthis error occurs when the lexer encounters a token that is not valid in the current context. this can happen due to typos, missing punctuation, or incorrect syntax.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var x = 10; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var x = $129$; // this is incorrect syntax, as the token #129# is invalid in kairo, the lexer does not recognize `$` as a valid token.\n}\n```\n\n## how to fix\ncheck the syntax of your code and ensure that all tokens are valid and correctly placed. look for typos, missing punctuation, or incorrect syntax that may be causing the error."; }
    case DiagID::S012E { return "# unterminated string literal error\n\nthis error occurs when the lexer encounters a string literal that is not properly terminated. this can happen if the closing quote is missing or if there is an eSape sequence that is not properly handled.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var s = \"hello world\"; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var s = \"hello world; // this is incorrect syntax, as the string literal is not properly terminated with a closing quote.\n}\n```\n\n## how to fix\nensure that all string literals are properly terminated with matching opening and closing quotes. check for any eSape sequences that may be causing the issue and ensure they are correctly formatted."; }
    case DiagID::S013E { return "# unterminated character literal error\n\nthis error occurs when the lexer encounters a character literal that is not properly terminated. this can happen if the closing quote is missing or if there is an eSape sequence that is not properly handled.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var c = \'a\'; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var c = \'a; // this is incorrect syntax, as the character literal is not properly terminated with a closing quote.\n}\n```\n\n## how to fix\nensure that all character literals are properly terminated with matching opening and closing quotes. check for any eSape sequences that may be causing the issue and ensure they are correctly formatted."; }
    case DiagID::S014E { return "# unterminated block comment error\n\nthis error occurs when the lexer encounters a block comment that is not properly terminated. this can happen if the closing comment delimiter is missing.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    /* this is a block comment */\n    var x = 10; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    /* this is a block comment\n    var x = 10; // this is incorrect syntax, as the block comment is not properly terminated with a closing delimiter.\n}\n```\n\n## how to fix\nensure that all block comments are properly terminated with matching opening and closing delimiters. check for any missing closing delimiters that may be causing the issue."; }
    case DiagID::S019E { return "# unclosed parenthesis error\n\nthis error occurs when the lexer encounters an opening parenthesis that is not properly closed. this can happen if the closing parenthesis is missing or if there is a mismatch in the number of opening and closing parentheses.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var x = (10 + 20); // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var x = (10 + 20; // this is incorrect syntax, as the opening parenthesis is not properly closed with a closing parenthesis.\n}\n```\n\n## how to fix\nensure that all opening parentheses are properly closed with matching closing parentheses. check for any missing closing parentheses that may be causing the issue."; }
    case DiagID::S020E { return "# unclosed bracket error\n\nthis error occurs when the lexer encounters an opening bracket that is not properly closed. this can happen if the closing bracket is missing or if there is a mismatch in the number of opening and closing brackets.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var arr = [1, 2, 3]; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var arr = [1, 2, 3; // this is incorrect syntax, as the opening bracket is not properly closed with a closing bracket.\n}\n```\n\n## how to fix\nensure that all opening brackets are properly closed with matching closing brackets. check for any missing closing brackets that may be causing the issue."; }
    case DiagID::S021E { return "# unclosed brace error\n\nthis error occurs when the lexer encounters an opening brace that is not properly closed. this can happen if the closing brace is missing or if there is a mismatch in the number of opening and closing braces.\n\n## example\n\n- correct usage:\n```kairo\nfn main() {\n    var obj = { key: \"value\" }; // this is correct syntax\n}\n```\n\n- incorrect usage:\n```kairo\nfn main() {\n    var obj = { key: \"value\"; // this is incorrect syntax, as the opening brace is not properly closed with a closing brace.\n}\n```\n\n## how to fix\nensure that all opening braces are properly closed with matching closing braces. check for any missing closing braces that may be causing the issue."; }
    case DiagID::S015E { return "# missing string or character literal delimiter\n\nthis error occurs when the lexer expected a string delimiter (`\"`) or character delimiter (`\'`) to begin a literal,\nbut encountered a different character. this usually means a prefix character (such as `f`, `b`, or `r`) was used\nwithout being followed by a valid opening quote.\n\n## example\n\n- correct usage:\n```kairo\nvar s = \"hello\";\nvar c = \'x\';\nvar f = f\"result: {x}\";\n```\n\n- incorrect usage:\n```kairo\nvar s = f 42;  // \'f\' prefix not followed by a quote\n```\n\n## how to fix\nensure that every string or character prefix is immediately followed by a matching opening delimiter (`\"` or `\'`)."; }
    case DiagID::S016E { return "# unmatched `}` in format string literal\n\nthis error occurs when a standalone `}` is found inside an f-string literal but there is no matching opening `{`.\nin a format string, `{` opens an interpolation expression and `}` closes it. a lone `}` with no corresponding `{`\nis invalid.\n\n## example\n\n- correct usage:\n```kairo\nvar msg = f\"value: {x}\";\n```\n\n- incorrect usage:\n```kairo\nvar msg = f\"value: }x{\";  // unmatched `}`\n```\n\n## how to fix\nremove the stray `}`, or if you intended a literal brace, escape it as `\\}` (only valid when `\\{`/`\\}` escape is\nsupported) or restructure the interpolation expression."; }
    case DiagID::S017E { return "# invalid escape sequence in string literal\n\nthis error occurs when the lexer encounters a backslash (`\\`) followed by a character that does not form a valid\nescape sequence in the current string context. the specific problem (unknown character, wrong string type, etc.)\nis described in the accompanying message.\n\n## example\n\n- correct usage:\n```kairo\nvar s = \"line one\\nline two\";  // \\n is a valid escape\n```\n\n- incorrect usage:\n```kairo\nvar s = \"bad \\q here\";  // \\q is not a recognized escape sequence\n```\n\n## how to fix\nconsult the list of valid escape sequences for your string type and correct or remove the invalid escape."; }
    case DiagID::S018E { return "# newline inside format string expression\n\nthis error occurs when a raw newline character appears inside the interpolation expression `{...}` of a format\nstring. format string expressions must be on a single line.\n\n## example\n\n- correct usage:\n```kairo\nvar msg = f\"result: {compute()}\";\n```\n\n- incorrect usage:\n```kairo\nvar msg = f\"result: {\n    compute()\n}\";  // newline inside { } is not allowed\n```\n\n## how to fix\nmove the expression to a single line, or assign the value to a temporary variable before the format string."; }
    case DiagID::S022E { return "# `\\{` or `\\}` escape invalid in non-format string\n\nthis error occurs when the escape sequences `\\{` or `\\}` are used inside a regular (non-format) string literal.\nthese escapes are only meaningful in format strings (`f\"...\"`) where `{` and `}` have special interpolation meaning.\nin a plain string they are unrecognized.\n\n## example\n\n- correct usage:\n```kairo\nvar escaped = f\"literal brace: \\{\";  // valid in f-string\n```\n\n- incorrect usage:\n```kairo\nvar s = \"literal brace: \\{\";  // invalid; \\{ only works in f-strings\n```\n\n## how to fix\nuse a format string prefix (`f\"...\"`) if you need to write a literal brace character via `\\{`/`\\}`, or simply\ninclude the brace as a plain character in a regular string."; }
    case DiagID::S023E { return "# malformed `\\x` hex escape sequence\n\nthis error occurs when a `\\x` escape sequence is not followed by exactly two valid hexadecimal digits.\nthe `\\x` escape requires exactly two hex digits in the range `0`-`9`, `a`-`f`, or `A`-`F`.\n\n## example\n\n- correct usage:\n```kairo\nvar tab = \"\\x09\";  // horizontal tab (U+0009)\n```\n\n- incorrect usage:\n```kairo\nvar bad = \"\\xGG\";  // G is not a hex digit\nvar bad2 = \"\\x9\";  // only one digit; two are required\n```\n\n## how to fix\nsupply exactly two hexadecimal digits after `\\x`, e.g. `\\x0A` for a newline."; }
    case DiagID::S024E { return "# `\\x` hex escape out of byte range\n\nthis error occurs when the value encoded by a `\\xHH` escape sequence exceeds 0xFF (255). the `\\x` form is\nlimited to single-byte values.\n\n## example\n\n- correct usage:\n```kairo\nvar byte = b\"\\xFF\";  // maximum valid byte escape\n```\n\n- incorrect usage:\n```kairo\nvar bad = b\"\\x1FF\";  // 0x1FF > 0xFF; too large for a byte escape\n```\n\n## how to fix\nuse a value in the range `0x00`-`0xFF`, or switch to a unicode escape (`\\u`) for larger codepoints."; }
    case DiagID::S025E { return "# octal escape only valid in byte strings\n\nthis error occurs when an octal escape sequence (`\\0`-`\\777`) appears in a regular (non-byte) string literal.\noctal escapes encode raw byte values and are only permitted in byte string literals (`b\"...\"`).\n\n## example\n\n- correct usage:\n```kairo\nvar byte_str = b\"\\101\";  // byte value 0x41 = \'A\'\n```\n\n- incorrect usage:\n```kairo\nvar s = \"\\101\";  // octal escapes require a byte string\n```\n\n## how to fix\nprefix the string with `b` to make it a byte string, or use a unicode escape (`\\u0041`) in a regular string."; }
    case DiagID::S026E { return "# octal escape has wrong digit count\n\nthis error occurs when an octal escape sequence contains fewer than 1 or more than 3 octal digits.\nvalid octal escapes are `\\0` through `\\377` (1-3 digits in the range `0`-`7`).\n\n## how to fix\nwrite between 1 and 3 octal digits following the backslash, e.g. `\\7`, `\\07`, or `\\007`."; }
    case DiagID::S027E { return "# octal escape out of byte range\n\nthis error occurs when the value encoded by an octal escape sequence exceeds 0xFF (255, i.e., octal 377).\noctal escapes are limited to single-byte values.\n\n## example\n\n- incorrect usage:\n```kairo\nvar bad = b\"\\400\";  // octal 0o400 = 256 > 0xFF\n```\n\n## how to fix\nuse an octal value in the range `\\0`-`\\377`, or switch to a `\\x` hex escape."; }
    case DiagID::S028E { return "# malformed `\\u` or `\\U` unicode escape sequence\n\nthis error occurs when a `\\u` or `\\U` escape sequence is not followed by the required number of valid\nhexadecimal digits. `\\u` requires exactly 4 hex digits and `\\U` requires exactly 8 hex digits.\n\n## example\n\n- correct usage:\n```kairo\nvar euro = \"\\u20AC\";    // U+20AC EURO SIGN\nvar emoji = \"\\U0001F600\"; // U+1F600 GRINNING FACE\n```\n\n- incorrect usage:\n```kairo\nvar bad = \"\\u20\";     // too few digits\nvar bad2 = \"\\uXXXX\";  // X is not a hex digit\n```\n\n## how to fix\nuse exactly 4 hex digits for `\\u` or exactly 8 hex digits for `\\U`."; }
    case DiagID::S029E { return "# `\\u` or `\\U` escape invalid in byte string\n\nthis error occurs when a unicode escape sequence (`\\u` or `\\U`) appears inside a byte string literal (`b\"...\"`).\nbyte strings store raw bytes and do not support multi-byte unicode escapes.\n\n## example\n\n- correct usage:\n```kairo\nvar s = \"\\u0041\";    // valid in a regular string\nvar b = b\"\\x41\";    // use byte escapes in byte strings\n```\n\n- incorrect usage:\n```kairo\nvar bad = b\"\\u0041\";  // unicode escape in a byte string\n```\n\n## how to fix\nremove the `b` prefix to use a regular string, or replace the unicode escape with an equivalent `\\x` or octal escape."; }
    case DiagID::S030E { return "# unicode escape out of valid codepoint range\n\nthis error occurs when a `\\u` or `\\U` escape encodes a value that exceeds the maximum valid unicode scalar value.\nthe maximum valid unicode codepoint is U+10FFFF.\n\n## example\n\n- incorrect usage:\n```kairo\nvar bad = \"\\U00200000\";  // 0x200000 > 0x10FFFF\n```\n\n## how to fix\nuse a codepoint in the range U+0000-U+10FFFF."; }
    case DiagID::S031E { return "# unicode escape encodes a surrogate code point\n\nthis error occurs when a `\\u` or `\\U` escape encodes a value in the surrogate range U+D800-U+DFFF.\nsurrogate code points are not valid unicode scalar values and cannot appear in source text or string literals.\n\n## example\n\n- incorrect usage:\n```kairo\nvar bad = \"\\uD800\";  // surrogate half; not a valid scalar value\n```\n\n## how to fix\nuse a codepoint outside the surrogate range (U+0000-U+D7FF or U+E000-U+10FFFF)."; }
    case DiagID::S032E { return "# `\\b` (backspace) escape invalid in byte string\n\nthis error occurs when the `\\b` escape sequence is used inside a byte string literal (`b\"...\"`). byte strings\ndo not support the `\\b` backspace shorthand.\n\n## example\n\n- correct usage:\n```kairo\nvar s = \"\\b\";      // backspace in a regular string\nvar b = b\"\\x08\";   // use the explicit byte value in a byte string\n```\n\n- incorrect usage:\n```kairo\nvar bad = b\"\\b\";   // \\b not valid in byte string\n```\n\n## how to fix\nreplace `\\b` with `\\x08` (the byte value for backspace) inside the byte string."; }
    case DiagID::S033E { return "# unknown escape sequence\n\nthis error occurs when the lexer encounters a backslash followed by a character that does not form any recognized\nescape sequence. for example, `\\q`, `\\j`, or `\\m` are not defined escape sequences.\n\n## example\n\n- incorrect usage:\n```kairo\nvar bad = \"hello \\w world\";  // \\w is not a valid escape\n```\n\n## how to fix\nreplace the unrecognized escape with a valid one, or remove the backslash if it was accidental. see the language\nreference for the full list of supported escape sequences."; }
    case DiagID::S034E { return "# unexpected closing delimiter\n\nthis error occurs when the lexer encounters a closing delimiter (`)`, `]`, or `}`) that has no corresponding\nopening delimiter earlier in the token stream.\n\n## example\n\n- incorrect usage:\n```kairo\nvar x = 10);   // `)` has no matching `(`\n```\n\n## how to fix\nremove the extraneous closing delimiter, or add the missing opening delimiter at the correct location."; }
    case DiagID::S035E { return "# mismatched delimiters\n\nthis error occurs when a closing delimiter (`)`, `]`, or `}`) does not match the kind of the most recently opened\ndelimiter. for example, opening with `(` but closing with `]`.\n\n## example\n\n- incorrect usage:\n```kairo\nvar arr = [1, 2, 3);  // opened with `[` but closed with `)`\n```\n\n## how to fix\nensure that every closing delimiter matches its corresponding opener: `(` pairs with `)`, `[` with `]`, and `{` with `}`."; }
    case DiagID::S036E { return "# expected macro name after `macro`\n\nthis error occurs when the lexer/preprocessor encounters the `macro` keyword but no valid identifier follows it.\nmacro definitions must have the form `macro name! { body }`.\n\n## example\n\n- correct usage:\n```kairo\nmacro greet! { \"hello\" }\n```\n\n- incorrect usage:\n```kairo\nmacro ! { \"hello\" }  // missing name\nmacro 42! { }        // 42 is not an identifier\n```\n\n## how to fix\nprovide a valid identifier immediately after the `macro` keyword."; }
    case DiagID::S037E { return "# expected `!` after macro name\n\nthis error occurs when the preprocessor sees `macro <name>` but no `!` follows the name.\nby convention all macro names end with `!` to distinguish them from functions and variables.\n\n## example\n\n- correct usage:\n```kairo\nmacro greet! { \"hello\" }\n```\n\n- incorrect usage:\n```kairo\nmacro greet { \"hello\" }  // missing `!`\n```\n\n## how to fix\nadd `!` immediately after the macro name."; }
    case DiagID::S038E { return "# expected `{` for macro body\n\nthis error occurs when the preprocessor starts parsing a macro definition but cannot find the opening\nbrace `{` that begins the macro body. the definition syntax is `macro name! { body }` or\n`macro name!(params) { body }`.\n\n## example\n\n- correct usage:\n```kairo\nmacro greet! { \"hello\" }\n```\n\n- incorrect usage:\n```kairo\nmacro greet!  \"hello\"   // `{` is missing\n```\n\n## how to fix\nadd `{` after the macro name (and optional parameter list) to open the macro body."; }
    case DiagID::S039E { return "# unmatched `{` in macro body\n\nthis error occurs when the opening brace of a macro body is never closed. the preprocessor\nreached the end of the token stream without finding the matching `}`.\n\n## example\n\n- incorrect usage:\n```kairo\nmacro greet! { \"hello\"   // missing `}`\n```\n\n## how to fix\nclose the macro body with a matching `}`."; }
    case DiagID::S040E { return "# duplicate macro definition\n\nthis error occurs when a macro with the same name is defined more than once in the same module scope.\neach macro name must be unique within its scope.\n\n## example\n\n- incorrect usage:\n```kairo\nmacro greet! { \"hello\" }\nmacro greet! { \"hi\" }   // duplicate in same scope\n```\n\n## how to fix\nrename one of the macros, or remove the duplicate definition. if you intend overloading, consider\nusing conditional logic inside a single macro body."; }
    case DiagID::S042E { return "# invalid macro parameter\n\nthis error occurs when the preprocessor encounters an unexpected token or an ordering violation in a\nmacro parameter list. common causes:\n- a non-identifier token where a parameter name is expected\n- a required parameter placed after a default parameter\n- a parameter placed after a variadic (`...`) parameter\n- a variadic parameter placed after a default parameter\n\n## example\n\n- correct usage:\n```kairo\nmacro foo!(a, b = 0, ...rest) { }\n```\n\n- incorrect usage:\n```kairo\nmacro foo!(...rest, b) { }   // parameter after variadic\nmacro foo!(a = 1, b) { }     // required after default\nmacro foo!(42) { }           // 42 is not a parameter name\n```\n\n## how to fix\nreorder parameters so that required parameters come first, default parameters next, and the variadic\nparameter (if any) last."; }
    case DiagID::S043E { return "# unterminated macro parameter list\n\nthis error occurs when the preprocessor reaches the end of the token stream (or the macro body `{`)\nwithout finding the closing `)` of the parameter list.\n\n## example\n\n- incorrect usage:\n```kairo\nmacro foo!(a, b { }   // missing `)` before `{`\n```\n\n## how to fix\nadd `)` to close the parameter list before the opening `{` of the macro body."; }
    case DiagID::S044E { return "# empty default value in macro parameter\n\nthis error occurs when a macro parameter is declared with `=` for a default value but the expression\nthat follows is empty or missing.\n\n## example\n\n- incorrect usage:\n```kairo\nmacro foo!(a = ) { }   // nothing after `=`\nmacro foo!(a =  ) { }  // only whitespace after `=`\n```\n\n## how to fix\nprovide a valid token expression after `=`, e.g. `a = 0` or `a = \"default\"`."; }
    case DiagID::U001W { return "This is placeholder diagnostics. (Warning)"; }
    case DiagID::U001I { return "This is placeholder diagnostics. (Info)"; }
    case DiagID::U001R { return "This is placeholder diagnostics. (Remark)"; }
    case DiagID::U001V { return "This is placeholder diagnostics. (Verbose)"; }
    case DiagID::U001N { return "This is placeholder diagnostics. (Note)"; }
    case DiagID::U001D { return "This is placeholder diagnostics. (Debug)"; }
    case DiagID::U001E { return "This is placeholder diagnostics. (Error)"; }
    case DiagID::U001F { return "This is placeholder diagnostics. (Fatal)"; }
    case DiagID::U002E { return "# unknown command-line flag\n\nthe driver received a flag that does not match any recognized option. this may be a typo,\nan unsupported flag, or a flag intended for a different tool.\n\n## example\n\n- incorrect usage:\n```\nkairo --foo-bar main.kro   // --foo-bar is not a known flag\n```\n\n## how to fix\nrun `kairo --help` to see the list of supported flags and correct the invocation."; }
    case DiagID::U003E { return "# invalid flag syntax\n\nthe driver encountered a malformed flag in the command-line arguments. common causes include\nusing `/-` (which is not supported), combining flags incorrectly, or providing a flag that\nbegins with an unexpected character sequence.\n\n## how to fix\nuse `-flag` for short flags, `--flag` for long flags, or `/flag` for Windows-style flags.\nthe `/-` prefix is not a valid flag introducer."; }
    case DiagID::U004E { return "# flag requires a value\n\na flag that requires an argument (such as `--output`, `--target`, or `-I`) was provided\nwithout a corresponding value.\n\n## example\n\n- incorrect usage:\n```\nkairo --output        // no path provided after --output\nkairo -I              // no include directory provided\n```\n\n## how to fix\nsupply the required value immediately after the flag: `--output=./bin/app` or `--output ./bin/app`."; }
  }
  return "";
}

eval fn diag_from_string(code_str: string) -> DiagID {
  var h = compute_hash(&code_str);
  return static_cast::<DiagID>(h);
}

