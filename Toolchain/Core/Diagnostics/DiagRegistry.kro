  eval fn S(num: u32, sev: DiagSeverity) -> DiagID {
    switch sev {
      case DiagSeverity::Ignored {
        switch num {
          case 1 { return DiagID::S001I; }
          default { std::crash(std::Error::RuntimeError("invalid diag number for S and severity Ignored")); }
        }
      }
      case DiagSeverity::Remark {
        switch num {
          case 1 { return DiagID::S001R; }
