// TODO: Make this is only to be added if interfaces are used that return types

// Define the Fraction struct with n and d (numerator and denominator)
struct Fraction {
    var n: i32;
    var d: i32;
}

// Add function at the global scope
fn add(a: i32, b: i32) -> i32 {
    return a + b;
}

// Overload the addition operator for Fraction
fn op + (a: Fraction, b: Fraction)[add] -> Fraction {
    var new_n = add(a.n + b.d, b.n + a.d);
    var new_d = a.d * b.d;
    return { .n = new_n,
             .d = new_d };
}

fn op - (a: Fraction, b: Fraction)[subtract] -> Fraction {
    var new_n = add(a.n - b.d, b.n - a.d);
    var new_d = a.d * b.d;
    return Fraction { n= new_n, d= new_d };
}

fn op * (a: Fraction, b: Fraction)[multiply] -> Fraction {
    var new_n = a.n * b.n;
    var new_d = a.d * b.d;
    return Fraction { n= new_n, d= new_d };
}

fn op / (a: Fraction, b: Fraction)[divide] -> Fraction {
    var new_n = a.n * b.d;
    var new_d = a.d * b.n;
    return Fraction { n= new_n, d= new_d };
}
/*
*/

// + - * / % ^ & | ~ ! = < > += -= *= /= %= ^= &= |= << >> >>= <<= == != <= >= <=>(since C++20) && || ++ -- , ->* -> ( ) [ ]

// Overload the unary minus operator for Fraction
fn op - (a: Fraction)[unary_minus] -> Fraction {
    return Fraction { n= -a.n, d= a.d };
}

// Overload the unary plus operator for Fraction

fn op + (a: Fraction)[unary_plus] -> Fraction {
    return Fraction { n= a.n, d= a.d };
}

// Overload the increment operator for Fraction

fn op ++ (a: Fraction)[increment] -> Fraction {
    return Fraction { n= a.n + a.d, d= a.d };
}

// Overload the decrement operator for Fraction

fn op -- (a: Fraction)[decrement] -> Fraction {
    return Fraction { n= a.n - a.d, d= a.d };
}

// Overload the addition assignment operator for Fraction

fn op += (a: Fraction, b: Fraction)[add_assign] -> Fraction {
    return a + b;
}

// Overload the subtraction assignment operator for Fraction

fn op -= (a: Fraction, b: Fraction)[subtract_assign] -> Fraction {
    return a - b;
}

// Overload the multiplication assignment operator for Fraction

fn op *= (a: Fraction, b: Fraction)[multiply_assign] -> Fraction {
    return a * b;
}

// Overload the division assignment operator for Fraction

fn op /= (a: Fraction, b: Fraction)[divide_assign] -> Fraction {
    return a / b;
}

// Overload the modulus assignment operator for Fraction

fn op %= (a: Fraction, b: Fraction)[modulus_assign] -> Fraction {
    return Fraction { n= a.n % b.n, d= a.d % b.d };
}

// Overload the bitwise AND assignment operator for Fraction

fn op &= (a: Fraction, b: Fraction)[bitwise_and_assign] -> Fraction {
    return Fraction { n= a.n & b.n, d= a.d & b.d };
}

// Overload the bitwise OR assignment operator for Fraction

fn op |= (a: Fraction, b: Fraction)[bitwise_or_assign] -> Fraction {
    return Fraction { n= a.n | b.n, d= a.d | b.d };
}

// Overload the bitwise XOR assignment operator for Fraction

fn op ^= (a: Fraction, b: Fraction)[bitwise_xor_assign] -> Fraction {
    return Fraction { n= a.n ^ b.n, d= a.d ^ b.d };
}

// Overload the left shift assignment operator for Fraction

fn op <<= (a: Fraction, b: Fraction)[left_shift_assign] -> Fraction {
    return Fraction { n= a.n << b.n, d= a.d << b.d };
}

// Overload the right shift assignment operator for Fraction

fn op >>= (a: Fraction, b: Fraction)[right_shift_assign] -> Fraction {
    return Fraction { n= a.n >> b.n, d= a.d >> b.d };
}

// Overload the modulus operator for Fraction

fn op % (a: Fraction, b: Fraction)[modulus] -> Fraction {
    return Fraction { n= a.n % b.n, d= a.d % b.d };
}

// Overload the bitwise AND operator for Fraction

fn op & (a: Fraction, b: Fraction)[bitwise_and] -> Fraction {
    return Fraction { n= a.n & b.n, d= a.d & b.d };
}

// Overload the bitwise OR operator for Fraction

fn op | (a: Fraction, b: Fraction)[bitwise_or] -> Fraction {
    return Fraction { n= a.n | b.n, d= a.d | b.d };
}

// Overload the bitwise XOR operator for Fraction

fn op ^ (a: Fraction, b: Fraction)[bitwise_xor] -> Fraction {
    return Fraction { n= a.n ^ b.n, d= a.d ^ b.d };
}

// Overload the left shift operator for Fraction

fn op << (a: Fraction, b: Fraction)[left_shift] -> Fraction {
    return Fraction { n= a.n << b.n, d= a.d << b.d };
}

// Overload the right shift operator for Fraction

fn op >> (a: Fraction, b: Fraction)[right_shift] -> Fraction {
    return Fraction { n= a.n >> b.n, d= a.d >> b.d };
}

// Overload the comparison operators for Fraction

fn op < (a: Fraction, b: Fraction)[less_than] -> bool {
    return a.n * b.d < b.n * a.d;
}

fn op > (a: Fraction, b: Fraction)[greater_than] -> bool {
    return a.n * b.d > b.n * a.d;
}

fn op <= (a: Fraction, b: Fraction)[less_than_or_equal] -> bool {
    return a.n * b.d <= b.n * a.d;
}

fn op >= (a: Fraction, b: Fraction)[greater_than_or_equal] -> bool {
    return a.n * b.d >= b.n * a.d;
}

// fn op <=> (a: Fraction, b: Fraction)[three_way_comparison] -> i32 {
//     if a.n * b.d < b.n * a.d {
//         return -1;
//     } else if a.n * b.d > b.n * a.d {
//         return 1;
//     } else {
//         return 0;
//     }
// }

fn op && (a: Fraction, b: Fraction)[logical_and] -> bool {
    return a.n && b.n && a.d && b.d;
}

fn op || (a: Fraction, b: Fraction)[logical_or] -> bool {
    return a.n || b.n || a.d || b.d;
}

fn op ! (a: Fraction)[logical_not] -> bool {
    return !a.n && !a.d;
}

// Overload the equality operator for Fraction
fn op == (a: Fraction, b: Fraction)[equals] -> bool {
    return a.n * b.d == b.n * a.d;
}

