// test.hlx
ffi "c++" import "chrono";
ffi "c++" import "random";

fn return_success() -> i32? {
    return 1;  // Always returns success
}

fn return_null() -> i32? {
    return null;  // Explicitly returns null
}

fn cause_panic() -> i32? {
    panic std::Error::RuntimeError("Intentional panic");
}

fn random_behavior() -> (i32?, i32) {
    /// Randomly execute one of the above functions
    var rd   = libcxx::random_device();
    // var x: unsafe *i32 = _NEW(i32);
    // *x = 19; // *x = 19 == *(x = 19) ! (*x) = 19
    var gen  = libcxx::mt19937(rd());
    var dist = libcxx::uniform_int_distribution::<i32>(0, 2);

    var result: i32? = null;

    var start = libcxx::chrono::high_resolution_clock::now();
    switch dist(gen) {
        case 0 {
            result = return_success();
        }
        case 1 {
            result = return_null();
        }
        case 2 {
            result = cause_panic();
        }
    }
    
    var end = libcxx::chrono::high_resolution_clock::now();

    var duration = libcxx::chrono::duration_cast::<libcxx::chrono::nanoseconds>(end - start).count();
    return (result, duration as i32);
}

// stores: {label: [duration, ...]} - map is c++ std::map
var times = map::<string, vec::<tuple::<string, i32>>>();

fn run_test_case(label: string, test_func: fn() -> i32?) {
    for _ in 0..5 {
        var state: string;

        var start = libcxx::chrono::high_resolution_clock::now();
        var result = test_func();
        var end = libcxx::chrono::high_resolution_clock::now();

        var duration = libcxx::chrono::duration_cast::<libcxx::chrono::nanoseconds>(end - start).count();

        if result == null {
            state = "null";
        } else if result == std::Error::RuntimeError() {
            state = "panic";
        } else if (result as i32) == 1 {
            state = "success";
        } else {
            state = "unknown";
        }

        if times.contains(label) {
            times[label].emplace_back(state, duration as i32);
        } else {
            times[label] = vec::<tuple::<string, i32>>();
            times[label].emplace_back(state, duration as i32);
        }
    }
}

fn main() -> i32 {
    print("Running Test Cases:\n");
    // print(f"blank fstring");
    // print(f"new \{\} fstring form {&return_success}\n");
    // print(f"new \\\{\\\} fstring form {&return_success}\n");
    // print(f"new fstring form {&return_success} ohhhhh using a curly in an fstring \{ ooooooo \} ----------------");
    // print(f"new fstring form {&return_success}, a: {&return_null}, b: {&cause_panic} ----------------\{\}");

    // more then 1 argument
    // run each test 5 times and add them to the times map
    run_test_case("return_success",  &return_success);
    run_test_case("return_null",     &return_null);
    run_test_case("cause_panic",     &cause_panic);

    // test random as well:
    for _ in 0..5 {
        var rd   = libcxx::random_device();
        // var x: unsafe *i32 = _NEW(i32);
        // *x = 19; // *x = 19 == *(x = 19) ! (*x) = 19
        var gen  = libcxx::mt19937(rd());
        var dist = libcxx::uniform_int_distribution::<i32>(0, 2);

        var result: i32? = null;

        var start = libcxx::chrono::high_resolution_clock::now();
        switch dist(gen) {
            case 0 {
                result = return_success();
            }
            case 1 {
                result = return_null();
            }
            case 2 {
                result = cause_panic();
            }
        }
        var end = libcxx::chrono::high_resolution_clock::now();

        var duration = libcxx::chrono::duration_cast::<libcxx::chrono::nanoseconds>(end - start).count();

        var state: string;
        if result == null {
            state = "null";
        } else if result == std::Error::RuntimeError() {
            state = "panic";
        } else if (result as i32) == 1 {
            state = "success";
        } else {
            state = "unknown";
        }

        if times.contains("random") {
            times["random"].emplace_back(state, duration as i32);
        } else {
            times["random"] = vec::<tuple::<string, i32>>();
            times["random"].emplace_back(state, duration as i32);
        }
    }

    for label, durations in times {
        for duration in durations {
            print(f"{label}: {libcxx::get::<0>(duration)} - {libcxx::get::<1>(duration)} ns\n");
        }
    }

    return 0;
}
